    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    // IQ-1396 zero-write diagnostics companion:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) derive required score/out spans with checked integer math;
    // 3) run commit-only parity and strict parity wrappers into private stages;
    // 4) enforce strict tuple parity + prove caller output window is unchanged.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 || required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q32;
    out_begin = (U64)out_probs_q16;
    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_probs_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_probs_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_parity_probs_q16 = MAlloc(required_out_bytes);
    if (!staged_parity_probs_q16)
    {
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_probs_q16_values)
    {
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_probs_q16 == scores_q32 ||
        staged_commit_probs_q16 == out_probs_q16 ||
        staged_parity_probs_q16 == scores_q32 ||
        staged_parity_probs_q16 == out_probs_q16 ||
        snapshot_out_probs_q16_values == scores_q32 ||
        snapshot_out_probs_q16_values == out_probs_q16 ||
        staged_commit_probs_q16 == staged_parity_probs_q16 ||
        staged_commit_probs_q16 == snapshot_out_probs_q16_values ||
        staged_parity_probs_q16 == snapshot_out_probs_q16_values)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        row_stride,
        staged_commit_probs_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        row_stride,
        staged_parity_probs_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_parity_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_commit_probs_q16[copy_index] != staged_parity_probs_q16[copy_index])
        {
            Free(snapshot_out_probs_q16_values);
            Free(staged_parity_probs_q16);
            Free(staged_commit_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
        {
            Free(snapshot_out_probs_q16_values);
            Free(staged_parity_probs_q16);
            Free(staged_commit_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    Free(snapshot_out_probs_q16_values);
    Free(staged_parity_probs_q16);
    Free(staged_commit_probs_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParity(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_score_bytes;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *staged_preflight_probs_q16;
    I64 *staged_commit_probs_q16;
    I64 *snapshot_out_probs_q16_values;
    U64 scores_begin;
    U64 scores_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    // IQ-1411 strict parity diagnostics gate:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) derive required score/out spans with checked integer math;
    // 3) run preflight-only parity companion (on caller output) + commit-only wrapper in private stage;
    // 4) enforce strict tuple parity + zero-write caller output discipline;
    // 5) atomically publish staged commit output only after all checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 || required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q32;
    out_begin = (U64)out_probs_q16;
    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_probs_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_probs_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_probs_q16_values)
    {
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_probs_q16 == scores_q32 ||
        staged_commit_probs_q16 == out_probs_q16 ||
        snapshot_out_probs_q16_values == scores_q32 ||
        snapshot_out_probs_q16_values == out_probs_q16 ||
        staged_commit_probs_q16 == snapshot_out_probs_q16_values)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        row_stride,
        out_probs_q16,
        out_capacity);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        row_stride,
        staged_commit_probs_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
        {
            Free(snapshot_out_probs_q16_values);
            Free(staged_commit_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_probs_q16[copy_index] = staged_commit_probs_q16[copy_index];

    Free(snapshot_out_probs_q16_values);
    Free(staged_commit_probs_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflight(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_scores_bytes;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_scores_q32_values;
    I64 *snapshot_out_probs_q16_values;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1403 canonical diagnostics preflight:
    // 1) freeze immutable geometry/capacity tuple + required-slot snapshots;
    // 2) derive required score/output cells with checked integer math only;
    // 3) prove caller output slab is unchanged on diagnostics path;
    // 4) atomically publish required tuple once all parity checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
    {
        if (snapshot_query_rows != query_rows ||
            snapshot_key_rows != key_rows ||
            snapshot_head_groups != head_groups ||
            snapshot_row_stride != row_stride ||
            snapshot_scores_capacity != scores_capacity ||
            snapshot_out_capacity != out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;

        if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
            out_required_out_cells != snapshot_out_required_out_cells_ptr)
            return ATTN_Q16_ERR_BAD_PARAM;
        if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
            *out_required_out_cells != snapshot_out_required_out_cells_value)
            return ATTN_Q16_ERR_BAD_PARAM;

        *out_required_score_cells = 0;
        *out_required_out_cells = 0;
        return ATTN_Q16_OK;
    }

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells == scores_q32 ||
        out_required_score_cells == out_probs_q16 ||
        out_required_out_cells == scores_q32 ||
        out_required_out_cells == out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_out_probs_q16_values = NULL;
    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_out_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_probs_q16_values)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_probs_q16_values == scores_q32 ||
            snapshot_out_probs_q16_values == out_probs_q16 ||
            snapshot_out_probs_q16_values == out_required_score_cells ||
            snapshot_out_probs_q16_values == out_required_out_cells)
        {
            Free(snapshot_out_probs_q16_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }
    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
    }

    *out_required_score_cells = required_score_cells;
    *out_required_out_cells = required_out_cells;

    if (snapshot_out_probs_q16_values)
        Free(snapshot_out_probs_q16_values);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStride(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_probs_q16_values;
    I64 staged_required_score_cells;
    I64 staged_required_out_cells;
    I64 staged_required_score_cells_second;
    I64 staged_required_out_cells_second;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1403 default-stride diagnostics contract:
    // 1) force canonical preflight geometry with row_stride = key_rows;
    // 2) derive required score/output cells with checked integer math;
    // 3) run canonical preflight twice and require deterministic tuple parity;
    // 4) atomically publish required tuple only after proving output slab is unchanged.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;

    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells == scores_q32 ||
        out_required_score_cells == out_probs_q16 ||
        out_required_out_cells == scores_q32 ||
        out_required_out_cells == out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_out_probs_q16_values = NULL;
    if (recomputed_required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(recomputed_required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_out_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_probs_q16_values)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_probs_q16_values == scores_q32 ||
            snapshot_out_probs_q16_values == out_probs_q16 ||
            snapshot_out_probs_q16_values == out_required_score_cells ||
            snapshot_out_probs_q16_values == out_required_out_cells)
        {
            Free(snapshot_out_probs_q16_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
            snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflight(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        key_rows,
        out_probs_q16,
        out_capacity,
        &staged_required_score_cells,
        &staged_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflight(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        key_rows,
        out_probs_q16,
        out_capacity,
        &staged_required_score_cells_second,
        &staged_required_out_cells_second);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_required_score_cells != staged_required_score_cells_second ||
        staged_required_out_cells != staged_required_out_cells_second)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_required_score_cells != recomputed_required_score_cells ||
        staged_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_required_score_cells > snapshot_scores_capacity ||
        staged_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }
    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_probs_q16_values);
    }

    *out_required_score_cells = staged_required_score_cells;
    *out_required_out_cells = staged_required_out_cells;
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_default_required_score_cells;
    I64 staged_default_required_out_cells;
    I64 staged_canonical_required_score_cells;
    I64 staged_canonical_required_out_cells;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1408 commit-only diagnostics contract:
    // 1) stage default-stride diagnostics (`row_stride = key_rows`);
    // 2) stage canonical diagnostics directly from preflight;
    // 3) enforce immutable geometry/capacity snapshots + strict tuple parity;
    // 4) atomically publish required tuple only after all checks pass.
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStride(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_default_required_score_cells,
        &staged_default_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflight(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        key_rows,
        out_probs_q16,
        out_capacity,
        &staged_canonical_required_score_cells,
        &staged_canonical_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_default_required_score_cells != staged_canonical_required_score_cells ||
        staged_default_required_out_cells != staged_canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_default_required_score_cells > snapshot_scores_capacity ||
        staged_default_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_score_cells = staged_default_required_score_cells;
    *out_required_out_cells = staged_default_required_out_cells;
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParity(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 staged_default_required_score_cells;
    I64 staged_default_required_out_cells;
    I64 staged_canonical_required_score_cells;
    I64 staged_canonical_required_out_cells;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1412 diagnostics parity contract:
    // 1) stage tuple from default-stride preflight (`row_stride = key_rows`);
    // 2) stage tuple from canonical preflight using explicit `row_stride`;
    // 3) re-derive required geometry with checked integer math;
    // 4) publish only when immutable snapshots and exact tuple parity hold.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;

    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStride(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_default_required_score_cells,
        &staged_default_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflight(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        key_rows,
        out_probs_q16,
        out_capacity,
        &staged_canonical_required_score_cells,
        &staged_canonical_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_default_required_score_cells != staged_canonical_required_score_cells ||
        staged_default_required_out_cells != staged_canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_default_required_score_cells != recomputed_required_score_cells ||
        staged_default_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_default_required_score_cells > snapshot_scores_capacity ||
        staged_default_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_score_cells = staged_default_required_score_cells;
    *out_required_out_cells = staged_default_required_out_cells;
    return ATTN_Q16_OK;
}

