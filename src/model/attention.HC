    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_only_required_score_cells != staged_commit_only_required_score_cells ||
        staged_preflight_only_required_out_cells != staged_commit_only_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_only_required_score_cells != recomputed_required_score_cells ||
        staged_preflight_only_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_only_required_score_cells > snapshot_scores_capacity ||
        staged_preflight_only_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_probs_q16_values);
    }
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_parity_required_score_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_preflight_required_score_cells;
    I64 staged_preflight_required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1441 commit-only hardening contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) re-derive required tuple with checked integer geometry math;
    // 3) seed and stage tuples via parity/preflight diagnostics wrappers;
    // 4) atomically publish only when snapshots and strict tuple parity hold.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    staged_parity_required_score_cells = recomputed_required_score_cells;
    staged_parity_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnlyPreflightOnlyParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_parity_required_score_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    staged_preflight_required_score_cells = recomputed_required_score_cells;
    staged_preflight_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnlyPreflightOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_preflight_required_score_cells,
        &staged_preflight_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells != staged_preflight_required_score_cells ||
        staged_parity_required_out_cells != staged_preflight_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells != recomputed_required_score_cells ||
        staged_parity_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells > snapshot_scores_capacity ||
        staged_parity_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_score_cells = staged_parity_required_score_cells;
    *out_required_out_cells = staged_parity_required_out_cells;
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_commit_only_required_score_cells;
    I64 staged_commit_only_required_out_cells;
    I64 staged_commit_only_required_score_cells_second;
    I64 staged_commit_only_required_out_cells_second;
    I64 staged_default_required_score_cells;
    I64 staged_default_required_out_cells;
    I64 staged_default_required_score_cells_second;
    I64 staged_default_required_out_cells_second;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_probs_q16_values;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1422 zero-write diagnostics contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) stage tuple from commit-only + canonical default-stride preflight paths;
    // 3) repeat both staging calls and require exact tuple parity across passes;
    // 4) re-derive strict required tuple via checked integer math;
    // 5) preserve caller output + required-cell slots on success and failure.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    snapshot_out_probs_q16_values = NULL;
    if (recomputed_required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(recomputed_required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_out_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_probs_q16_values)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_probs_q16_values == scores_q32 ||
            snapshot_out_probs_q16_values == out_probs_q16)
        {
            Free(snapshot_out_probs_q16_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
            snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_commit_only_required_score_cells,
        &staged_commit_only_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStride(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_default_required_score_cells,
        &staged_default_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_commit_only_required_score_cells_second,
        &staged_commit_only_required_out_cells_second);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStride(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_default_required_score_cells_second,
        &staged_default_required_out_cells_second);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != staged_default_required_score_cells ||
        staged_commit_only_required_out_cells != staged_default_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != staged_commit_only_required_score_cells_second ||
        staged_commit_only_required_out_cells != staged_commit_only_required_out_cells_second)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_default_required_score_cells != staged_default_required_score_cells_second ||
        staged_default_required_out_cells != staged_default_required_out_cells_second)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != recomputed_required_score_cells ||
        staged_commit_only_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells > snapshot_scores_capacity ||
        staged_commit_only_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_probs_q16_values);
    }
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParity(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_preflight_required_score_cells;
    I64 staged_preflight_required_out_cells;
    I64 staged_commit_only_required_score_cells;
    I64 staged_commit_only_required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_probs_q16_values;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1423 strict diagnostics parity gate:
    // 1) stage tuples from commit-only-preflight diagnostics and commit-only wrappers;
    // 2) re-derive required tuple from immutable snapshots with checked integer math;
    // 3) enforce exact tuple parity across staged sources;
    // 4) preserve caller required slots + probability buffer (zero-write diagnostics).
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    snapshot_out_probs_q16_values = NULL;
    if (recomputed_required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(recomputed_required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_out_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_probs_q16_values)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_probs_q16_values == scores_q32 ||
            snapshot_out_probs_q16_values == out_probs_q16)
        {
            Free(snapshot_out_probs_q16_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
            snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];
    }

    staged_preflight_required_score_cells = recomputed_required_score_cells;
    staged_preflight_required_out_cells = recomputed_required_out_cells;

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_preflight_required_score_cells,
        &staged_preflight_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_commit_only_required_score_cells,
        &staged_commit_only_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_required_score_cells != staged_commit_only_required_score_cells ||
        staged_preflight_required_out_cells != staged_commit_only_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_required_score_cells != recomputed_required_score_cells ||
        staged_preflight_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_required_score_cells > snapshot_scores_capacity ||
        staged_preflight_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_probs_q16_values);
    }
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_parity_required_score_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_preflight_required_score_cells;
    I64 staged_preflight_required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1426 commit-only diagnostics hardening:
    // 1) re-derive required tuple from immutable geometry snapshots;
    // 2) seed strict tuple into both zero-write diagnostics wrappers;
    // 3) require wrappers preserve seeded tuple under parity checks;
    // 4) atomically publish required cells only on strict tuple parity.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    staged_parity_required_score_cells = recomputed_required_score_cells;
    staged_parity_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_parity_required_score_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    staged_preflight_required_score_cells = recomputed_required_score_cells;
    staged_preflight_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_preflight_required_score_cells,
        &staged_preflight_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells != staged_preflight_required_score_cells ||
        staged_parity_required_out_cells != staged_preflight_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells != recomputed_required_score_cells ||
        staged_parity_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells > snapshot_scores_capacity ||
        staged_parity_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_score_cells = staged_parity_required_score_cells;
    *out_required_out_cells = staged_parity_required_out_cells;
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 staged_parity_required_score_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_commit_required_score_cells;
    I64 staged_commit_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_probs_q16_values;
    I64 *staged_parity_out_probs_q16;
    I64 *staged_commit_out_probs_q16;
    I64 *parity_out_probs_q16;
    I64 parity_out_capacity;
    I64 *commit_out_probs_q16;
    I64 commit_out_capacity;
    I32 status;

    snapshot_out_probs_q16_values = NULL;
    staged_parity_out_probs_q16 = NULL;
    staged_commit_out_probs_q16 = NULL;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;
    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1436 zero-write diagnostics companion:
    // 1) freeze immutable geometry/capacity tuple + caller diagnostics slots;
    // 2) stage parity-commit-only and strict-parity wrappers on private outputs;
    // 3) enforce strict required tuple parity across both wrappers;
    // 4) prove caller output and required-cell slots remain unchanged.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    required_score_cells = 0;
    required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(required_score_cells,
                                           key_rows,
                                           &required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (required_score_cells > scores_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells == scores_q32 ||
        out_required_score_cells == out_probs_q16 ||
        out_required_out_cells == scores_q32 ||
        out_required_out_cells == out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    parity_out_probs_q16 = out_probs_q16;
    parity_out_capacity = out_capacity;
    commit_out_probs_q16 = out_probs_q16;
    commit_out_capacity = out_capacity;

    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            goto Cleanup;
        if (required_out_bytes <= 0)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_probs_q16_values)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        staged_parity_out_probs_q16 = MAlloc(required_out_bytes);
        if (!staged_parity_out_probs_q16)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        staged_commit_out_probs_q16 = MAlloc(required_out_bytes);
        if (!staged_commit_out_probs_q16)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        if (snapshot_out_probs_q16_values == scores_q32 ||
            snapshot_out_probs_q16_values == out_probs_q16 ||
            snapshot_out_probs_q16_values == out_required_score_cells ||
            snapshot_out_probs_q16_values == out_required_out_cells ||
            staged_parity_out_probs_q16 == scores_q32 ||
            staged_parity_out_probs_q16 == out_probs_q16 ||
            staged_parity_out_probs_q16 == out_required_score_cells ||
            staged_parity_out_probs_q16 == out_required_out_cells ||
            staged_commit_out_probs_q16 == scores_q32 ||
            staged_commit_out_probs_q16 == out_probs_q16 ||
            staged_commit_out_probs_q16 == out_required_score_cells ||
            staged_commit_out_probs_q16 == out_required_out_cells ||
            snapshot_out_probs_q16_values == staged_parity_out_probs_q16 ||
            snapshot_out_probs_q16_values == staged_commit_out_probs_q16 ||
            staged_parity_out_probs_q16 == staged_commit_out_probs_q16)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];

        parity_out_probs_q16 = staged_parity_out_probs_q16;
        parity_out_capacity = required_out_cells;
        commit_out_probs_q16 = staged_commit_out_probs_q16;
        commit_out_capacity = required_out_cells;
    }

    staged_parity_required_score_cells = required_score_cells;
    staged_parity_required_out_cells = required_out_cells;
    staged_commit_required_score_cells = required_score_cells;
    staged_commit_required_out_cells = required_out_cells;

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        commit_out_probs_q16,
        commit_out_capacity,
        &staged_commit_required_score_cells,
        &staged_commit_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        parity_out_probs_q16,
        parity_out_capacity,
        &staged_parity_required_score_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(snapshot_query_rows == 0 || snapshot_key_rows == 0))
    {
        status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                           snapshot_key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            goto Cleanup;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           snapshot_key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            goto Cleanup;

        status = AttentionTryMulI64Checked(snapshot_query_rows,
                                           snapshot_key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            goto Cleanup;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_score_cells != required_score_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_score_cells != required_score_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_score_cells != staged_commit_required_score_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                status = ATTN_Q16_ERR_BAD_PARAM;
                goto Cleanup;
            }
        }
    }

    status = ATTN_Q16_OK;

Cleanup:
    if (staged_commit_out_probs_q16)
        Free(staged_commit_out_probs_q16);
    if (staged_parity_out_probs_q16)
        Free(staged_parity_out_probs_q16);
    if (snapshot_out_probs_q16_values)
        Free(snapshot_out_probs_q16_values);
    return status;
}

