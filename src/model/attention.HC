        staged_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafePreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 q_span_bytes;
    I64 k_span_bytes;
    I64 out_span_bytes;
    I64 stage_capacity_bytes;
    I64 q_base_addr;
    I64 q_end_addr;
    I64 k_base_addr;
    I64 k_end_addr;
    I64 out_base_addr;
    I64 out_end_addr;
    I64 stage_base_addr;
    I64 stage_end_addr;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-645 alias-safe contract:
    // 1) run canonical explicit-stride no-alloc preflight diagnostics;
    // 2) reject any live-span overlap between staged buffer window and
    //    q/k/out windows (interior-pointer alias safe);
    // 3) delegate compute+commit to canonical commit-capacity helper.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells,
        &required_stage_cells,
        &required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes > commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_commit_required_stage_cells = required_stage_cells;
    *out_commit_required_stage_bytes = required_stage_bytes;
    *out_required_out_cells = required_out_cells;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    if (!staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;
    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &stage_capacity_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_stage_bytes > stage_capacity_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(required_q_cells,
                                       sizeof(I64),
                                       &q_span_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       sizeof(I64),
                                       &k_span_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &out_span_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    q_base_addr = (I64)q_rows_q16;
    k_base_addr = (I64)k_rows_q16;
    out_base_addr = (I64)out_scores_q32;
    stage_base_addr = (I64)staged_scores_q32;

    status = AttentionByteRangeEndChecked(q_base_addr,
                                          q_span_bytes,
                                          &q_end_addr);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionByteRangeEndChecked(k_base_addr,
                                          k_span_bytes,
                                          &k_end_addr);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionByteRangeEndChecked(out_base_addr,
                                          out_span_bytes,
                                          &out_end_addr);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionByteRangeEndChecked(stage_base_addr,
                                          stage_capacity_bytes,
                                          &stage_end_addr);
    if (status != ATTN_Q16_OK)
        return status;

    if (AttentionByteRangesOverlap(stage_base_addr,
                                   stage_end_addr,
                                   q_base_addr,
                                   q_end_addr))
        return ATTN_Q16_ERR_BAD_PARAM;
    if (AttentionByteRangesOverlap(stage_base_addr,
                                   stage_end_addr,
                                   k_base_addr,
                                   k_end_addr))
        return ATTN_Q16_ERR_BAD_PARAM;
    if (AttentionByteRangesOverlap(stage_base_addr,
                                   stage_end_addr,
                                   out_base_addr,
                                   out_end_addr))
        return ATTN_Q16_ERR_BAD_PARAM;

    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafeDefaultCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 commit_stage_cell_capacity;
    I64 commit_stage_byte_capacity;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-651 default-capacity alias-safe wrapper contract:
    // derive commit capacities from packed stage shape and caller staging
    // bytes, then dispatch through the canonical alias-safe commit helper.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafe(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        staged_scores_q32,
        staged_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafeDefaultCapacityPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes)
{
    I64 commit_stage_cell_capacity;
    I64 commit_stage_byte_capacity;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 commit_required_stage_cells;
    I64 commit_required_stage_bytes;
    I64 commit_required_out_cells;
    I32 status;

    if (!out_required_q_cells || !out_required_k_cells || !out_required_out_cells ||
        !out_required_stage_cells || !out_required_stage_bytes)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-660 alias-safe default-capacity preflight contract:
    // 1) derive default commit capacities from packed stage shape and caller
    //    staging bytes;
    // 2) compute q/k/out/stage diagnostics through canonical explicit-stride
    //    no-alloc preflight;
    // 3) run canonical alias-safe commit-capacity preflight-only wrapper so
    //    overlap semantics stay centralized;
    // 4) publish diagnostics atomically only after all checks pass.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells,
        &required_stage_cells,
        &required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafePreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        staged_scores_q32,
        staged_scores_capacity,
        &commit_required_stage_cells,
        &commit_required_stage_bytes,
        &commit_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (commit_required_stage_cells != required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_bytes != required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_out_cells != required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_q_cells = required_q_cells;
    *out_required_k_cells = required_k_cells;
    *out_required_out_cells = commit_required_out_cells;
    *out_required_stage_cells = commit_required_stage_cells;
    *out_required_stage_bytes = commit_required_stage_bytes;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityDefaultCapacityAliasSafePreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_commit_stage_cell_capacity,
    I64 *out_commit_stage_byte_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_stage_cell_capacity;
    I64 commit_stage_byte_capacity;
    I32 status;

    if (!out_commit_stage_cell_capacity || !out_commit_stage_byte_capacity ||
        !out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-652 alias-safe default-capacity preflight contract:
    // 1) derive default commit capacities from packed stage shape and caller
    //    staging bytes;
    // 2) run canonical alias-safe commit-capacity preflight diagnostics;
    // 3) expose derived capacities + required stage/out diagnostics atomically.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafePreflightOnly(
            q_rows_q16,
            q_rows_capacity,
            query_row_count,
            query_row_stride_q16,
            k_rows_q16,
            k_rows_capacity,
            token_count,
            k_row_stride_q16,
            head_dim,
            out_scores_q32,
            out_scores_capacity,
            out_row_stride,
            commit_stage_cell_capacity,
            commit_stage_byte_capacity,
            staged_scores_q32,
            staged_scores_capacity,
            out_commit_required_stage_cells,
            out_commit_required_stage_bytes,
            out_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    *out_commit_stage_cell_capacity = commit_stage_cell_capacity;
    *out_commit_stage_byte_capacity = commit_stage_byte_capacity;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitOnly(
    I64 query_row_count,
    I64 token_count,
    I64 out_row_stride,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 required_stage_cells;
    I64 required_out_cells;
    I64 row_index;
    I64 token_index;
    I64 out_row_base;
    I64 stage_row_base;
    I64 out_index;
    I64 stage_index;
    I32 status;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // Strided row-major output must provide at least one full live-token slab
    // per row. Smaller strides alias row payloads and violate no-partial
    // commit semantics for this direct commit-only helper.
    if (query_row_count > 0 && token_count > 0 && out_row_stride < token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count - 1,
                                       out_row_stride,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_out_cells,
                                       token_count,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    // First pass validates all packed-stage and strided-output indices.
    // Any overflow aborts before caller output is modified.
    for (row_index = 0; row_index < query_row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           out_row_stride,
                                           &out_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           token_count,
                                           &stage_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(out_row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
                return status;
            if (out_index < 0 || out_index >= out_scores_capacity)
                return ATTN_Q16_ERR_BAD_PARAM;

            status = AttentionTryAddI64Checked(stage_row_base,
                                               token_index,
                                               &stage_index);
            if (status != ATTN_Q16_OK)
                return status;
            if (stage_index < 0 || stage_index >= staged_scores_capacity)
                return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    // Commit pass copies live token lanes only, preserving row padding in
    // caller destination buffers for strided layouts.
    for (row_index = 0; row_index < query_row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           out_row_stride,
                                           &out_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           token_count,
                                           &stage_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(out_row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryAddI64Checked(stage_row_base,
                                               token_index,
                                               &stage_index);
            if (status != ATTN_Q16_OK)
                return status;

            out_scores_q32[out_index] = staged_scores_q32[stage_index];
        }
    }

    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideCommitOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_out_row_stride;
    I64 required_stage_cells;
    I64 required_out_cells;
    I64 row_index;
    I64 token_index;
    I64 row_base;
    I64 stage_row_base;
    I64 out_index;
    I64 stage_index;
    I32 status;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    return AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnly(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_out_row_stride;
    I64 required_stage_cells;
    I64 required_out_cells;
    I64 row_index;
    I64 token_index;
    I64 row_base;
    I64 stage_row_base;
    I64 out_index;
    I64 stage_index;
    I32 status;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    // IQ-626 canonical commit-only contract:
    // staged rows are tightly packed by `token_count`, destination rows use
    // default stride, and all indexing is validated with checked
    // `{row_base + token_index}` arithmetic before any output write.
    default_out_row_stride = token_count;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count - 1,
                                       default_out_row_stride,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_out_cells,
                                       token_count,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    // First pass validates every packed source and default-stride destination
    // index. Any checked arithmetic failure keeps caller outputs untouched.
    for (row_index = 0; row_index < query_row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           default_out_row_stride,
                                           &row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           token_count,
                                           &stage_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryAddI64Checked(stage_row_base,
                                               token_index,
                                               &stage_index);
            if (status != ATTN_Q16_OK)
                return status;
        }
    }

    // Commit pass publishes only live token lanes, preserving strict
    // all-or-nothing no-partial semantics.
    for (row_index = 0; row_index < query_row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           default_out_row_stride,
                                           &row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           token_count,
                                           &stage_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryAddI64Checked(stage_row_base,
                                               token_index,
                                               &stage_index);
            if (status != ATTN_Q16_OK)
                return status;

            out_scores_q32[out_index] = staged_scores_q32[stage_index];
        }
    }

    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_out_cells,
    I64 *out_last_out_index)
{
    I64 default_out_row_stride;
    I64 required_stage_cells;
    I64 required_out_cells;
    I64 last_out_index;
    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_out_cells ||
        !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_out_cells ||
        out_required_stage_cells == out_last_out_index ||
        out_required_out_cells == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;

    // IQ-802 diagnostics-only commit-only preflight contract:
    // 1) derive checked `{required_stage_cells,required_out_cells,last_out_index}`
    //    for default-stride commit geometry;
    // 2) validate staged/output capacities without writing score buffers;
    // 3) revalidate immutable geometry snapshot;
    // 4) atomically publish diagnostics on success only.
    if (!query_row_count || !token_count)
    {
        required_stage_cells = 0;
        required_out_cells = 0;
        last_out_index = 0;
    }
    else
    {
        status = AttentionTryMulI64Checked(query_row_count,
                                           token_count,
                                           &required_stage_cells);
        if (status != ATTN_Q16_OK)
            return status;

        default_out_row_stride = token_count;
        status = AttentionTryMulI64Checked(query_row_count - 1,
                                           default_out_row_stride,
                                           &required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(required_out_cells,
                                           token_count,
                                           &required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (required_stage_cells > staged_scores_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
        if (required_out_cells > out_scores_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;

        status = AttentionTryAddI64Checked(required_out_cells,
                                           -1,
                                           &last_out_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = required_stage_cells;
    *out_required_out_cells = required_out_cells;
    *out_last_out_index = last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytes(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells,
    I64 *out_last_out_index)
{
    I64 staged_required_stage_cells;
    I64 staged_required_out_cells;
    I64 staged_last_out_index;
    I64 recomputed_required_stage_cells;
    I64 recomputed_required_stage_bytes;
    I64 expected_last_out_index;
    I64 *snapshot_staged_scores_q32;
    I64 *snapshot_out_scores_q32;
    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_required_out_cells ||
        out_required_stage_bytes == out_last_out_index ||
        out_required_out_cells == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == staged_scores_q32 ||
        out_required_stage_cells == out_scores_q32 ||
        out_required_stage_bytes == staged_scores_q32 ||
        out_required_stage_bytes == out_scores_q32 ||
        out_required_out_cells == staged_scores_q32 ||
        out_required_out_cells == out_scores_q32 ||
        out_last_out_index == staged_scores_q32 ||
        out_last_out_index == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_staged_scores_q32 = staged_scores_q32;
    snapshot_out_scores_q32 = out_scores_q32;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;

    // IQ-817 required-bytes diagnostics contract:
    // 1) stage canonical default-stride commit-only preflight tuple;
    // 2) derive checked `required_stage_bytes = required_stage_cells*sizeof(I64)`;
    // 3) revalidate immutable geometry snapshots/pointers + tuple invariants;
    // 4) atomically publish diagnostics only after full success.
    status =
        AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnly(
            query_row_count,
            token_count,
            staged_scores_q32,
            staged_scores_capacity,
            out_scores_q32,
            out_scores_capacity,
            &staged_required_stage_cells,
            &staged_required_out_cells,
            &staged_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (recomputed_required_stage_cells == 0)
    {
        expected_last_out_index = 0;
    }
    else
    {
        status = AttentionTryAddI64Checked(recomputed_required_stage_cells,
                                           -1,
                                           &expected_last_out_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_q32 != staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_q32 != out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_out_index != expected_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = staged_required_stage_cells;
    *out_required_stage_bytes = recomputed_required_stage_bytes;
    *out_required_out_cells = staged_required_out_cells;
    *out_last_out_index = staged_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParity(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells,
    I64 *out_last_out_index)
{
    I64 commit_preflight_required_stage_cells;
    I64 commit_preflight_required_out_cells;
    I64 commit_preflight_last_out_index;

    I64 required_bytes_required_stage_cells;
    I64 required_bytes_required_stage_bytes;
    I64 required_bytes_required_out_cells;
    I64 required_bytes_last_out_index;

    I64 expected_commit_required_stage_bytes;

    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_required_out_cells ||
        out_required_stage_bytes == out_last_out_index ||
        out_required_out_cells == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;

    // IQ-803 diagnostics-only required-bytes parity gate:
    // 1) stage tuple from canonical commit-only preflight helper;
    // 2) stage tuple from canonical required-bytes helper;
    // 3) derive bytes from commit-only cells using checked math;
    // 4) enforce immutable snapshot + exact tuple parity;
    // 5) atomically publish diagnostics only on full success.
    status =
        AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnly(
            query_row_count,
            token_count,
            staged_scores_q32,
            staged_scores_capacity,
            out_scores_q32,
            out_scores_capacity,
            &commit_preflight_required_stage_cells,
            &commit_preflight_required_out_cells,
            &commit_preflight_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytes(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity,
        &required_bytes_required_stage_cells,
        &required_bytes_required_stage_bytes,
        &required_bytes_required_out_cells,
        &required_bytes_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(commit_preflight_required_stage_cells,
                                       sizeof(I64),
                                       &expected_commit_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (commit_preflight_required_stage_cells !=
        required_bytes_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_preflight_required_out_cells != required_bytes_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_preflight_last_out_index != required_bytes_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (expected_commit_required_stage_bytes !=
        required_bytes_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = commit_preflight_required_stage_cells;
    *out_required_stage_bytes = expected_commit_required_stage_bytes;
    *out_required_out_cells = commit_preflight_required_out_cells;
    *out_last_out_index = commit_preflight_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 stage_cell_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_out_row_stride;
    I64 required_stage_cells;
    I64 required_out_cells;
    I32 status;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || stage_cell_capacity < 0 ||
        out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    // IQ-599 no-alloc commit-only contract:
    // - staged rows are tightly packed by `token_count`;
    // - destination rows use default token-major stride;
    // - caller-provided stage capacity is validated before commit.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    default_out_row_stride = token_count;
    status = AttentionTryMulI64Checked(query_row_count - 1,
                                       default_out_row_stride,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_out_cells,
                                       token_count,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_cells > stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideCommitOnly(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStride(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_query_row_stride_q16;
    I64 default_k_row_stride_q16;
    I64 default_out_row_stride;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-570 default-stride batch contract:
    // - query rows are tightly packed head vectors.
    // - key rows are tightly packed head vectors.
    // - output rows are token-major with token_count row stride.
    // Delegate to the checked rows core so overflow and row-major
    // layout behavior are identical to explicit composition.
    default_query_row_stride_q16 = head_dim;
    default_k_row_stride_q16 = head_dim;
    default_out_row_stride = token_count;

    return AttentionQ16ComputeScaledQKRowsChecked(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        default_query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_out_row_stride);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStride(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_query_row_stride_q16;
    I64 default_k_row_stride_q16;
    I64 default_out_row_stride;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-561 default-stride no-partial batch contract:
    // - query rows are tightly packed head vectors.
    // - key rows are tightly packed head vectors.
    // - output rows are token-major with token_count row stride.
    // Delegate to the strict no-partial rows core so staged all-or-nothing
    // write semantics and overflow checks exactly match explicit composition.
    default_query_row_stride_q16 = head_dim;
    default_k_row_stride_q16 = head_dim;
    default_out_row_stride = token_count;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartial(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        default_query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_out_row_stride);
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedCommitOnlyParity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_in_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_last_in_index,
    I64 *out_last_out_index)
{
    I64 canonical_required_in_cells;
    I64 canonical_required_out_cells;
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 canonical_last_in_index;
    I64 canonical_last_out_index;

    I64 parity_required_in_cells;
    I64 parity_required_out_cells;
    I64 parity_required_stage_cells;
    I64 parity_required_stage_bytes;
    I64 parity_last_in_index;
    I64 parity_last_out_index;

    I64 snapshot_in_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I32 status;

    if (!out_required_in_cells || !out_required_out_cells ||
        !out_required_stage_cells || !out_required_stage_bytes ||
        !out_last_in_index || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_in_cells == out_required_out_cells ||
        out_required_in_cells == out_required_stage_cells ||
        out_required_in_cells == out_required_stage_bytes ||
        out_required_in_cells == out_last_in_index ||
        out_required_in_cells == out_last_out_index ||
        out_required_out_cells == out_required_stage_cells ||
        out_required_out_cells == out_required_stage_bytes ||
        out_required_out_cells == out_last_in_index ||
        out_required_out_cells == out_last_out_index ||
        out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_last_in_index ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_last_in_index ||
        out_required_stage_bytes == out_last_out_index ||
        out_last_in_index == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_in_scores_capacity = in_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_row_count = row_count;
    snapshot_token_count = token_count;

    // IQ-733 hardened diagnostics parity contract:
    // 1) stage canonical default-capacity no-alloc diagnostics;
    // 2) stage preflight-only hardened diagnostics commit path;
    // 3) enforce immutable caller geometry snapshots;
    // 4) atomically publish only after full parity match.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardened(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &canonical_required_in_cells,
            &canonical_required_out_cells,
            &canonical_required_stage_cells,
            &canonical_required_stage_bytes,
            &canonical_last_in_index,
            &canonical_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedPreflightOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &parity_required_in_cells,
            &parity_required_out_cells,
            &parity_required_stage_cells,
            &parity_required_stage_bytes,
            &parity_last_in_index,
            &parity_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_in_scores_capacity != in_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (canonical_required_in_cells != parity_required_in_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_out_cells != parity_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_cells != parity_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_bytes != parity_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_in_index != parity_last_in_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_out_index != parity_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_in_cells = parity_required_in_cells;
    *out_required_out_cells = parity_required_out_cells;
    *out_required_stage_cells = parity_required_stage_cells;
    *out_required_stage_bytes = parity_required_stage_bytes;
    *out_last_in_index = parity_last_in_index;
    *out_last_out_index = parity_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedCommitOnlyParityNoAllocHardened(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_in_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_last_in_index,
    I64 *out_last_out_index)
{
    I64 canonical_required_in_cells;
    I64 canonical_required_out_cells;
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 canonical_last_in_index;
    I64 canonical_last_out_index;

    I64 hardened_required_in_cells;
    I64 hardened_required_out_cells;
    I64 hardened_required_stage_cells;
    I64 hardened_required_stage_bytes;
    I64 hardened_last_in_index;
    I64 hardened_last_out_index;

    I64 snapshot_in_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I32 status;

    if (!out_required_in_cells || !out_required_out_cells ||
        !out_required_stage_cells || !out_required_stage_bytes ||
        !out_last_in_index || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_in_cells == out_required_out_cells ||
        out_required_in_cells == out_required_stage_cells ||
        out_required_in_cells == out_required_stage_bytes ||
        out_required_in_cells == out_last_in_index ||
        out_required_in_cells == out_last_out_index ||
        out_required_out_cells == out_required_stage_cells ||
        out_required_out_cells == out_required_stage_bytes ||
        out_required_out_cells == out_last_in_index ||
        out_required_out_cells == out_last_out_index ||
        out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_last_in_index ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_last_in_index ||
        out_required_stage_bytes == out_last_out_index ||
        out_last_in_index == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_in_scores_capacity = in_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_row_count = row_count;
    snapshot_token_count = token_count;

    // IQ-734 hardened no-alloc parity wrapper contract:
    // 1) stage canonical diagnostics from IQ-733 commit-only parity helper;
    // 2) independently stage hardened diagnostics from no-alloc helper;
    // 3) revalidate immutable caller geometry snapshots;
    // 4) publish atomically only when the full diagnostics tuple matches.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedCommitOnlyParity(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &canonical_required_in_cells,
            &canonical_required_out_cells,
            &canonical_required_stage_cells,
            &canonical_required_stage_bytes,
            &canonical_last_in_index,
            &canonical_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardened(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &hardened_required_in_cells,
            &hardened_required_out_cells,
            &hardened_required_stage_cells,
            &hardened_required_stage_bytes,
            &hardened_last_in_index,
            &hardened_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_in_scores_capacity != in_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (canonical_required_in_cells != hardened_required_in_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_out_cells != hardened_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_cells != hardened_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_bytes != hardened_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_in_index != hardened_last_in_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_out_index != hardened_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_in_cells = hardened_required_in_cells;
    *out_required_out_cells = hardened_required_out_cells;
    *out_required_stage_cells = hardened_required_stage_cells;
    *out_required_stage_bytes = hardened_required_stage_bytes;
    *out_last_in_index = hardened_last_in_index;
    *out_last_out_index = hardened_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesNoAllocHardenedDefaultCapacity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_in_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_last_in_index,
    I64 *out_last_out_index)
{
    I64 canonical_required_in_cells;
    I64 canonical_required_out_cells;
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 canonical_last_in_index;
    I64 canonical_last_out_index;

    I64 recomputed_required_stage_cells;
    I64 recomputed_required_stage_bytes;
    I64 expected_last_index;
    I64 snapshot_in_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I32 status;

    if (!in_scores_q32 || !out_scores_q32 || !out_required_in_cells ||
        !out_required_out_cells || !out_required_stage_cells ||
        !out_required_stage_bytes || !out_last_in_index || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_in_scores_capacity = in_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_row_count = row_count;
    snapshot_token_count = token_count;

    // IQ-720 diagnostics-only hardened default-capacity contract:
    // 1) stage canonical diagnostics from the no-alloc hardened helper;
    // 2) independently recompute stage geometry from {row_count,token_count};
    // 3) require exact tuple parity and immutable caller shape/capacity inputs;
    // 4) atomically publish diagnostics only after full parity validation.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesNoAllocHardened(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &canonical_required_in_cells,
            &canonical_required_out_cells,
            &canonical_required_stage_cells,
            &canonical_required_stage_bytes,
            &canonical_last_in_index,
            &canonical_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (recomputed_required_stage_cells == 0)
        expected_last_index = 0;
    else
    {
        status = AttentionTryAddI64Checked(recomputed_required_stage_cells,
                                           -1,
                                           &expected_last_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_in_scores_capacity != in_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (canonical_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_bytes != recomputed_required_stage_bytes)
