    if (staged_required_k_bytes != canonical_required_k_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_bytes != canonical_required_out_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_last_q_base_index = staged_last_q_base_index;
    *out_last_k_base_index = staged_last_k_base_index;
    *out_last_out_base_index = staged_last_out_base_index;
    *out_required_q_cells = staged_required_q_cells;
    *out_required_k_cells = staged_required_k_cells;
    *out_required_out_cells = staged_required_out_cells;
    *out_required_q_bytes = staged_required_q_bytes;
    *out_required_k_bytes = staged_required_k_bytes;
    *out_required_out_bytes = staged_required_out_bytes;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideRequiredBytesPreflightOnlyDefaultCapacityCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *q_rows_q16,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 *out_last_q_base_index,
    I64 *out_last_k_base_index,
    I64 *out_last_out_base_index,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells,
    I64 *out_required_q_bytes,
    I64 *out_required_k_bytes,
    I64 *out_required_out_bytes)
{
    I64 staged_last_q_base_index;
    I64 staged_last_k_base_index;
    I64 staged_last_out_base_index;
    I64 staged_required_q_cells;
    I64 staged_required_k_cells;
    I64 staged_required_out_cells;
    I64 staged_required_q_bytes;
    I64 staged_required_k_bytes;
    I64 staged_required_out_bytes;

    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 snapshot_head_dim;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 recomputed_required_q_bytes;
    I64 recomputed_required_k_bytes;
    I64 recomputed_required_out_bytes;
    I64 recomputed_last_q_base_index;
    I64 recomputed_last_k_base_index;
    I64 recomputed_last_out_base_index;
    I32 status;

    if (!out_last_q_base_index || !out_last_k_base_index ||
        !out_last_out_base_index || !out_required_q_cells ||
        !out_required_k_cells || !out_required_out_cells ||
        !out_required_q_bytes || !out_required_k_bytes ||
        !out_required_out_bytes)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_last_q_base_index == out_last_k_base_index ||
        out_last_q_base_index == out_last_out_base_index ||
        out_last_q_base_index == out_required_q_cells ||
        out_last_q_base_index == out_required_k_cells ||
        out_last_q_base_index == out_required_out_cells ||
        out_last_q_base_index == out_required_q_bytes ||
        out_last_q_base_index == out_required_k_bytes ||
        out_last_q_base_index == out_required_out_bytes ||
        out_last_k_base_index == out_last_out_base_index ||
        out_last_k_base_index == out_required_q_cells ||
        out_last_k_base_index == out_required_k_cells ||
        out_last_k_base_index == out_required_out_cells ||
        out_last_k_base_index == out_required_q_bytes ||
        out_last_k_base_index == out_required_k_bytes ||
        out_last_k_base_index == out_required_out_bytes ||
        out_last_out_base_index == out_required_q_cells ||
        out_last_out_base_index == out_required_k_cells ||
        out_last_out_base_index == out_required_out_cells ||
        out_last_out_base_index == out_required_q_bytes ||
        out_last_out_base_index == out_required_k_bytes ||
        out_last_out_base_index == out_required_out_bytes ||
        out_required_q_cells == out_required_k_cells ||
        out_required_q_cells == out_required_out_cells ||
        out_required_q_cells == out_required_q_bytes ||
        out_required_q_cells == out_required_k_bytes ||
        out_required_q_cells == out_required_out_bytes ||
        out_required_k_cells == out_required_out_cells ||
        out_required_k_cells == out_required_q_bytes ||
        out_required_k_cells == out_required_k_bytes ||
        out_required_k_cells == out_required_out_bytes ||
        out_required_out_cells == out_required_q_bytes ||
        out_required_out_cells == out_required_k_bytes ||
        out_required_out_cells == out_required_out_bytes ||
        out_required_q_bytes == out_required_k_bytes ||
        out_required_q_bytes == out_required_out_bytes ||
        out_required_k_bytes == out_required_out_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_head_dim = head_dim;

    // IQ-834 commit-only diagnostics hardening:
    // 1) stage outputs from the parity helper into private locals;
    // 2) recompute canonical geometry from immutable snapshot inputs;
    // 3) enforce exact parity for required-cells/bytes and last-base indices;
    // 4) atomically publish only after all checks succeed.

    status =
        AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideRequiredBytesPreflightOnlyDefaultCapacityCommitOnlyPreflightOnlyParity(
            q_rows_q16,
            query_row_count,
            k_rows_q16,
            token_count,
            head_dim,
            out_scores_q32,
            &staged_last_q_base_index,
            &staged_last_k_base_index,
            &staged_last_out_base_index,
            &staged_required_q_cells,
            &staged_required_k_cells,
            &staged_required_out_cells,
            &staged_required_q_bytes,
            &staged_required_k_bytes,
            &staged_required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count,
                                       head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(token_count,
                                       head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_q_cells,
                                       sizeof(I64),
                                       &recomputed_required_q_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       sizeof(I64),
                                       &recomputed_required_k_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_out_cells,
                                       sizeof(I64),
                                       &recomputed_required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (query_row_count == 0)
    {
        recomputed_last_q_base_index = 0;
        recomputed_last_out_base_index = 0;
    }
    else
    {
        status = AttentionTryMulI64Checked(query_row_count - 1,
                                           head_dim,
                                           &recomputed_last_q_base_index);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_row_count - 1,
                                           token_count,
                                           &recomputed_last_out_base_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (token_count == 0)
    {
        recomputed_last_k_base_index = 0;
    }
    else
    {
        status = AttentionTryMulI64Checked(token_count - 1,
                                           head_dim,
                                           &recomputed_last_k_base_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_head_dim != head_dim)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_q_cells != recomputed_required_q_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_k_cells != recomputed_required_k_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_q_bytes != recomputed_required_q_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_k_bytes != recomputed_required_k_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_bytes != recomputed_required_out_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_last_q_base_index != recomputed_last_q_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_k_base_index != recomputed_last_k_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_out_base_index != recomputed_last_out_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_last_q_base_index = staged_last_q_base_index;
    *out_last_k_base_index = staged_last_k_base_index;
    *out_last_out_base_index = staged_last_out_base_index;
    *out_required_q_cells = staged_required_q_cells;
    *out_required_k_cells = staged_required_k_cells;
    *out_required_out_cells = staged_required_out_cells;
    *out_required_q_bytes = staged_required_q_bytes;
    *out_required_k_bytes = staged_required_k_bytes;
    *out_required_out_bytes = staged_required_out_bytes;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParityCommitOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells,
    I64 *out_last_out_index)
{
    I64 staged_required_stage_cells;
    I64 staged_required_stage_bytes;
    I64 staged_required_out_cells;
    I64 staged_last_out_index;
    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_required_out_cells ||
        out_required_stage_bytes == out_last_out_index ||
        out_required_out_cells == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;

    // IQ-837 strict commit-only wrapper contract:
    // 1) stage diagnostics from canonical required-bytes parity helper;
    // 2) revalidate immutable geometry/capacity snapshots;
    // 3) atomically publish outputs only after all checks succeed.
    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParity(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity,
        &staged_required_stage_cells,
        &staged_required_stage_bytes,
        &staged_required_out_cells,
        &staged_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = staged_required_stage_cells;
    *out_required_stage_bytes = staged_required_stage_bytes;
    *out_required_out_cells = staged_required_out_cells;
    *out_last_out_index = staged_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParityCommitOnlyPreflightOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells,
    I64 *out_last_out_index)
{
    I64 staged_required_stage_cells;
    I64 staged_required_stage_bytes;
    I64 staged_required_out_cells;
    I64 staged_last_out_index;

    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 canonical_required_out_cells;
    I64 canonical_last_out_index;

    I64 recomputed_required_stage_cells;
    I64 recomputed_required_stage_bytes;
    I64 recomputed_required_out_cells;
    I64 recomputed_last_out_index;

    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 *snapshot_staged_scores_q32;
    I64 *snapshot_out_scores_q32;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_required_out_cells ||
        out_required_stage_bytes == out_last_out_index ||
        out_required_out_cells == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_staged_scores_q32 = staged_scores_q32;
    snapshot_out_scores_q32 = out_scores_q32;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;

    // IQ-1040 diagnostics-only preflight companion contract:
    // 1) stage diagnostics from parity-commit-only wrapper;
    // 2) stage canonical tuple from parity base helper;
    // 3) recompute tuple directly from immutable scalar snapshots;
    // 4) enforce immutable snapshots and exact tuple parity;
    // 5) publish outputs only after full parity success.
    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParityCommitOnly(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity,
        &staged_required_stage_cells,
        &staged_required_stage_bytes,
        &staged_required_out_cells,
        &staged_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParity(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity,
        &canonical_required_stage_cells,
        &canonical_required_stage_bytes,
        &canonical_required_out_cells,
        &canonical_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    // Direct integer recompute from immutable geometry snapshots.
    // required_stage_cells = query_row_count * token_count
    // required_stage_bytes = required_stage_cells * sizeof(I64)
    // required_out_cells   = required_stage_cells
    // last_out_index       = required_out_cells ? required_out_cells - 1 : 0
    status = AttentionTryMulI64Checked(snapshot_query_row_count,
                                       snapshot_token_count,
                                       &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    recomputed_required_out_cells = recomputed_required_stage_cells;
    if (recomputed_required_out_cells == 0)
    {
        recomputed_last_out_index = 0;
    }
    else
    {
        status = AttentionTryAddI64Checked(recomputed_required_out_cells,
                                           -1,
                                           &recomputed_last_out_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_q32 != staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_q32 != out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells != canonical_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_stage_bytes != canonical_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_out_index != canonical_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_out_index != recomputed_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = staged_required_stage_cells;
    *out_required_stage_bytes = staged_required_stage_bytes;
    *out_required_out_cells = staged_required_out_cells;
    *out_last_out_index = staged_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialCommitOnlyPreflightOnlyRequiredBytesParityPreflightOnlyCommitOnly(
    I64 query_row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells,
    I64 *out_last_out_index)
{
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 canonical_required_out_cells;
    I64 canonical_last_out_index;

    I64 preflight_required_stage_cells;
    I64 preflight_required_stage_bytes;
    I64 preflight_required_out_cells;
    I64 preflight_last_out_index;

    I64 snapshot_query_row_count;
    I64 snapshot_token_count;
    I64 snapshot_staged_scores_capacity;
