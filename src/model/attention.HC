    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1437 strict diagnostics parity gate:
    // 1) freeze immutable geometry/capacity and caller slot snapshots;
    // 2) stage tuple from IQ-1436 zero-write diagnostics companion;
    // 3) stage tuple from IQ-1426 commit-only parity wrapper;
    // 4) re-derive required tuple via checked integer math and enforce parity;
    // 5) preserve caller outputs + required-cell slots (zero-write semantics).
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_required_score_cells == scores_q32 ||
        out_required_score_cells == out_probs_q16 ||
        out_required_out_cells == scores_q32 ||
