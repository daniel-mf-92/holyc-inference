        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_parity_required_q_cells,
        &staged_parity_required_k_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_q_rows_capacity != q_rows_capacity ||
        snapshot_k_rows_capacity != k_rows_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_parity_required_q_cells != required_q_cells ||
        staged_parity_required_k_cells != required_k_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_q_cells != required_q_cells ||
        staged_commit_required_k_cells != required_k_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_parity_required_q_cells != staged_commit_required_q_cells ||
        staged_parity_required_k_cells != staged_commit_required_k_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_q_cells != snapshot_out_required_q_cells_ptr ||
        out_required_k_cells != snapshot_out_required_k_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }
    if (*out_required_q_cells != snapshot_out_required_q_cells_value ||
        *out_required_k_cells != snapshot_out_required_k_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_scores_q32[copy_index] != snapshot_out_scores_q32[copy_index])
            {
                Free(snapshot_out_scores_q32);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
    }

    *out_required_q_cells = staged_parity_required_q_cells;
    *out_required_k_cells = staged_parity_required_k_cells;
    *out_required_out_cells = staged_parity_required_out_cells;

    if (snapshot_out_scores_q32)
        Free(snapshot_out_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_q_rows_capacity;
    I64 snapshot_k_rows_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_out_required_q_cells_ptr;
    I64 *snapshot_out_required_k_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_q_cells_value;
    I64 snapshot_out_required_k_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 staged_parity_required_q_cells;
    I64 staged_parity_required_k_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_commit_required_q_cells;
    I64 staged_commit_required_k_cells;
    I64 staged_commit_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_scores_q32;
    I32 status;

    if (!out_required_q_cells || !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_q_cells == out_required_k_cells ||
        out_required_q_cells == out_required_out_cells ||
        out_required_k_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_q_rows_capacity = q_rows_capacity;
    snapshot_k_rows_capacity = k_rows_capacity;
    snapshot_out_capacity = out_capacity;

    snapshot_out_required_q_cells_ptr = out_required_q_cells;
    snapshot_out_required_k_cells_ptr = out_required_k_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_q_cells_value = *out_required_q_cells;
    snapshot_out_required_k_cells_value = *out_required_k_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1390 strict diagnostics parity gate:
    // 1) freeze geometry/capacity tuple + caller diagnostics slots;
    // 2) derive required q/k/out tuple with checked integer math;
    // 3) run parity-preflight and parity-commit wrappers into staged tuples;
    // 4) enforce exact tuple parity + immutable snapshots;
    // 5) atomically publish diagnostics only after all checks pass.
    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_q_cells == q_rows_q16 ||
        out_required_q_cells == k_rows_q16 ||
        out_required_q_cells == out_scores_q32 ||
        out_required_k_cells == q_rows_q16 ||
        out_required_k_cells == k_rows_q16 ||
        out_required_k_cells == out_scores_q32 ||
        out_required_out_cells == q_rows_q16 ||
        out_required_out_cells == k_rows_q16 ||
        out_required_out_cells == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_out_scores_q32 = NULL;
    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_out_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_out_scores_q32 = MAlloc(required_out_bytes);
        if (!snapshot_out_scores_q32)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_scores_q32 == q_rows_q16 ||
            snapshot_out_scores_q32 == k_rows_q16 ||
            snapshot_out_scores_q32 == out_scores_q32 ||
            snapshot_out_scores_q32 == out_required_q_cells ||
            snapshot_out_scores_q32 == out_required_k_cells ||
            snapshot_out_scores_q32 == out_required_out_cells)
        {
            Free(snapshot_out_scores_q32);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_scores_q32[copy_index] = out_scores_q32[copy_index];
    }

    staged_parity_required_q_cells = required_q_cells;
    staged_parity_required_k_cells = required_k_cells;
    staged_parity_required_out_cells = required_out_cells;

    staged_commit_required_q_cells = required_q_cells;
    staged_commit_required_k_cells = required_k_cells;
    staged_commit_required_out_cells = required_out_cells;

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_parity_required_q_cells,
        &staged_parity_required_k_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_commit_required_q_cells,
        &staged_commit_required_k_cells,
        &staged_commit_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_q_rows_capacity != q_rows_capacity ||
        snapshot_k_rows_capacity != k_rows_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_parity_required_q_cells != required_q_cells ||
        staged_parity_required_k_cells != required_k_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_q_cells != required_q_cells ||
        staged_commit_required_k_cells != required_k_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_parity_required_q_cells != staged_commit_required_q_cells ||
        staged_parity_required_k_cells != staged_commit_required_k_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_q_cells != snapshot_out_required_q_cells_ptr ||
        out_required_k_cells != snapshot_out_required_k_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }
    if (*out_required_q_cells != snapshot_out_required_q_cells_value ||
        *out_required_k_cells != snapshot_out_required_k_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_scores_q32[copy_index] != snapshot_out_scores_q32[copy_index])
            {
                Free(snapshot_out_scores_q32);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
    }

    *out_required_q_cells = staged_parity_required_q_cells;
    *out_required_k_cells = staged_parity_required_k_cells;
    *out_required_out_cells = staged_parity_required_out_cells;

    if (snapshot_out_scores_q32)
        Free(snapshot_out_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_out_capacity;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 staged_preflight_required_q_cells;
    I64 staged_preflight_required_k_cells;
    I64 staged_preflight_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_scores_q32;
    I64 *staged_commit_scores_q32;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_out_capacity = out_capacity;

    // IQ-1424 strict diagnostics parity gate:
    // 1) freeze immutable geometry tuple and derive required q/k/out spans;
    // 2) run preflight-only diagnostics companion on staged required tuple;
    // 3) run commit-only parity scorer on staged output buffer;
    // 4) require exact required-tuple parity + immutable snapshots;
    // 5) publish scores only after all checks pass.
    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_scores_q32 = MAlloc(required_out_bytes);
    if (!staged_commit_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    snapshot_out_scores_q32 = MAlloc(required_out_bytes);
    if (!snapshot_out_scores_q32)
    {
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_scores_q32 == q_rows_q16 ||
        staged_commit_scores_q32 == k_rows_q16 ||
        staged_commit_scores_q32 == out_scores_q32 ||
        snapshot_out_scores_q32 == q_rows_q16 ||
        snapshot_out_scores_q32 == k_rows_q16 ||
        snapshot_out_scores_q32 == out_scores_q32 ||
        staged_commit_scores_q32 == snapshot_out_scores_q32)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_scores_q32[copy_index] = out_scores_q32[copy_index];

    staged_preflight_required_q_cells = required_q_cells;
    staged_preflight_required_k_cells = required_k_cells;
    staged_preflight_required_out_cells = required_out_cells;

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_preflight_required_q_cells,
        &staged_preflight_required_k_cells,
        &staged_preflight_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        staged_commit_scores_q32,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_out_capacity != out_capacity)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_required_q_cells != required_q_cells ||
        staged_preflight_required_k_cells != required_k_cells ||
        staged_preflight_required_out_cells != required_out_cells)
    {
        Free(snapshot_out_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_scores_q32[copy_index] != snapshot_out_scores_q32[copy_index])
        {
            Free(snapshot_out_scores_q32);
            Free(staged_commit_scores_q32);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_scores_q32[copy_index] = staged_commit_scores_q32[copy_index];

    Free(snapshot_out_scores_q32);
    Free(staged_commit_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_q_rows_capacity;
    I64 snapshot_k_rows_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_out_required_q_cells_ptr;
    I64 *snapshot_out_required_k_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_q_cells_value;
    I64 snapshot_out_required_k_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 staged_parity_required_q_cells;
    I64 staged_parity_required_k_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_commit_required_q_cells;
    I64 staged_commit_required_k_cells;
    I64 staged_commit_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_scores_q32;
    I64 *staged_parity_scores_q32;
    I64 *parity_out_scores_q32;
    I64 parity_out_capacity;
    I32 status;

    snapshot_out_scores_q32 = NULL;
    staged_parity_scores_q32 = NULL;

    if (!out_required_q_cells || !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_q_cells == out_required_k_cells ||
        out_required_q_cells == out_required_out_cells ||
        out_required_k_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_q_rows_capacity = q_rows_capacity;
    snapshot_k_rows_capacity = k_rows_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_out_required_q_cells_ptr = out_required_q_cells;
    snapshot_out_required_k_cells_ptr = out_required_k_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_q_cells_value = *out_required_q_cells;
    snapshot_out_required_k_cells_value = *out_required_k_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1425 commit-only hardening wrapper:
    // 1) freeze immutable geometry/capacity tuple + diagnostics-slot pointers;
    // 2) derive required q/k/out tuple via checked integer math;
    // 3) run strict parity + canonical preflight-only wrappers on staged buffers;
    // 4) require exact tuple parity and unchanged caller state;
    // 5) atomically publish required tuple only after all checks pass.
    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_q_cells == q_rows_q16 ||
        out_required_q_cells == k_rows_q16 ||
        out_required_q_cells == out_scores_q32 ||
        out_required_k_cells == q_rows_q16 ||
        out_required_k_cells == k_rows_q16 ||
        out_required_k_cells == out_scores_q32 ||
        out_required_out_cells == q_rows_q16 ||
        out_required_out_cells == k_rows_q16 ||
        out_required_out_cells == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    parity_out_scores_q32 = out_scores_q32;
    parity_out_capacity = out_capacity;

    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            goto Cleanup;
        if (required_out_bytes <= 0)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        snapshot_out_scores_q32 = MAlloc(required_out_bytes);
        if (!snapshot_out_scores_q32)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        staged_parity_scores_q32 = MAlloc(required_out_bytes);
        if (!staged_parity_scores_q32)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        if (snapshot_out_scores_q32 == q_rows_q16 ||
            snapshot_out_scores_q32 == k_rows_q16 ||
            snapshot_out_scores_q32 == out_scores_q32 ||
            snapshot_out_scores_q32 == out_required_q_cells ||
            snapshot_out_scores_q32 == out_required_k_cells ||
            snapshot_out_scores_q32 == out_required_out_cells ||
            staged_parity_scores_q32 == q_rows_q16 ||
            staged_parity_scores_q32 == k_rows_q16 ||
            staged_parity_scores_q32 == out_scores_q32 ||
            staged_parity_scores_q32 == out_required_q_cells ||
            staged_parity_scores_q32 == out_required_k_cells ||
            staged_parity_scores_q32 == out_required_out_cells ||
            staged_parity_scores_q32 == snapshot_out_scores_q32)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_scores_q32[copy_index] = out_scores_q32[copy_index];

        parity_out_scores_q32 = staged_parity_scores_q32;
        parity_out_capacity = required_out_cells;
    }

    staged_parity_required_q_cells = required_q_cells;
    staged_parity_required_k_cells = required_k_cells;
    staged_parity_required_out_cells = required_out_cells;
    staged_commit_required_q_cells = required_q_cells;
    staged_commit_required_k_cells = required_k_cells;
    staged_commit_required_out_cells = required_out_cells;

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParity(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        parity_out_scores_q32,
        parity_out_capacity);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_commit_required_q_cells,
        &staged_commit_required_k_cells,
        &staged_commit_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_parity_required_q_cells,
        &staged_parity_required_k_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_q_rows_capacity != q_rows_capacity ||
        snapshot_k_rows_capacity != k_rows_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_q_cells > snapshot_q_rows_capacity ||
        required_k_cells > snapshot_k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_q_cells != required_q_cells ||
        staged_parity_required_k_cells != required_k_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_q_cells != required_q_cells ||
        staged_commit_required_k_cells != required_k_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_q_cells != staged_commit_required_q_cells ||
        staged_parity_required_k_cells != staged_commit_required_k_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (out_required_q_cells != snapshot_out_required_q_cells_ptr ||
        out_required_k_cells != snapshot_out_required_k_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }
    if (*out_required_q_cells != snapshot_out_required_q_cells_value ||
        *out_required_k_cells != snapshot_out_required_k_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_scores_q32[copy_index] != snapshot_out_scores_q32[copy_index])
            {
                status = ATTN_Q16_ERR_BAD_PARAM;
                goto Cleanup;
            }
        }
    }

    *out_required_q_cells = staged_parity_required_q_cells;
    *out_required_k_cells = staged_parity_required_k_cells;
    *out_required_out_cells = staged_parity_required_out_cells;
    status = ATTN_Q16_OK;

Cleanup:
    if (staged_parity_scores_q32)
        Free(staged_parity_scores_q32);
    if (snapshot_out_scores_q32)
        Free(snapshot_out_scores_q32);
    return status;
}

