            &canonical_required_stage_cells,
            &canonical_required_stage_bytes,
            &canonical_last_in_index,
            &canonical_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (recomputed_required_stage_cells == 0)
        expected_last_index = 0;
    else
    {
        status = AttentionTryAddI64Checked(recomputed_required_stage_cells,
                                           -1,
                                           &expected_last_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_in_scores_capacity != in_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (canonical_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_in_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_out_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_in_index != expected_last_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_out_index != expected_last_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_in_cells = canonical_required_in_cells;
    *out_required_out_cells = canonical_required_out_cells;
    *out_required_stage_cells = canonical_required_stage_cells;
    *out_required_stage_bytes = canonical_required_stage_bytes;
    *out_last_in_index = canonical_last_in_index;
    *out_last_out_index = canonical_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytes(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 stage_cell_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 required_in_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I32 status;

    if (!in_scores_q32 || !out_scores_q32 || !out_required_stage_cells ||
        !out_required_stage_bytes || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        stage_cell_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-621 required-bytes helper contract for default-stride no-alloc rows:
    // 1) reuse the canonical no-alloc preflight helper for checked in/out/stage
    //    span validation;
    // 2) convert required stage cells to bytes with checked I64 multiply;
    // 3) publish only the diagnostics needed by no-alloc staging callers.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocPreflightOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            stage_cell_capacity,
            &required_in_cells,
            &required_out_cells,
            &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(required_stage_cells,
                                       sizeof(I64),
                                       &required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    *out_required_stage_cells = required_stage_cells;
    *out_required_stage_bytes = required_stage_bytes;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

// Default-capacity wrapper for no-alloc required-bytes diagnostics.
//
// IQ-622 contract:
// - derive `stage_cell_capacity = row_count * token_count` using checked
//   overflow-safe integer math;
// - route all diagnostics/null/shape contracts through the canonical
//   ...NoAllocRequiredBytes helper so behavior stays composition-identical.
I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesDefaultCapacity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 default_stage_cell_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &default_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytes(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        out_scores_q32,
        out_scores_capacity,
        default_stage_cell_capacity,
        out_required_stage_cells,
        out_required_stage_bytes,
        out_required_out_cells);
}

// Default commit-cell-capacity wrapper for no-alloc required-bytes commit
// diagnostics.
I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacityDefault(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_byte_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_stage_cell_capacity;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        out_commit_required_stage_cells,
        out_commit_required_stage_bytes,
        out_required_out_cells);
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_required_stage_cells;
    I64 commit_required_stage_bytes;
    I64 required_out_cells;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-623 commit-capacity diagnostics contract:
    // derive strict required stage cells/bytes through the canonical no-alloc
    // required-bytes helper, then validate those diagnostics against caller
    // commit scratch limits before commit-only dispatch.
    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytes(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        &commit_required_stage_cells,
        &commit_required_stage_bytes,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (commit_required_stage_bytes > commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_commit_required_stage_cells = commit_required_stage_cells;
    *out_commit_required_stage_bytes = commit_required_stage_bytes;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 required_out_cells;
    I64 recomputed_required_stage_bytes;
    I64 staging_capacity_bytes;
    I32 status;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &staging_capacity_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    // IQ-624 no-alloc commit-capacity execution contract:
    // 1) enforce caller commit scratch limits through the shared
    //    ...NoAllocRequiredBytesCommitCapacity diagnostics path;
    // 2) compute staged default-stride scaled rows into caller scratch;
    // 3) commit staged live cells atomically through no-alloc commit-only.
    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        &required_stage_cells,
        &required_stage_bytes,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    // IQ-813 diagnostics hardening:
    // validate that the returned commit-gating tuple is internally consistent
    // before any staged compute starts. This preserves strict no-partial
    // semantics by rejecting malformed diagnostics up front.
    if (required_stage_cells < 0 || required_stage_bytes < 0 ||
        required_out_cells < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!row_count || !token_count)
        return ATTN_Q16_OK;

    if (!staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;
    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes > staging_capacity_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    // Preserve strict no-partial semantics: staging scratch must not alias
    // source or destination buffers when compute+commit execute in stages.
    if (staged_scores_q32 == in_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_q32 == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionQ16ApplyScoreScaleRowsCheckedDefaultStride(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        score_scale_q16,
        staged_scores_q32,
        staged_scores_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
        row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        required_stage_cells,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityPreflightOnly(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 staged_required_stage_cells;
    I64 staged_required_stage_bytes;
    I64 staged_required_out_cells;
    I64 recomputed_required_in_cells;
    I64 recomputed_required_stage_cells;
    I64 recomputed_required_stage_bytes;
    I64 recomputed_required_out_cells;
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I64 snapshot_score_scale_q16;
    I64 snapshot_commit_stage_cell_capacity;
    I64 snapshot_stage_capacity;
    I64 snapshot_out_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_bytes == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_stage_cells == in_scores_q32 ||
        out_required_stage_cells == out_scores_q32 ||
        out_required_stage_cells == staged_scores_q32 ||
        out_required_stage_bytes == in_scores_q32 ||
        out_required_stage_bytes == out_scores_q32 ||
        out_required_stage_bytes == staged_scores_q32 ||
        out_required_out_cells == in_scores_q32 ||
        out_required_out_cells == out_scores_q32 ||
        out_required_out_cells == staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-860 diagnostics-only no-write contract:
    // 1) stage the required-size tuple through the IQ-813 diagnostics path;
    // 2) recompute canonical required sizes from immutable snapshots;
    // 3) enforce snapshot and tuple parity before atomic diagnostics publish.
    snapshot_row_count = row_count;
    snapshot_token_count = token_count;
    snapshot_score_scale_q16 = score_scale_q16;
    snapshot_commit_stage_cell_capacity = commit_stage_cell_capacity;
    snapshot_stage_capacity = staged_scores_capacity;
    snapshot_out_capacity = out_scores_capacity;

    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        &staged_required_stage_cells,
        &staged_required_stage_bytes,
        &staged_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocPreflightOnly(
        in_scores_q32,
        in_scores_capacity,
        snapshot_row_count,
        snapshot_token_count,
        out_scores_q32,
        snapshot_out_capacity,
        snapshot_commit_stage_cell_capacity,
        &recomputed_required_in_cells,
        &recomputed_required_out_cells,
        &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_score_scale_q16 != score_scale_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_commit_stage_cell_capacity != commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_stage_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells > snapshot_stage_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = staged_required_stage_cells;
    *out_required_stage_bytes = staged_required_stage_bytes;
    *out_required_out_cells = staged_required_out_cells;

    recomputed_required_in_cells = recomputed_required_in_cells;

    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityDefaultCapacity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 default_commit_stage_cell_capacity;
    I64 default_commit_stage_byte_capacity;
    I32 status;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-625 default-capacity commit contract:
    // derive commit scratch limits from live row/token geometry
    // (`row_count * token_count`) and caller staging bytes
    // (`staged_scores_capacity * sizeof(I64)`), then route all
    // no-partial semantics through the canonical commit-capacity wrapper.
    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &default_commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &default_commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_commit_stage_cell_capacity,
        default_commit_stage_byte_capacity,
        staged_scores_q32,
        staged_scores_capacity);
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityParity(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *parity_out_scores_q32,
    I64 parity_out_scores_capacity,
    I64 *parity_staged_scores_q32,
    I64 parity_staged_scores_capacity)
{
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I64 snapshot_score_scale_q16;
    I64 snapshot_commit_stage_cell_capacity;
    I64 snapshot_commit_stage_byte_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_parity_out_scores_capacity;
    I64 snapshot_parity_staged_scores_capacity;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 required_out_cells;
    I64 recomputed_required_stage_bytes;
    I64 elem_index;
    I32 canonical_status;
    I32 explicit_status;
    I32 publish_status;
    I32 status;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;
    if (!staged_scores_q32 || !parity_out_scores_q32 || !parity_staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0 || parity_out_scores_capacity < 0 ||
        parity_staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_scores_q32 == in_scores_q32 || staged_scores_q32 == out_scores_q32 ||
        staged_scores_q32 == parity_out_scores_q32 ||
        staged_scores_q32 == parity_staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (parity_out_scores_q32 == in_scores_q32 ||
        parity_out_scores_q32 == out_scores_q32 ||
        parity_out_scores_q32 == parity_staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (parity_staged_scores_q32 == in_scores_q32 ||
        parity_staged_scores_q32 == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_row_count = row_count;
    snapshot_token_count = token_count;
    snapshot_score_scale_q16 = score_scale_q16;
    snapshot_commit_stage_cell_capacity = commit_stage_cell_capacity;
    snapshot_commit_stage_byte_capacity = commit_stage_byte_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_parity_out_scores_capacity = parity_out_scores_capacity;
    snapshot_parity_staged_scores_capacity = parity_staged_scores_capacity;

    // IQ-861 parity gate contract:
    // 1) Stage required-byte/cell diagnostics from canonical no-alloc helper.
    // 2) Execute canonical commit-capacity path into dedicated parity buffers.
    // 3) Independently stage default-stride scaled rows and require exact
    //    element parity with canonical output before any caller publish.
    // 4) Atomically publish via commit-only helper only after full parity.
    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        &required_stage_cells,
        &required_stage_bytes,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells < 0 || required_stage_bytes < 0 || required_out_cells < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!row_count || !token_count)
        return ATTN_Q16_OK;

    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_cells > parity_staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > parity_out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > parity_staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    canonical_status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        score_scale_q16,
        parity_out_scores_q32,
        parity_out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        parity_staged_scores_q32,
        parity_staged_scores_capacity);
    if (canonical_status != ATTN_Q16_OK)
        return canonical_status;

    status = AttentionQ16ApplyScoreScaleRowsCheckedDefaultStride(
        in_scores_q32,
        in_scores_capacity,
        row_count,
        token_count,
        score_scale_q16,
        staged_scores_q32,
        staged_scores_capacity);
    if (status != canonical_status)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (status != ATTN_Q16_OK)
        return status;

    explicit_status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
        row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        required_stage_cells,
        parity_staged_scores_q32,
        parity_staged_scores_capacity);
    if (explicit_status != canonical_status)
        return ATTN_Q16_ERR_BAD_PARAM;

    for (elem_index = 0; elem_index < required_out_cells; elem_index++) {
        if (parity_staged_scores_q32[elem_index] != parity_out_scores_q32[elem_index])
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_row_count != row_count || snapshot_token_count != token_count ||
        snapshot_score_scale_q16 != score_scale_q16 ||
        snapshot_commit_stage_cell_capacity != commit_stage_cell_capacity ||
        snapshot_commit_stage_byte_capacity != commit_stage_byte_capacity ||
        snapshot_out_scores_capacity != out_scores_capacity ||
        snapshot_staged_scores_capacity != staged_scores_capacity ||
        snapshot_parity_out_scores_capacity != parity_out_scores_capacity ||
        snapshot_parity_staged_scores_capacity != parity_staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    publish_status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
        row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        required_stage_cells,
        out_scores_q32,
        out_scores_capacity);

    if (publish_status != canonical_status)
        return ATTN_Q16_ERR_BAD_PARAM;

    for (elem_index = 0; elem_index < required_out_cells; elem_index++) {
        if (out_scores_q32[elem_index] != parity_out_scores_q32[elem_index])
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    return publish_status;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityParityPreflightOnly(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *parity_out_scores_q32,
    I64 parity_out_scores_capacity,
    I64 *parity_staged_scores_q32,
    I64 parity_staged_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I64 snapshot_score_scale_q16;
    I64 snapshot_commit_stage_cell_capacity;
    I64 snapshot_commit_stage_byte_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_parity_out_scores_capacity;
    I64 snapshot_parity_staged_scores_capacity;

    I64 preflight_required_stage_cells;
    I64 preflight_required_stage_bytes;
    I64 preflight_required_out_cells;
    I64 parity_preflight_required_stage_cells;
    I64 parity_preflight_required_stage_bytes;
    I64 parity_preflight_required_out_cells;
    I64 required_required_stage_cells;
    I64 required_required_stage_bytes;
    I64 required_required_out_cells;
    I64 recomputed_required_cells;
    I64 recomputed_required_bytes;
    I64 recomputed_required_out_cells;
    I64 overflow_probe_cells;
    I64 overflow_probe_bytes;
    I64 required_in_cells;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_bytes == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32 || !staged_scores_q32 ||
        !parity_out_scores_q32 || !parity_staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0 || parity_out_scores_capacity < 0 ||
        parity_staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-866 overflow precedence: geometry overflow must be surfaced before
    // any downstream capacity-comparison errors.
    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &overflow_probe_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(overflow_probe_cells,
                                       sizeof(I64),
                                       &overflow_probe_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_required_stage_cells == in_scores_q32 ||
        out_required_stage_cells == out_scores_q32 ||
        out_required_stage_cells == staged_scores_q32 ||
        out_required_stage_cells == parity_out_scores_q32 ||
        out_required_stage_cells == parity_staged_scores_q32 ||
        out_required_stage_bytes == in_scores_q32 ||
        out_required_stage_bytes == out_scores_q32 ||
        out_required_stage_bytes == staged_scores_q32 ||
        out_required_stage_bytes == parity_out_scores_q32 ||
        out_required_stage_bytes == parity_staged_scores_q32 ||
        out_required_out_cells == in_scores_q32 ||
        out_required_out_cells == out_scores_q32 ||
        out_required_out_cells == staged_scores_q32 ||
        out_required_out_cells == parity_out_scores_q32 ||
        out_required_out_cells == parity_staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_row_count = row_count;
    snapshot_token_count = token_count;
    snapshot_score_scale_q16 = score_scale_q16;
    snapshot_commit_stage_cell_capacity = commit_stage_cell_capacity;
    snapshot_commit_stage_byte_capacity = commit_stage_byte_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_parity_out_scores_capacity = parity_out_scores_capacity;
    snapshot_parity_staged_scores_capacity = parity_staged_scores_capacity;

    // IQ-866 diagnostics-only wrapper contract:
    // 1) stage required-cell/byte diagnostics through no-write wrappers;
    // 2) recompute canonical geometry tuple from immutable snapshots;
    // 3) run IQ-861 parity gate against isolated scratch buffers so caller
    //    out/stage slabs are never mutated on this diagnostics path;
    // 4) enforce snapshot + tuple parity, then atomically publish diagnostics.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityPreflightOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            score_scale_q16,
            out_scores_q32,
            out_scores_capacity,
            commit_stage_cell_capacity,
            commit_stage_byte_capacity,
            staged_scores_q32,
            staged_scores_capacity,
            &preflight_required_stage_cells,
            &preflight_required_stage_bytes,
            &preflight_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityPreflightOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            score_scale_q16,
            parity_out_scores_q32,
            parity_out_scores_capacity,
            commit_stage_cell_capacity,
            commit_stage_byte_capacity,
            parity_staged_scores_q32,
            parity_staged_scores_capacity,
            &parity_preflight_required_stage_cells,
            &parity_preflight_required_stage_bytes,
            &parity_preflight_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        in_scores_q32,
        in_scores_capacity,
        snapshot_row_count,
        snapshot_token_count,
        out_scores_q32,
        snapshot_out_scores_capacity,
        snapshot_commit_stage_cell_capacity,
        snapshot_commit_stage_byte_capacity,
        &required_required_stage_cells,
        &required_required_stage_bytes,
        &required_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocPreflightOnly(
        in_scores_q32,
        in_scores_capacity,
        snapshot_row_count,
        snapshot_token_count,
        out_scores_q32,
        snapshot_out_scores_capacity,
        snapshot_commit_stage_cell_capacity,
        &required_in_cells,
        &recomputed_required_out_cells,
        &recomputed_required_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_cells,
                                       sizeof(I64),
                                       &recomputed_required_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_in_cells != recomputed_required_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_score_scale_q16 != score_scale_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_commit_stage_cell_capacity != commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_commit_stage_byte_capacity != commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_parity_out_scores_capacity != parity_out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_parity_staged_scores_capacity != parity_staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (preflight_required_stage_cells != recomputed_required_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_stage_bytes != recomputed_required_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (parity_preflight_required_stage_cells != recomputed_required_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (parity_preflight_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (parity_preflight_required_stage_bytes != recomputed_required_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (preflight_required_stage_cells != parity_preflight_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_stage_bytes != parity_preflight_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_out_cells != parity_preflight_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (required_required_stage_cells != recomputed_required_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_required_stage_bytes != recomputed_required_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = preflight_required_stage_cells;
    *out_required_stage_bytes = preflight_required_stage_bytes;
    *out_required_out_cells = preflight_required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
    I64 row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 stage_cell_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 required_stage_cells;
    I64 required_out_cells;
    I32 status;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (staged_scores_capacity < 0 || out_scores_capacity < 0 ||
        stage_cell_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideCommitOnlyPreflightOnly(
            row_count,
            token_count,
            staged_scores_capacity,
            out_scores_capacity,
            &required_stage_cells,
            &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    // IQ-595 no-alloc commit-only contract:
    // caller announces scratch/stage budget in cells, and commit path must
    // reject writes if required staged slab exceeds that budget.
    if (required_stage_cells > stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    return AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideCommitOnly(
        row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideCommitOnly(
    I64 row_count,
    I64 token_count,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_row_stride;
    I64 required_stage_cells;
    I64 required_out_cells;
    I64 row_index;
    I64 token_index;
    I64 row_base;
    I64 stage_row_base;
    I64 out_index;
    I64 stage_index;
    I32 status;

    if (!staged_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideCommitOnlyPreflightOnly(
            row_count,
            token_count,
            staged_scores_capacity,
            out_scores_capacity,
            &required_stage_cells,
            &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (!row_count || !token_count)
        return ATTN_Q16_OK;

    // IQ-592 commit-only contract for default-stride row-major slabs:
    // both staged and destination rows are tightly packed by token_count.
    // Validate all checked index math before first caller-visible write.
    default_row_stride = token_count;

    // Pass 1: checked index validation only (no writes).
    for (row_index = 0; row_index < row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           default_row_stride,
                                           &row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           token_count,
                                           &stage_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryAddI64Checked(stage_row_base,
                                               token_index,
                                               &stage_index);
            if (status != ATTN_Q16_OK)
                return status;
        }
    }

    // Pass 2: commit live token lanes only; no row padding writes.
    for (row_index = 0; row_index < row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           default_row_stride,
                                           &row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           token_count,
                                           &stage_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryAddI64Checked(stage_row_base,
                                               token_index,
                                               &stage_index);
            if (status != ATTN_Q16_OK)
                return status;

            out_scores_q32[out_index] = staged_scores_q32[stage_index];
        }
    }

    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideCommitOnlyPreflightOnly(
    I64 row_count,
    I64 token_count,
    I64 staged_scores_capacity,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_out_cells)
{
    I64 default_row_stride;
    I64 required_stage_cells;
    I64 required_out_cells;
    I32 status;

    if (!out_required_stage_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!row_count || !token_count)
    {
        *out_required_stage_cells = 0;
        *out_required_out_cells = 0;
        return ATTN_Q16_OK;
    }

    default_row_stride = token_count;

    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(row_count - 1,
                                       default_row_stride,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_out_cells,
                                       token_count,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = required_stage_cells;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowChecked(I64 *q_row_q16,
                                          I64 q_row_capacity,
                                          I64 *k_rows_q16,
                                          I64 k_rows_capacity,
                                          I64 token_count,
                                          I64 k_row_stride_q16,
                                          I64 head_dim,
                                          I64 score_scale_q16,
                                          I64 *out_scores_q32,
                                          I64 out_scores_capacity,
                                          I64 out_score_stride)
{
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_k_cells;
    I64 required_out_cells;
    I32 status;

    status = AttentionQ16ComputeScaledQKRowCheckedPreflightOnly(
        q_row_q16,
        q_row_capacity,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_score_stride,
        &last_k_base_index,
        &last_out_base_index,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    // Stage 1: compute unscaled Q·K row in Q32 lanes.
    status = AttentionQ16ComputeQKDotRowChecked(q_row_q16,
                                                q_row_capacity,
                                                k_rows_q16,
                                                k_rows_capacity,
                                                token_count,
                                                k_row_stride_q16,
                                                head_dim,
                                                out_scores_q32,
                                                out_scores_capacity,
                                                out_score_stride);
    if (status != ATTN_Q16_OK)
        return status;

    // Stage 2: apply checked Q16 scale in-place over the same row layout so
    // callers get deterministic pre-softmax score buffers.
    return AttentionQ16ApplyScoreScaleChecked(out_scores_q32,
                                              out_scores_capacity,
                                              token_count,
                                              out_score_stride,
                                              score_scale_q16,
                                              out_scores_q32,
                                              out_scores_capacity,
                                              out_score_stride);
}

I32 AttentionQ16ComputeScaledQKRowCheckedPreflightOnly(
    I64 *q_row_q16,
    I64 q_row_capacity,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_score_stride,
    I64 *out_last_k_base_index,
    I64 *out_last_out_base_index,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 required_k_cells;
    I64 required_out_cells;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I32 status;

    if (!q_row_q16 || !k_rows_q16 || !out_scores_q32 ||
        !out_last_k_base_index || !out_last_out_base_index ||
        !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_row_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (token_count < 0 || k_row_stride_q16 < 0 || head_dim < 0 ||
        out_score_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (head_dim > q_row_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!token_count)
    {
        *out_last_k_base_index = 0;
        *out_last_out_base_index = 0;
        *out_required_k_cells = 0;
        *out_required_out_cells = 0;
        return ATTN_Q16_OK;
    }

    if (k_row_stride_q16 < head_dim)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_score_stride < 1)
        return ATTN_Q16_ERR_BAD_PARAM;

    // Keep K/output span checks identical to QK-row checked core so wrappers
    // can preflight with exact success/error diagnostics before score writes.
    status = AttentionTryMulI64Checked(token_count,
                                       k_row_stride_q16,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_k_cells > k_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(token_count - 1,
                                       k_row_stride_q16,
                                       &last_k_base_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(token_count - 1,
                                       out_score_stride,
                                       &last_out_base_index);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(last_out_base_index,
                                       1,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_last_k_base_index = last_k_base_index;
    *out_last_out_base_index = last_out_base_index;
    *out_required_k_cells = required_k_cells;
    *out_required_out_cells = required_out_cells;

    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowCheckedDefaultStrideNoPartialPreflightOnly(
    I64 *q_row_q16,
    I64 q_row_capacity,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_last_k_base_index,
    I64 *out_last_out_base_index,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 default_k_row_stride_q16;
    I64 default_out_score_stride;

    if (!q_row_q16 || !k_rows_q16 || !out_scores_q32 ||
        !out_last_k_base_index || !out_last_out_base_index ||
        !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_row_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-559 default-stride no-partial diagnostics:
    // derive the same row-major strides used by staged no-partial wrappers
    // so callers can validate full K/output spans before score writes.
    default_k_row_stride_q16 = head_dim;
    default_out_score_stride = token_count;

    return AttentionQ16ComputeScaledQKRowCheckedNoPartialPreflightOnly(
        q_row_q16,
        q_row_capacity,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        default_out_score_stride,
        out_last_k_base_index,
        out_last_out_base_index,
        out_required_k_cells,
        out_required_out_cells);
}

I32 AttentionQ16ComputeScaledQKRowCheckedNoPartialPreflightOnly(
    I64 *q_row_q16,
    I64 q_row_capacity,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_score_stride,
    I64 *out_last_k_base_index,
    I64 *out_last_out_base_index,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    // IQ-563 no-partial row diagnostics are intentionally identical to the
    // checked row preflight contract. Staged wrappers use this helper before
    // any score writes so all required spans and base indices are validated
    // up-front with exact overflow/error behavior.
    return AttentionQ16ComputeScaledQKRowCheckedPreflightOnly(
        q_row_q16,
        q_row_capacity,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_score_stride,
        out_last_k_base_index,
        out_last_out_base_index,
        out_required_k_cells,
        out_required_out_cells);
}

I32 AttentionQ16ComputeScaledQKRowCheckedDefaultStride(I64 *q_row_q16,
                                                       I64 q_row_capacity,
                                                       I64 *k_rows_q16,
                                                       I64 k_rows_capacity,
                                                       I64 token_count,
                                                       I64 head_dim,
                                                       I64 score_scale_q16,
                                                       I64 *out_scores_q32,
                                                       I64 out_scores_capacity)
{
    I64 default_k_row_stride_q16;
    I64 default_out_score_stride;

    if (!q_row_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_row_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-564 default row-major no-partial bridge contracts:
    // - K rows are tightly packed by head_dim lanes.
    // - Output score row is spaced by token_count lanes.
    // Delegate through the no-partial row helper so this default wrapper
    // preserves staged all-or-nothing semantics while keeping the same
    // stride derivation and checked overflow/span validation.
    default_k_row_stride_q16 = head_dim;
    default_out_score_stride = token_count;

    return AttentionQ16ComputeScaledQKRowCheckedNoPartial(
        q_row_q16,
        q_row_capacity,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_out_score_stride);
}

I32 AttentionQ16ComputeScaledQKRowCheckedNoPartial(I64 *q_row_q16,
                                                   I64 q_row_capacity,
                                                   I64 *k_rows_q16,
                                                   I64 k_rows_capacity,
                                                   I64 token_count,
                                                   I64 k_row_stride_q16,
                                                   I64 head_dim,
                                                   I64 score_scale_q16,
                                                   I64 *out_scores_q32,
                                                   I64 out_scores_capacity,
                                                   I64 out_score_stride)
{
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_k_cells;
    I64 stage_cells;
    I64 stage_bytes;
    I64 required_out_cells;
    I64 token_index;
    I64 out_base;
    I64 *staged_scores_q32;
    I32 status;

    if (!q_row_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_row_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (token_count < 0 || k_row_stride_q16 < 0 || head_dim < 0 ||
        out_score_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionQ16ComputeScaledQKRowCheckedNoPartialPreflightOnly(
        q_row_q16,
        q_row_capacity,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_score_stride,
        &last_k_base_index,
        &last_out_base_index,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (!token_count)
        return ATTN_Q16_OK;

    // Stage into a dense contiguous token row first so failures never mutate
    // caller output. Commit to strided output only after full success.
    stage_cells = token_count;
    status = AttentionTryMulI64Checked(stage_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_scores_q32 = MAlloc(stage_bytes);
    if (!staged_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    status = AttentionQ16ComputeScaledQKRowChecked(q_row_q16,
                                                   q_row_capacity,
                                                   k_rows_q16,
                                                   k_rows_capacity,
                                                   token_count,
                                                   k_row_stride_q16,
                                                   head_dim,
                                                   score_scale_q16,
                                                   staged_scores_q32,
                                                   stage_cells,
                                                   1);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_scores_q32);
        return status;
    }

    for (token_index = 0; token_index < token_count; token_index++)
    {
        status = AttentionTryMulI64Checked(token_index,
                                           out_score_stride,
                                           &out_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_scores_q32);
            return status;
        }

        out_scores_q32[out_base] = staged_scores_q32[token_index];
    }

    Free(staged_scores_q32);
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowCheckedNoPartialDefaultStride(
    I64 *q_row_q16,
    I64 q_row_capacity,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity)
{
    I64 default_k_row_stride_q16;
    I64 default_out_score_stride;

    if (!q_row_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_row_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-566 default-stride no-partial contract:
    // - key rows are tightly packed with head_dim cells per token.
    // - output scores are token-major with token_count stride.
    // Delegate to the checked no-partial core so staged all-or-nothing
    // semantics and overflow validation stay identical to explicit composition.
    default_k_row_stride_q16 = head_dim;
    default_out_score_stride = token_count;

    return AttentionQ16ComputeScaledQKRowCheckedNoPartial(
        q_row_q16,
        q_row_capacity,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_out_score_stride);
}

I32 AttentionQ16ComputeHeadScoresCheckedNoPartial(
    I64 *q_head_row_q16,
    I64 q_head_row_capacity,
    I64 *k_head_rows_q16,
    I64 k_head_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_head_scores_q32,
    I64 out_head_scores_capacity)
{
    // WS5 single-head score contract:
    // - query row is one head (head_dim Q16 lanes)
    // - key rows are token-major and tightly packed by head_dim
    // - outputs are staged then committed with no-partial semantics
    // Delegate to the checked default-stride row kernel so all overflow-safe
    // dot accumulation and staged commit behavior remains centralized.
    return AttentionQ16ComputeScaledQKRowCheckedNoPartialDefaultStride(
        q_head_row_q16,
        q_head_row_capacity,
        k_head_rows_q16,
        k_head_rows_capacity,
        token_count,
        head_dim,
        score_scale_q16,
        out_head_scores_q32,
        out_head_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *out_last_q_base_index,
    I64 *out_last_k_base_index,
    I64 *out_last_out_base_index,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 last_q_base_index;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 recomputed_last_q_base_index;
    I64 recomputed_last_k_base_index;
    I64 recomputed_last_out_base_index;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32 ||
        !out_last_q_base_index || !out_last_k_base_index ||
        !out_last_out_base_index || !out_required_q_cells ||
        !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_row_count > 0 && query_row_stride_q16 < head_dim)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count > 0 && token_count > 0 && out_row_stride < token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!query_row_count)
    {
        *out_last_q_base_index = 0;
        *out_last_k_base_index = 0;
        *out_last_out_base_index = 0;
        *out_required_q_cells = 0;
        *out_required_k_cells = 0;
        *out_required_out_cells = 0;
        return ATTN_Q16_OK;
    }

    status = AttentionTryMulI64Checked(query_row_count - 1,
                                       query_row_stride_q16,
                                       &last_q_base_index);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(last_q_base_index,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_q_cells > q_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(token_count,
                                       k_row_stride_q16,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_k_cells > k_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!token_count)
    {
        *out_last_q_base_index = last_q_base_index;
        *out_last_k_base_index = 0;
        *out_last_out_base_index = 0;
        *out_required_q_cells = required_q_cells;
        *out_required_k_cells = required_k_cells;
        *out_required_out_cells = 0;
        return ATTN_Q16_OK;
    }

    status = AttentionTryMulI64Checked(token_count - 1,
                                       k_row_stride_q16,
                                       &last_k_base_index);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count - 1,
                                       out_row_stride,
                                       &last_out_base_index);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(last_out_base_index,
                                       token_count,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_last_q_base_index = last_q_base_index;
    *out_last_k_base_index = last_k_base_index;
    *out_last_out_base_index = last_out_base_index;
    *out_required_q_cells = required_q_cells;
    *out_required_k_cells = required_k_cells;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *out_last_q_base_index,
    I64 *out_last_k_base_index,
    I64 *out_last_out_base_index,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 last_q_base_index;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I32 status;

    if (!out_last_q_base_index || !out_last_k_base_index ||
        !out_last_out_base_index || !out_required_q_cells ||
        !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    // IQ-587: preserve strict no-partial diagnostics semantics by staging
    // all preflight outputs locally and committing to caller pointers only on
    // full success.
    status = AttentionQ16ComputeScaledQKRowsCheckedPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &last_q_base_index,
        &last_k_base_index,
        &last_out_base_index,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    // IQ-568: derive all diagnostics from checked index math and verify they
    // match the shared preflight helper before exposing outputs. This keeps
    // no-partial wrappers deterministic and catches any future drift between
    // staged diagnostics and explicit guard composition.
    if (!query_row_count)
    {
        recomputed_last_q_base_index = 0;
        recomputed_last_k_base_index = 0;
        recomputed_last_out_base_index = 0;
        recomputed_required_q_cells = 0;
        recomputed_required_k_cells = 0;
        recomputed_required_out_cells = 0;
    }
    else
    {
        status = AttentionTryMulI64Checked(query_row_count - 1,
                                           query_row_stride_q16,
                                           &recomputed_last_q_base_index);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryAddI64Checked(recomputed_last_q_base_index,
                                           head_dim,
                                           &recomputed_required_q_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(token_count,
                                           k_row_stride_q16,
                                           &recomputed_required_k_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (!token_count)
        {
            recomputed_last_k_base_index = 0;
            recomputed_last_out_base_index = 0;
            recomputed_required_out_cells = 0;
        }
        else
        {
            status = AttentionTryMulI64Checked(token_count - 1,
                                               k_row_stride_q16,
                                               &recomputed_last_k_base_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryMulI64Checked(query_row_count - 1,
                                               out_row_stride,
                                               &recomputed_last_out_base_index);
            if (status != ATTN_Q16_OK)
                return status;

            status = AttentionTryAddI64Checked(recomputed_last_out_base_index,
                                               token_count,
                                               &recomputed_required_out_cells);
            if (status != ATTN_Q16_OK)
                return status;
        }
    }

    if (last_q_base_index != recomputed_last_q_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (last_k_base_index != recomputed_last_k_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (last_out_base_index != recomputed_last_out_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_q_cells != recomputed_required_q_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_k_cells != recomputed_required_k_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_last_q_base_index = last_q_base_index;
    *out_last_k_base_index = last_k_base_index;
    *out_last_out_base_index = last_out_base_index;
    *out_required_q_cells = required_q_cells;
    *out_required_k_cells = required_k_cells;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsChecked(I64 *q_rows_q16,
                                           I64 q_rows_capacity,
                                           I64 query_row_count,
                                           I64 query_row_stride_q16,
                                           I64 *k_rows_q16,
                                           I64 k_rows_capacity,
                                           I64 token_count,
                                           I64 k_row_stride_q16,
                                           I64 head_dim,
                                           I64 score_scale_q16,
                                           I64 *out_scores_q32,
                                           I64 out_scores_capacity,
                                           I64 out_row_stride)
{
    I64 last_q_base_index;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 row_index;
    I64 q_row_base;
    I64 out_row_base;
    I32 status;

    status = AttentionQ16ComputeScaledQKRowsCheckedPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &last_q_base_index,
        &last_k_base_index,
        &last_out_base_index,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (!query_row_count)
        return ATTN_Q16_OK;

    for (row_index = 0; row_index < query_row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           query_row_stride_q16,
                                           &q_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(row_index,
                                           out_row_stride,
                                           &out_row_base);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionQ16ComputeScaledQKRowChecked(q_rows_q16 + q_row_base,
                                                       head_dim,
                                                       k_rows_q16,
                                                       k_rows_capacity,
                                                       token_count,
                                                       k_row_stride_q16,
                                                       head_dim,
                                                       score_scale_q16,
                                                       out_scores_q32 + out_row_base,
                                                       token_count,
                                                       1);
        if (status != ATTN_Q16_OK)
            return status;
    }

    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartial(I64 *q_rows_q16,
                                                    I64 q_rows_capacity,
                                                    I64 query_row_count,
                                                    I64 query_row_stride_q16,
                                                    I64 *k_rows_q16,
                                                    I64 k_rows_capacity,
                                                    I64 token_count,
                                                    I64 k_row_stride_q16,
                                                    I64 head_dim,
                                                    I64 score_scale_q16,
                                                    I64 *out_scores_q32,
                                                    I64 out_scores_capacity,
                                                    I64 out_row_stride)
{
    I64 last_q_base_index;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 stage_cells;
    I64 stage_bytes;
    I64 row_index;
    I64 token_index;
    I64 row_base;
    I64 out_index;
    I64 *staged_scores_q32;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // Empty query batches never touch output.
    if (!query_row_count)
        return ATTN_Q16_OK;

    // If there are no tokens, row cores do zero work and perform no writes.
    if (!token_count)
    {
        return AttentionQ16ComputeScaledQKRowsChecked(
            q_rows_q16,
            q_rows_capacity,
            query_row_count,
            query_row_stride_q16,
            k_rows_q16,
            k_rows_capacity,
            token_count,
            k_row_stride_q16,
            head_dim,
            score_scale_q16,
            out_scores_q32,
            out_scores_capacity,
            out_row_stride);
    }

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &last_q_base_index,
        &last_k_base_index,
        &last_out_base_index,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    // Stage complete row-major score slab so any failure leaves caller output
    // untouched. RowsChecked owns all math/overflow checks.
    stage_cells = required_out_cells;
    status = AttentionTryMulI64Checked(stage_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_scores_q32 = MAlloc(stage_bytes);
    if (!staged_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    status = AttentionQ16ComputeScaledQKRowsChecked(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        score_scale_q16,
        staged_scores_q32,
        stage_cells,
        out_row_stride);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_scores_q32);
        return status;
    }

    // Commit only live token cells (preserve caller padding between rows).
    for (row_index = 0; row_index < query_row_count; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           out_row_stride,
                                           &row_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_scores_q32);
            return status;
        }

        for (token_index = 0; token_index < token_count; token_index++)
        {
            status = AttentionTryAddI64Checked(row_base,
                                               token_index,
                                               &out_index);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_scores_q32);
                return status;
            }

            out_scores_q32[out_index] = staged_scores_q32[out_index];
        }
    }

    Free(staged_scores_q32);
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 default_query_row_stride_q16;
    I64 default_k_row_stride_q16;
    I64 default_out_row_stride;
    I64 last_q_base_index;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32 ||
        !out_required_q_cells || !out_required_k_cells ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-562 default-stride no-partial diagnostics contract:
    // - query rows are tightly packed by `head_dim` lanes.
    // - key rows are tightly packed by `head_dim` lanes.
    // - output rows are token-major with `token_count` stride.
    // This function computes all span diagnostics up-front so staged wrappers
    // can reject before any score writes to caller output buffers.
    default_query_row_stride_q16 = head_dim;
    default_k_row_stride_q16 = head_dim;
    default_out_row_stride = token_count;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        default_query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        default_out_row_stride,
        &last_q_base_index,
        &last_k_base_index,
        &last_out_base_index,
        out_required_q_cells,
        out_required_k_cells,
        out_required_out_cells);
    return status;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedPreflightOnlyCommitOnly(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_in_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_last_in_index,
    I64 *out_last_out_index)
{
    I64 canonical_required_in_cells;
    I64 canonical_required_out_cells;
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 canonical_last_in_index;
    I64 canonical_last_out_index;

    I64 parity_required_in_cells;
    I64 parity_required_out_cells;
    I64 parity_required_stage_cells;
    I64 parity_required_stage_bytes;
    I64 parity_last_in_index;
    I64 parity_last_out_index;

    I64 snapshot_in_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I32 status;

    if (!out_required_in_cells || !out_required_out_cells ||
        !out_required_stage_cells || !out_required_stage_bytes ||
        !out_last_in_index || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_in_cells == out_required_out_cells ||
        out_required_in_cells == out_required_stage_cells ||
        out_required_in_cells == out_required_stage_bytes ||
        out_required_in_cells == out_last_in_index ||
        out_required_in_cells == out_last_out_index ||
        out_required_out_cells == out_required_stage_cells ||
        out_required_out_cells == out_required_stage_bytes ||
        out_required_out_cells == out_last_in_index ||
        out_required_out_cells == out_last_out_index ||
        out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_last_in_index ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_last_in_index ||
        out_required_stage_bytes == out_last_out_index ||
        out_last_in_index == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_in_scores_capacity = in_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_row_count = row_count;
    snapshot_token_count = token_count;

    // IQ-723 commit-only diagnostics wrapper:
    // 1) stage canonical diagnostics from hardened preflight-only default-capacity path;
    // 2) stage parity diagnostics from hardened default-capacity path;
    // 3) validate immutable caller snapshots and exact tuple parity;
    // 4) atomically publish diagnostics only after all checks succeed.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedPreflightOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &canonical_required_in_cells,
            &canonical_required_out_cells,
            &canonical_required_stage_cells,
            &canonical_required_stage_bytes,
            &canonical_last_in_index,
            &canonical_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardened(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &parity_required_in_cells,
            &parity_required_out_cells,
            &parity_required_stage_cells,
            &parity_required_stage_bytes,
            &parity_last_in_index,
            &parity_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_in_scores_capacity != in_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (canonical_required_in_cells != parity_required_in_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_out_cells != parity_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_cells != parity_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_required_stage_bytes != parity_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_in_index != parity_last_in_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_last_out_index != parity_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_in_cells = parity_required_in_cells;
    *out_required_out_cells = parity_required_out_cells;
    *out_required_stage_cells = parity_required_stage_cells;
    *out_required_stage_bytes = parity_required_stage_bytes;
    *out_last_in_index = parity_last_in_index;
    *out_last_out_index = parity_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedCommitOnlyPreflightOnly(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_in_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_last_in_index,
    I64 *out_last_out_index)
{
    I64 commit_required_in_cells;
    I64 commit_required_out_cells;
    I64 commit_required_stage_cells;
    I64 commit_required_stage_bytes;
    I64 commit_last_in_index;
    I64 commit_last_out_index;

    I64 preflight_required_in_cells;
    I64 preflight_required_out_cells;
    I64 preflight_required_stage_cells;
    I64 preflight_required_stage_bytes;
    I64 preflight_last_in_index;
    I64 preflight_last_out_index;

    I64 snapshot_in_scores_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I64 recomputed_required_stage_cells;
    I64 recomputed_required_stage_bytes;
    I64 expected_last_index;
    I32 status;

    if (!out_required_in_cells || !out_required_out_cells ||
        !out_required_stage_cells || !out_required_stage_bytes ||
        !out_last_in_index || !out_last_out_index)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_in_cells == out_required_out_cells ||
        out_required_in_cells == out_required_stage_cells ||
        out_required_in_cells == out_required_stage_bytes ||
        out_required_in_cells == out_last_in_index ||
        out_required_in_cells == out_last_out_index ||
        out_required_out_cells == out_required_stage_cells ||
        out_required_out_cells == out_required_stage_bytes ||
        out_required_out_cells == out_last_in_index ||
        out_required_out_cells == out_last_out_index ||
        out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_last_in_index ||
        out_required_stage_cells == out_last_out_index ||
        out_required_stage_bytes == out_last_in_index ||
        out_required_stage_bytes == out_last_out_index ||
        out_last_in_index == out_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_in_scores_capacity = in_scores_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_row_count = row_count;
    snapshot_token_count = token_count;

    // IQ-792 diagnostics preflight-only contract:
    // 1) stage canonical diagnostics from IQ-722 commit-only parity wrapper;
    // 2) stage parity diagnostics from IQ-723 preflight-only commit wrapper;
    // 3) revalidate immutable caller geometry snapshots;
    // 4) atomically publish diagnostics only after exact tuple parity.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedCommitOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &commit_required_in_cells,
            &commit_required_out_cells,
            &commit_required_stage_cells,
            &commit_required_stage_bytes,
            &commit_last_in_index,
            &commit_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedPreflightOnlyCommitOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &preflight_required_in_cells,
            &preflight_required_out_cells,
            &preflight_required_stage_cells,
            &preflight_required_stage_bytes,
            &preflight_last_in_index,
            &preflight_last_out_index);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_in_scores_capacity != in_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(row_count,
                                       token_count,
                                       &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (recomputed_required_stage_cells == 0)
        expected_last_index = 0;
    else
    {
        status = AttentionTryAddI64Checked(recomputed_required_stage_cells,
                                           -1,
                                           &expected_last_index);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (commit_required_in_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_out_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_last_in_index != expected_last_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_last_out_index != expected_last_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (preflight_required_in_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_out_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_last_in_index != expected_last_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (preflight_last_out_index != expected_last_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (commit_required_in_cells != preflight_required_in_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_out_cells != preflight_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_cells != preflight_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_bytes != preflight_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_last_in_index != preflight_last_in_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_last_out_index != preflight_last_out_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_in_cells = preflight_required_in_cells;
    *out_required_out_cells = preflight_required_out_cells;
    *out_required_stage_cells = preflight_required_stage_cells;
    *out_required_stage_bytes = preflight_required_stage_bytes;
    *out_last_in_index = preflight_last_in_index;
    *out_last_out_index = preflight_last_out_index;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 stage_cell_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_out_cells)
{
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32 ||
        !out_required_stage_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (stage_cell_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-596 default-stride no-alloc preflight contract:
    // use the checked no-partial default-stride diagnostics helper so
    // q/k/out span guards are centralized before no-alloc staged commits.
    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideNoPartialPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = required_stage_cells;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialPreflightOnlyDefaultStrideNoAllocDefaultCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_out_cells)
{
    I64 default_stage_cell_capacity;
    I32 status;

    if (!out_required_stage_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-627 default-capacity no-alloc preflight contract:
    // derive caller stage-cell capacity from exact live default-stride score
    // slab (`query_row_count * token_count`) with checked overflow math, then
    // delegate diagnostics and span validation to the canonical no-alloc
    // preflight helper so error/no-partial semantics stay identical.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &default_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        default_stage_cell_capacity,
        out_required_stage_cells,
        out_required_out_cells);
}

