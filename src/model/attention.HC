    }

    staged_preflight_only_required_score_cells = recomputed_required_score_cells;
    staged_preflight_only_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_preflight_only_required_score_cells,
        &staged_preflight_only_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    staged_commit_only_required_score_cells = recomputed_required_score_cells;
    staged_commit_only_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_commit_only_required_score_cells,
        &staged_commit_only_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_only_required_score_cells != staged_commit_only_required_score_cells ||
        staged_preflight_only_required_out_cells != staged_commit_only_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_only_required_score_cells != recomputed_required_score_cells ||
        staged_preflight_only_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_preflight_only_required_score_cells > snapshot_scores_capacity ||
        staged_preflight_only_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_probs_q16_values);
    }
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_strict_parity_required_score_cells;
    I64 staged_strict_parity_required_out_cells;
    I64 staged_preflight_only_required_score_cells;
    I64 staged_preflight_only_required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1438 commit-only diagnostics hardening:
    // 1) re-derive required tuple from immutable geometry/capacity snapshots;
    // 2) seed tuple into strict-parity and zero-write preflight wrappers;
    // 3) require exact tuple parity across both wrappers and recomputed tuple;
    // 4) atomically publish required cells only on strict parity success.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    staged_strict_parity_required_score_cells = recomputed_required_score_cells;
    staged_strict_parity_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_strict_parity_required_score_cells,
        &staged_strict_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    staged_preflight_only_required_score_cells = recomputed_required_score_cells;
    staged_preflight_only_required_out_cells = recomputed_required_out_cells;
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_preflight_only_required_score_cells,
        &staged_preflight_only_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_strict_parity_required_score_cells != staged_preflight_only_required_score_cells ||
        staged_strict_parity_required_out_cells != staged_preflight_only_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_strict_parity_required_score_cells != recomputed_required_score_cells ||
        staged_strict_parity_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_strict_parity_required_score_cells > snapshot_scores_capacity ||
        staged_strict_parity_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_score_cells = staged_strict_parity_required_score_cells;
    *out_required_out_cells = staged_strict_parity_required_out_cells;
    return ATTN_Q16_OK;
}

#define GQA_ATTN_VALUE_MIX_CLAMP_Q16 ((I64)32 << ATTN_Q16_SHIFT)

I32 GQAAttentionValueMixQ16Checked(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 kv_rows;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 stage_bytes;
    I64 query_index;
    I64 token_index;
    I64 dim_index;
    I64 score_base;
    I64 out_base;
    I64 kv_head_index;
    I64 value_token_base;
    I64 mix_acc_q32;
    I64 product_q32;
    I64 mixed_q16;
    I64 rounding_bias_q32;
    I64 neg_acc_q32;
    I64 copy_index;
    I64 *staged_out_values_q16;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_cells > scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_value_cells > values_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_out_values_q16 = MAlloc(stage_bytes);
    if (!staged_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    rounding_bias_q32 = ((I64)1 << (ATTN_Q16_SHIFT - 1));

    // Integer-only attention value mix:
    // out[q,d] = clamp_q16( round_q16( Sum_t ( score[q,t]_Q16 * value[kv(q),t,d]_Q16 ) ) )
    for (query_index = 0; query_index < query_rows; query_index++)
    {
        status = AttentionTryMulI64Checked(query_index,
                                           row_stride,
                                           &score_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_out_values_q16);
            return status;
        }

        status = AttentionTryMulI64Checked(query_index,
                                           value_dim,
                                           &out_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_out_values_q16);
            return status;
        }

        kv_head_index = query_index / head_groups;

        for (dim_index = 0; dim_index < value_dim; dim_index++)
        {
            mix_acc_q32 = 0;

            for (token_index = 0; token_index < key_rows; token_index++)
            {
                status = AttentionTryMulI64Checked(kv_head_index,
                                                   key_rows,
                                                   &value_token_base);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
                status = AttentionTryAddI64Checked(value_token_base,
                                                   token_index,
                                                   &value_token_base);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
                status = AttentionTryMulI64Checked(value_token_base,
                                                   value_dim,
                                                   &value_token_base);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
                status = AttentionTryAddI64Checked(value_token_base,
                                                   dim_index,
                                                   &value_token_base);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }

                status = AttentionTryMulI64Checked(scores_q16[score_base + token_index],
                                                   values_q16[value_token_base],
                                                   &product_q32);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }

                status = AttentionTryAddI64Checked(mix_acc_q32,
                                                   product_q32,
                                                   &mix_acc_q32);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
            }

            if (mix_acc_q32 >= 0)
            {
                status = AttentionTryAddI64Checked(mix_acc_q32,
                                                   rounding_bias_q32,
                                                   &mixed_q16);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
                mixed_q16 = mixed_q16 >> ATTN_Q16_SHIFT;
            }
            else
            {
                status = AttentionTryMulI64Checked(mix_acc_q32,
                                                   -1,
                                                   &neg_acc_q32);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
                status = AttentionTryAddI64Checked(neg_acc_q32,
                                                   rounding_bias_q32,
                                                   &neg_acc_q32);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
                neg_acc_q32 = neg_acc_q32 >> ATTN_Q16_SHIFT;
                status = AttentionTryMulI64Checked(neg_acc_q32,
                                                   -1,
                                                   &mixed_q16);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_out_values_q16);
                    return status;
                }
            }

            if (mixed_q16 > GQA_ATTN_VALUE_MIX_CLAMP_Q16)
                mixed_q16 = GQA_ATTN_VALUE_MIX_CLAMP_Q16;
            if (mixed_q16 < -GQA_ATTN_VALUE_MIX_CLAMP_Q16)
                mixed_q16 = -GQA_ATTN_VALUE_MIX_CLAMP_Q16;

            staged_out_values_q16[out_base + dim_index] = mixed_q16;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_out_values_q16[copy_index];

    Free(staged_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartial(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 kv_rows;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 stage_bytes;
    I64 copy_index;
    I64 *staged_out_values_q16;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;

    // IQ-1373 no-partial contract:
    // 1) snapshot immutable geometry/capacity tuple;
    // 2) derive required score/value/output spans with checked integer math;
    // 3) run canonical value-mix into private stage buffer;
    // 4) re-check snapshot parity and atomically publish outputs.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_cells > scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_value_cells > values_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_out_values_q16 = MAlloc(stage_bytes);
    if (!staged_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    status = GQAAttentionValueMixQ16Checked(scores_q16,
                                            scores_capacity,
                                            query_rows,
                                            key_rows,
                                            value_dim,
                                            head_groups,
                                            row_stride,
                                            values_q16,
                                            values_capacity,
                                            staged_out_values_q16,
                                            required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_out_values_q16[copy_index];

    Free(staged_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 required_score_bytes;
    I64 required_value_bytes;
    I64 required_out_bytes;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_out_values_q16;
    I64 *parity_out_values_q16;
    U64 scores_begin;
    U64 scores_end;
    U64 values_begin;
    U64 values_end;
    U64 out_begin;
    U64 out_end;
    U64 snapshot_scores_digest;
    U64 snapshot_values_digest;
    U64 recomputed_scores_digest;
    U64 recomputed_values_digest;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;

    // IQ-1374 commit-only hardening contract:
    // 1) freeze immutable geometry/capacity tuple and derive score/value/out spans;
    // 2) reject live output overlap with score/value source windows;
    // 3) run no-partial and canonical value-mix paths into private staging slabs;
    // 4) publish mixed rows only when strict tuple and parity checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       sizeof(I64),
                                       &required_value_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 ||
        required_value_bytes <= 0 ||
        required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q16;
    values_begin = (U64)values_q16;
    out_begin = (U64)out_values_q16;

    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(values_begin,
                                       (U64)required_value_bytes,
                                       &values_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_begin < values_end && values_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (values_begin < scores_end && scores_begin < values_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    parity_out_values_q16 = MAlloc(required_out_bytes);
    if (!parity_out_values_q16)
    {
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_out_values_q16 == scores_q16 ||
        staged_out_values_q16 == values_q16 ||
        staged_out_values_q16 == out_values_q16 ||
        parity_out_values_q16 == scores_q16 ||
        parity_out_values_q16 == values_q16 ||
        parity_out_values_q16 == out_values_q16 ||
        staged_out_values_q16 == parity_out_values_q16)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartial(scores_q16,
                                                     scores_capacity,
                                                     query_rows,
                                                     key_rows,
                                                     value_dim,
                                                     head_groups,
                                                     row_stride,
                                                     values_q16,
                                                     values_capacity,
                                                     staged_out_values_q16,
                                                     required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16Checked(scores_q16,
                                            scores_capacity,
                                            query_rows,
                                            key_rows,
                                            value_dim,
                                            head_groups,
                                            row_stride,
                                            values_q16,
                                            values_capacity,
                                            parity_out_values_q16,
                                            required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(parity_out_values_q16);
        Free(staged_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_out_values_q16[copy_index] != parity_out_values_q16[copy_index])
        {
            Free(parity_out_values_q16);
            Free(staged_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_out_values_q16[copy_index];

    Free(parity_out_values_q16);
    Free(staged_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParity(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_commit_out_values_q16;
    I64 *staged_nopartial_out_values_q16;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;

    // IQ-1388 strict diagnostics parity contract:
    // 1) freeze immutable geometry/capacity tuple;
    // 2) derive required score/value/output spans with checked integer math;
    // 3) execute commit-only and canonical no-partial paths on private staging buffers;
    // 4) require strict required-tuple parity before atomic publish.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_values_q16 == scores_q16 || out_values_q16 == values_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_nopartial_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_nopartial_out_values_q16)
    {
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_out_values_q16 == scores_q16 ||
        staged_commit_out_values_q16 == values_q16 ||
        staged_commit_out_values_q16 == out_values_q16 ||
        staged_nopartial_out_values_q16 == scores_q16 ||
        staged_nopartial_out_values_q16 == values_q16 ||
        staged_nopartial_out_values_q16 == out_values_q16 ||
        staged_commit_out_values_q16 == staged_nopartial_out_values_q16)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnly(scores_q16,
                                                                scores_capacity,
                                                                query_rows,
                                                                key_rows,
                                                                value_dim,
                                                                head_groups,
                                                                row_stride,
                                                                values_q16,
                                                                values_capacity,
                                                                staged_commit_out_values_q16,
                                                                required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartial(scores_q16,
                                                     scores_capacity,
                                                     query_rows,
                                                     key_rows,
                                                     value_dim,
                                                     head_groups,
                                                     row_stride,
                                                     values_q16,
                                                     values_capacity,
                                                     staged_nopartial_out_values_q16,
                                                     required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(staged_nopartial_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_commit_out_values_q16[copy_index] != staged_nopartial_out_values_q16[copy_index])
        {
            Free(staged_nopartial_out_values_q16);
            Free(staged_commit_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_commit_out_values_q16[copy_index];

    Free(staged_nopartial_out_values_q16);
    Free(staged_commit_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 required_score_bytes;
    I64 required_value_bytes;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_parity_out_values_q16;
    I64 *staged_commit_out_values_q16;
    U64 scores_begin;
    U64 scores_end;
    U64 values_begin;
    U64 values_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;

    // IQ-1389 commit-only parity hardening contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) derive required score/value/output spans with checked integer math;
    // 3) run parity and commit-only wrappers into private staging slabs;
    // 4) enforce strict required-tuple parity + staged output parity;
    // 5) atomically publish mixed rows only after all checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       sizeof(I64),
                                       &required_value_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 ||
        required_value_bytes <= 0 ||
        required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q16;
    values_begin = (U64)values_q16;
    out_begin = (U64)out_values_q16;

    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(values_begin,
                                       (U64)required_value_bytes,
                                       &values_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_begin < values_end && values_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (values_begin < scores_end && scores_begin < values_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_parity_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_parity_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_commit_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_out_values_q16)
    {
        Free(staged_parity_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_parity_out_values_q16 == scores_q16 ||
        staged_parity_out_values_q16 == values_q16 ||
        staged_parity_out_values_q16 == out_values_q16 ||
        staged_commit_out_values_q16 == scores_q16 ||
        staged_commit_out_values_q16 == values_q16 ||
        staged_commit_out_values_q16 == out_values_q16 ||
        staged_parity_out_values_q16 == staged_commit_out_values_q16)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParity(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        staged_parity_out_values_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        staged_commit_out_values_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(staged_commit_out_values_q16);
        Free(staged_parity_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_parity_out_values_q16[copy_index] != staged_commit_out_values_q16[copy_index])
        {
            Free(staged_commit_out_values_q16);
            Free(staged_parity_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_parity_out_values_q16[copy_index];

    Free(staged_commit_out_values_q16);
    Free(staged_parity_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 required_score_bytes;
    I64 required_value_bytes;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_commit_only_out_values_q16;
    I64 *staged_parity_out_values_q16;
    I64 *snapshot_out_values_q16_values;
    U64 snapshot_scores_digest;
    U64 snapshot_values_digest;
    U64 recomputed_scores_digest;
    U64 recomputed_values_digest;
    U64 scores_begin;
    U64 scores_end;
    U64 values_begin;
    U64 values_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;

    // IQ-1404 zero-write diagnostics contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) stage parity-commit-only and parity outputs in private slabs;
    // 3) enforce strict required tuple + staged output parity;
    // 4) prove caller output window is unchanged (no publish).
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       sizeof(I64),
                                       &required_value_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 ||
        required_value_bytes <= 0 ||
        required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q16;
    values_begin = (U64)values_q16;
    out_begin = (U64)out_values_q16;

    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(values_begin,
                                       (U64)required_value_bytes,
                                       &values_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_begin < values_end && values_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (values_begin < scores_end && scores_begin < values_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_only_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_only_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_parity_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_parity_out_values_q16)
    {
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    snapshot_out_values_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_values_q16_values)
    {
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_only_out_values_q16 == scores_q16 ||
        staged_commit_only_out_values_q16 == values_q16 ||
        staged_commit_only_out_values_q16 == out_values_q16 ||
        staged_parity_out_values_q16 == scores_q16 ||
        staged_parity_out_values_q16 == values_q16 ||
        staged_parity_out_values_q16 == out_values_q16 ||
        snapshot_out_values_q16_values == scores_q16 ||
        snapshot_out_values_q16_values == values_q16 ||
        snapshot_out_values_q16_values == out_values_q16 ||
        staged_commit_only_out_values_q16 == staged_parity_out_values_q16 ||
        staged_commit_only_out_values_q16 == snapshot_out_values_q16_values ||
        staged_parity_out_values_q16 == snapshot_out_values_q16_values)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];

    status = AttentionQ16BufferDigest64(scores_q16,
                                        required_score_cells,
                                        &snapshot_scores_digest);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }
    status = AttentionQ16BufferDigest64(values_q16,
                                        required_value_cells,
                                        &snapshot_values_digest);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        staged_commit_only_out_values_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParity(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        staged_parity_out_values_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionQ16BufferDigest64(scores_q16,
                                        required_score_cells,
                                        &recomputed_scores_digest);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }
    status = AttentionQ16BufferDigest64(values_q16,
                                        required_value_cells,
                                        &recomputed_values_digest);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return status;
    }

    if (snapshot_scores_digest != recomputed_scores_digest ||
        snapshot_values_digest != recomputed_values_digest)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_parity_out_values_q16);
        Free(staged_commit_only_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_commit_only_out_values_q16[copy_index] != staged_parity_out_values_q16[copy_index])
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_parity_out_values_q16);
            Free(staged_commit_only_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_parity_out_values_q16);
            Free(staged_commit_only_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    Free(snapshot_out_values_q16_values);
    Free(staged_parity_out_values_q16);
    Free(staged_commit_only_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParity(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_commit_out_values_q16;
    I64 *snapshot_out_values_q16_values;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;

    // IQ-1419 strict diagnostics parity gate:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) derive required score/value/output spans with checked integer math;
    // 3) execute preflight-only diagnostics on caller output and commit-only parity on private stage;
    // 4) enforce exact required tuple parity + zero-write caller-output discipline;
    // 5) publish staged commit output only after all checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    kv_rows = 0;
    if (!(query_rows == 0 || key_rows == 0 || value_dim == 0))
    {
        kv_rows = query_rows / head_groups;
        if (kv_rows <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    snapshot_out_values_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_values_q16_values)
    {
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_out_values_q16 == scores_q16 ||
        staged_commit_out_values_q16 == values_q16 ||
        staged_commit_out_values_q16 == out_values_q16 ||
        snapshot_out_values_q16_values == scores_q16 ||
        snapshot_out_values_q16_values == values_q16 ||
        snapshot_out_values_q16_values == out_values_q16 ||
        staged_commit_out_values_q16 == snapshot_out_values_q16_values)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        out_values_q16,
        out_capacity);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        staged_commit_out_values_q16,
        required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    kv_rows = 0;
    if (!(snapshot_query_rows == 0 || snapshot_key_rows == 0 || snapshot_value_dim == 0))
    {
        kv_rows = snapshot_query_rows / snapshot_head_groups;
        if (kv_rows <= 0)
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_commit_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_commit_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_commit_out_values_q16[copy_index];

    Free(snapshot_out_values_q16_values);
    Free(staged_commit_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_value_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_value_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_value_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 staged_parity_required_score_cells;
    I64 staged_parity_required_value_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_preflight_required_score_cells;
    I64 staged_preflight_required_value_cells;
    I64 staged_preflight_required_out_cells;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *snapshot_out_values_q16_values;
    I64 *staged_parity_out_values_q16;
    I64 *parity_out_values_q16;
    I64 parity_out_capacity;
    I32 status;

    snapshot_out_values_q16_values = NULL;
    staged_parity_out_values_q16 = NULL;

    if (!out_required_score_cells || !out_required_value_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_score_cells == out_required_value_cells ||
        out_required_score_cells == out_required_out_cells ||
        out_required_value_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;
    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_value_cells_ptr = out_required_value_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_value_cells_value = *out_required_value_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1434 commit-only hardening wrapper:
    // 1) freeze immutable geometry/capacity tuple + required-slot pointers;
    // 2) derive required score/value/output tuple via checked integer math;
    // 3) run parity diagnostics on staged output + preflight-only on caller output;
    // 4) require strict tuple parity and unchanged caller output/required slots;
    // 5) atomically publish required tuple only after all checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    kv_rows = 0;
    if (!(query_rows == 0 || key_rows == 0 || value_dim == 0))
    {
        kv_rows = query_rows / head_groups;
        if (kv_rows <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells == scores_q16 ||
        out_required_score_cells == values_q16 ||
        out_required_score_cells == out_values_q16 ||
        out_required_value_cells == scores_q16 ||
        out_required_value_cells == values_q16 ||
        out_required_value_cells == out_values_q16 ||
        out_required_out_cells == scores_q16 ||
        out_required_out_cells == values_q16 ||
        out_required_out_cells == out_values_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    parity_out_values_q16 = out_values_q16;
    parity_out_capacity = out_capacity;

    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            goto Cleanup;
        if (required_out_bytes <= 0)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        snapshot_out_values_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_values_q16_values)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        staged_parity_out_values_q16 = MAlloc(required_out_bytes);
        if (!staged_parity_out_values_q16)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        if (snapshot_out_values_q16_values == scores_q16 ||
            snapshot_out_values_q16_values == values_q16 ||
            snapshot_out_values_q16_values == out_values_q16 ||
            snapshot_out_values_q16_values == out_required_score_cells ||
            snapshot_out_values_q16_values == out_required_value_cells ||
            snapshot_out_values_q16_values == out_required_out_cells ||
            staged_parity_out_values_q16 == scores_q16 ||
            staged_parity_out_values_q16 == values_q16 ||
            staged_parity_out_values_q16 == out_values_q16 ||
            staged_parity_out_values_q16 == out_required_score_cells ||
            staged_parity_out_values_q16 == out_required_value_cells ||
            staged_parity_out_values_q16 == out_required_out_cells ||
            staged_parity_out_values_q16 == snapshot_out_values_q16_values)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];

        parity_out_values_q16 = staged_parity_out_values_q16;
        parity_out_capacity = required_out_cells;
    }

    staged_parity_required_score_cells = required_score_cells;
    staged_parity_required_value_cells = required_value_cells;
    staged_parity_required_out_cells = required_out_cells;
    staged_preflight_required_score_cells = required_score_cells;
    staged_preflight_required_value_cells = required_value_cells;
    staged_preflight_required_out_cells = required_out_cells;

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParity(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        parity_out_values_q16,
        parity_out_capacity);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        out_values_q16,
        out_capacity);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    kv_rows = 0;
    if (!(snapshot_query_rows == 0 || snapshot_key_rows == 0 || snapshot_value_dim == 0))
    {
        kv_rows = snapshot_query_rows / snapshot_head_groups;
        if (kv_rows <= 0)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_score_cells != staged_preflight_required_score_cells ||
        staged_parity_required_value_cells != staged_preflight_required_value_cells ||
        staged_parity_required_out_cells != staged_preflight_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_score_cells != required_score_cells ||
        staged_parity_required_value_cells != required_value_cells ||
        staged_parity_required_out_cells != required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_value_cells != snapshot_out_required_value_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_value_cells != snapshot_out_required_value_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
            {
                status = ATTN_Q16_ERR_BAD_PARAM;
                goto Cleanup;
            }
        }
    }

    *out_required_score_cells = staged_parity_required_score_cells;
    *out_required_value_cells = staged_parity_required_value_cells;
    *out_required_out_cells = staged_parity_required_out_cells;
    status = ATTN_Q16_OK;

Cleanup:
    if (staged_parity_out_values_q16)
        Free(staged_parity_out_values_q16);
    if (snapshot_out_values_q16_values)
        Free(snapshot_out_values_q16_values);
    return status;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_value_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_value_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_value_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 staged_parity_required_score_cells;
    I64 staged_parity_required_value_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_commit_required_score_cells;
    I64 staged_commit_required_value_cells;
    I64 staged_commit_required_out_cells;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *snapshot_out_values_q16_values;
    I64 *staged_parity_out_values_q16;
    I64 *staged_commit_out_values_q16;
    I64 *parity_out_values_q16;
    I64 parity_out_capacity;
    I64 *commit_out_values_q16;
    I64 commit_out_capacity;
    I32 status;

    snapshot_out_values_q16_values = NULL;
    staged_parity_out_values_q16 = NULL;
    staged_commit_out_values_q16 = NULL;

    if (!out_required_score_cells || !out_required_value_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_score_cells == out_required_value_cells ||
        out_required_score_cells == out_required_out_cells ||
        out_required_value_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;
    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_value_cells_ptr = out_required_value_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_value_cells_value = *out_required_value_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1449 zero-write diagnostics companion:
    // 1) freeze immutable geometry/capacity tuple + caller diagnostics slots;
    // 2) stage strict parity and commit-only wrappers on private output slabs;
    // 3) enforce exact required score/value/out tuple parity across both wrappers;
    // 4) prove caller output + required-cell slots remain unchanged.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    kv_rows = 0;
    if (!(query_rows == 0 || key_rows == 0 || value_dim == 0))
    {
        kv_rows = query_rows / head_groups;
        if (kv_rows <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells == scores_q16 ||
        out_required_score_cells == values_q16 ||
        out_required_score_cells == out_values_q16 ||
        out_required_value_cells == scores_q16 ||
        out_required_value_cells == values_q16 ||
        out_required_value_cells == out_values_q16 ||
        out_required_out_cells == scores_q16 ||
        out_required_out_cells == values_q16 ||
        out_required_out_cells == out_values_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    parity_out_values_q16 = out_values_q16;
    parity_out_capacity = out_capacity;
    commit_out_values_q16 = out_values_q16;
    commit_out_capacity = out_capacity;

    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            goto Cleanup;
        if (required_out_bytes <= 0)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        snapshot_out_values_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_values_q16_values)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        staged_parity_out_values_q16 = MAlloc(required_out_bytes);
        if (!staged_parity_out_values_q16)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        staged_commit_out_values_q16 = MAlloc(required_out_bytes);
        if (!staged_commit_out_values_q16)
        {
            status = ATTN_Q16_ERR_OVERFLOW;
            goto Cleanup;
        }

        if (snapshot_out_values_q16_values == scores_q16 ||
            snapshot_out_values_q16_values == values_q16 ||
            snapshot_out_values_q16_values == out_values_q16 ||
            snapshot_out_values_q16_values == out_required_score_cells ||
            snapshot_out_values_q16_values == out_required_value_cells ||
            snapshot_out_values_q16_values == out_required_out_cells ||
            staged_parity_out_values_q16 == scores_q16 ||
            staged_parity_out_values_q16 == values_q16 ||
            staged_parity_out_values_q16 == out_values_q16 ||
            staged_parity_out_values_q16 == out_required_score_cells ||
            staged_parity_out_values_q16 == out_required_value_cells ||
            staged_parity_out_values_q16 == out_required_out_cells ||
            staged_commit_out_values_q16 == scores_q16 ||
            staged_commit_out_values_q16 == values_q16 ||
            staged_commit_out_values_q16 == out_values_q16 ||
            staged_commit_out_values_q16 == out_required_score_cells ||
            staged_commit_out_values_q16 == out_required_value_cells ||
            staged_commit_out_values_q16 == out_required_out_cells ||
            snapshot_out_values_q16_values == staged_parity_out_values_q16 ||
            snapshot_out_values_q16_values == staged_commit_out_values_q16 ||
            staged_parity_out_values_q16 == staged_commit_out_values_q16)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];

        parity_out_values_q16 = staged_parity_out_values_q16;
        parity_out_capacity = required_out_cells;
        commit_out_values_q16 = staged_commit_out_values_q16;
        commit_out_capacity = required_out_cells;
    }

    staged_parity_required_score_cells = required_score_cells;
    staged_parity_required_value_cells = required_value_cells;
    staged_parity_required_out_cells = required_out_cells;
    staged_commit_required_score_cells = required_score_cells;
    staged_commit_required_value_cells = required_value_cells;
    staged_commit_required_out_cells = required_out_cells;

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParity(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        parity_out_values_q16,
        parity_out_capacity);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        row_stride,
        values_q16,
        values_capacity,
        commit_out_values_q16,
        commit_out_capacity,
        &staged_commit_required_score_cells,
        &staged_commit_required_value_cells,
        &staged_commit_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    kv_rows = 0;
    if (!(snapshot_query_rows == 0 || snapshot_key_rows == 0 || snapshot_value_dim == 0))
    {
        kv_rows = snapshot_query_rows / snapshot_head_groups;
        if (kv_rows <= 0)
        {
            status = ATTN_Q16_ERR_BAD_PARAM;
            goto Cleanup;
        }
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
        goto Cleanup;

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_score_cells != required_score_cells ||
        staged_parity_required_value_cells != required_value_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_score_cells != required_score_cells ||
        staged_commit_required_value_cells != required_value_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_score_cells != staged_commit_required_score_cells ||
        staged_parity_required_value_cells != staged_commit_required_value_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_value_cells != snapshot_out_required_value_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_value_cells != snapshot_out_required_value_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
            {
                status = ATTN_Q16_ERR_BAD_PARAM;
                goto Cleanup;
            }
        }
    }

    status = ATTN_Q16_OK;

Cleanup:
    if (staged_commit_out_values_q16)
        Free(staged_commit_out_values_q16);
    if (staged_parity_out_values_q16)
        Free(staged_parity_out_values_q16);
    if (snapshot_out_values_q16_values)
        Free(snapshot_out_values_q16_values);
    return status;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyPreflightOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_commit_out_values_q16;
    I64 *staged_canonical_out_values_q16;
    I64 *snapshot_out_values_q16_values;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;

    // IQ-1378 zero-write diagnostics contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) stage commit-only and canonical no-partial outputs privately;
    // 3) enforce strict required tuple parity from checked recompute;
    // 4) require caller output window to remain unchanged.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_canonical_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_canonical_out_values_q16)
    {
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    snapshot_out_values_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_values_q16_values)
    {
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_out_values_q16 == scores_q16 ||
        staged_commit_out_values_q16 == values_q16 ||
        staged_commit_out_values_q16 == out_values_q16 ||
        staged_canonical_out_values_q16 == scores_q16 ||
        staged_canonical_out_values_q16 == values_q16 ||
        staged_canonical_out_values_q16 == out_values_q16 ||
        snapshot_out_values_q16_values == scores_q16 ||
        snapshot_out_values_q16_values == values_q16 ||
        snapshot_out_values_q16_values == out_values_q16 ||
        staged_commit_out_values_q16 == staged_canonical_out_values_q16 ||
        staged_commit_out_values_q16 == snapshot_out_values_q16_values ||
        staged_canonical_out_values_q16 == snapshot_out_values_q16_values)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnly(scores_q16,
                                                                scores_capacity,
                                                                query_rows,
                                                                key_rows,
                                                                value_dim,
                                                                head_groups,
                                                                row_stride,
                                                                values_q16,
                                                                values_capacity,
                                                                staged_commit_out_values_q16,
                                                                required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartial(scores_q16,
                                                     scores_capacity,
                                                     query_rows,
                                                     key_rows,
                                                     value_dim,
                                                     head_groups,
                                                     row_stride,
                                                     values_q16,
                                                     values_capacity,
                                                     staged_canonical_out_values_q16,
                                                     required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_canonical_out_values_q16);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_commit_out_values_q16[copy_index] != staged_canonical_out_values_q16[copy_index])
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_canonical_out_values_q16);
            Free(staged_commit_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_canonical_out_values_q16);
            Free(staged_commit_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    Free(snapshot_out_values_q16_values);
    Free(staged_canonical_out_values_q16);
    Free(staged_commit_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyPreflightOnlyParity(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
    I64 values_capacity,
    I64 *out_values_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_value_dim;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_values_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q16;
    I64 *snapshot_values_q16;
    I64 *snapshot_out_values_q16;
    I64 required_score_cells;
    I64 required_value_cells;
    I64 required_out_cells;
    I64 required_score_bytes;
    I64 required_value_bytes;
    I64 required_out_bytes;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_value_cells;
    I64 recomputed_required_out_cells;
    I64 kv_rows;
    I64 copy_index;
    I64 *staged_commit_out_values_q16;
    I64 *snapshot_out_values_q16_values;
    U64 scores_begin;
    U64 scores_end;
    U64 values_begin;
    U64 values_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!scores_q16 || !values_q16 || !out_values_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || values_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || value_dim < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_value_dim = value_dim;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_values_capacity = values_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q16 = scores_q16;
    snapshot_values_q16 = values_q16;
    snapshot_out_values_q16 = out_values_q16;

    // IQ-1380 strict diagnostics parity contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) derive required score/value/output spans and reject source/output overlap;
    // 3) execute preflight-only diagnostics on caller output and commit-only path on private stage;
    // 4) enforce exact required tuple parity + no-write diagnostics before atomic publish.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0 || value_dim == 0)
        return ATTN_Q16_OK;

    kv_rows = query_rows / head_groups;
    if (kv_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(kv_rows,
                                       key_rows,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       value_dim,
                                       &required_value_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       value_dim,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_value_cells > values_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_value_cells,
                                       sizeof(I64),
                                       &required_value_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 ||
        required_value_bytes <= 0 ||
        required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q16;
    values_begin = (U64)values_q16;
    out_begin = (U64)out_values_q16;

    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(values_begin,
                                       (U64)required_value_bytes,
                                       &values_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_begin < values_end && values_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_out_values_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_out_values_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    snapshot_out_values_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_values_q16_values)
    {
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_out_values_q16 == scores_q16 ||
        staged_commit_out_values_q16 == values_q16 ||
        staged_commit_out_values_q16 == out_values_q16 ||
        staged_commit_out_values_q16 == snapshot_out_values_q16_values ||
        snapshot_out_values_q16_values == scores_q16 ||
        snapshot_out_values_q16_values == values_q16 ||
        snapshot_out_values_q16_values == out_values_q16)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyPreflightOnly(scores_q16,
                                                                             scores_capacity,
                                                                             query_rows,
                                                                             key_rows,
                                                                             value_dim,
                                                                             head_groups,
                                                                             row_stride,
                                                                             values_q16,
                                                                             values_capacity,
                                                                             out_values_q16,
                                                                             out_capacity);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialCommitOnly(scores_q16,
                                                                scores_capacity,
                                                                query_rows,
                                                                key_rows,
                                                                value_dim,
                                                                head_groups,
                                                                row_stride,
                                                                values_q16,
                                                                values_capacity,
                                                                staged_commit_out_values_q16,
                                                                required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    kv_rows = snapshot_query_rows / snapshot_head_groups;
    if (kv_rows <= 0)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = AttentionTryMulI64Checked(kv_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_value_cells,
                                       snapshot_value_dim,
                                       &recomputed_required_value_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_value_dim,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_value_cells != recomputed_required_value_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_value_cells > snapshot_values_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_values_q16_values);
        Free(staged_commit_out_values_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
        {
            Free(snapshot_out_values_q16_values);
            Free(staged_commit_out_values_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_values_q16[copy_index] = staged_commit_out_values_q16[copy_index];

    Free(snapshot_out_values_q16_values);
    Free(staged_commit_out_values_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionValueMixQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *scores_q16,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 value_dim,
    I64 head_groups,
    I64 row_stride,
    I64 *values_q16,
