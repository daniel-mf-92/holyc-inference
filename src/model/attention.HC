    status = GQAAttentionValueMixQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        values_q16,
        values_capacity,
        out_values_q16,
        out_capacity,
        &staged_commit_only_required_score_cells,
        &staged_commit_only_required_value_cells,
        &staged_commit_only_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return status;
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialPreflightDefaultStrideParity(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        values_q16,
        values_capacity,
        out_values_q16,
        out_capacity,
        &staged_parity_required_score_cells,
        &staged_parity_required_value_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_value_dim != value_dim ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_values_capacity != values_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q16 != scores_q16 ||
        snapshot_values_q16 != values_q16 ||
        snapshot_out_values_q16 != out_values_q16)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != staged_parity_required_score_cells ||
        staged_commit_only_required_value_cells != staged_parity_required_value_cells ||
        staged_commit_only_required_out_cells != staged_parity_required_out_cells)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != recomputed_required_score_cells ||
        staged_commit_only_required_value_cells != recomputed_required_value_cells ||
        staged_commit_only_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells > snapshot_scores_capacity ||
        staged_commit_only_required_value_cells > snapshot_values_capacity ||
        staged_commit_only_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_value_cells != snapshot_out_required_value_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_value_cells != snapshot_out_required_value_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_values_q16_values)
            Free(snapshot_out_values_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_out_values_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_values_q16[copy_index] != snapshot_out_values_q16_values[copy_index])
            {
                Free(snapshot_out_values_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_values_q16_values);
    }
    return ATTN_Q16_OK;
}

