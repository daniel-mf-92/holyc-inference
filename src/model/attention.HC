I32 AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideRequiredBytesPreflightOnlyDefaultCapacityCommitOnlyPreflightOnlyParity(
    I64 *q_rows_q16,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
