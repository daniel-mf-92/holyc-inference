    if (status != ATTN_Q16_OK)
        return status;

    if (canonical_commit_stage_cell_capacity != strided_commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (canonical_commit_stage_byte_capacity != strided_commit_stage_byte_capacity)
