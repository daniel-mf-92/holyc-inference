            Free(snapshot_out_scores_q32);
        if (staged_commit_scores_q32)
            Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_scores_q32[copy_index] != snapshot_out_scores_q32[copy_index])
            {
                Free(snapshot_out_scores_q32);
                Free(staged_commit_scores_q32);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
    }

    *out_required_q_cells = staged_preflight_required_q_cells;
    *out_required_k_cells = staged_preflight_required_k_cells;
    *out_required_out_cells = staged_preflight_required_out_cells;

    if (snapshot_out_scores_q32)
        Free(snapshot_out_scores_q32);
    if (staged_commit_scores_q32)
        Free(staged_commit_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
