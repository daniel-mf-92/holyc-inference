    // 3) enforce tuple parity + immutable geometry snapshot checks;
    // 4) atomically publish diagnostics only after all checks pass.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialPreflightOnlyDefaultStrideRequiredStageBytesDefaultCapacityNoAllocHardenedCommitOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            out_scores_q32,
            out_scores_capacity,
            &staged_required_in_cells,
