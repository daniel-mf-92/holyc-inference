    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_out_capacity = out_capacity;

    // IQ-1406 commit-only parity hardening contract:
    // 1) freeze immutable geometry tuple and derive required q/k/out spans;
    // 2) reject live input/output alias windows;
    // 3) stage parity and commit-only wrappers on private output buffers;
    // 4) atomically publish only after strict tuple and output parity.
