        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-605 default-capacity contract:
    // derive caller stage capacity from exact live score slab footprint
    // (`query_row_count * token_count`) with checked overflow arithmetic,
    // then delegate all no-alloc required-bytes diagnostics to the shared
    // helper so null/shape/span semantics stay identical.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &default_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytes(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        default_stage_cell_capacity,
        out_required_stage_cells,
        out_required_stage_bytes,
        out_required_out_cells);
}

// Default commit-cell-capacity wrapper for no-alloc required-bytes commit
// diagnostics.
//
// IQ-615 contract:
// - derive commit_stage_cell_capacity = query_row_count * token_count using
//   checked overflow arithmetic;
// - preserve no-allocation semantics by routing all diagnostics through
//   ...NoAllocRequiredBytesCommitCapacity;
// - keep NULL/shape/capacity diagnostics identical to explicit composition.
I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacityDefault(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_byte_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_stage_cell_capacity;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        out_commit_required_stage_cells,
        out_commit_required_stage_bytes,
        out_required_out_cells);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityDefaultCapacityPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 staged_scores_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_stage_cell_capacity;
    I64 commit_stage_byte_capacity;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-629 preflight-only default-capacity contract:
    // derive default commit scratch capacities from the live query/token slab
    // and caller staging capacity, then route diagnostics through the shared
    // ...NoAllocRequiredBytesCommitCapacity helper with no compute/commit.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        out_commit_required_stage_cells,
        out_commit_required_stage_bytes,
        out_required_out_cells);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_required_stage_cells;
    I64 commit_required_stage_bytes;
    I64 required_out_cells;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-606 commit-capacity diagnostics contract:
    // derive strict required stage cells/bytes through the canonical no-alloc
    // required-bytes helper, then validate those diagnostics against caller
    // commit scratch limits before routing to commit-only paths.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytes(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        &commit_required_stage_cells,
        &commit_required_stage_bytes,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (commit_required_stage_bytes > commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_commit_required_stage_cells = commit_required_stage_cells;
    *out_commit_required_stage_bytes = commit_required_stage_bytes;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAlloc(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 stage_cell_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 required_stage_cells;
    I64 required_out_cells;
    I64 required_stage_bytes;
    I64 staging_capacity_bytes;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-604 no-alloc no-partial default-stride contract:
    // 1) preflight all q/k/out/staging spans with checked math;
    // 2) compute full batch into caller-owned staging slab;
    // 3) commit through no-alloc commit-only helper for all-or-nothing writes.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        stage_cell_capacity,
        &required_stage_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    if (!staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;
    if (staged_scores_capacity < required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(required_stage_cells,
                                       sizeof(I64),
                                       &required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &staging_capacity_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_stage_bytes > staging_capacity_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    // Staging must not alias live tensors or destination output.
    if (staged_scores_q32 == q_rows_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_q32 == k_rows_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_q32 == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStride(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        score_scale_q16,
        staged_scores_q32,
        staged_scores_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        required_stage_cells,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocDefaultCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 default_stage_cell_capacity;
    I64 staging_capacity_bytes;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 required_out_cells;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &default_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &staging_capacity_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    // IQ-607 default-capacity no-alloc contract:
    // derive stage capacity from the exact live score slab
    // (`query_row_count * token_count`) and route staging diagnostics
    // through commit-capacity required-bytes validation before compute.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        default_stage_cell_capacity,
        staging_capacity_bytes,
        &required_stage_cells,
        &required_stage_bytes,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    if (!staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes > staging_capacity_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    // No-partial guarantee for destination output requires caller staging to
    // be separate from source/destination tensor buffers.
    if (staged_scores_q32 == q_rows_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_q32 == k_rows_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_scores_q32 == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStride(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        score_scale_q16,
        staged_scores_q32,
        staged_scores_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        required_stage_cells,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 required_out_cells;
    I64 staging_capacity_bytes;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &staging_capacity_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    // IQ-616 commit-capacity no-alloc contract:
    // 1) enforce caller commit scratch contracts through the shared
    //    required-bytes helper (`commit_stage_cell_capacity`,
    //    `commit_stage_byte_capacity`);
    // 2) compute into caller-provided staging buffer with default strides;
    // 3) commit staged live score slab atomically via no-alloc commit-only.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesCommitCapacity(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        &required_stage_cells,
        &required_stage_bytes,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    if (!staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;
    if (required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes > staging_capacity_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(required_q_cells,
                                       sizeof(I64),
                                       &required_q_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       sizeof(I64),
                                       &required_k_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_bytes <= 0 || required_q_bytes <= 0 ||
        required_k_bytes <= 0 || required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // No-partial contract: staging must not overlap live Q/K/output spans.
    // This guards interior-pointer aliasing, not just exact pointer equality.
    staged_begin = (U64)staged_scores_q32;
    q_begin = (U64)q_rows_q16;
    k_begin = (U64)k_rows_q16;
    out_begin = (U64)out_scores_q32;

    status = AttentionTryAddU64Checked(staged_begin,
                                       (U64)required_stage_bytes,
                                       &staged_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(q_begin,
                                       (U64)required_q_bytes,
                                       &q_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(k_begin,
                                       (U64)required_k_bytes,
                                       &k_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (staged_begin < q_end && q_begin < staged_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_begin < k_end && k_begin < staged_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_begin < out_end && out_begin < staged_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionQ16ComputeScaledQKRowsCheckedDefaultStride(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        score_scale_q16,
        staged_scores_q32,
        staged_scores_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitOnly(
        query_row_count,
        token_count,
        staged_scores_q32,
        staged_scores_capacity,
        required_stage_cells,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityDefaultCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 default_commit_stage_cell_capacity;
    I64 default_commit_stage_byte_capacity;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-617 default-capacity commit contract:
    // derive commit scratch limits from the live default-stride batch shape
    // (`query_row_count * token_count`) and caller stage buffer cells
    // (`staged_scores_capacity * sizeof(I64)`), then route all no-partial
    // compute/commit semantics through the canonical commit-capacity wrapper.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &default_commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &default_commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacity(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_commit_stage_cell_capacity,
        default_commit_stage_byte_capacity,
        staged_scores_q32,
        staged_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityAliasSafeDefaultCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 head_dim,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity)
{
    I64 default_query_row_stride_q16;
    I64 default_k_row_stride_q16;
    I64 default_out_row_stride;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-672 default-stride alias-safe default-capacity compute contract:
    // derive canonical packed strides from model geometry, then route compute
    // and commit through the explicit-stride alias-safe default-capacity
    // helper so overflow, overlap, and no-partial semantics stay centralized.
    default_query_row_stride_q16 = head_dim;
    default_k_row_stride_q16 = head_dim;
    default_out_row_stride = token_count;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitCapacityAliasSafeDefaultCapacity(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        default_query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        default_k_row_stride_q16,
        head_dim,
        score_scale_q16,
        out_scores_q32,
        out_scores_capacity,
        default_out_row_stride,
        staged_scores_q32,
        staged_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocPreflightOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes)
{
    I64 last_q_base_index;
    I64 last_k_base_index;
    I64 last_out_base_index;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I32 status;

    if (!out_required_q_cells || !out_required_k_cells || !out_required_out_cells ||
        !out_required_stage_cells || !out_required_stage_bytes)
        return ATTN_Q16_ERR_NULL_PTR;

    // IQ-637 explicit-stride no-alloc preflight contract:
    // 1) reuse the canonical no-partial span checker for Q/K/out windows;
    // 2) derive packed staging requirements (`query_row_count * token_count`);
    // 3) stage every diagnostic locally and only commit on full success.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &last_q_base_index,
        &last_k_base_index,
        &last_out_base_index,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(required_stage_cells,
                                       sizeof(I64),
                                       &required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    *out_required_q_cells = required_q_cells;
    *out_required_k_cells = required_k_cells;
    *out_required_out_cells = required_out_cells;
    *out_required_stage_cells = required_stage_cells;
    *out_required_stage_bytes = required_stage_bytes;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 commit_required_stage_cells;
    I64 commit_required_stage_bytes;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells,
        &commit_required_stage_cells,
        &commit_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (commit_required_stage_cells > commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_bytes > commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_commit_required_stage_cells = commit_required_stage_cells;
    *out_commit_required_stage_bytes = commit_required_stage_bytes;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafe(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_stage_cells;
    I64 required_stage_bytes;
    I64 canonical_required_q_cells;
    I64 canonical_required_k_cells;
    I64 canonical_required_out_cells;
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 q_span_bytes;
    I64 k_span_bytes;
    I64 out_span_bytes;
    I64 stage_capacity_bytes;
    I64 q_base_addr;
    I64 q_end_addr;
    I64 k_base_addr;
    I64 k_end_addr;
    I64 out_base_addr;
    I64 out_end_addr;
    I64 stage_base_addr;
    I64 stage_end_addr;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-648 alias-safe required-bytes contract:
    // 1) run canonical explicit-stride preflight to get required q/k/out/stage;
    // 2) enforce commit capacity bounds for staging cell+byte diagnostics;
    // 3) for active rows/tokens, reject staged-vs-q/k/out live-span overlap
    //    under interior-pointer layouts;
    // 4) publish diagnostics only after all checks pass.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &required_q_cells,
        &required_k_cells,
        &required_out_cells,
        &required_stage_cells,
        &required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_stage_cells > commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes > commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_row_count && token_count)
    {
        if (!staged_scores_q32)
            return ATTN_Q16_ERR_NULL_PTR;
        if (required_stage_cells > staged_scores_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;

        status = AttentionTryMulI64Checked(staged_scores_capacity,
                                           sizeof(I64),
                                           &stage_capacity_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_stage_bytes > stage_capacity_bytes)
            return ATTN_Q16_ERR_BAD_PARAM;

        status = AttentionTryMulI64Checked(required_q_cells,
                                           sizeof(I64),
                                           &q_span_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryMulI64Checked(required_k_cells,
                                           sizeof(I64),
                                           &k_span_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &out_span_bytes);
        if (status != ATTN_Q16_OK)
            return status;

        q_base_addr = (I64)q_rows_q16;
        k_base_addr = (I64)k_rows_q16;
        out_base_addr = (I64)out_scores_q32;
        stage_base_addr = (I64)staged_scores_q32;

        status = AttentionByteRangeEndChecked(q_base_addr,
                                              q_span_bytes,
                                              &q_end_addr);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionByteRangeEndChecked(k_base_addr,
                                              k_span_bytes,
                                              &k_end_addr);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionByteRangeEndChecked(out_base_addr,
                                              out_span_bytes,
                                              &out_end_addr);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionByteRangeEndChecked(stage_base_addr,
                                              stage_capacity_bytes,
                                              &stage_end_addr);
        if (status != ATTN_Q16_OK)
            return status;

        if (AttentionByteRangesOverlap(stage_base_addr,
                                       stage_end_addr,
                                       q_base_addr,
                                       q_end_addr))
            return ATTN_Q16_ERR_BAD_PARAM;
        if (AttentionByteRangesOverlap(stage_base_addr,
                                       stage_end_addr,
                                       k_base_addr,
                                       k_end_addr))
            return ATTN_Q16_ERR_BAD_PARAM;
        if (AttentionByteRangesOverlap(stage_base_addr,
                                       stage_end_addr,
                                       out_base_addr,
                                       out_end_addr))
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    // IQ-675 hardening: publish diagnostics only after alias-safe preflight
    // and canonical required-bytes diagnostics agree across every required
    // q/k/out/stage span field so callers cannot observe mixed diagnostics.
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytes(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &canonical_required_q_cells,
        &canonical_required_k_cells,
        &canonical_required_out_cells,
        &canonical_required_stage_cells,
        &canonical_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells != canonical_required_q_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_k_cells != canonical_required_k_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells != canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_cells != canonical_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes != canonical_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_commit_required_stage_cells = required_stage_cells;
    *out_commit_required_stage_bytes = required_stage_bytes;
    *out_required_out_cells = required_out_cells;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafeDefaultCapacity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *out_commit_required_stage_cells,
    I64 *out_commit_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 commit_stage_cell_capacity;
    I64 commit_stage_byte_capacity;
    I32 status;

    if (!out_commit_required_stage_cells || !out_commit_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32 || !staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-654 default-capacity alias-safe required-bytes diagnostics:
    // derive commit capacity from packed stage geometry + caller staging bytes,
    // then route through the canonical alias-safe commit-capacity diagnostics
    // helper so overlap + bounds semantics stay identical.
    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &commit_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(staged_scores_capacity,
                                       sizeof(I64),
                                       &commit_stage_byte_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafe(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        staged_scores_q32,
        staged_scores_capacity,
        out_commit_required_stage_cells,
        out_commit_required_stage_bytes,
        out_required_out_cells);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafeCommitOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 required_q_cells,
    I64 required_k_cells,
    I64 required_out_cells,
    I64 required_stage_cells,
    I64 required_stage_bytes)
{
    I64 canonical_required_q_cells;
    I64 canonical_required_k_cells;
    I64 canonical_required_out_cells;
    I64 canonical_required_stage_cells;
    I64 canonical_required_stage_bytes;
    I64 commit_required_stage_cells;
    I64 commit_required_stage_bytes;
    I64 commit_required_out_cells;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_q_cells < 0 || required_k_cells < 0 || required_out_cells < 0 ||
        required_stage_cells < 0 || required_stage_bytes < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-677 commit-only contract:
    // 1) re-run canonical alias-safe required-bytes diagnostics so commit-stage
    //    capacities + live alias windows are validated at commit time;
    // 2) re-derive canonical q/k/out/stage requirements and require exact
    //    equality with caller-provided prevalidated diagnostics;
    // 3) only after full validation succeeds, atomically commit staged scores
    //    into caller strided output (strict no-partial writes).
    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafe(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        commit_stage_cell_capacity,
        commit_stage_byte_capacity,
        staged_scores_q32,
        staged_scores_capacity,
        &commit_required_stage_cells,
        &commit_required_stage_bytes,
        &commit_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        query_row_stride_q16,
        k_rows_q16,
        k_rows_capacity,
        token_count,
        k_row_stride_q16,
        head_dim,
        out_scores_q32,
        out_scores_capacity,
        out_row_stride,
        &canonical_required_q_cells,
        &canonical_required_k_cells,
        &canonical_required_out_cells,
        &canonical_required_stage_cells,
        &canonical_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells != canonical_required_q_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_k_cells != canonical_required_k_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells != canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_cells != canonical_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_stage_bytes != canonical_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (commit_required_stage_cells != canonical_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_stage_bytes != canonical_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_required_out_cells != canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!query_row_count || !token_count)
        return ATTN_Q16_OK;

    return AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocCommitOnly(
        query_row_count,
        token_count,
        out_row_stride,
        staged_scores_q32,
        staged_scores_capacity,
        out_scores_q32,
        out_scores_capacity);
}

I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafeDefaultCapacityCommitOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 query_row_count,
    I64 query_row_stride_q16,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 token_count,
    I64 k_row_stride_q16,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 out_row_stride,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 required_q_cells,
    I64 required_k_cells,
    I64 required_out_cells,
    I64 required_stage_cells,
    I64 required_stage_bytes)
{
    I64 commit_stage_cell_capacity;
    I64 commit_stage_byte_capacity;
    I64 preflight_required_q_cells;
    I64 preflight_required_k_cells;
    I64 preflight_required_out_cells;
    I64 preflight_required_stage_cells;
    I64 preflight_required_stage_bytes;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_row_count < 0 || query_row_stride_q16 < 0 || token_count < 0 ||
        k_row_stride_q16 < 0 || head_dim < 0 || out_row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_q_cells < 0 || required_k_cells < 0 || required_out_cells < 0 ||
        required_stage_cells < 0 || required_stage_bytes < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    // IQ-678 default-capacity alias-safe commit-only contract:
    // 1) derive default commit capacities from packed stage geometry and
    //    caller staging bytes;
    // 2) run canonical default-capacity preflight-only helper so q/k/out/
    //    stage diagnostics plus alias-safe commit capacities are published
    //    atomically from one validated source;
    // 3) require exact equality with caller-provided diagnostics;
    // 4) dispatch canonical alias-safe commit-only path with no compute side
    //    effects and strict no-partial output writes.
    status =
        AttentionQ16ComputeScaledQKRowsCheckedNoPartialStridedNoAllocRequiredBytesCommitCapacityAliasSafeDefaultCapacityPreflightOnly(
            q_rows_q16,
            q_rows_capacity,
            query_row_count,
            query_row_stride_q16,
