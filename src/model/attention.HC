    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1413 commit-only hardening contract:
    // 1) stage diagnostics tuple from default-stride parity gate;
    // 2) stage diagnostics tuple from default-stride preflight helper;
    // 3) re-derive required geometry tuple with checked integer math;
    // 4) atomically publish only when snapshots and strict tuple parity hold.
    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_parity_required_score_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStride(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_default_required_score_cells,
        &staged_default_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells != staged_default_required_score_cells ||
        staged_parity_required_out_cells != staged_default_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells != recomputed_required_score_cells ||
        staged_parity_required_out_cells != recomputed_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_parity_required_score_cells > snapshot_scores_capacity ||
        staged_parity_required_out_cells > snapshot_out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_score_cells = staged_parity_required_score_cells;
    *out_required_out_cells = staged_parity_required_out_cells;
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnlyPreflightOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 *out_probs_q16,
    I64 out_capacity,
    I64 *out_required_score_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 *snapshot_out_required_score_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_score_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 staged_commit_only_required_score_cells;
    I64 staged_commit_only_required_out_cells;
    I64 staged_parity_required_score_cells;
    I64 staged_parity_required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_scores_bytes;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_scores_q32_values;
    I64 *snapshot_out_probs_q16_values;
    I32 status;

    if (!out_required_score_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;
    if (out_required_score_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    snapshot_out_required_score_cells_ptr = out_required_score_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_score_cells_value = *out_required_score_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1428 zero-write diagnostics contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) stage tuples from parity-commit and parity diagnostic helpers;
    // 3) re-derive required tuple with checked integer geometry math;
    // 4) preserve caller score/output buffers + required-cell slots on success/failure.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    recomputed_required_score_cells = 0;
    recomputed_required_out_cells = 0;
    if (!(query_rows == 0 || key_rows == 0))
    {
        status = AttentionTryMulI64Checked(query_rows - 1,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;
        status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                           key_rows,
                                           &recomputed_required_score_cells);
        if (status != ATTN_Q16_OK)
            return status;

        status = AttentionTryMulI64Checked(query_rows,
                                           key_rows,
                                           &recomputed_required_out_cells);
        if (status != ATTN_Q16_OK)
            return status;

        if (recomputed_required_score_cells > scores_capacity ||
            recomputed_required_out_cells > out_capacity)
            return ATTN_Q16_ERR_BAD_PARAM;
    }

    snapshot_scores_q32_values = NULL;
    if (recomputed_required_score_cells > 0)
    {
        status = AttentionTryMulI64Checked(recomputed_required_score_cells,
                                           sizeof(I64),
                                           &required_scores_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_scores_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_scores_q32_values = MAlloc(required_scores_bytes);
        if (!snapshot_scores_q32_values)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_scores_q32_values == scores_q32 ||
            snapshot_scores_q32_values == out_probs_q16)
        {
            Free(snapshot_scores_q32_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < recomputed_required_score_cells; copy_index++)
            snapshot_scores_q32_values[copy_index] = scores_q32[copy_index];
    }

    snapshot_out_probs_q16_values = NULL;
    if (recomputed_required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(recomputed_required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
        {
            if (snapshot_scores_q32_values)
                Free(snapshot_scores_q32_values);
            return status;
        }
        if (required_out_bytes <= 0)
        {
            if (snapshot_scores_q32_values)
                Free(snapshot_scores_q32_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
        if (!snapshot_out_probs_q16_values)
        {
            if (snapshot_scores_q32_values)
                Free(snapshot_scores_q32_values);
            return ATTN_Q16_ERR_OVERFLOW;
        }

        if (snapshot_out_probs_q16_values == scores_q32 ||
            snapshot_out_probs_q16_values == out_probs_q16)
        {
            Free(snapshot_out_probs_q16_values);
            if (snapshot_scores_q32_values)
                Free(snapshot_scores_q32_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
            snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnly(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_commit_only_required_score_cells,
        &staged_commit_only_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParity(
        scores_q32,
        scores_capacity,
        query_rows,
        key_rows,
        head_groups,
        out_probs_q16,
        out_capacity,
        &staged_parity_required_score_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != staged_parity_required_score_cells ||
        staged_commit_only_required_out_cells != staged_parity_required_out_cells)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells != recomputed_required_score_cells ||
        staged_commit_only_required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_commit_only_required_score_cells > snapshot_scores_capacity ||
        staged_commit_only_required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_score_cells != snapshot_out_required_score_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (*out_required_score_cells != snapshot_out_required_score_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_scores_q32_values)
            Free(snapshot_scores_q32_values);
        if (snapshot_out_probs_q16_values)
            Free(snapshot_out_probs_q16_values);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (snapshot_scores_q32_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_score_cells; copy_index++)
        {
            if (scores_q32[copy_index] != snapshot_scores_q32_values[copy_index])
            {
                Free(snapshot_scores_q32_values);
                if (snapshot_out_probs_q16_values)
                    Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_scores_q32_values);
    }

    if (snapshot_out_probs_q16_values)
    {
        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
        {
            if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
            {
                Free(snapshot_out_probs_q16_values);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
        Free(snapshot_out_probs_q16_values);
    }
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialPreflightDefaultStrideParityCommitOnlyPreflightOnlyParity(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
