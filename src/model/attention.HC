    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &default_stage_cell_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        query_row_count,
        k_rows_q16,
