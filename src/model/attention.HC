I32 AttentionQ16ComputeScaledQKRowsCheckedNoPartialDefaultStrideNoAllocRequiredBytesPreflightOnlyDefaultCapacityCommitOnlyHardenedPreflightOnlyNoAllocCommitOnlyParity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
