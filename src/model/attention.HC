        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_q_cells > snapshot_q_rows_capacity ||
        required_k_cells > snapshot_k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_q_cells != required_q_cells ||
        staged_parity_required_k_cells != required_k_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_q_cells != required_q_cells ||
        staged_commit_required_k_cells != required_k_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (staged_parity_required_q_cells != staged_commit_required_q_cells ||
        staged_parity_required_k_cells != staged_commit_required_k_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (staged_parity_scores_q32[copy_index] != staged_commit_scores_q32[copy_index])
            {
                status = ATTN_Q16_ERR_BAD_PARAM;
                goto Cleanup;
            }
        }
    }

    if (out_required_q_cells != snapshot_out_required_q_cells_ptr ||
        out_required_k_cells != snapshot_out_required_k_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }
    if (*out_required_q_cells != snapshot_out_required_q_cells_value ||
        *out_required_k_cells != snapshot_out_required_k_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        status = ATTN_Q16_ERR_BAD_PARAM;
        goto Cleanup;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_scores_q32[copy_index] != snapshot_out_scores_q32_values[copy_index])
            {
                status = ATTN_Q16_ERR_BAD_PARAM;
                goto Cleanup;
            }
        }
    }

    status = ATTN_Q16_OK;

Cleanup:
    if (staged_commit_scores_q32)
        Free(staged_commit_scores_q32);
    if (staged_parity_scores_q32)
        Free(staged_parity_scores_q32);
    if (snapshot_out_scores_q32_values)
        Free(snapshot_out_scores_q32_values);
    return status;
}

#define GQA_SOFTMAX_EXP_MAX_Q16  655360
I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParityCommitOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity,
    I64 *out_required_q_cells,
    I64 *out_required_k_cells,
    I64 *out_required_out_cells)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_q_rows_capacity;
    I64 snapshot_k_rows_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_out_required_q_cells_ptr;
    I64 *snapshot_out_required_k_cells_ptr;
    I64 *snapshot_out_required_out_cells_ptr;
    I64 snapshot_out_required_q_cells_value;
    I64 snapshot_out_required_k_cells_value;
    I64 snapshot_out_required_out_cells_value;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 staged_parity_required_q_cells;
    I64 staged_parity_required_k_cells;
    I64 staged_parity_required_out_cells;
    I64 staged_commit_required_q_cells;
    I64 staged_commit_required_k_cells;
    I64 staged_commit_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *snapshot_out_scores_q32;
    I32 status;

    if (!out_required_q_cells || !out_required_k_cells || !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_q_cells == out_required_k_cells ||
        out_required_q_cells == out_required_out_cells ||
        out_required_k_cells == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_q_rows_capacity = q_rows_capacity;
    snapshot_k_rows_capacity = k_rows_capacity;
    snapshot_out_capacity = out_capacity;

    snapshot_out_required_q_cells_ptr = out_required_q_cells;
    snapshot_out_required_k_cells_ptr = out_required_k_cells;
    snapshot_out_required_out_cells_ptr = out_required_out_cells;
    snapshot_out_required_q_cells_value = *out_required_q_cells;
    snapshot_out_required_k_cells_value = *out_required_k_cells;
    snapshot_out_required_out_cells_value = *out_required_out_cells;

    // IQ-1391 commit-only hardening wrapper:
    // 1) freeze immutable geometry/capacity tuple + caller diagnostics slots;
    // 2) derive required q/k/out tuple with checked integer math;
    // 3) run strict parity and preflight-only companions into staged tuples;
    // 4) enforce exact tuple parity + immutable caller-state snapshots;
    // 5) atomically publish diagnostics only after both wrappers agree exactly.
    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_q_cells == q_rows_q16 ||
        out_required_q_cells == k_rows_q16 ||
        out_required_q_cells == out_scores_q32 ||
        out_required_k_cells == q_rows_q16 ||
        out_required_k_cells == k_rows_q16 ||
        out_required_k_cells == out_scores_q32 ||
        out_required_out_cells == q_rows_q16 ||
        out_required_out_cells == k_rows_q16 ||
        out_required_out_cells == out_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_out_scores_q32 = NULL;
    if (required_out_cells > 0)
    {
        status = AttentionTryMulI64Checked(required_out_cells,
                                           sizeof(I64),
                                           &required_out_bytes);
        if (status != ATTN_Q16_OK)
            return status;
        if (required_out_bytes <= 0)
            return ATTN_Q16_ERR_BAD_PARAM;

        snapshot_out_scores_q32 = MAlloc(required_out_bytes);
        if (!snapshot_out_scores_q32)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_scores_q32 == q_rows_q16 ||
            snapshot_out_scores_q32 == k_rows_q16 ||
            snapshot_out_scores_q32 == out_scores_q32 ||
            snapshot_out_scores_q32 == out_required_q_cells ||
            snapshot_out_scores_q32 == out_required_k_cells ||
            snapshot_out_scores_q32 == out_required_out_cells)
        {
            Free(snapshot_out_scores_q32);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
            snapshot_out_scores_q32[copy_index] = out_scores_q32[copy_index];
    }

    staged_parity_required_q_cells = required_q_cells;
    staged_parity_required_k_cells = required_k_cells;
    staged_parity_required_out_cells = required_out_cells;

    staged_commit_required_q_cells = required_q_cells;
    staged_commit_required_k_cells = required_k_cells;
    staged_commit_required_out_cells = required_out_cells;

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnlyParity(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_parity_required_q_cells,
        &staged_parity_required_k_cells,
        &staged_parity_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnlyPreflightOnlyParityCommitOnlyPreflightOnly(
        q_rows_q16,
        q_rows_capacity,
        q_rows,
        k_rows_q16,
        k_rows_capacity,
        k_rows,
        group_count,
        seq_len,
        head_dim,
        out_scores_q32,
        out_capacity,
        &staged_commit_required_q_cells,
        &staged_commit_required_k_cells,
        &staged_commit_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_q_rows_capacity != q_rows_capacity ||
        snapshot_k_rows_capacity != k_rows_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_parity_required_q_cells != required_q_cells ||
        staged_parity_required_k_cells != required_k_cells ||
        staged_parity_required_out_cells != required_out_cells ||
        staged_commit_required_q_cells != required_q_cells ||
        staged_commit_required_k_cells != required_k_cells ||
        staged_commit_required_out_cells != required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (staged_parity_required_q_cells != staged_commit_required_q_cells ||
        staged_parity_required_k_cells != staged_commit_required_k_cells ||
        staged_parity_required_out_cells != staged_commit_required_out_cells)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (out_required_q_cells != snapshot_out_required_q_cells_ptr ||
        out_required_k_cells != snapshot_out_required_k_cells_ptr ||
        out_required_out_cells != snapshot_out_required_out_cells_ptr)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }
    if (*out_required_q_cells != snapshot_out_required_q_cells_value ||
        *out_required_k_cells != snapshot_out_required_k_cells_value ||
        *out_required_out_cells != snapshot_out_required_out_cells_value)
    {
        if (snapshot_out_scores_q32)
            Free(snapshot_out_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_out_cells > 0)
    {
        for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        {
            if (out_scores_q32[copy_index] != snapshot_out_scores_q32[copy_index])
            {
                Free(snapshot_out_scores_q32);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
    }

    *out_required_q_cells = staged_parity_required_q_cells;
    *out_required_k_cells = staged_parity_required_k_cells;
    *out_required_out_cells = staged_parity_required_out_cells;

    if (snapshot_out_scores_q32)
        Free(snapshot_out_scores_q32);
    return ATTN_Q16_OK;
}
#define GQA_SOFTMAX_EXP_MIN_Q16 -655360
#define GQA_SOFTMAX_ONE_Q16      (1 << ATTN_Q16_SHIFT)

I64 FPQ16Exp(I64 x);

I32 GQAAttentionApplySoftmaxQ16Checked(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity)
{
    I64 required_score_cells;
    I64 required_out_cells;
    I64 stage_bytes;
    I64 row_index;
    I64 col_index;
    I64 row_base;
    I64 row_max_q32;
    I64 shifted_q16;
    I64 exp_lane_q16;
    I64 exp_sum_q16;
    I64 numerator_q16;
    I64 prob_q16;
    I64 prob_sum_q16;
    I64 best_index;
    I64 best_value_q16;
    I64 remainder_q16;
    I64 add_value_q16;
    I64 commit_index;
    I64 *staged_probs_q16;
    I32 status;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_cells > scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_probs_q16 = MAlloc(stage_bytes);
    if (!staged_probs_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    for (row_index = 0; row_index < query_rows; row_index++)
    {
        status = AttentionTryMulI64Checked(row_index,
                                           row_stride,
                                           &row_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_probs_q16);
            return status;
        }

        row_max_q32 = scores_q32[row_base];
        for (col_index = 1; col_index < key_rows; col_index++)
        {
            if (scores_q32[row_base + col_index] > row_max_q32)
                row_max_q32 = scores_q32[row_base + col_index];
        }

        exp_sum_q16 = 0;
        best_index = 0;
        best_value_q16 = -1;
        for (col_index = 0; col_index < key_rows; col_index++)
        {
            shifted_q16 = (scores_q32[row_base + col_index] - row_max_q32) >> ATTN_Q16_SHIFT;
            if (shifted_q16 > GQA_SOFTMAX_EXP_MAX_Q16)
                shifted_q16 = GQA_SOFTMAX_EXP_MAX_Q16;
            if (shifted_q16 < GQA_SOFTMAX_EXP_MIN_Q16)
                shifted_q16 = GQA_SOFTMAX_EXP_MIN_Q16;

            exp_lane_q16 = FPQ16Exp(shifted_q16);
            if (exp_lane_q16 <= 0)
            {
                Free(staged_probs_q16);
                return ATTN_Q16_ERR_BAD_PARAM;
            }

            staged_probs_q16[row_index * key_rows + col_index] = exp_lane_q16;
            status = AttentionTryAddI64Checked(exp_sum_q16,
                                               exp_lane_q16,
                                               &exp_sum_q16);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_probs_q16);
                return status;
            }

            if (exp_lane_q16 > best_value_q16)
            {
                best_value_q16 = exp_lane_q16;
                best_index = col_index;
            }
        }

        if (exp_sum_q16 <= 0)
        {
            Free(staged_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        prob_sum_q16 = 0;
        for (col_index = 0; col_index < key_rows; col_index++)
        {
            status = AttentionTryMulI64Checked(staged_probs_q16[row_index * key_rows + col_index],
                                               GQA_SOFTMAX_ONE_Q16,
                                               &numerator_q16);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_probs_q16);
                return status;
            }

            status = AttentionTryAddI64Checked(numerator_q16,
                                               exp_sum_q16 / 2,
                                               &numerator_q16);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_probs_q16);
                return status;
            }

            prob_q16 = numerator_q16 / exp_sum_q16;
            if (prob_q16 < 0)
                prob_q16 = 0;

            staged_probs_q16[row_index * key_rows + col_index] = prob_q16;
            status = AttentionTryAddI64Checked(prob_sum_q16,
                                               prob_q16,
                                               &prob_sum_q16);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_probs_q16);
                return status;
            }
        }

        remainder_q16 = GQA_SOFTMAX_ONE_Q16 - prob_sum_q16;
        if (remainder_q16 > 0)
        {
            status = AttentionTryAddI64Checked(staged_probs_q16[row_index * key_rows + best_index],
                                               remainder_q16,
                                               &add_value_q16);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_probs_q16);
                return status;
            }
            staged_probs_q16[row_index * key_rows + best_index] = add_value_q16;
        }
        else if (remainder_q16 < 0)
        {
            remainder_q16 = -remainder_q16;
            for (col_index = 0; col_index < key_rows && remainder_q16 > 0; col_index++)
            {
                commit_index = row_index * key_rows + ((best_index + col_index) % key_rows);
                if (!staged_probs_q16[commit_index])
                    continue;

                if (staged_probs_q16[commit_index] > remainder_q16)
                {
                    staged_probs_q16[commit_index] -= remainder_q16;
                    remainder_q16 = 0;
                }
                else
                {
                    remainder_q16 -= staged_probs_q16[commit_index];
                    staged_probs_q16[commit_index] = 0;
                }
            }

            if (remainder_q16 != 0)
            {
                Free(staged_probs_q16);
                return ATTN_Q16_ERR_BAD_PARAM;
            }
        }
    }

    for (commit_index = 0; commit_index < required_out_cells; commit_index++)
        out_probs_q16[commit_index] = staged_probs_q16[commit_index];

    Free(staged_probs_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartial(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 stage_bytes;
    I64 copy_index;
    I64 *staged_probs_q16;
    I32 status;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;

    // IQ-1369 no-partial contract:
    // 1) snapshot immutable geometry/capacity tuple;
    // 2) derive required score/output spans with checked integer math;
    // 3) run canonical softmax into private stage buffer;
    // 4) re-check snapshot parity and atomically publish outputs.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_cells > scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_probs_q16 = MAlloc(stage_bytes);
    if (!staged_probs_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    status = GQAAttentionApplySoftmaxQ16Checked(scores_q32,
                                                scores_capacity,
                                                query_rows,
                                                key_rows,
                                                head_groups,
                                                row_stride,
                                                staged_probs_q16,
                                                required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_probs_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_probs_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_probs_q16[copy_index] = staged_probs_q16[copy_index];

    Free(staged_probs_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 required_score_bytes;
    I64 required_out_bytes;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 copy_index;
    I64 *staged_probs_q16;
    I64 *parity_probs_q16;
    U64 scores_begin;
    U64 scores_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;

    // IQ-1370 commit-only hardening contract:
    // 1) freeze geometry/capacity tuple and derive required spans;
    // 2) reject live score/output alias windows;
    // 3) run no-partial + canonical helpers into private stage buffers;
    // 4) publish only when strict tuple parity checks pass.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_score_cells,
                                       sizeof(I64),
                                       &required_score_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_score_bytes <= 0 || required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    scores_begin = (U64)scores_q32;
    out_begin = (U64)out_probs_q16;
    status = AttentionTryAddU64Checked(scores_begin,
                                       (U64)required_score_bytes,
                                       &scores_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < scores_end && scores_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_probs_q16 = MAlloc(required_out_bytes);
    if (!staged_probs_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    parity_probs_q16 = MAlloc(required_out_bytes);
    if (!parity_probs_q16)
    {
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_probs_q16 == scores_q32 ||
        staged_probs_q16 == out_probs_q16 ||
        parity_probs_q16 == scores_q32 ||
        parity_probs_q16 == out_probs_q16 ||
        staged_probs_q16 == parity_probs_q16)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartial(scores_q32,
                                                         scores_capacity,
                                                         query_rows,
                                                         key_rows,
                                                         head_groups,
                                                         row_stride,
                                                         staged_probs_q16,
                                                         required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16Checked(scores_q32,
                                                scores_capacity,
                                                query_rows,
                                                key_rows,
                                                head_groups,
                                                row_stride,
                                                parity_probs_q16,
                                                required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > snapshot_scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(parity_probs_q16);
        Free(staged_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_probs_q16[copy_index] != parity_probs_q16[copy_index])
        {
            Free(parity_probs_q16);
            Free(staged_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_probs_q16[copy_index] = staged_probs_q16[copy_index];

    Free(parity_probs_q16);
    Free(staged_probs_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnly(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *staged_commit_probs_q16;
    I64 *staged_canonical_probs_q16;
    I64 *snapshot_out_probs_q16_values;
    I32 status;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    // IQ-1371 zero-write diagnostics contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) stage commit-only and canonical no-partial outputs privately;
    // 3) enforce strict required tuple parity from checked recompute;
    // 4) require caller output window to remain unchanged.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
                                       row_stride,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddI64Checked(required_score_cells,
                                       key_rows,
                                       &required_score_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_rows,
                                       key_rows,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_score_cells > scores_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_probs_q16 = MAlloc(required_out_bytes);
    if (!staged_commit_probs_q16)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_canonical_probs_q16 = MAlloc(required_out_bytes);
    if (!staged_canonical_probs_q16)
    {
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    snapshot_out_probs_q16_values = MAlloc(required_out_bytes);
    if (!snapshot_out_probs_q16_values)
    {
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_probs_q16 == scores_q32 ||
        staged_commit_probs_q16 == out_probs_q16 ||
        staged_canonical_probs_q16 == scores_q32 ||
        staged_canonical_probs_q16 == out_probs_q16 ||
        snapshot_out_probs_q16_values == scores_q32 ||
        snapshot_out_probs_q16_values == out_probs_q16 ||
        staged_commit_probs_q16 == staged_canonical_probs_q16 ||
        staged_commit_probs_q16 == snapshot_out_probs_q16_values ||
        staged_canonical_probs_q16 == snapshot_out_probs_q16_values)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        snapshot_out_probs_q16_values[copy_index] = out_probs_q16[copy_index];

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnly(scores_q32,
                                                                    scores_capacity,
                                                                    query_rows,
                                                                    key_rows,
                                                                    head_groups,
                                                                    row_stride,
                                                                    staged_commit_probs_q16,
                                                                    required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = GQAAttentionApplySoftmaxQ16CheckedNoPartial(scores_q32,
                                                         scores_capacity,
                                                         query_rows,
                                                         key_rows,
                                                         head_groups,
                                                         row_stride,
                                                         staged_canonical_probs_q16,
                                                         required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_query_rows - 1,
                                       snapshot_row_stride,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }
    status = AttentionTryAddI64Checked(recomputed_required_score_cells,
                                       snapshot_key_rows,
                                       &recomputed_required_score_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }
    status = AttentionTryMulI64Checked(snapshot_query_rows,
                                       snapshot_key_rows,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return status;
    }

    if (snapshot_query_rows != query_rows ||
        snapshot_key_rows != key_rows ||
        snapshot_head_groups != head_groups ||
        snapshot_row_stride != row_stride ||
        snapshot_scores_capacity != scores_capacity ||
        snapshot_out_capacity != out_capacity ||
        snapshot_scores_q32 != scores_q32 ||
        snapshot_out_probs_q16 != out_probs_q16)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells != recomputed_required_score_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_score_cells > scores_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(snapshot_out_probs_q16_values);
        Free(staged_canonical_probs_q16);
        Free(staged_commit_probs_q16);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_commit_probs_q16[copy_index] != staged_canonical_probs_q16[copy_index])
        {
            Free(snapshot_out_probs_q16_values);
            Free(staged_canonical_probs_q16);
            Free(staged_commit_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (out_probs_q16[copy_index] != snapshot_out_probs_q16_values[copy_index])
        {
            Free(snapshot_out_probs_q16_values);
            Free(staged_canonical_probs_q16);
            Free(staged_commit_probs_q16);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    Free(snapshot_out_probs_q16_values);
    Free(staged_canonical_probs_q16);
    Free(staged_commit_probs_q16);
    return ATTN_Q16_OK;
}

I32 GQAAttentionApplySoftmaxQ16CheckedNoPartialCommitOnlyPreflightOnlyParity(
    I64 *scores_q32,
    I64 scores_capacity,
    I64 query_rows,
    I64 key_rows,
    I64 head_groups,
    I64 row_stride,
    I64 *out_probs_q16,
    I64 out_capacity)
{
    I64 snapshot_query_rows;
    I64 snapshot_key_rows;
    I64 snapshot_head_groups;
    I64 snapshot_row_stride;
    I64 snapshot_scores_capacity;
    I64 snapshot_out_capacity;
    I64 *snapshot_scores_q32;
    I64 *snapshot_out_probs_q16;
    I64 required_score_cells;
    I64 required_out_cells;
    I64 recomputed_required_score_cells;
    I64 recomputed_required_out_cells;
    I64 required_score_bytes;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *staged_commit_probs_q16;
    I64 *snapshot_out_probs_q16_values;
    U64 scores_begin;
    U64 scores_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!scores_q32 || !out_probs_q16)
        return ATTN_Q16_ERR_NULL_PTR;

    if (scores_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (query_rows < 0 || key_rows < 0 || head_groups <= 0 || row_stride < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_rows = query_rows;
    snapshot_key_rows = key_rows;
    snapshot_head_groups = head_groups;
    snapshot_row_stride = row_stride;
    snapshot_scores_capacity = scores_capacity;
    snapshot_out_capacity = out_capacity;
    snapshot_scores_q32 = scores_q32;
    snapshot_out_probs_q16 = out_probs_q16;

    // IQ-1379 strict parity contract:
    // 1) freeze immutable geometry/capacity + pointer snapshots;
    // 2) derive required score/out spans with checked integer math;
    // 3) run preflight-only diagnostics (zero-write) and commit-only in private stage;
    // 4) enforce strict tuple parity + immutable snapshots;
    // 5) atomically publish staged probabilities only after full parity passes.
    if (query_rows > 0 && (query_rows % head_groups) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (key_rows > row_stride)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (query_rows == 0 || key_rows == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(query_rows - 1,
