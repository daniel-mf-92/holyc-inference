        if (!snapshot_out_values_q16_values)
            return ATTN_Q16_ERR_OVERFLOW;

        if (snapshot_out_values_q16_values == scores_q16 ||
            snapshot_out_values_q16_values == values_q16 ||
            snapshot_out_values_q16_values == out_values_q16)
        {
            Free(snapshot_out_values_q16_values);
            return ATTN_Q16_ERR_BAD_PARAM;
        }

        for (copy_index = 0; copy_index < recomputed_required_out_cells; copy_index++)
            snapshot_out_values_q16_values[copy_index] = out_values_q16[copy_index];
    }

    status = GQAAttentionValueMixQ16CheckedNoPartialPreflightDefaultStrideCommitOnly(
        scores_q16,
        scores_capacity,
        query_rows,
        key_rows,
        value_dim,
        head_groups,
        values_q16,
        values_capacity,
        out_values_q16,
        out_capacity,
        &staged_commit_only_required_score_cells,
        &staged_commit_only_required_value_cells,
        &staged_commit_only_required_out_cells);
    if (status != ATTN_Q16_OK)
