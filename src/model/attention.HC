        !out_last_out_base_index || !out_required_q_cells ||
        !out_required_k_cells || !out_required_out_cells ||
        !out_required_q_bytes || !out_required_k_bytes ||
        !out_required_out_bytes)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_last_q_base_index == out_last_k_base_index ||
        out_last_q_base_index == out_last_out_base_index ||
        out_last_q_base_index == out_required_q_cells ||
        out_last_q_base_index == out_required_k_cells ||
        out_last_q_base_index == out_required_out_cells ||
        out_last_q_base_index == out_required_q_bytes ||
        out_last_q_base_index == out_required_k_bytes ||
        out_last_q_base_index == out_required_out_bytes ||
        out_last_k_base_index == out_last_out_base_index ||
        out_last_k_base_index == out_required_q_cells ||
        out_last_k_base_index == out_required_k_cells ||
        out_last_k_base_index == out_required_out_cells ||
        out_last_k_base_index == out_required_q_bytes ||
        out_last_k_base_index == out_required_k_bytes ||
        out_last_k_base_index == out_required_out_bytes ||
        out_last_out_base_index == out_required_q_cells ||
        out_last_out_base_index == out_required_k_cells ||
        out_last_out_base_index == out_required_out_cells ||
        out_last_out_base_index == out_required_q_bytes ||
        out_last_out_base_index == out_required_k_bytes ||
        out_last_out_base_index == out_required_out_bytes ||
        out_required_q_cells == out_required_k_cells ||
        out_required_q_cells == out_required_out_cells ||
        out_required_q_cells == out_required_q_bytes ||
        out_required_q_cells == out_required_k_bytes ||
        out_required_q_cells == out_required_out_bytes ||
        out_required_k_cells == out_required_out_cells ||
        out_required_k_cells == out_required_q_bytes ||
        out_required_k_cells == out_required_k_bytes ||
        out_required_k_cells == out_required_out_bytes ||
        out_required_out_cells == out_required_q_bytes ||
        out_required_out_cells == out_required_k_bytes ||
        out_required_out_cells == out_required_out_bytes ||
        out_required_q_bytes == out_required_k_bytes ||
        out_required_q_bytes == out_required_out_bytes ||
        out_required_k_bytes == out_required_out_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (query_row_count < 0 || token_count < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_query_row_count = query_row_count;
    snapshot_token_count = token_count;
    snapshot_head_dim = head_dim;

    status = AttentionTryMulI64Checked(query_row_count,
                                       head_dim,
                                       &q_rows_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(token_count,
                                       head_dim,
                                       &k_rows_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(query_row_count,
                                       token_count,
                                       &out_scores_capacity);
    if (status != ATTN_Q16_OK)
        return status;

    snapshot_q_rows_capacity = q_rows_capacity;
    snapshot_k_rows_capacity = k_rows_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;

    // IQ-835 diagnostics-only preflight companion contract:
    // 1) stage full diagnostics from commit-only parity wrapper;
    // 2) recompute canonical default-capacity tuple via base preflight helper;
    // 3) revalidate immutable geometry/capacity snapshots;
    // 4) atomically publish staged diagnostics only after exact tuple parity.
    status =
        AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideRequiredBytesPreflightOnlyDefaultCapacityCommitOnlyPreflightOnlyParityCommitOnly(
            q_rows_q16,
            query_row_count,
            k_rows_q16,
            token_count,
            head_dim,
            out_scores_q32,
            &staged_last_q_base_index,
            &staged_last_k_base_index,
            &staged_last_out_base_index,
            &staged_required_q_cells,
            &staged_required_k_cells,
            &staged_required_out_cells,
            &staged_required_q_bytes,
            &staged_required_k_bytes,
            &staged_required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    status =
        AttentionQ16ComputeScaledQKRowsCheckedDefaultStrideRequiredBytesPreflightOnlyDefaultCapacity(
            q_rows_q16,
            query_row_count,
            k_rows_q16,
            token_count,
            head_dim,
            out_scores_q32,
            &canonical_last_q_base_index,
            &canonical_last_k_base_index,
            &canonical_last_out_base_index,
            &canonical_required_q_cells,
            &canonical_required_k_cells,
            &canonical_required_out_cells,
            &canonical_required_q_bytes,
            &canonical_required_k_bytes,
            &canonical_required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_query_row_count != query_row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_head_dim != head_dim)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (snapshot_q_rows_capacity != q_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_k_rows_capacity != k_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_last_q_base_index != canonical_last_q_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_k_base_index != canonical_last_k_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_last_out_base_index != canonical_last_out_base_index)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_q_cells != canonical_required_q_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_k_cells != canonical_required_k_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != canonical_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_q_bytes != canonical_required_q_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_k_bytes != canonical_required_k_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_bytes != canonical_required_out_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_last_q_base_index = staged_last_q_base_index;
    *out_last_k_base_index = staged_last_k_base_index;
    *out_last_out_base_index = staged_last_out_base_index;
    *out_required_q_cells = staged_required_q_cells;
    *out_required_k_cells = staged_required_k_cells;
    *out_required_out_cells = staged_required_out_cells;
    *out_required_q_bytes = staged_required_q_bytes;
    *out_required_k_bytes = staged_required_k_bytes;
    *out_required_out_bytes = staged_required_out_bytes;
    return ATTN_Q16_OK;
}

I32 AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityParityCommitOnly(
    I64 *in_scores_q32,
    I64 in_scores_capacity,
    I64 row_count,
    I64 token_count,
    I64 score_scale_q16,
    I64 *out_scores_q32,
    I64 out_scores_capacity,
    I64 commit_stage_cell_capacity,
    I64 commit_stage_byte_capacity,
    I64 *staged_scores_q32,
    I64 staged_scores_capacity,
    I64 *parity_out_scores_q32,
    I64 parity_out_scores_capacity,
    I64 *parity_staged_scores_q32,
    I64 parity_staged_scores_capacity,
    I64 *out_required_stage_cells,
    I64 *out_required_stage_bytes,
    I64 *out_required_out_cells)
{
    I64 snapshot_row_count;
    I64 snapshot_token_count;
    I64 snapshot_score_scale_q16;
    I64 snapshot_commit_stage_cell_capacity;
    I64 snapshot_commit_stage_byte_capacity;
    I64 snapshot_out_scores_capacity;
    I64 snapshot_staged_scores_capacity;
    I64 snapshot_parity_out_scores_capacity;
    I64 snapshot_parity_staged_scores_capacity;

    I64 staged_required_stage_cells;
    I64 staged_required_stage_bytes;
    I64 staged_required_out_cells;
    I64 recomputed_required_stage_cells;
    I64 recomputed_required_stage_bytes;
    I32 status;

    if (!out_required_stage_cells || !out_required_stage_bytes ||
        !out_required_out_cells)
        return ATTN_Q16_ERR_NULL_PTR;

    if (out_required_stage_cells == out_required_stage_bytes ||
        out_required_stage_cells == out_required_out_cells ||
        out_required_stage_bytes == out_required_out_cells)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (!in_scores_q32 || !out_scores_q32 || !staged_scores_q32 ||
        !parity_out_scores_q32 || !parity_staged_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (in_scores_capacity < 0 || out_scores_capacity < 0 ||
        staged_scores_capacity < 0 || parity_out_scores_capacity < 0 ||
        parity_staged_scores_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (row_count < 0 || token_count < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (commit_stage_cell_capacity < 0 || commit_stage_byte_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (out_required_stage_cells == in_scores_q32 ||
        out_required_stage_cells == out_scores_q32 ||
        out_required_stage_cells == staged_scores_q32 ||
        out_required_stage_cells == parity_out_scores_q32 ||
        out_required_stage_cells == parity_staged_scores_q32 ||
        out_required_stage_bytes == in_scores_q32 ||
        out_required_stage_bytes == out_scores_q32 ||
        out_required_stage_bytes == staged_scores_q32 ||
        out_required_stage_bytes == parity_out_scores_q32 ||
        out_required_stage_bytes == parity_staged_scores_q32 ||
        out_required_out_cells == in_scores_q32 ||
        out_required_out_cells == out_scores_q32 ||
        out_required_out_cells == staged_scores_q32 ||
        out_required_out_cells == parity_out_scores_q32 ||
        out_required_out_cells == parity_staged_scores_q32)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_row_count = row_count;
    snapshot_token_count = token_count;
    snapshot_score_scale_q16 = score_scale_q16;
    snapshot_commit_stage_cell_capacity = commit_stage_cell_capacity;
    snapshot_commit_stage_byte_capacity = commit_stage_byte_capacity;
    snapshot_out_scores_capacity = out_scores_capacity;
    snapshot_staged_scores_capacity = staged_scores_capacity;
    snapshot_parity_out_scores_capacity = parity_out_scores_capacity;
    snapshot_parity_staged_scores_capacity = parity_staged_scores_capacity;

    // IQ-867 commit-only diagnostics wrapper contract:
    // 1) Stage diagnostics through IQ-866 preflight-only parity helper.
    // 2) Recompute canonical row/token geometry from immutable snapshots.
    // 3) Enforce exact tuple parity and capacity contracts.
    // 4) Atomically publish diagnostics only after all checks pass.
    status =
        AttentionQ16ApplyScoreScaleRowsCheckedNoPartialDefaultStrideNoAllocCommitCapacityParityPreflightOnly(
            in_scores_q32,
            in_scores_capacity,
            row_count,
            token_count,
            score_scale_q16,
            out_scores_q32,
            out_scores_capacity,
            commit_stage_cell_capacity,
            commit_stage_byte_capacity,
            staged_scores_q32,
            staged_scores_capacity,
            parity_out_scores_q32,
            parity_out_scores_capacity,
            parity_staged_scores_q32,
            parity_staged_scores_capacity,
            &staged_required_stage_cells,
            &staged_required_stage_bytes,
            &staged_required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(snapshot_row_count,
                                       snapshot_token_count,
                                       &recomputed_required_stage_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(recomputed_required_stage_cells,
                                       sizeof(I64),
                                       &recomputed_required_stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    if (snapshot_row_count != row_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_token_count != token_count)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_score_scale_q16 != score_scale_q16)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_commit_stage_cell_capacity != commit_stage_cell_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_commit_stage_byte_capacity != commit_stage_byte_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_out_scores_capacity != out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_staged_scores_capacity != staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_parity_out_scores_capacity != parity_out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (snapshot_parity_staged_scores_capacity != parity_staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells != recomputed_required_stage_cells)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_stage_bytes != recomputed_required_stage_bytes)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (staged_required_stage_cells > staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_stage_cells > parity_staged_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells > out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (staged_required_out_cells > parity_out_scores_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    *out_required_stage_cells = staged_required_stage_cells;
    *out_required_stage_bytes = staged_required_stage_bytes;
    *out_required_out_cells = staged_required_out_cells;
    return ATTN_Q16_OK;
}

#define GQA_ATTN_SCORE_CLAMP_Q32 ((I64)32 << ATTN_Q16_SHIFT)

I32 GQAAttentionScoreQ16Checked(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity)
{
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 stage_bytes;
    I64 scale_divisor;
    I64 query_index;
    I64 token_index;
    I64 lane_index;
    I64 q_base;
    I64 out_row_base;
    I64 kv_head_index;
    I64 kv_seq_base;
    I64 k_base;
    I64 score_q32;
    I64 product_q32;
    I64 scaled_score_q32;
    I64 *staged_scores_q32;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (q_rows > 0 && k_rows <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (q_rows > 0 && (q_rows % group_count) != 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(k_rows,
                                       group_count,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_k_cells != q_rows)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_q_cells > q_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_k_cells > k_rows_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_scores_q32 = MAlloc(stage_bytes);
    if (!staged_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    // Deterministic integer-only pre-softmax scaling. We keep full Q32
    // accumulators and divide by head width to bound logits before clamp.
    scale_divisor = head_dim;
    if (scale_divisor <= 0)
        scale_divisor = 1;

    for (query_index = 0; query_index < q_rows; query_index++)
    {
        status = AttentionTryMulI64Checked(query_index,
                                           head_dim,
                                           &q_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_scores_q32);
            return status;
        }

        status = AttentionTryMulI64Checked(query_index,
                                           seq_len,
                                           &out_row_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_scores_q32);
            return status;
        }

        kv_head_index = query_index / group_count;
        status = AttentionTryMulI64Checked(kv_head_index,
                                           seq_len,
                                           &kv_seq_base);
        if (status != ATTN_Q16_OK)
        {
            Free(staged_scores_q32);
            return status;
        }

        for (token_index = 0; token_index < seq_len; token_index++)
        {
            status = AttentionTryAddI64Checked(kv_seq_base,
                                               token_index,
                                               &k_base);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_scores_q32);
                return status;
            }

            status = AttentionTryMulI64Checked(k_base,
                                               head_dim,
                                               &k_base);
            if (status != ATTN_Q16_OK)
            {
                Free(staged_scores_q32);
                return status;
            }

            score_q32 = 0;
            for (lane_index = 0; lane_index < head_dim; lane_index++)
            {
                status = AttentionTryMulI64Checked(q_rows_q16[q_base + lane_index],
                                                   k_rows_q16[k_base + lane_index],
                                                   &product_q32);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_scores_q32);
                    return status;
                }

                status = AttentionTryAddI64Checked(score_q32,
                                                   product_q32,
                                                   &score_q32);
                if (status != ATTN_Q16_OK)
                {
                    Free(staged_scores_q32);
                    return status;
                }
            }

            scaled_score_q32 = score_q32 / scale_divisor;
            if (scaled_score_q32 > GQA_ATTN_SCORE_CLAMP_Q32)
                scaled_score_q32 = GQA_ATTN_SCORE_CLAMP_Q32;
            if (scaled_score_q32 < -GQA_ATTN_SCORE_CLAMP_Q32)
                scaled_score_q32 = -GQA_ATTN_SCORE_CLAMP_Q32;

            staged_scores_q32[out_row_base + token_index] = scaled_score_q32;
        }
    }

    for (query_index = 0; query_index < required_out_cells; query_index++)
        out_scores_q32[query_index] = staged_scores_q32[query_index];

    Free(staged_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartial(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_out_capacity;
    I64 required_out_cells;
    I64 stage_bytes;
    I64 copy_index;
    I64 *staged_scores_q32;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_out_capacity = out_capacity;

    // IQ-1365 staged-commit contract:
    // 1) snapshot immutable geometry tuple;
    // 2) preflight required output cells and stage into temp buffer;
    // 3) re-check tuple + capacities;
    // 4) publish output only after canonical score pass succeeds.
    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &stage_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (stage_bytes <= 0)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_scores_q32 = MAlloc(stage_bytes);
    if (!staged_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    status = GQAAttentionScoreQ16Checked(q_rows_q16,
                                         q_rows_capacity,
                                         q_rows,
                                         k_rows_q16,
                                         k_rows_capacity,
                                         k_rows,
                                         group_count,
                                         seq_len,
                                         head_dim,
                                         staged_scores_q32,
                                         required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_out_capacity != out_capacity)
    {
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_out_cells > snapshot_out_capacity)
    {
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_scores_q32[copy_index] = staged_scores_q32[copy_index];

    Free(staged_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnly(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_out_capacity;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 required_q_bytes;
    I64 required_k_bytes;
    I64 required_out_bytes;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 copy_index;
    I64 *staged_scores_q32;
    I64 *parity_scores_q32;
    U64 q_begin;
    U64 q_end;
    U64 k_begin;
    U64 k_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_out_capacity = out_capacity;

    // IQ-1366 commit-only hardening contract:
    // 1) freeze geometry tuple and derive required q/k/out spans;
    // 2) reject live input/output alias windows;
    // 3) run both no-partial and canonical score paths into staging slabs;
    // 4) publish only after strict tuple + parity checks pass.
    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_q_cells,
                                       sizeof(I64),
                                       &required_q_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       sizeof(I64),
                                       &required_k_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_q_bytes <= 0 || required_k_bytes <= 0 || required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    q_begin = (U64)q_rows_q16;
    k_begin = (U64)k_rows_q16;
    out_begin = (U64)out_scores_q32;

    status = AttentionTryAddU64Checked(q_begin,
                                       (U64)required_q_bytes,
                                       &q_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(k_begin,
                                       (U64)required_k_bytes,
                                       &k_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < q_end && q_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_begin < k_end && k_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_scores_q32 = MAlloc(required_out_bytes);
    if (!staged_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    parity_scores_q32 = MAlloc(required_out_bytes);
    if (!parity_scores_q32)
    {
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_scores_q32 == q_rows_q16 ||
        staged_scores_q32 == k_rows_q16 ||
        staged_scores_q32 == out_scores_q32 ||
        parity_scores_q32 == q_rows_q16 ||
        parity_scores_q32 == k_rows_q16 ||
        parity_scores_q32 == out_scores_q32 ||
        staged_scores_q32 == parity_scores_q32)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionScoreQ16CheckedNoPartial(q_rows_q16,
                                                  q_rows_capacity,
                                                  q_rows,
                                                  k_rows_q16,
                                                  k_rows_capacity,
                                                  k_rows,
                                                  group_count,
                                                  seq_len,
                                                  head_dim,
                                                  staged_scores_q32,
                                                  required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return status;
    }

    status = GQAAttentionScoreQ16Checked(q_rows_q16,
                                         q_rows_capacity,
                                         q_rows,
                                         k_rows_q16,
                                         k_rows_capacity,
                                         k_rows,
                                         group_count,
                                         seq_len,
                                         head_dim,
                                         parity_scores_q32,
                                         required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_out_capacity != out_capacity)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(parity_scores_q32);
        Free(staged_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_scores_q32[copy_index] != parity_scores_q32[copy_index])
        {
            Free(parity_scores_q32);
            Free(staged_scores_q32);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_scores_q32[copy_index] = staged_scores_q32[copy_index];

    Free(parity_scores_q32);
    Free(staged_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParity(
    I64 *q_rows_q16,
    I64 q_rows_capacity,
    I64 q_rows,
    I64 *k_rows_q16,
    I64 k_rows_capacity,
    I64 k_rows,
    I64 group_count,
    I64 seq_len,
    I64 head_dim,
    I64 *out_scores_q32,
    I64 out_capacity)
{
    I64 snapshot_q_rows;
    I64 snapshot_k_rows;
    I64 snapshot_group_count;
    I64 snapshot_seq_len;
    I64 snapshot_head_dim;
    I64 snapshot_out_capacity;
    I64 required_q_cells;
    I64 required_k_cells;
    I64 required_out_cells;
    I64 recomputed_required_q_cells;
    I64 recomputed_required_k_cells;
    I64 recomputed_required_out_cells;
    I64 required_q_bytes;
    I64 required_k_bytes;
    I64 required_out_bytes;
    I64 copy_index;
    I64 *staged_commit_scores_q32;
    I64 *staged_nopartial_scores_q32;
    U64 q_begin;
    U64 q_end;
    U64 k_begin;
    U64 k_end;
    U64 out_begin;
    U64 out_end;
    I32 status;

    if (!q_rows_q16 || !k_rows_q16 || !out_scores_q32)
        return ATTN_Q16_ERR_NULL_PTR;

    if (q_rows_capacity < 0 || k_rows_capacity < 0 || out_capacity < 0)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (q_rows < 0 || k_rows < 0 || group_count <= 0 || seq_len < 0 || head_dim < 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    snapshot_q_rows = q_rows;
    snapshot_k_rows = k_rows;
    snapshot_group_count = group_count;
    snapshot_seq_len = seq_len;
    snapshot_head_dim = head_dim;
    snapshot_out_capacity = out_capacity;

    // IQ-1405 strict diagnostics parity gate:
    // 1) freeze immutable geometry tuple and derive required q/k/out spans;
    // 2) execute commit-only and canonical no-partial paths on private staging;
    // 3) enforce exact tuple parity + immutable snapshot checks;
    // 4) publish only after both staged outputs match cell-for-cell.
    status = AttentionTryMulI64Checked(q_rows,
                                       head_dim,
                                       &required_q_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(k_rows,
                                       seq_len,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       head_dim,
                                       &required_k_cells);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(q_rows,
                                       seq_len,
                                       &required_out_cells);
    if (status != ATTN_Q16_OK)
        return status;

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > out_capacity)
        return ATTN_Q16_ERR_BAD_PARAM;

    if (required_out_cells == 0)
        return ATTN_Q16_OK;

    status = AttentionTryMulI64Checked(required_q_cells,
                                       sizeof(I64),
                                       &required_q_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryMulI64Checked(required_k_cells,
                                       sizeof(I64),
                                       &required_k_bytes);
    if (status != ATTN_Q16_OK)
        return status;

    status = AttentionTryMulI64Checked(required_out_cells,
                                       sizeof(I64),
                                       &required_out_bytes);
    if (status != ATTN_Q16_OK)
        return status;
    if (required_q_bytes <= 0 || required_k_bytes <= 0 || required_out_bytes <= 0)
        return ATTN_Q16_ERR_BAD_PARAM;

    q_begin = (U64)q_rows_q16;
    k_begin = (U64)k_rows_q16;
    out_begin = (U64)out_scores_q32;

    status = AttentionTryAddU64Checked(q_begin,
                                       (U64)required_q_bytes,
                                       &q_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(k_begin,
                                       (U64)required_k_bytes,
                                       &k_end);
    if (status != ATTN_Q16_OK)
        return status;
    status = AttentionTryAddU64Checked(out_begin,
                                       (U64)required_out_bytes,
                                       &out_end);
    if (status != ATTN_Q16_OK)
        return status;

    if (out_begin < q_end && q_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;
    if (out_begin < k_end && k_begin < out_end)
        return ATTN_Q16_ERR_BAD_PARAM;

    staged_commit_scores_q32 = MAlloc(required_out_bytes);
    if (!staged_commit_scores_q32)
        return ATTN_Q16_ERR_OVERFLOW;

    staged_nopartial_scores_q32 = MAlloc(required_out_bytes);
    if (!staged_nopartial_scores_q32)
    {
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_OVERFLOW;
    }

    if (staged_commit_scores_q32 == q_rows_q16 ||
        staged_commit_scores_q32 == k_rows_q16 ||
        staged_commit_scores_q32 == out_scores_q32 ||
        staged_nopartial_scores_q32 == q_rows_q16 ||
        staged_nopartial_scores_q32 == k_rows_q16 ||
        staged_nopartial_scores_q32 == out_scores_q32 ||
        staged_commit_scores_q32 == staged_nopartial_scores_q32)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    status = GQAAttentionScoreQ16CheckedNoPartialCommitOnly(q_rows_q16,
                                                            q_rows_capacity,
                                                            q_rows,
                                                            k_rows_q16,
                                                            k_rows_capacity,
                                                            k_rows,
                                                            group_count,
                                                            seq_len,
                                                            head_dim,
                                                            staged_commit_scores_q32,
                                                            required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = GQAAttentionScoreQ16CheckedNoPartial(q_rows_q16,
                                                  q_rows_capacity,
                                                  q_rows,
                                                  k_rows_q16,
                                                  k_rows_capacity,
                                                  k_rows,
                                                  group_count,
                                                  seq_len,
                                                  head_dim,
                                                  staged_nopartial_scores_q32,
                                                  required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_head_dim,
                                       &recomputed_required_q_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_k_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }
    status = AttentionTryMulI64Checked(recomputed_required_k_cells,
                                       snapshot_head_dim,
                                       &recomputed_required_k_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    status = AttentionTryMulI64Checked(snapshot_q_rows,
                                       snapshot_seq_len,
                                       &recomputed_required_out_cells);
    if (status != ATTN_Q16_OK)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return status;
    }

    if (snapshot_q_rows != q_rows ||
        snapshot_k_rows != k_rows ||
        snapshot_group_count != group_count ||
        snapshot_seq_len != seq_len ||
        snapshot_head_dim != head_dim ||
        snapshot_out_capacity != out_capacity)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells != recomputed_required_q_cells ||
        required_k_cells != recomputed_required_k_cells ||
        required_out_cells != recomputed_required_out_cells)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    if (required_q_cells > q_rows_capacity ||
        required_k_cells > k_rows_capacity ||
        required_out_cells > snapshot_out_capacity)
    {
        Free(staged_nopartial_scores_q32);
        Free(staged_commit_scores_q32);
        return ATTN_Q16_ERR_BAD_PARAM;
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
    {
        if (staged_commit_scores_q32[copy_index] != staged_nopartial_scores_q32[copy_index])
        {
            Free(staged_nopartial_scores_q32);
            Free(staged_commit_scores_q32);
            return ATTN_Q16_ERR_BAD_PARAM;
        }
    }

    for (copy_index = 0; copy_index < required_out_cells; copy_index++)
        out_scores_q32[copy_index] = staged_commit_scores_q32[copy_index];

    Free(staged_nopartial_scores_q32);
    Free(staged_commit_scores_q32);
    return ATTN_Q16_OK;
}

I32 GQAAttentionScoreQ16CheckedNoPartialCommitOnlyParityCommitOnly(
