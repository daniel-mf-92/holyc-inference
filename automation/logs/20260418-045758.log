{"type":"item.started","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"cd /Users/danielmatthews-ferrero/Documents/local-codebases/holyc-inference && python3 - <<'PY'\nimport re\nfrom pathlib import Path\ntext=Path('MASTER_TASKS.md').read_text()\nlines=text.splitlines()\n# extract IQ checklist lines\niq=[]\nfor i,l in enumerate(lines,1):\n    m=re.match(r'- \\\\[( |x)\\\\] (IQ-\\\\d+) (.*)',l)\n    if m:\n        iq.append((i,m.group(2),m.group(1)==' ',m.group(3)))\nunchecked=[x for x in iq if x[2]]\nprint('total',len(iq),'unchecked',len(unchecked))\nfor row in unchecked[:20]:\n    print(row[0],row[1],row[3][:140])\n# max id\nmx=max(int(x[1].split('-')[1]) for x in iq)\nprint('maxid',mx)\n# unchecked ws\nws=[]\nfor i,l in enumerate(lines,1):\n    m=re.match(r'- \\\\[( |x)\\\\] (WS\\\\d+-\\\\d+) (.*)',l)\n    if m and m.group(1)==' ':\n        ws.append((i,m.group(2),m.group(3)))\nprint('unchecked_ws',len(ws))\nfor w in ws[:30]:\n    print(w[0],w[1],w[2][:120])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
