{"type":"item.started","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport math, random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\nI64_MAX = (1<<63)-1\n\n\ndef fp_mul(a,b):\n    prod = a*b\n    if prod >= 0:\n        return (prod + (1<<15)) >> 16\n    return -(((-prod)+(1<<15))>>16)\n\ndef fp_div(num, den):\n    if den == 0:\n        return 0\n    sign = 1\n    if num < 0:\n        sign = -sign\n        num = -num\n    if den < 0:\n        sign = -sign\n        den = -den\n    q = ((num << 16) + (den>>1)) // den\n    return -q if sign < 0 else q\n\ndef fp_from_int(x):\n    return x << 16\n\ndef intsqrt_u64(x):\n    res = 0\n    bit = 1 << 62\n    while bit > x:\n        bit >>= 2\n    while bit:\n        if x >= res + bit:\n            x -= res + bit\n            res = (res >> 1) + bit\n        else:\n            res >>= 1\n        bit >>= 2\n    return res\n\ndef fp_sqrt(x):\n    if x <= 0:\n        return 0\n    shifted = I64_MAX if x > (I64_MAX >> 16) else (x << 16)\n    return intsqrt_u64(shifted)\n\ndef rmsnorm_q16(inp, w, eps_q16):\n    s = 0\n    for x in inp:\n        sq = fp_mul(x,x)\n        s = I64_MAX if s > I64_MAX - sq else s + sq\n    mean_sq = fp_div(s, fp_from_int(len(inp)))\n    mean_sq = I64_MAX if mean_sq > I64_MAX - eps_q16 else mean_sq + eps_q16\n    denom = fp_sqrt(mean_sq)\n    if denom <= 0:\n        return [0]*len(inp)\n    inv = fp_div(FP_Q16_ONE, denom)\n    out = []\n    for x,g in zip(inp,w):\n        norm = fp_mul(x, inv)\n        out.append(fp_mul(norm,g))\n    return out\n\nmax_abs_err = 0.0\nrandom.seed(0)\nfor _ in range(300):\n    n = random.randint(8, 128)\n    inp_f = [random.uniform(-4.0, 4.0) for _ in range(n)]\n    w_f = [random.uniform(0.2, 1.8) for _ in range(n)]\n    eps = 1e-5\n\n    inp_q = [int(round(v * FP_Q16_ONE)) for v in inp_f]\n    w_q = [int(round(v * FP_Q16_ONE)) for v in w_f]\n    eps_q = int(round(eps * FP_Q16_ONE))\n\n    out_q = rmsnorm_q16(inp_q, w_q, eps_q)\n    rms = math.sqrt(sum(v*v for v in inp_f)/n + eps)\n    out_f = [(x/rms)*g for x,g in zip(inp_f,w_f)]\n\n    for a,b in zip(out_q,out_f):\n        err = abs((a/FP_Q16_ONE)-b)\n        if err > max_abs_err:\n            max_abs_err = err\n\nprint(f\\\"rmsnorm_q16_checks=ok max_abs_err={max_abs_err:.6f}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
