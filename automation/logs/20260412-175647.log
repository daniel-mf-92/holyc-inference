{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/gguf/tensor_data_base.HC | sed -n '1,220p'; echo '---'; nl -ba src/gguf/tensor_data_base.HC | sed -n '220,520p'; echo '---'; nl -ba src/gguf/tensor_data_base.HC | sed -n '520,820p'\"","aggregated_output":"     1\t// tensor_data_base.HC\n     2\t// GGUF tensor-data base alignment helpers for HolyC inference runtime.\n     3\t\n     4\t#define GGUF_TDBASE_OK 0\n     5\t#define GGUF_TDBASE_ERR_NULL_PTR 1\n     6\t#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n     7\t#define GGUF_TDBASE_ERR_OVERFLOW 3\n     8\t#define GGUF_TDBASE_ERR_MISALIGNED_BASE 4\n     9\t#define GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET 5\n    10\t#define GGUF_TDBASE_ERR_BAD_TYPE 6\n    11\t#define GGUF_TDBASE_ERR_OUT_OF_BOUNDS 7\n    12\t#define GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE 8\n    13\t#define GGUF_TDBASE_ERR_OVERLAP 9\n    14\t\n    15\t// GGUF default tensor alignment when metadata key `general.alignment`\n    16\t// is absent.\n    17\t#define GGUF_DEFAULT_ALIGNMENT 32\n    18\t\n    19\t// Subset of ggml tensor types currently enabled in HolyC inference runtime.\n    20\t// Keep this list strict and explicit so sizing math never silently accepts\n    21\t// unknown quantization tags from malformed GGUF files.\n    22\t#define GGML_TYPE_F32   0\n    23\t#define GGML_TYPE_F16   1\n    24\t#define GGML_TYPE_Q4_0  2\n    25\t#define GGML_TYPE_Q8_0  8\n    26\t\n    27\t// GGML quantization blocks for runtime-critical formats:\n    28\t// - F32/F16 are scalar types (block size 1).\n    29\t// - Q4_0 and Q8_0 are packed in 32-element blocks.\n    30\t#define GGML_BLCK_SIZE_F32   1\n    31\t#define GGML_BLCK_SIZE_F16   1\n    32\t#define GGML_BLCK_SIZE_Q4_0  32\n    33\t#define GGML_BLCK_SIZE_Q8_0  32\n    34\t\n    35\t// Block payload byte widths from ggml struct layouts:\n    36\t// - Q4_0: fp16 scale (2 bytes) + 16 packed nibbles = 18 bytes.\n    37\t// - Q8_0: fp16 scale (2 bytes) + 32 signed bytes = 34 bytes.\n    38\t#define GGML_TYPE_SIZE_F32   4\n    39\t#define GGML_TYPE_SIZE_F16   2\n    40\t#define GGML_TYPE_SIZE_Q4_0  18\n    41\t#define GGML_TYPE_SIZE_Q8_0  34\n    42\t\n    43\tI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n    44\t{\n    45\t    if (!out_block_size)\n    46\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    47\t\n    48\t    switch (ggml_type)\n    49\t    {\n    50\t        case GGML_TYPE_F32:\n    51\t            *out_block_size = GGML_BLCK_SIZE_F32;\n    52\t            return GGUF_TDBASE_OK;\n    53\t        case GGML_TYPE_F16:\n    54\t            *out_block_size = GGML_BLCK_SIZE_F16;\n    55\t            return GGUF_TDBASE_OK;\n    56\t        case GGML_TYPE_Q4_0:\n    57\t            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n    58\t            return GGUF_TDBASE_OK;\n    59\t        case GGML_TYPE_Q8_0:\n    60\t            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n    61\t            return GGUF_TDBASE_OK;\n    62\t    }\n    63\t\n    64\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    65\t}\n    66\t\n    67\tI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n    68\t{\n    69\t    if (!out_block_bytes)\n    70\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    71\t\n    72\t    switch (ggml_type)\n    73\t    {\n    74\t        case GGML_TYPE_F32:\n    75\t            *out_block_bytes = GGML_TYPE_SIZE_F32;\n    76\t            return GGUF_TDBASE_OK;\n    77\t        case GGML_TYPE_F16:\n    78\t            *out_block_bytes = GGML_TYPE_SIZE_F16;\n    79\t            return GGUF_TDBASE_OK;\n    80\t        case GGML_TYPE_Q4_0:\n    81\t            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n    82\t            return GGUF_TDBASE_OK;\n    83\t        case GGML_TYPE_Q8_0:\n    84\t            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n    85\t            return GGUF_TDBASE_OK;\n    86\t    }\n    87\t\n    88\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    89\t}\n    90\t\n    91\tI64 GGUFTensorBytesForType(U32 ggml_type,\n    92\t                           U64 element_count,\n    93\t                           U64 *out_tensor_nbytes)\n    94\t{\n    95\t    U64 block_size;\n    96\t    U64 block_bytes;\n    97\t    U64 block_count;\n    98\t    I64 err;\n    99\t\n   100\t    if (!out_tensor_nbytes)\n   101\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   102\t\n   103\t    err = GGUFTensorTypeBlockSize(ggml_type, &block_size);\n   104\t    if (err != GGUF_TDBASE_OK)\n   105\t        return err;\n   106\t\n   107\t    err = GGUFTensorTypeBlockBytes(ggml_type, &block_bytes);\n   108\t    if (err != GGUF_TDBASE_OK)\n   109\t        return err;\n   110\t\n   111\t    // Quantized formats are stored in fixed-size element blocks.\n   112\t    // Reject non-multiples instead of silently rounding/truncating.\n   113\t    if (element_count % block_size)\n   114\t        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE;\n   115\t\n   116\t    block_count = element_count / block_size;\n   117\t\n   118\t    // Byte size = number of blocks * bytes per block.\n   119\t    // Guard overflow before multiplication for malformed giant tensors.\n   120\t    if (block_count > 0xFFFFFFFFFFFFFFFF / block_bytes)\n   121\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   122\t\n   123\t    *out_tensor_nbytes = block_count * block_bytes;\n   124\t    return GGUF_TDBASE_OK;\n   125\t}\n   126\t\n   127\tBool GGUFIsPow2U32(U32 value)\n   128\t{\n   129\t    if (!value)\n   130\t        return FALSE;\n   131\t    return (value & (value - 1)) == 0;\n   132\t}\n   133\t\n   134\tI64 GGUFValidateAlignment(U32 alignment)\n   135\t{\n   136\t    if (!GGUFIsPow2U32(alignment))\n   137\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   138\t    return GGUF_TDBASE_OK;\n   139\t}\n   140\t\n   141\tI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n   142\t{\n   143\t    U64 mask;\n   144\t\n   145\t    if (!out)\n   146\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   147\t\n   148\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   149\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   150\t\n   151\t    // For power-of-two alignments, align-up is:\n   152\t    //   (value + (alignment - 1)) & ~(alignment - 1)\n   153\t    // Keep overflow checks explicit so giant malformed offsets are rejected.\n   154\t    mask = (U64)alignment - 1;\n   155\t    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n   156\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   157\t\n   158\t    *out = (value + mask) & ~mask;\n   159\t    return GGUF_TDBASE_OK;\n   160\t}\n   161\t\n   162\tI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n   163\t                            U32 alignment,\n   164\t                            U64 *out_tensor_data_base)\n   165\t{\n   166\t    return GGUFAlignUpU64(cursor_after_tensor_info,\n   167\t                          alignment,\n   168\t                          out_tensor_data_base);\n   169\t}\n   170\t\n   171\tI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n   172\t                                   U64 *out_tensor_data_base)\n   173\t{\n   174\t    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n   175\t                                   GGUF_DEFAULT_ALIGNMENT,\n   176\t                                   out_tensor_data_base);\n   177\t}\n   178\t\n   179\tBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n   180\t{\n   181\t    U64 mask;\n   182\t\n   183\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   184\t        return FALSE;\n   185\t\n   186\t    mask = (U64)alignment - 1;\n   187\t    return (offset & mask) == 0;\n   188\t}\n   189\t\n   190\tI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n   191\t                             U64 tensor_rel_offset,\n   192\t                             U32 alignment,\n   193\t                             U64 *out_tensor_abs)\n   194\t{\n   195\t    if (!out_tensor_abs)\n   196\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   197\t\n   198\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   199\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   200\t\n   201\t    // Both base and relative tensor offsets must preserve GGUF alignment.\n   202\t    // Enforcing this here keeps every downstream payload read auditable.\n   203\t    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n   204\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n   205\t    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n   206\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n   207\t\n   208\t    // Absolute payload pointer is base + relative offset.\n   209\t    // Keep overflow check explicit for malformed large files.\n   210\t    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n   211\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   212\t\n   213\t    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n   214\t    return GGUF_TDBASE_OK;\n   215\t}\n   216\t\n   217\tI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n   218\t                                    U64 tensor_rel_offset,\n   219\t                                    U64 *out_tensor_abs)\n   220\t{\n---\n   220\t{\n   221\t    return GGUFTensorDataBaseOffset(tensor_data_base,\n   222\t                                    tensor_rel_offset,\n   223\t                                    GGUF_DEFAULT_ALIGNMENT,\n   224\t                                    out_tensor_abs);\n   225\t}\n   226\t\n   227\tI64 GGUFTensorResolveRange(U64 tensor_data_base,\n   228\t                           U64 tensor_rel_offset,\n   229\t                           U64 tensor_nbytes,\n   230\t                           U64 gguf_file_nbytes,\n   231\t                           U32 alignment,\n   232\t                           U64 *out_tensor_abs_start,\n   233\t                           U64 *out_tensor_abs_end)\n   234\t{\n   235\t    U64 abs_start;\n   236\t    U64 abs_end;\n   237\t    I64 err;\n   238\t\n   239\t    if (!out_tensor_abs_start || !out_tensor_abs_end)\n   240\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   241\t\n   242\t    // Resolve and validate the absolute tensor start offset first.\n   243\t    err = GGUFTensorDataBaseOffset(tensor_data_base,\n   244\t                                   tensor_rel_offset,\n   245\t                                   alignment,\n   246\t                                   &abs_start);\n   247\t    if (err != GGUF_TDBASE_OK)\n   248\t        return err;\n   249\t\n   250\t    // Tensor byte-range is [abs_start, abs_start + tensor_nbytes).\n   251\t    // Guard add overflow before constructing the exclusive end.\n   252\t    if (abs_start > 0xFFFFFFFFFFFFFFFF - tensor_nbytes)\n   253\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   254\t    abs_end = abs_start + tensor_nbytes;\n   255\t\n   256\t    // Reject ranges that run past the file boundary.\n   257\t    // A tensor may legally end exactly at gguf_file_nbytes.\n   258\t    if (abs_end > gguf_file_nbytes)\n   259\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n   260\t\n   261\t    *out_tensor_abs_start = abs_start;\n   262\t    *out_tensor_abs_end   = abs_end;\n   263\t    return GGUF_TDBASE_OK;\n   264\t}\n   265\t\n   266\tI64 GGUFTensorResolveRangeDefault(U64 tensor_data_base,\n   267\t                                  U64 tensor_rel_offset,\n   268\t                                  U64 tensor_nbytes,\n   269\t                                  U64 gguf_file_nbytes,\n   270\t                                  U64 *out_tensor_abs_start,\n   271\t                                  U64 *out_tensor_abs_end)\n   272\t{\n   273\t    return GGUFTensorResolveRange(tensor_data_base,\n   274\t                                  tensor_rel_offset,\n   275\t                                  tensor_nbytes,\n   276\t                                  gguf_file_nbytes,\n   277\t                                  GGUF_DEFAULT_ALIGNMENT,\n   278\t                                  out_tensor_abs_start,\n   279\t                                  out_tensor_abs_end);\n   280\t}\n   281\t\n   282\tI64 GGUFValidateTensorRanges(U64 tensor_data_base,\n   283\t                             U32 alignment,\n   284\t                             U64 gguf_file_nbytes,\n   285\t                             U64 tensor_count,\n   286\t                             U64 *tensor_rel_offsets,\n   287\t                             U64 *tensor_nbytes,\n   288\t                             U64 *out_bad_index)\n   289\t{\n   290\t    U64 i;\n   291\t    U64 j;\n   292\t    U64 start_i;\n   293\t    U64 end_i;\n   294\t    U64 start_j;\n   295\t    U64 end_j;\n   296\t    I64 err;\n   297\t\n   298\t    if (!tensor_rel_offsets || !tensor_nbytes)\n   299\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   300\t\n   301\t    if (out_bad_index)\n   302\t        *out_bad_index = 0;\n   303\t\n   304\t    // Pass 1: each tensor range must be individually valid.\n   305\t    // This enforces aligned offsets, add-overflow safety, and EOF bounds.\n   306\t    for (i = 0; i < tensor_count; ++i)\n   307\t    {\n   308\t        err = GGUFTensorResolveRange(tensor_data_base,\n   309\t                                     tensor_rel_offsets[i],\n   310\t                                     tensor_nbytes[i],\n   311\t                                     gguf_file_nbytes,\n   312\t                                     alignment,\n   313\t                                     &start_i,\n   314\t                                     &end_i);\n   315\t        if (err != GGUF_TDBASE_OK)\n   316\t        {\n   317\t            if (out_bad_index)\n   318\t                *out_bad_index = i;\n   319\t            return err;\n   320\t        }\n   321\t    }\n   322\t\n   323\t    // Pass 2: pairwise overlap check.\n   324\t    // Explicit O(n^2) keeps logic simple and fully auditable in HolyC.\n   325\t    for (i = 0; i < tensor_count; ++i)\n   326\t    {\n   327\t        err = GGUFTensorResolveRange(tensor_data_base,\n   328\t                                     tensor_rel_offsets[i],\n   329\t                                     tensor_nbytes[i],\n   330\t                                     gguf_file_nbytes,\n   331\t                                     alignment,\n   332\t                                     &start_i,\n   333\t                                     &end_i);\n   334\t        if (err != GGUF_TDBASE_OK)\n   335\t            return err;\n   336\t\n   337\t        for (j = i + 1; j < tensor_count; ++j)\n   338\t        {\n   339\t            err = GGUFTensorResolveRange(tensor_data_base,\n   340\t                                         tensor_rel_offsets[j],\n   341\t                                         tensor_nbytes[j],\n   342\t                                         gguf_file_nbytes,\n   343\t                                         alignment,\n   344\t                                         &start_j,\n   345\t                                         &end_j);\n   346\t            if (err != GGUF_TDBASE_OK)\n   347\t                return err;\n   348\t\n   349\t            // Half-open intervals [start, end) overlap when each interval starts\n   350\t            // before the other ends. Exact touching boundaries are legal.\n   351\t            if ((start_i < end_j) && (start_j < end_i))\n   352\t            {\n   353\t                if (out_bad_index)\n   354\t                    *out_bad_index = j;\n   355\t                return GGUF_TDBASE_ERR_OVERLAP;\n   356\t            }\n   357\t        }\n   358\t    }\n   359\t\n   360\t    return GGUF_TDBASE_OK;\n   361\t}\n   362\t\n   363\tU0 GGUFSwapU64(U64 *a, U64 *b)\n   364\t{\n   365\t    U64 tmp;\n   366\t\n   367\t    tmp = *a;\n   368\t    *a = *b;\n   369\t    *b = tmp;\n   370\t}\n   371\t\n   372\tBool GGUFTensorRangeGreater(U64 a_off,\n   373\t                            U64 a_nbytes,\n   374\t                            U64 b_off,\n   375\t                            U64 b_nbytes)\n   376\t{\n   377\t    if (a_off > b_off)\n   378\t        return TRUE;\n   379\t    if (a_off < b_off)\n   380\t        return FALSE;\n   381\t\n   382\t    // Tie-break by nbytes so equal offsets are ordered shortest-first.\n   383\t    // This preserves GGUFValidateTensorRanges behavior for zero-byte ranges.\n   384\t    return a_nbytes > b_nbytes;\n   385\t}\n   386\t\n   387\tU0 GGUFTensorRangeSiftDown(U64 *tensor_rel_offsets,\n   388\t                           U64 *tensor_nbytes,\n   389\t                           U64 root,\n   390\t                           U64 end)\n   391\t{\n   392\t    U64 child;\n   393\t    U64 swap_idx;\n   394\t\n   395\t    while (TRUE)\n   396\t    {\n   397\t        child = root * 2 + 1;\n   398\t        if (child > end)\n   399\t            return;\n   400\t\n   401\t        swap_idx = root;\n   402\t\n   403\t        if (GGUFTensorRangeGreater(tensor_rel_offsets[child],\n   404\t                                   tensor_nbytes[child],\n   405\t                                   tensor_rel_offsets[swap_idx],\n   406\t                                   tensor_nbytes[swap_idx]))\n   407\t            swap_idx = child;\n   408\t\n   409\t        if (child + 1 <= end &&\n   410\t            GGUFTensorRangeGreater(tensor_rel_offsets[child + 1],\n   411\t                                   tensor_nbytes[child + 1],\n   412\t                                   tensor_rel_offsets[swap_idx],\n   413\t                                   tensor_nbytes[swap_idx]))\n   414\t            swap_idx = child + 1;\n   415\t\n   416\t        if (swap_idx == root)\n   417\t            return;\n   418\t\n   419\t        GGUFSwapU64(&tensor_rel_offsets[root], &tensor_rel_offsets[swap_idx]);\n   420\t        GGUFSwapU64(&tensor_nbytes[root], &tensor_nbytes[swap_idx]);\n   421\t        root = swap_idx;\n   422\t    }\n   423\t}\n   424\t\n   425\tU0 GGUFTensorSortRangesByOffset(U64 tensor_count,\n   426\t                                U64 *tensor_rel_offsets,\n   427\t                                U64 *tensor_nbytes)\n   428\t{\n   429\t    U64 start;\n   430\t    U64 end;\n   431\t\n   432\t    if (tensor_count < 2)\n   433\t        return;\n   434\t\n   435\t    // In-place heapsort by relative offset so overlap detection can scan once.\n   436\t    // We swap offset and nbytes together to preserve each tensor range pair.\n   437\t    start = (tensor_count - 2) / 2 + 1;\n   438\t    while (start > 0)\n   439\t    {\n   440\t        --start;\n   441\t        GGUFTensorRangeSiftDown(tensor_rel_offsets,\n   442\t                                tensor_nbytes,\n   443\t                                start,\n   444\t                                tensor_count - 1);\n   445\t    }\n   446\t\n   447\t    end = tensor_count - 1;\n   448\t    while (end > 0)\n   449\t    {\n   450\t        GGUFSwapU64(&tensor_rel_offsets[0], &tensor_rel_offsets[end]);\n   451\t        GGUFSwapU64(&tensor_nbytes[0], &tensor_nbytes[end]);\n   452\t\n   453\t        --end;\n   454\t        GGUFTensorRangeSiftDown(tensor_rel_offsets,\n   455\t                                tensor_nbytes,\n   456\t                                0,\n   457\t                                end);\n   458\t    }\n   459\t}\n   460\t\n   461\tI64 GGUFValidateTensorRangesSorted(U64 tensor_data_base,\n   462\t                                   U32 alignment,\n   463\t                                   U64 gguf_file_nbytes,\n   464\t                                   U64 tensor_count,\n   465\t                                   U64 *tensor_rel_offsets,\n   466\t                                   U64 *tensor_nbytes,\n   467\t                                   U64 *out_bad_index)\n   468\t{\n   469\t    U64 i;\n   470\t    U64 start_i;\n   471\t    U64 end_i;\n   472\t    U64 max_end;\n   473\t    I64 err;\n   474\t\n   475\t    if (!tensor_rel_offsets || !tensor_nbytes)\n   476\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   477\t\n   478\t    if (out_bad_index)\n   479\t        *out_bad_index = 0;\n   480\t\n   481\t    // Pass 1: preserve strict per-range validation behavior from\n   482\t    // GGUFValidateTensorRanges before any in-place reordering.\n   483\t    for (i = 0; i < tensor_count; ++i)\n   484\t    {\n   485\t        err = GGUFTensorResolveRange(tensor_data_base,\n   486\t                                     tensor_rel_offsets[i],\n   487\t                                     tensor_nbytes[i],\n   488\t                                     gguf_file_nbytes,\n   489\t                                     alignment,\n   490\t                                     &start_i,\n   491\t                                     &end_i);\n   492\t        if (err != GGUF_TDBASE_OK)\n   493\t        {\n   494\t            if (out_bad_index)\n   495\t                *out_bad_index = i;\n   496\t            return err;\n   497\t        }\n   498\t    }\n   499\t\n   500\t    if (tensor_count < 2)\n   501\t        return GGUF_TDBASE_OK;\n   502\t\n   503\t    // Sort in-place by tensor relative offsets.\n   504\t    GGUFTensorSortRangesByOffset(tensor_count,\n   505\t                                 tensor_rel_offsets,\n   506\t                                 tensor_nbytes);\n   507\t\n   508\t    // Single linear overlap scan over half-open ranges [start, end).\n   509\t    err = GGUFTensorResolveRange(tensor_data_base,\n   510\t                                 tensor_rel_offsets[0],\n   511\t                                 tensor_nbytes[0],\n   512\t                                 gguf_file_nbytes,\n   513\t                                 alignment,\n   514\t                                 &start_i,\n   515\t                                 &max_end);\n   516\t    if (err != GGUF_TDBASE_OK)\n   517\t        return err;\n   518\t\n   519\t    for (i = 1; i < tensor_count; ++i)\n   520\t    {\n---\n   520\t    {\n   521\t        err = GGUFTensorResolveRange(tensor_data_base,\n   522\t                                     tensor_rel_offsets[i],\n   523\t                                     tensor_nbytes[i],\n   524\t                                     gguf_file_nbytes,\n   525\t                                     alignment,\n   526\t                                     &start_i,\n   527\t                                     &end_i);\n   528\t        if (err != GGUF_TDBASE_OK)\n   529\t            return err;\n   530\t\n   531\t        if (start_i < max_end)\n   532\t        {\n   533\t            if (out_bad_index)\n   534\t                *out_bad_index = i;\n   535\t            return GGUF_TDBASE_ERR_OVERLAP;\n   536\t        }\n   537\t\n   538\t        if (end_i > max_end)\n   539\t            max_end = end_i;\n   540\t    }\n   541\t\n   542\t    return GGUF_TDBASE_OK;\n   543\t}\n   544\t\n   545\tI64 GGUFTensorInfoResolveByteSpans(U64 tensor_data_base,\n   546\t                                   U32 alignment,\n   547\t                                   U64 gguf_file_nbytes,\n   548\t                                   U64 tensor_count,\n   549\t                                   U64 *tensor_rel_offsets,\n   550\t                                   U64 *tensor_element_counts,\n   551\t                                   U32 *tensor_ggml_types,\n   552\t                                   U64 *out_tensor_nbytes,\n   553\t                                   U64 *out_bad_index)\n   554\t{\n   555\t    U64 i;\n   556\t    I64 err;\n   557\t\n   558\t    if (!tensor_rel_offsets || !tensor_element_counts ||\n   559\t        !tensor_ggml_types || !out_tensor_nbytes)\n   560\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   561\t\n   562\t    if (out_bad_index)\n   563\t        *out_bad_index = 0;\n   564\t\n   565\t    // Pass 1: compute payload byte spans directly from ggml type + element count.\n   566\t    // This keeps tensor sizing math centralized in GGUFTensorBytesForType.\n   567\t    for (i = 0; i < tensor_count; ++i)\n   568\t    {\n   569\t        err = GGUFTensorBytesForType(tensor_ggml_types[i],\n   570\t                                     tensor_element_counts[i],\n   571\t                                     &out_tensor_nbytes[i]);\n   572\t        if (err != GGUF_TDBASE_OK)\n   573\t        {\n   574\t            if (out_bad_index)\n   575\t                *out_bad_index = i;\n   576\t            return err;\n   577\t        }\n   578\t    }\n   579\t\n   580\t    // Pass 2: validate and sort ranges using the computed byte spans.\n   581\t    // GGUFValidateTensorRangesSorted reorders offsets and nbytes in-place.\n   582\t    return GGUFValidateTensorRangesSorted(tensor_data_base,\n   583\t                                          alignment,\n   584\t                                          gguf_file_nbytes,\n   585\t                                          tensor_count,\n   586\t                                          tensor_rel_offsets,\n   587\t                                          out_tensor_nbytes,\n   588\t                                          out_bad_index);\n   589\t}\n   590\t\n   591\tI64 GGUFTensorInfoResolveAbsRanges(U64 tensor_data_base,\n   592\t                                   U32 alignment,\n   593\t                                   U64 gguf_file_nbytes,\n   594\t                                   U64 tensor_count,\n   595\t                                   U64 *tensor_rel_offsets,\n   596\t                                   U64 *tensor_element_counts,\n   597\t                                   U32 *tensor_ggml_types,\n   598\t                                   U64 *out_tensor_nbytes,\n   599\t                                   U64 *out_abs_starts,\n   600\t                                   U64 *out_abs_ends,\n   601\t                                   U64 *out_bad_index)\n   602\t{\n   603\t    U64 i;\n   604\t    U64 abs_start;\n   605\t    I64 err;\n   606\t\n   607\t    if (!out_abs_starts || !out_abs_ends)\n   608\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   609\t\n   610\t    // First derive byte spans, enforce alignmen