{"type":"item.started","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc 'rg -n \"''^## Inference Queue|''^### WS|''^- '\"\\\\[ \\\\] IQ-|\"'^- '\"\\\\[x\\\\] IQ-|\"'^## Progress Ledger\" MASTER_TASKS.md | sed -n '\"'1,260p'; echo '---'; python3 - << 'PY'\nimport re, pathlib\np=pathlib.Path('MASTER_TASKS.md').read_text()\nall_iq=[int(m.group(1)) for m in re.finditer(r\\\"\"'^- '\"\\\\[[ x]\\\\] IQ-(\\\\d{3})\\\", p, re.M)]\nunchecked=[int(m.group(1)) for m in re.finditer(r\\\"\"'^- '\"\\\\[ \\\\] IQ-(\\\\d{3})\\\", p, re.M)]\nchecked=[int(m.group(1)) for m in re.finditer(r\\\"\"'^- '\"\\\\[x\\\\] IQ-(\\\\d{3})\\\", p, re.M)]\nprint('IQ_TOTAL',len(all_iq))\nprint('IQ_UNCHECKED',len(unchecked))\nprint('IQ_CHECKED',len(checked))\nprint('IQ_MAX',max(all_iq) if all_iq else None)\nprint('IQ_FIRST_UNCHECKED',min(unchecked) if unchecked else None)\n# map WS unchecked\ndef ws_ids(prefix):\n    return [m.group(1) for m in re.finditer(rf\\\"\"'^- '\"\\\\[ \\\\] ({prefix}-\\\\d+)\\\", p, re.M)]\nfor w in range(0,14):\n    pref=f'WS{w}'\n    ids=ws_ids(pref)\n    if ids:\n      print(pref,'unchecked',len(ids),'first',ids[0])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
