l-write behavior.\n    err = GGUFMetadataReadU8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &raw_u8);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // GGUF bool payloads are strict 0/1 in one byte.\n    if (raw_u8 > 1)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    *out_value = (raw_u8 != 0);\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n","exit_code":0,"status":"completed"}}
