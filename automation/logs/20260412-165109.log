{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/gguf/tensor_data_base.HC | sed -n '1,320p'\"","aggregated_output":"     1\t// tensor_data_base.HC\n     2\t// GGUF tensor-data base alignment helpers for HolyC inference runtime.\n     3\t\n     4\t#define GGUF_TDBASE_OK 0\n     5\t#define GGUF_TDBASE_ERR_NULL_PTR 1\n     6\t#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n     7\t#define GGUF_TDBASE_ERR_OVERFLOW 3\n     8\t#define GGUF_TDBASE_ERR_MISALIGNED_BASE 4\n     9\t#define GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET 5\n    10\t#define GGUF_TDBASE_ERR_BAD_TYPE 6\n    11\t\n    12\t// GGUF default tensor alignment when metadata key `general.alignment`\n    13\t// is absent.\n    14\t#define GGUF_DEFAULT_ALIGNMENT 32\n    15\t\n    16\t// Subset of ggml tensor types currently enabled in HolyC inference runtime.\n    17\t// Keep this list strict and explicit so sizing math never silently accepts\n    18\t// unknown quantization tags from malformed GGUF files.\n    19\t#define GGML_TYPE_F32   0\n    20\t#define GGML_TYPE_F16   1\n    21\t#define GGML_TYPE_Q4_0  2\n    22\t#define GGML_TYPE_Q8_0  8\n    23\t\n    24\t// GGML quantization blocks for runtime-critical formats:\n    25\t// - F32/F16 are scalar types (block size 1).\n    26\t// - Q4_0 and Q8_0 are packed in 32-element blocks.\n    27\t#define GGML_BLCK_SIZE_F32   1\n    28\t#define GGML_BLCK_SIZE_F16   1\n    29\t#define GGML_BLCK_SIZE_Q4_0  32\n    30\t#define GGML_BLCK_SIZE_Q8_0  32\n    31\t\n    32\t// Block payload byte widths from ggml struct layouts:\n    33\t// - Q4_0: fp16 scale (2 bytes) + 16 packed nibbles = 18 bytes.\n    34\t// - Q8_0: fp16 scale (2 bytes) + 32 signed bytes = 34 bytes.\n    35\t#define GGML_TYPE_SIZE_F32   4\n    36\t#define GGML_TYPE_SIZE_F16   2\n    37\t#define GGML_TYPE_SIZE_Q4_0  18\n    38\t#define GGML_TYPE_SIZE_Q8_0  34\n    39\t\n    40\tI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n    41\t{\n    42\t    if (!out_block_size)\n    43\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    44\t\n    45\t    switch (ggml_type)\n    46\t    {\n    47\t        case GGML_TYPE_F32:\n    48\t            *out_block_size = GGML_BLCK_SIZE_F32;\n    49\t            return GGUF_TDBASE_OK;\n    50\t        case GGML_TYPE_F16:\n    51\t            *out_block_size = GGML_BLCK_SIZE_F16;\n    52\t            return GGUF_TDBASE_OK;\n    53\t        case GGML_TYPE_Q4_0:\n    54\t            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n    55\t            return GGUF_TDBASE_OK;\n    56\t        case GGML_TYPE_Q8_0:\n    57\t            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n    58\t            return GGUF_TDBASE_OK;\n    59\t    }\n    60\t\n    61\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    62\t}\n    63\t\n    64\tI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n    65\t{\n    66\t    if (!out_block_bytes)\n    67\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    68\t\n    69\t    switch (ggml_type)\n    70\t    {\n    71\t        case GGML_TYPE_F32:\n    72\t            *out_block_bytes = GGML_TYPE_SIZE_F32;\n    73\t            return GGUF_TDBASE_OK;\n    74\t        case GGML_TYPE_F16:\n    75\t            *out_block_bytes = GGML_TYPE_SIZE_F16;\n    76\t            return GGUF_TDBASE_OK;\n    77\t        case GGML_TYPE_Q4_0:\n    78\t            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n    79\t            return GGUF_TDBASE_OK;\n    80\t        case GGML_TYPE_Q8_0:\n    81\t            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n    82\t            return GGUF_TDBASE_OK;\n    83\t    }\n    84\t\n    85\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    86\t}\n    87\t\n    88\tBool GGUFIsPow2U32(U32 value)\n    89\t{\n    90\t    if (!value)\n    91\t        return FALSE;\n    92\t    return (value & (value - 1)) == 0;\n    93\t}\n    94\t\n    95\tI64 GGUFValidateAlignment(U32 alignment)\n    96\t{\n    97\t    if (!GGUFIsPow2U32(alignment))\n    98\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    99\t    return GGUF_TDBASE_OK;\n   100\t}\n   101\t\n   102\tI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n   103\t{\n   104\t    U64 mask;\n   105\t\n   106\t    if (!out)\n   107\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   108\t\n   109\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   110\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   111\t\n   112\t    // For power-of-two alignments, align-up is:\n   113\t    //   (value + (alignment - 1)) & ~(alignment - 1)\n   114\t    // Keep overflow checks explicit so giant malformed offsets are rejected.\n   115\t    mask = (U64)alignment - 1;\n   116\t    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n   117\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   118\t\n   119\t    *out = (value + mask) & ~mask;\n   120\t    return GGUF_TDBASE_OK;\n   121\t}\n   122\t\n   123\tI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n   124\t                            U32 alignment,\n   125\t                            U64 *out_tensor_data_base)\n   126\t{\n   127\t    return GGUFAlignUpU64(cursor_after_tensor_info,\n   128\t                          alignment,\n   129\t                          out_tensor_data_base);\n   130\t}\n   131\t\n   132\tI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n   133\t                                   U64 *out_tensor_data_base)\n   134\t{\n   135\t    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n   136\t                                   GGUF_DEFAULT_ALIGNMENT,\n   137\t                                   out_tensor_data_base);\n   138\t}\n   139\t\n   140\tBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n   141\t{\n   142\t    U64 mask;\n   143\t\n   144\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   145\t        return FALSE;\n   146\t\n   147\t    mask = (U64)alignment - 1;\n   148\t    return (offset & mask) == 0;\n   149\t}\n   150\t\n   151\tI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n   152\t                             U64 tensor_rel_offset,\n   153\t                             U32 alignment,\n   154\t                             U64 *out_tensor_abs)\n   155\t{\n   156\t    if (!out_tensor_abs)\n   157\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   158\t\n   159\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   160\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   161\t\n   162\t    // Both base and relative tensor offsets must preserve GGUF alignment.\n   163\t    // Enforcing this here keeps every downstream payload read auditable.\n   164\t    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n   165\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n   166\t    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n   167\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n   168\t\n   169\t    // Absolute payload pointer is base + relative offset.\n   170\t    // Keep overflow check explicit for malformed large files.\n   171\t    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n   172\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   173\t\n   174\t    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n   175\t    return GGUF_TDBASE_OK;\n   176\t}\n   177\t\n   178\tI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n   179\t                                    U64 tensor_rel_offset,\n   180\t                                    U64 *out_tensor_abs)\n   181\t{\n   182\t    return GGUFTensorDataBaseOffset(tensor_data_base,\n   183\t                                    tensor_rel_offset,\n   184\t                                    GGUF_DEFAULT_ALIGNMENT,\n   185\t                                    out_tensor_abs);\n   186\t}\n","exit_code":0,"status":"completed"}}
