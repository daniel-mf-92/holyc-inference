lock_dot_q32);\n    }\n\n    *io_accum_q16 = total_q16;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ16AccumulateChecked(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 block_dot_q16;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !io_accum_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n\n    // Checked variant for hostile inputs:\n    //   block Q32 dot -> rounded Q16 -> checked add into accumulator lane.\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        block_dot_q16 = Q4_0_Q8_0DotQ32ToQ16(block_dot_q32);\n        if (!Q4_0Q8_0TryAddI64(total_q16, block_dot_q16, &total_q16))\n            return Q4_0_Q8_0_ERR_OVERFLOW;\n    }\n\n    *io_accum_q16 = total_q16;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16)\n{\n    I64 accum_q16;\n    I32 status;\n\n    if (!row_blocks_q4 || !vec_blocks_q8 || !out_dot_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    // WS4 row kernels consume Q16 lanes directly.\n---\n// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n#define Q8_0_AVX2_PAIR_COUNT         16\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n#define Q8_0_AVX2_ERR_OVERFLOW       3\n\n#define Q8_0_AVX2_I64_MAX            0x7FFFFFFFFFFFFFFF\n#define Q8_0_AVX2_I64_MIN            (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nBool Q8_0AVX2TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q8_0_AVX2_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q8_0_AVX2_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nBool Q8_0AVX2TryMulI64(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs == -1 && rhs == Q8_0_AVX2_I64_MIN)\n        return FALSE;\n    if (rhs == -1 && lhs == Q8_0_AVX2_I64_MIN)\n        return FALSE;\n\n    if (lhs > 0)\n    {\n        if (rhs > 0)\n        {\n            if (lhs > Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (rhs < Q8_0_AVX2_I64_MIN / lhs)\n                return FALSE;\n        }\n    }\n    else\n    {\n        if (rhs > 0)\n        {\n            if (lhs < Q8_0_AVX2_I64_MIN / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (lhs < Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n    }\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI64 Q8_0AVX2RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0AVX2RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n   