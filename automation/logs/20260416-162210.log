\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0_Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0_Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0_Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0_Q8_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nBool Q4_0Q8_0TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q4_0_Q8_0_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q4_0_Q8_0_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nBool Q4_0Q8_0TryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs > Q4_0_Q8_0_I64_MAX / rhs)\n        return FALSE;\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI32 Q4_0_Q8_0DotProductBlockQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n    U8 packed_q4;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0_Q8_0F16ToQ16(lhs_q4->d_fp16);\n    rhs_scale_q16 = Q4_0_Q8_0F16ToQ16(rhs_q8->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // q_dot_q0 = Sum(q4_signed_i * q8_signed_i).\n    // Q4 stores two values per byte, so map each nibble to one Q8 lane.\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        packed_q4 = lhs_q4->qs[byte_index];\n\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, FALSE) * rhs_q8->qs[(byte_index << 1)];\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, TRUE) * rhs_q8->qs[(byte_index << 1) + 1];\n    }\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32);\n\nI32 Q4_0_Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    return Q4_0Q8_0DotProductBlocksQ32(lhs_q4, rhs_q8, block_count, out_dot_q32);\n}\n\nI32 Q4_0Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16);\n\nI32 Q4_0_Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16)\n{\n    return Q4_0Q8_0DotRowBlocksQ16(row_blocks_q4, vec_blocks_q8, block_count, out_dot_q16);\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        // Keep the widened Q32 accumulation explicit and checked.\n        // For realistic LLaMA dimensions this stays far inside I64,\n        // but we still hard-fail if a hostile input tries to overflow.\n        if (!Q4_0Q8_0TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n            return Q4_0_Q8_0_ERR_OVERFLOW;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32ToQ16(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    // Mixed-kernel WS4 matmul callers can keep the full dot in I64 Q32,\n    // then round once when handing the lane back to Q16 accumulation.\n    status = Q4_0Q8_0DotProductBlocksQ32(lhs_q4, rhs_q8, block_count, &total_dot_q32);\n    if (status != Q4_0_Q8_0_OK)\n        return status;\n\n    *out_dot_q16 = Q4_0_Q8_0DotQ32ToQ16(total_dot_q32);\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ16Accumulate(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !io_accum_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n--- q4_0_dot.HC ---\n// q4_0_dot.HC\n// Naive integer-only Q4_0 dot product kernels for TempleOS.\n//\n// Math:\n//   For each block, GGML Q4_0 stores 32 4-bit values and one fp16 scale d.\n//   Decode uses: x_i = d * (q_i - 8)\n//\n// Integer HolyC form:\n//   d_q16   = Round(d * 2^16)\n//   q_s     = nibble - 8   (in [-8, 7])\n//   x_q16   = d_q16 * q_s\n//   dot_q32 = Sum(x_q16 * y_q16)\n//           = (dA_q16 * dB_q16) * Sum(qA_s * qB_s)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n\n#define Q4_0_OK               0\n#define Q4_0_ERR_NULL_PTR     1\n#define Q4_0_ERR_BAD_DST_LEN  2\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nI64 Q4_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nI32 Q4_0DotProductBlockQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 nibble_dot_q0;\n    I64 byte_index;\n    U8 lhs_packed;\n    U8 rhs_packed;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q4_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0F16ToQ16(lhs->d_fp16);\n    rhs_scale_q16 = Q4_0F16ToQ16(rhs->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    nibble_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        lhs_packed = lhs->qs[byte_index];\n        rhs_packed = rhs->qs[byte_index];\n\n        nibble_dot_q0 += Q4_0NibbleToSigned(lhs_packed, FALSE) * Q4_0NibbleToSigned(rhs_packed, FALSE);\n        nibble_dot_q0 += Q4_0NibbleToSigned(lhs_packed, TRUE) * Q4_0NibbleToSigned(rhs_packed, TRUE);\n    }\n\n    *out_dot_q32 = scale_prod_q32 * nibble_dot_q0;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotProductBlocksQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q4_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotProductBlocksQ32ToQ16(Q4_0Block *lhs, Q4_0Block *rhs, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q16)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    // WS4 matmul callers can keep a widened I64 Q32 path for the full dot,\n    // then round once to Q16 at the hand-off boundary.\n    status = Q4_0DotProductBlocksQ32(lhs, rhs, block_count, &total_dot_q32);\n    if (status != Q4_0_OK)\n        return status;\n\n    *out_dot_q16 = Q4_0DotQ32ToQ16(total_dot_q32);\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotRowBlocksQ16(Q4_0Block *row_blocks, Q4_0Block *vec_blocks, I64 block_count, I64 *out_dot_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q16;\n    I32 status;\n\n    if (!row_blocks || !vec_blocks || !out_dot_q16)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    // Matmul row kernels usually keep accumulators in Q16 lanes.\n    // Convert each block dot Q32->Q16 with explicit rounding before summation,\n    // so every 32-value block contribution stays auditable and deterministic.\n    total_dot_q16 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0DotProductBlockQ32(&row_blocks[block_index], &vec_blocks[block_index], &block_dot_q32);\n        if (status != Q4_0_OK)\n            return status;\n\n        total_dot_q16 += Q4_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *out_dot_q16 = total_dot_q16;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotRowsQ16MatrixVector(Q4_0Block *matrix_blocks, I64 row_count, I64 row_stride_blocks, Q4_0Block *vec_blocks, I64 vec_block_count, I64 *out_rows_q16)\n{\n    I64 row_index;\n    I64 row_dot_q16;\n    Q4_0Block *row_ptr;\n    I32 status;\n\n    if (!matrix_blocks || !vec_blocks || !out_rows_q16)\n        return Q4_0_ERR_NULL_PTR;\n    if (row_count < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    // Each row starts at matrix_blocks + row_index * row_stride_blocks.\n    // Only vec_block_count active blocks participate in the row dot.\n    // Enforce stride >= active vector span so row slices are valid and explicit.\n    if (row_count > 0 && row_stride_blocks < vec_block_count)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    for (row_index = 0; row_index < row_count; ++row_index)\n    {\n        row_ptr = &matrix_blocks[row_index * row_stride_blocks];\n        status = Q4_0DotRowBlocksQ16(row_ptr, vec_blocks, vec_block_count, &row_dot_q16);\n        if (status != Q4_0_OK)\n            return status;\n\n        out_rows_q16[row_index] = row_dot_q16;\n    }\n\n    return Q4_0_OK;\n}\n\nI64 Q4_0DotQ32ToQ16(I64 dot_q32)\n{\n    return Q4_0RoundShiftRightSigned(dot_q32, 16);\n}\n--- q8_0_dot.HC ---\n// q8_0_dot.HC\n// Naive integer-only Q8_0 dot product kernels for TempleOS.\n//\n// Math:\n//   GGML Q8_0 stores 32 signed 8-bit values and one fp16 scale d per block.\n//   Decode uses: x_i = d * q_i\n//\n// Integer HolyC form:\n//   d_q16    = Round(d * 2^16)\n//   x_q16    = d_q16 * q_i\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (dA_q16 * dB_q16) * Sum(qA_i * qB_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q8_0_OK               0\n#define Q8_0_ERR_NULL_PTR     1\n#define Q8_0_ERR_BAD_DST_LEN  2\n#define Q8_0_ERR_OVERFLOW     3\n#define Q8_0_I64_MAX          0x7FFFFFFFFFFFFFFF\n#define Q8_0_I64_MIN          (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nBool Q8_0TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q8_0_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q8_0_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nBool Q8_0TryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs > Q8_0_I64_MAX / rhs)\n        return FALSE;\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI64 Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0DotProductBlockQ32(Q8_0