{"type":"item.started","item":{"id":"item_25","type":"command_execution","command":"/bin/zsh -lc 'set -e\nfor f in ~/Documents/local-codebases/temple-sanhedrin/research/*.md; do echo \"--- $f\"; sed -n '\"'1,120p' \\\"\"'$f\" >/dev/null; done\npython3 tests/test_q4_0_q8_0_dot_kernel.py\npython3 tests/test_q4_0_q8_0_matmul_tiled_checked.py\npython3 - <<'\"'PY'\nimport pathlib, random, sys\nsys.path.append(str(pathlib.Path('tests').resolve()))\nfrom test_q4_0_q8_0_dot_kernel import (\n    Q4_0_Q8_0_OK, make_q4_block, make_q8_block, q4_0_q8_0_dot_blocks_avx2_q32_checked,\n)\n\nI64_MAX = (1<<63)-1\nERR_NULL=1\nERR_BAD=2\nERR_OVF=3\n\ndef mul_nonneg(a,b):\n    if a<0 or b<0: return (False,0)\n    if a==0 or b==0: return (True,0)\n    if a> I64_MAX//b: return (False,0)\n    return (True,a*b)\n\ndef add_nonneg(a,b):\n    if a<0 or b<0: return (False,0)\n    if a> I64_MAX-b: return (False,0)\n    return (True,a+b)\n\ndef matmul_q32_tiled_avx2_checked(lhs,lhs_cap,rows,lhs_stride,rhs,rhs_cap,cols,rhs_stride,k,tile_r,tile_c,out_cap,out_stride):\n    if lhs is None or rhs is None: return ERR_NULL,[]\n    if min(lhs_cap,rhs_cap,out_cap,rows,cols,k,lhs_stride,rhs_stride,out_stride)<0: return ERR_BAD,[]\n    if tile_r<=0 or tile_c<=0: return ERR_BAD,[]\n    if k>lhs_stride or k>rhs_stride: return ERR_BAD,[]\n    if rows>0 and out_stride<cols: return ERR_BAD,[]\n    ok,need_l=mul_nonneg(rows,lhs_stride)\n    if not ok: return ERR_OVF,[]\n    ok,need_r=mul_nonneg(cols,rhs_stride)\n    if not ok: return ERR_OVF,[]\n    ok,need_o=mul_nonneg(rows,out_stride)\n    if not ok: return ERR_OVF,[]\n    if need_l>lhs_cap or need_r>rhs_cap or need_o>out_cap: return ERR_BAD,[]\n    out=[0]*need_o\n    rs=0\n    while rs<rows:\n        ok,re=add_nonneg(rs,tile_r)\n        if not ok: return ERR_OVF,[]\n        re=min(re,rows)\n        cs=0\n        while cs<cols:\n            ok,ce=add_nonneg(cs,tile_c)\n            if not ok: return ERR_OVF,[]\n            ce=min(ce,cols)\n            for r in range(rs,re):\n                ok,lb=mul_nonneg(r,lhs_stride)\n                if not ok: return ERR_OVF,[]\n                ok,ob=mul_nonneg(r,out_stride)\n                if not ok: return ERR_OVF,[]\n                lrow=lhs[lb:lb+k]\n                for c in range(cs,ce):\n                    ok,rb=mul_nonneg(c,rhs_stride)\n                    if not ok: return ERR_OVF,[]\n                    ok,oi=add_nonneg(ob,c)\n                    if not ok: return ERR_OVF,[]\n                    rcol=rhs[rb:rb+k]\n                    err,d=q4_0_q8_0_dot_blocks_avx2_q32_checked(lrow,rcol,k)\n                    if err\"'!=Q4_0_Q8_0_OK: return err,[]\n                    out[oi]=d\n            cs=ce\n        rs=re\n    return Q4_0_Q8_0_OK,out\n\ndef ref(lhs,rows,lhs_stride,rhs,cols,rhs_stride,k,out_stride):\n    out=[0]*(rows*out_stride)\n    for r in range(rows):\n        lbase=r*lhs_stride\n        for c in range(cols):\n            rbase=c*rhs_stride\n            err,d=q4_0_q8_0_dot_blocks_avx2_q32_checked(lhs[lbase:lbase+k],rhs[rbase:rbase+k],k)\n            assert err==Q4_0_Q8_0_OK\n            out[r*out_stride+c]=d\n    return out\n\nrng=random.Random(2026041619)\nfor _ in range(140):\n    rows=rng.randint(1,6); cols=rng.randint(1,6); k=rng.randint(1,5)\n    lhs_stride=k+rng.randint(0,2); rhs_stride=k+rng.randint(0,2); out_stride=cols+rng.randint(0,2)\n    lhs_cap=rows*lhs_stride; rhs_cap=cols*rhs_stride; out_cap=rows*out_stride\n    lhs=[make_q4_block(rng) for _ in range(lhs_cap)]\n    rhs=[make_q8_block(rng) for _ in range(rhs_cap)]\n    err,got=matmul_q32_tiled_avx2_checked(lhs,lhs_cap,rows,lhs_stride,rhs,rhs_cap,cols,rhs_stride,k,rng.randint(1,4),rng.randint(1,4),out_cap,out_stride)\n    assert err==Q4_0_Q8_0_OK\n    assert got==ref(lhs,rows,lhs_stride,rhs,cols,rhs_stride,k,out_stride)\nprint('\"'q4_0_q8_0_matmul_tiled_avx2_q32_reference_checks=ok')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
