IN / lhs)\n                return FALSE;\n        }\n    }\n    else\n    {\n        if (rhs > 0)\n        {\n            if (lhs < Q8_0_AVX2_I64_MIN / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (lhs < Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n    }\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI64 Q8_0AVX2RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0AVX2RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0AVX2RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0AVX2RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q8_0AVX2DotQ32ToQ16(I64 dot_q32)\n{\n    // Dot products carry Q16*Q16 scale in Q32 during accumulation.\n    // Hand-off to Q16 row kernels is one rounded signed downshift by 16.\n    return Q8_0AVX2RoundShiftRightSigned(dot_q32, 16);\n}\n\nI64 Q8_0AVX2F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0AVX2RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0AVX2RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0Pack32ToI16LanesAVX2(I8 *src_q8, I64 src_len, I16 *dst_i16, I64 dst_len)\n{\n    I64 lane;\n\n    if (!src_q8 || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (src_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Lane contract:\n    //   dst_i16[i] = SignExtend16(src_q8[i]) for i in [0, 31]\n    // This exact order matches the two AVX2 16-lane halves that would be\n    // produced by widening bytes 0..15 then 16..31.\n    for (lane = 0; lane < Q8_0_AVX2_VALUES_PER_BLOCK; ++lane)\n        dst_i16[lane] = (I16)src_q8[lane];\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0PackBlockToI16LanesAVX2(Q8_0Block *block, I16 *dst_i16, I64 dst_len)\n{\n    if (!block || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    return Q8_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\n\nI32 Q8_0MulI16LanesToI32PairsAVX2(I16 *lhs_i16,\n                                  I64 lhs_len,\n                                  I16 *rhs_i16,\n                                  I64 rhs_len,\n                                  I32 *dst_i32,\n                                  I64 dst_len)\n{\n    I64 pair_index;\n    I64 lane_base;\n    I32 product0;\n    I32 product1;\n\n    if (!lhs_i16 || !rhs_i16 || !dst_i32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (lhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Contract mirrors AVX2 `vpmaddwd` lane behavior used by quantized dot kernels:\n    // - Multiply lane pairs independently in signed 16-bit domain.\n    // - Accumulate each adjacent pair into one signed 32-bit output.\n    // - Preserve lane order so output pair k maps to input lanes [2k, 2k+1].\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        lane_base = pair_index << 1;\n\n        product0 = lhs_i16[lane_base] * rhs_i16[lane_base];\n        product1 = lhs_i16[lane_base + 1] * rhs_i16[lane_base + 1];\n\n        dst_i32[pair_index] = product0 + product1;\n    }\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0HSumI32PairsAVX2(I32 *pairs_i32,\n                         I64 pairs_len,\n                         I64 *out_sum_i64)\n{\n    I64 pair_index;\n    I64 running_sum;\n    I64 term;\n\n    if (!pairs_i32 || !out_sum_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n    if (pairs_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Horizontal reduction contract:\n    // - Sum all 16 pairwise I32 partial products into one signed I64 scalar.\n    // - Preserve deterministic lane order (0..15) for auditability parity\n    //   against the scalar reference path.\n    // - Explicit overflow checks keep reduction safe if this helper is reused\n    //   for wider accumulation streams in future kernels.\n    running_sum = 0;\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        term = (I64)pairs_i32[pair_index];\n\n        if (term > 0 && running_sum > Q8_0_AVX2_I64_MAX - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (term < 0 && running_sum < Q8_0_AVX2_I64_MIN - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n\n        running_sum += term;\n    }\n\n    *out_sum_i64 = running_sum;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotI16LanesAVX2(I16 *lhs_i16,\n                        I64 lhs_len,\n                        I16 *rhs_i16,\n                        I64 rhs_len,\n                        I64 *out_dot_i64)\n{\n    I32 pairs_i32[Q8_0_AVX2_PAIR_COUNT];\n    I64 dot_i64;\n    I32 status;\n\n    if (!lhs_i16 || !rhs_i16 || !out_dot_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    // Compose the lane-dot from the two audited AVX2-shape primitives:\n    // 1) `vpmaddwd`-equivalent pairwise multiply-add over 32 I16 lanes.\n    // 2) Horizontal sum over 16 I32 pair partials into one I64 scalar.\n    // Keeping this composition explicit preserves bit-level auditability while\n    // allowing future inline-asm replacement of each stage independently.\n    status = Q8_0MulI16LanesToI32PairsAVX2(lhs_i16,\n                                           lhs_len,\n                                           rhs_i16,\n                                           rhs_len,\n                                           pairs_i32,\n                                           Q8_0_AVX2_PAIR_COUNT);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    status = Q8_0HSumI32PairsAVX2(pairs_i32,\n                                  Q8_0_AVX2_PAIR_COUNT,\n                                  &dot_i64);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    *out_dot_i64 = dot_i64;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotBlocksAVX2Q32Checked(Q8_0Block *lhs,\n                                Q8_0Block *rhs,\n                                I64 block_count,\n                                I64 *out_dot_q32)\n{\n    I64 block_index;\n    I16 lhs_lanes_i16[Q8_0_AVX2_VALUES_PER_BLOCK];\n    I16 rhs_lanes_i16[Q8_0_AVX2_VALUES_PER_BLOCK];\n    I64 q_dot_q0;\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n--- matmul mixed ---\n// q4_0_q8_0_matmul.HC\n// Checked tiled mixed Q4_0 x Q8_0 matmul kernel for TempleOS.\n//\n// Runtime contract:\n//   - lhs is an MxK matrix in row-major block layout (Q4_0 blocks).\n//   - rhs is an NxK matrix in row-major \"column bank\" layout (Q8_0 blocks),\n//     where each logical B-column is stored as one contiguous row of K blocks.\n//   - out is MxN Q16 matrix (I64 lanes) with explicit output row stride.\n\n#define Q4_0_Q8_0_MATMUL_VALUES_PER_BLOCK 32\n#define Q4_0_Q8_0_MATMUL_Q4_PACKED_BYTES  16\n#define Q4_0_Q8_0_MATMUL_Q8_PACKED_BYTES  32\n\n#define Q4_0_Q8_0_MATMUL_OK               0\n#define Q4_0_Q8_0_MATMUL_ERR_NULL_PTR     1\n#define Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN  2\n#define Q4_0_Q8_0_MATMUL_ERR_OVERFLOW     3\n#define Q4_0_Q8_0_MATMUL_I64_MAX          0x7FFFFFFFFFFFFFFF\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_Q8_0_MATMUL_Q4_PACKED_BYTES];\n};\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q4_0_Q8_0_MATMUL_Q8_PACKED_BYTES];\n};\n\n// Declared in src/quant/q4_0_q8_0_dot.HC.\nI32 Q4_0_Q8_0DotProductBlocksQ16AccumulateChecked(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16);\n\nBool Q4_0Q8_0MatMulTryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs > Q4_0_Q8_0_MATMUL_I64_MAX / rhs)\n        return FALSE;\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nBool Q4_0Q8_0MatMulTryAddI64NonNeg(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n    if (lhs > Q4_0_Q8_0_MATMUL_I64_MAX - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nI64 Q4_0Q8_0MatMulMinI64(I64 lhs, I64 rhs)\n{\n    if (lhs < rhs)\n        return lhs;\n    return rhs;\n}\n\nI32 Q4_0Q8_0MatMulQ16TiledChecked(\n    Q4_0Block *lhs_q4_blocks,\n    I64 lhs_q4_block_capacity,\n    I64 row_count,\n    I64 lhs_row_stride_blocks,\n    Q8_0Block *rhs_q8_col_blocks,\n    I64 rhs_q8_block_capacity,\n    I64 col_count,\n    I64 rhs_col_stride_blocks,\n    I64 k_block_count,\n    I64 tile_rows,\n    I64 tile_cols,\n    I64 *out_cells_q16,\n    I64 out_cell_capacity,\n    I64 out_row_stride_cells)\n{\n    I64 lhs_required_blocks;\n    I64 rhs_required_blocks;\n    I64 out_required_cells;\n    I64 row_tile_start;\n    I64 col_tile_start;\n    I64 row_tile_end;\n    I64 col_tile_end;\n    I64 row_index;\n    I64 col_index;\n    I64 lhs_row_base;\n    I64 rhs_col_base;\n    I64 out_row_base;\n    I64 out_index;\n    I64 cell_dot_q16;\n    Q4_0Block *lhs_row_ptr;\n    Q8_0Block *rhs_col_ptr;\n    I32 status;\n\n    if (!lhs_q4_blocks || !rhs_q8_col_blocks || !out_cells_q16)\n        return Q4_0_Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (lhs_q4_block_capacity < 0 || rhs_q8_block_capacity < 0 || out_cell_capacity < 0)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (tile_rows <= 0 || tile_cols <= 0)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Active K span must fit inside each source row stride.\n    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Output row stride must cover active output columns.\n    if (row_count > 0 && out_row_stride_cells < col_count)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Capacity proofs for full row-strided views.\n    if (!Q4_0Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n        return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q4_0Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n        return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q4_0Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n        return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n\n    if (lhs_required_blocks > lhs_q4_block_capacity)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (rhs_required_blocks > rhs_q8_block_capacity)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (out_required_cells > out_cell_capacity)\n        return Q4_0_Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Tiled traversal keeps cache locality while leaving every row/col dot visible.\n    row_tile_start = 0;\n    while (row_tile_start < row_count)\n    {\n        if (!Q4_0Q8_0MatMulTryAddI64NonNeg(row_tile_start, tile_rows, &row_tile_end))\n            return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n        row_tile_end = Q4_0Q8_0MatMulMinI64(row_tile_end, row_count);\n\n        col_tile_start = 0;\n        while (col_tile_start < col_count)\n        {\n            if (!Q4_0Q8_0MatMulTryAddI64NonNeg(col_tile_start, tile_cols, &col_tile_end))\n                return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n            col_tile_end = Q4_0Q8_0MatMulMinI64(col_tile_end, col_count);\n\n            for (row_index = row_tile_start; row_index < row_tile_end; ++row_index)\n            {\n                if (!Q4_0Q8_0MatMulTryMulI64NonNeg(row_index, lhs_row_stride_blocks, &lhs_row_base))\n                    return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n                if (!Q4_0Q8_0MatMulTryMulI64NonNeg(row_index, out_row_stride_cells, &out_row_base))\n                    return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n\n                lhs_row_ptr = &lhs_q4_blocks[lhs_row_base];\n\n                for (col_index = col_tile_start; col_index < col_tile_end; ++col_index)\n                {\n                    if (!Q4_0Q8_0MatMulTryMulI64NonNeg(col_index, rhs_col_stride_blocks, &rhs_col_base))\n                        return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n                    if (!Q4_0Q8_0MatMulTryAddI64NonNeg(out_row_base, col_index, &out_index))\n                        return Q4_0_Q8_0_MATMUL_ERR_OVERFLOW;\n\n                    rhs_col_ptr = &rhs_q8_col_blocks[rhs_col_base];\n                    cell_dot_q16 = 0;\n\n                    // Core mixed-kernel inner product stays fully integer and ch