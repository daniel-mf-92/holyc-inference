31\t    Q8_0Block *rhs_col_blocks,\n   432\t    I64 rhs_block_capacity,\n   433\t    I64 rhs_cols,\n   434\t    I64 rhs_col_stride_blocks,\n   435\t    I64 k_block_count,\n   436\t    I64 tile_rows,\n   437\t    I64 tile_cols,\n   438\t    I64 *out_mat_q32,\n   439\t    I64 out_capacity,\n   440\t    I64 out_row_stride_cols)\n   441\t{\n   442\t    I64 required_lhs_blocks;\n   443\t    I64 required_rhs_blocks;\n   444\t    I64 required_out_cells;\n   445\t    I64 tile_row_start;\n   446\t    I64 tile_col_start;\n   447\t    I64 tile_row_end;\n   448\t    I64 tile_col_end;\n   449\t    I64 row_index;\n   450\t    I64 col_index;\n   451\t    I64 lhs_row_base;\n   452\t    I64 rhs_col_base;\n   453\t    I64 out_index;\n   454\t    I64 dot_q32;\n   455\t    I32 status;\n   456\t\n   457\t    if (!lhs_matrix_blocks || !rhs_col_blocks || !out_mat_q32)\n   458\t        return Q8_0_AVX2_ERR_NULL_PTR;\n   459\t\n   460\t    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_capacity < 0)\n   461\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   462\t    if (lhs_rows < 0 || lhs_row_stride_blocks < 0)\n   463\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   464\t    if (rhs_cols < 0 || rhs_col_stride_blocks < 0)\n   465\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   466\t    if (k_block_count < 0 || out_row_stride_cols < 0)\n   467\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   468\t    if (tile_rows <= 0 || tile_cols <= 0)\n   469\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   470\t\n   471\t    // Matrix layout contracts:\n   472\t    // - lhs_matrix_blocks stores A as row-major rows, each row consuming\n   473\t    //   k_block_count active Q8_0 blocks inside lhs_row_stride_blocks stride.\n   474\t    // - rhs_col_blocks stores B as pre-transposed columns, each column\n   475\t    //   consuming k_block_count active Q8_0 blocks inside rhs_col_stride_blocks.\n   476\t    // - out_mat_q32 stores C as row-major Q32 cells with out_row_stride_cols.\n   477\t    if (lhs_rows > 0 && lhs_row_stride_blocks < k_block_count)\n   478\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   479\t    if (rhs_cols > 0 && rhs_col_stride_blocks < k_block_count)\n   480\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   481\t    if (lhs_rows > 0 && out_row_stride_cols < rhs_cols)\n   482\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   483\t\n   484\t    if (!Q8_0AVX2TryMulI64(lhs_rows, lhs_row_stride_blocks, &required_lhs_blocks))\n   485\t        return Q8_0_AVX2_ERR_OVERFLOW;\n   486\t    if (required_lhs_blocks > lhs_block_capacity)\n   487\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   488\t\n   489\t    if (!Q8_0AVX2TryMulI64(rhs_cols, rhs_col_stride_blocks, &required_rhs_blocks))\n   490\t        return Q8_0_AVX2_ERR_OVERFLOW;\n   491\t    if (required_rhs_blocks > rhs_block_capacity)\n   492\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   493\t\n   494\t    if (!Q8_0AVX2TryMulI64(lhs_rows, out_row_stride_cols, &required_out_cells))\n   495\t        return Q8_0_AVX2_ERR_OVERFLOW;\n   496\t    if (required_out_cells > out_capacity)\n   497\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   498\t\n   499\t    // Tiled traversal keeps hot row/column windows local for later AVX2 asm.\n   500\t    // Dot primitive remains the checked AVX2-shape kernel so arithmetic and\n   501\t    // overflow behavior are identical to the audited block-level path.\n   502\t    for (tile_row_start = 0; tile_row_start < lhs_rows; tile_row_start += tile_rows)\n   503\t    {\n   504\t        tile_row_end = tile_row_start + tile_rows;\n   505\t        if (tile_row_end > lhs_rows)\n   506\t            tile_row_end = lhs_rows;\n   507\t\n   508\t        for (tile_col_start = 0; tile_col_start < rhs_cols; tile_col_start += tile_cols)\n   509\t        {\n   510\t            tile_col_end = tile_col_start + tile_cols;\n   511\t            if (tile_col_end > rhs_cols)\n   512\t                tile_col_end = rhs_cols;\n   513\t\n   514\t            for (row_index = tile_row_start; row_index < tile_row_end; ++row_index)\n   515\t            {\n   516\t                if (!Q8_0AVX2TryMulI64(row_index, lhs_row_stride_blocks, &lhs_row_base))\n   517\t                    return Q8_0_AVX2_ERR_OVERFLOW;\n   518\t\n   519\t                for (col_index = tile_col_start; col_index < tile_col_end; ++col_index)\n   520\t                {\n---\n   520\t                {\n   521\t                    if (!Q8_0AVX2TryMulI64(col_index, rhs_col_stride_blocks, &rhs_col_base))\n   522\t                        return Q8_0_AVX2_ERR_OVERFLOW;\n   523\t\n   524\t                    status = Q8_0DotBlocksAVX2Q32Checked(\n   525\t                        &lhs_matrix_blocks[lhs_row_base],\n   526\t                        &rhs_col_blocks[rhs_col_base],\n   527\t                        k_block_count,\n   528\t                        &dot_q32);\n   529\t                    if (status != Q8_0_AVX2_OK)\n   530\t                        return status;\n   531\t\n   532\t                    if (!Q8_0AVX2TryMulI64(row_index, out_row_stride_cols, &out_index))\n   533\t                        return Q8_0_AVX2_ERR_OVERFLOW;\n   534\t                    if (!Q8_0AVX2TryAddI64(out_index, col_index, &out_index))\n   535\t                        return Q8_0_AVX2_ERR_OVERFLOW;\n   536\t\n   537\t                    out_mat_q32[out_index] = dot_q32;\n   538\t                }\n   539\t            }\n   540\t        }\n   541\t    }\n   542\t\n   543\t    return Q8_0_AVX2_OK;\n   544\t}\n   545\t\n   546\tI32 Q8_0DotBlocksAVX2Q32ToQ16Checked(Q8_0Block *lhs,\n   547\t                                     Q8_0Block *rhs,\n   548\t                                     I64 block_count,\n   549\t                                     I64 *out_dot_q16)\n   550\t{\n   551\t    I64 total_dot_q32;\n   552\t    I32 status;\n   553\t\n   554\t    if (!lhs || !rhs || !out_dot_q16)\n   555\t        return Q8_0_AVX2_ERR_NULL_PTR;\n   556\t    if (block_count < 0)\n   557\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   558\t\n   559\t    // Single-rounding contract for row kernels:\n   560\t    // 1) Build checked full Q32 dot over all blocks.\n   561\t    // 2) Downshift once Q32->Q16 at the boundary.\n   562\t    // This avoids per-block rounding drift and preserves GGML-style intent.\n   563\t    status = Q8_0DotBlocksAVX2Q32Checked(lhs, rhs, block_count, &total_dot_q32);\n   564\t    if (status != Q8_0_AVX2_OK)\n   565\t        return status;\n   566\t\n   567\t    *out_dot_q16 = Q8_0AVX2DotQ32ToQ16(total_dot_q32);\n   568\t    return Q8_0_AVX2_OK;\n   569\t}\n   570\t\n   571\tI32 Q8_0DotRowsAVX2Q32ToQ16Checked(\n   572\t    Q8_0Block *matrix_blocks,\n   573\t    I64 matrix_block_capacity,\n   574\t    I64 row_count,\n   575\t    I64 row_stride_blocks,\n   576\t    Q8_0Block *vec_blocks,\n   577\t    I64 vec_block_capacity,\n   578\t    I64 vec_block_count,\n   579\t    I64 *out_rows_q16)\n   580\t{\n   581\t    I64 row_index;\n   582\t    I64 required_matrix_blocks;\n   583\t    I64 row_base;\n   584\t    Q8_0Block *row_ptr;\n   585\t    I64 row_dot_q16;\n   586\t    I32 status;\n   587\t\n   588\t    if (!matrix_blocks || !vec_blocks || !out_rows_q16)\n   589\t        return Q8_0_AVX2_ERR_NULL_PTR;\n   590\t\n   591\t    if (matrix_block_capacity < 0 || vec_block_capacity < 0)\n   592\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   593\t    if (row_count < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n   594\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   595\t\n   596\t    // Row layout contract mirrors Q32 row helper:\n   597\t    // - Row i begins at matrix_blocks + i*row_stride_blocks.\n   598\t    // - Each row consumes vec_block_count active blocks for the dot.\n   599\t    if (row_count > 0 && row_stride_blocks < vec_block_count)\n   600\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   601\t    if (vec_block_count > vec_block_capacity)\n   602\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   603\t\n   604\t    if (!Q8_0AVX2TryMulI64(row_count, row_stride_blocks, &required_matrix_blocks))\n   605\t        return Q8_0_AVX2_ERR_OVERFLOW;\n   606\t    if (required_matrix_blocks > matrix_block_capacity)\n   607\t        return Q8_0_AVX2_ERR_BAD_LEN;\n   608\t\n   609\t    // Single-rounding row contract:\n   610\t    // - Build each row dot in checked Q32 precision across all K blocks.\n   611\t    // - Downshift once Q32->Q16 after full-row accumulation.\n   612\t    // This preserves GGML-style rounding behavior and avoids per-block drift.\n   613\t    for (row_index = 0; row_index < row_count; ++row_index)\n   614\t    {\n   615\t        if (!Q8_0AVX2TryMulI64(row_index, row_stride_blocks, &row_base))\n   616\t            return Q8_0_AVX2_ERR_OVERFLOW;\n   617\t\n   618\t        row_ptr = &matrix_blocks[row_base];\n   619\t        status = Q8_0DotBlocksAVX2Q32ToQ16Checked(row_ptr,\n   620\t                                                  vec_blocks,\n   621\t                                                  vec_block_count,\n   622\t                                                  &row_dot_q16);\n   623\t        if (status != Q8_0_AVX2_OK)\n   624\t            return status;\n   625\t\n   626\t        out_rows_q16[row_index] = row_dot_q16;\n   627\t    }\n   628\t\n   629\t    return Q8_0_AVX2_OK;\n   630\t}\n---\n     1\t// q8_0_matmul.HC\n     2\t// Checked tiled Q8_0 matmul kernel for TempleOS.\n     3\t//\n     4\t// Runtime contract:\n     5\t//   - lhs is an MxK matrix in row-major block layout (Q8_0 blocks).\n     6\t//   - rhs is an NxK matrix in row-major \"column bank\" layout where each output\n     7\t//     column of logical B (KxN) is stored as one contiguous row of K blocks.\n     8\t//     This keeps every output cell as an explicit row-dot between two block rows.\n     9\t//   - out is MxN Q16 matrix (I64 lanes) with explicit output row stride.\n    10\t\n    11\t#define Q8_0_MATMUL_VALUES_PER_BLOCK 32\n    12\t#define Q8_0_MATMUL_PACKED_BYTES     32\n    13\t\n    14\t#define Q8_0_MATMUL_OK               0\n    15\t#define Q8_0_MATMUL_ERR_NULL_PTR     1\n    16\t#define Q8_0_MATMUL_ERR_BAD_DST_LEN  2\n    17\t#define Q8_0_MATMUL_ERR_OVERFLOW     3\n    18\t#define Q8_0_MATMUL_I64_MAX          0x7FFFFFFFFFFFFFFF\n    19\t\n    20\tclass Q8_0Block\n    21\t{\n    22\t    U16 d_fp16;\n    23\t    I8 qs[Q8_0_MATMUL_PACKED_BYTES];\n    24\t};\n    25\t\n    26\t// Declared in src/quant/q8_0_dot.HC.\n    27\tI32 Q8_0DotProductBlocksQ16AccumulateChecked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16);\n    28\t// Declared in src/quant/q8_0_avx2.HC.\n    29\tI32 Q8_0DotBlocksAVX2Q32Checked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32);\n    30\tI32 Q8_0DotBlocksAVX2Q32ToQ16Checked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q16);\n    31\t\n    32\tBool Q8_0MatMulTryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n    33\t{\n    34\t    if (!out_prod)\n    35\t        return FALSE;\n    36\t    if (lhs < 0 || rhs < 0)\n    37\t        return FALSE;\n    38\t\n    39\t    if (!lhs || !rhs)\n    40\t    {\n    41\t        *out_prod = 0;\n    42\t        return TRUE;\n    43\t    }\n    44\t\n    45\t    if (lhs > Q8_0_MATMUL_I64_MAX / rhs)\n    46\t        return FALSE;\n    47\t\n    48\t    *out_prod = lhs * rhs;\n    49\t    return TRUE;\n    50\t}\n    51\t\n    52\tBool Q8_0MatMulTryAddI64NonNeg(I64 lhs, I64 rhs, I64 *out_sum)\n    53\t{\n    54\t    if (!out_sum)\n    55\t        return FALSE;\n    56\t    if (lhs < 0 || rhs < 0)\n    57\t        return FALSE;\n    58\t    if (lhs > Q8_0_MATMUL_I64_MAX - rhs)\n    59\t        return FALSE;\n    60\t\n    61\t    *out_sum = lhs + rhs;\n    62\t    return TRUE;\n    63\t}\n    64\t\n    65\tI64 Q8_0MatMulMinI64(I64 lhs, I64 rhs)\n    66\t{\n    67\t    if (lhs < rhs)\n    68\t        return lhs;\n    69\t    return rhs;\n    70\t}\n    71\t\n    72\tI32 Q8_0MatMulQ16TiledChecked(\n    73\t    Q8_0Block *lhs_blocks,\n    74\t    I64 lhs_block_capacity,\n    75\t    I64 row_count,\n    76\t    I64 lhs_row_stride_blocks,\n    77\t    Q8_0Block *rhs_col_blocks,\n    78\t    I64 rhs_block_capacity,\n    79\t    I64 col_count,\n    80\t    I64 rhs_col_stride_blocks,\n    81\t    I64 k_block_count,\n    82\t    I64 tile_rows,\n    83\t    I64 tile_cols,\n    84\t    I64 *out_cells_q16,\n    85\t    I64 out_cell_capacity,\n    86\t    I64 out_row_stride_cells)\n    87\t{\n    88\t    I64 lhs_required_blocks;\n    89\t    I64 rhs_required_blocks;\n    90\t    I64 out_required_cells;\n    91\t    I64 row_tile_start;\n    92\t    I64 col_tile_start;\n    93\t    I64 row_tile_end;\n    94\t    I64 col_tile_end;\n    95\t    I64 row_index;\n    96\t    I64 col_index;\n    97\t    I64 lhs_row_base;\n    98\t    I64 rhs_col_base;\n    99\t    I64 out_row_base;\n   100\t    I64 out_index;\n   101\t    I64 cell_dot_q16;\n   102\t    Q8_0Block *lhs_row_ptr;\n   103\t    Q8_0Block *rhs_col_ptr;\n   104\t    I32 status;\n   105\t\n   106\t    if (!lhs_blocks || !rhs_col_blocks || !out_cells_q16)\n   107\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n   108\t\n   109\t    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_cell_capacity < 0)\n   110\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   111\t    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n   112\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   113\t    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n   114\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   115\t    if (tile_rows <= 0 || tile_cols <= 0)\n   116\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   117\t\n   118\t    // Active K span must fit inside each source row stride.\n   119\t    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n   120\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   121\t\n   122\t    // Output row stride must cover active output columns.\n   123\t    if (row_count > 0 && out_row_stride_cells < col_count)\n   124\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   125\t\n   126\t    // Capacity proofs for full row-strided views.\n   127\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n   128\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   129\t    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n   130\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   131\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n   132\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   133\t\n   134\t    if (lhs_required_blocks > lhs_block_capacity)\n   135\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   136\t    if (rhs_required_blocks > rhs_block_capacity)\n   137\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   138\t    if (out_required_cells > out_cell_capacity)\n   139\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   140\t\n   141\t    // Tiled traversal keeps working-set bounded while preserving direct math visibility.\n   142\t    row_tile_start = 0;\n   143\t    while (row_tile_start < row_count)\n   144\t    {\n   145\t        if (!Q8_0MatMulTryAddI64NonNeg(row_tile_start, tile_rows, &row_tile_end))\n   146\t            return Q8_0_MATMUL_ERR_OVERFLOW;\n   147\t        row_tile_end = Q8_0MatMulMinI64(row_tile_end, row_count);\n   148\t\n   149\t        col_tile_start = 0;\n   150\t        while (col_tile_start < col_count)\n   151\t        {\n   152\t            if (!Q8_0MatMulTryAddI64NonNeg(col_tile_start, tile_cols, &col_tile_end))\n   153\t                return Q8_0_MATMUL_ERR_OVERFLOW;\n   154\t            col_tile_end = Q8_0MatMulMinI64(col_tile_end, col_count);\n   155\t\n   156\t            for (row_index = row_tile_start; row_index < row_tile_end; ++row_index)\n   157\t            {\n   158\t                if (!Q8_0MatMulTryMulI64NonNeg(row_index, lhs_row_stride_blocks, &lhs_row_base))\n   159\t                    return Q8_0_MATMUL_ERR_OVERFLOW;\n   160\t                if (!Q8_0MatMulTryMulI64NonNeg(row_index, out_row_stride_cells, &out_row_base))\n   161\t                    return Q8_0_MATMUL_ERR_OVERFLOW;\n   162\t\n   163\t                lhs_row_ptr = &lhs_blocks[lhs_row_base];\n   164\t\n   165\t                for (col_index = col_tile_start; col_index < col_tile_end; ++col_index)\n   166\t                {\n   167\t                    if (!Q8_0MatMulTryMulI64NonNeg(col_index, rhs_col_stride_blocks, &rhs_col_base))\n   168\t                        return Q8_0_MATMUL_ERR_OVERFLOW;\n   169\t                    if (!Q8_0MatMulTryAddI64NonNeg(out_row_base, col_index, &out_index))\n   170\t                        return Q8_0_MATMUL_ERR_OVERFLOW;\n   171\t\n   172\t                    rhs_col_ptr = &rhs_col_blocks[rhs_col_base];\n   173\t                    cell_dot_q16 = 0;\n   174\t\n   175\t                    status = Q8_0DotProductBlocksQ16AccumulateChecked(lhs_row_ptr, rhs_col_ptr, k_block_count, &cell_dot_q16);\n   176\t                    if (status != Q8_0_MATMUL_OK)\n   177\t                        return status;\n   178\t\n   179\t                    out_cells_q16[out_index] = cell_dot_q16;\n   180\t                }\n   181\t            }\n   182\t\n   183\t            col_tile_start = col_tile_end;\n   184\t        }\n   185\t\n   186\t        row_tile_start = row_tile_end;\n   187\t    }\n   188\t\n   189\t    return Q8_0_MATMUL_OK;\n   190\t}\n   191\t\n   192\tI32 Q8_0MatMulQ32TiledAVX2Checked(\n   193\t    Q8_0Block *lhs_blocks,\n   194\t    I64 lhs_block_capacity,\n   195\t    I64 row_count,\n   196\t    I64 lhs_row_stride_blocks,\n   197\t    Q8_0Block *rhs_col_blocks,\n   198\t    I64 rhs_block_capacity,\n   199\t    I64 col_count,\n   200\t    I64 rhs_col_stride_blocks,\n   201\t    I64 k_block_count,\n   202\t    I64 tile_rows,\n   203\t    I64 tile_cols,\n   204\t    I64 *out_cells_q32,\n   205\t    I64 out_cell_capacity,\n   206\t    I64 out_row_stride_cells)\n   207\t{\n   208\t    I64 lhs_required_blocks;\n   209\t    I64 rhs_required_blocks;\n   210\t    I64 out_required_cells;\n   211\t    I64 row_tile_start;\n   212\t    I64 col_tile_start;\n   213\t    I64 row_tile_end;\n   214\t    I64 col_tile_end;\n   215\t    I64 row_index;\n   216\t    I64 col_index;\n   217\t    I64 lhs_row_base;\n   218\t    I64 rhs_col_base;\n   219\t    I64 out_row_base;\n   220\t    I64 out_index;\n   221\t    I64 cell_dot_q32;\n   222\t    Q8_0Block *lhs_row_ptr;\n   223\t    Q8_0Block *rhs_col_ptr;\n   224\t    I32 status;\n   225\t\n   226\t    if (!lhs_blocks || !rhs_col_blocks || !out_cells_q32)\n   227\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n   228\t\n   229\t    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_cell_capacity < 0)\n   230\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   231\t    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n   232\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   233\t    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n   234\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   235\t    if (tile_rows <= 0 || tile_cols <= 0)\n   236\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   237\t\n   238\t    // Active K span must fit inside each source row stride.\n   239\t    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n   240\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   241\t\n   242\t    // Output row stride must cover active output columns.\n   243\t    if (row_count > 0 && out_row_stride_cells < col_count)\n   244\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   245\t\n   246\t    // Capacity proofs for full row-strided views.\n   247\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n   248\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   249\t    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n   250\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   251\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n   252\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   253\t\n   254\t    if (lhs_required_blocks > lhs_block_capacity)\n   255\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   256\t    if (rhs_required_blocks > rhs_block_capacity)\n   257\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   258\t    if (out_required_cells > out_cell_capacity)\n   259\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   260\t\n","exit_code":0,"status":"completed"}}
