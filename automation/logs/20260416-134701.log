GGUF_TDBASE_ERR_NULL_PTR 1\n#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n#define GGUF_TDBASE_ERR_OVERFLOW 3\n#define GGUF_TDBASE_ERR_MISALIGNED_BASE 4\n#define GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET 5\n#define GGUF_TDBASE_ERR_BAD_TYPE 6\n#define GGUF_TDBASE_ERR_OUT_OF_BOUNDS 7\n#define GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE 8\n#define GGUF_TDBASE_ERR_OVERLAP 9\n\n// GGUF default tensor alignment when metadata key `general.alignment`\n// is absent.\n#define GGUF_DEFAULT_ALIGNMENT 32\n\n// Subset of ggml tensor types currently enabled in HolyC inference runtime.\n// Keep this list strict and explicit so sizing math never silently accepts\n// unknown quantization tags from malformed GGUF files.\n#define GGML_TYPE_F32   0\n#define GGML_TYPE_F16   1\n#define GGML_TYPE_Q4_0  2\n#define GGML_TYPE_Q8_0  8\n\n// GGML quantization blocks for runtime-critical formats:\n// - F32/F16 are scalar types (block size 1).\n// - Q4_0 and Q8_0 are packed in 32-element blocks.\n#define GGML_BLCK_SIZE_F32   1\n#define GGML_BLCK_SIZE_F16   1\n#define GGML_BLCK_SIZE_Q4_0  32\n#define GGML_BLCK_SIZE_Q8_0  32\n\n// Block payload byte widths from ggml struct layouts:\n// - Q4_0: fp16 scale (2 bytes) + 16 packed nibbles = 18 bytes.\n// - Q8_0: fp16 scale (2 bytes) + 32 signed bytes = 34 bytes.\n#define GGML_TYPE_SIZE_F32   4\n#define GGML_TYPE_SIZE_F16   2\n#define GGML_TYPE_SIZE_Q4_0  18\n#define GGML_TYPE_SIZE_Q8_0  34\n\nI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n{\n    if (!out_block_size)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    switch (ggml_type)\n    {\n        case GGML_TYPE_F32:\n            *out_block_size = GGML_BLCK_SIZE_F32;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_F16:\n            *out_block_size = GGML_BLCK_SIZE_F16;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q4_0:\n            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q8_0:\n            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n            return GGUF_TDBASE_OK;\n    }\n\n    return GGUF_TDBASE_ERR_BAD_TYPE;\n}\n\nI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n{\n    if (!out_block_bytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    switch (ggml_type)\n    {\n        case GGML_TYPE_F32:\n            *out_block_bytes = GGML_TYPE_SIZE_F32;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_F16:\n            *out_block_bytes = GGML_TYPE_SIZE_F16;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q4_0:\n            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q8_0:\n            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n            return GGUF_TDBASE_OK;\n    }\n\n    return GGUF_TDBASE_ERR_BAD_TYPE;\n}\n\nI64 GGUFTensorBytesForType(U32 ggml_type,\n                           U64 element_count,\n                           U64 *out_tensor_nbytes)\n{\n    U64 block_size;\n    U64 block_bytes;\n    U64 block_count;\n    I64 err;\n\n    if (!out_tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    err = GGUFTensorTypeBlockSize(ggml_type, &block_size);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    err = GGUFTensorTypeBlockBytes(ggml_type, &block_bytes);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // Quantized formats are stored in fixed-size element blocks.\n    // Reject non-multiples instead of silently rounding/truncating.\n    if (element_count % block_size)\n        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE;\n\n    block_count = element_count / block_size;\n\n    // Byte size = number of blocks * bytes per block.\n    // Guard overflow before multiplication for malformed giant tensors.\n    if (block_count > 0xFFFFFFFFFFFFFFFF / block_bytes)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out_tensor_nbytes = block_count * block_bytes;\n    return GGUF_TDBASE_OK;\n}\n\nBool GGUFIsPow2U32(U32 value)\n{\n    if (!value)\n        return FALSE;\n    return (value & (value - 1)) == 0;\n}\n\nI64 GGUFValidateAlignment(U32 alignment)\n{\n    if (!GGUFIsPow2U32(alignment))\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n{\n    U64 mask;\n\n    if (!out)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n\n    // For power-of-two alignments, align-up is:\n    //   (value + (alignment - 1)) & ~(alignment - 1)\n    // Keep overflow checks explicit so giant malformed offsets are rejected.\n    mask = (U64)alignment - 1;\n    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out = (value + mask) & ~mask;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n                            U32 alignment,\n                            U64 *out_tensor_data_base)\n{\n    return GGUFAlignUpU64(cursor_after_tensor_info,\n                          alignment,\n                          out_tensor_data_base);\n}\n\nI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n                                   U64 *out_tensor_data_base)\n{\n    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n                                   GGUF_DEFAULT_ALIGNMENT,\n                                   out_tensor_data_base);\n}\n\nBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n{\n    U64 mask;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return FALSE;\n\n    mask = (U64)alignment - 1;\n    return (offset & mask) == 0;\n}\n\nI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n                             U64 tensor_rel_offset,\n                             U32 alignment,\n                             U64 *out_tensor_abs)\n{\n    if (!out_tensor_abs)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n\n    // Both base and relative tensor offsets must preserve GGUF alignment.\n    // Enforcing this here keeps every downstream payload read auditable.\n    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n\n    // Absolute payload pointer is base + relative offset.\n    // Keep overflow check explicit for malformed large files.\n    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n                                    U64 tensor_rel_offset,\n                                    U64 *out_tensor_abs)\n{\n    return GGUFTensorDataBaseOffset(tensor_data_base,\n                                    tensor_rel_offset,\n                                    GGUF_DEFAULT_ALIGNMENT,\n                                    out_tensor_abs);\n}\n\nI64 GGUFTensorResolveRange(U64 tensor_data_base,\n                           U64 tensor_rel_offset,\n                           U64 tensor_nbytes,\n                           U64 gguf_file_nbytes,\n                           U32 alignment,\n                           U64 *out_tensor_abs_start,\n                           U64 *out_tensor_abs_end)\n{\n    U64 abs_start;\n    U64 abs_end;\n    I64 err;\n\n    if (!out_tensor_abs_start || !out_tensor_abs_end)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    // Resolve and validate the absolute tensor start offset first.\n    err = GGUFTensorDataBaseOffset(tensor_data_base,\n                                   tensor_rel_offset,\n                                   alignment,\n                                   &abs_start);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // Tensor byte-range is [abs_start, abs_start + tensor_nbytes).\n    // Guard add overflow before constructing the exclusive end.\n    if (abs_start > 0xFFFFFFFFFFFFFFFF - tensor_nbytes)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n    abs_end = abs_start + tensor_nbytes;\n\n    // Reject ranges that run past the file boundary.\n    // A tensor may legally end exactly at gguf_file_nbytes.\n    if (abs_end > gguf_file_nbytes)\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/quant/q8_0_avx2.HC; sed -n '1,260p' tests/test_q8_0_dot.py; ls tests | rg 'q8_0|avx2|dot'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/quant/q8_0_avx2.HC; sed -n '1,260p' tests/test_q8_0_dot.py; ls tests | rg 'q8_0|avx2|dot'\"","aggregated_output":"// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n#define Q8_0_AVX2_PAIR_COUNT         16\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n#define Q8_0_AVX2_ERR_OVERFLOW       3\n\n#define Q8_0_AVX2_I64_MAX            0x7FFFFFFFFFFFFFFF\n#define Q8_0_AVX2_I64_MIN            (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nI32 Q8_0Pack32ToI16LanesAVX2(I8 *src_q8, I64 src_len, I16 *dst_i16, I64 dst_len)\n{\n    I64 lane;\n\n    if (!src_q8 || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (src_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Lane contract:\n    //   dst_i16[i] = SignExtend16(src_q8[i]) for i in [0, 31]\n    // This exact order matches the two AVX2 16-lane halves that would be\n    // produced by widening bytes 0..15 then 16..31.\n    for (lane = 0; lane < Q8_0_AVX2_VALUES_PER_BLOCK; ++lane)\n        dst_i16[lane] = (I16)src_q8[lane];\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0PackBlockToI16LanesAVX2(Q8_0Block *block, I16 *dst_i16, I64 dst_len)\n{\n    if (!block || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    return Q8_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\n\nI32 Q8_0MulI16LanesToI32PairsAVX2(I16 *lhs_i16,\n                                  I64 lhs_len,\n                                  I16 *rhs_i16,\n                                  I64 rhs_len,\n                                  I32 *dst_i32,\n                                  I64 dst_len)\n{\n    I64 pair_index;\n    I64 lane_base;\n    I32 product0;\n    I32 product1;\n\n    if (!lhs_i16 || !rhs_i16 || !dst_i32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (lhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Contract mirrors AVX2 `vpmaddwd` lane behavior used by quantized dot kernels:\n    // - Multiply lane pairs independently in signed 16-bit domain.\n    // - Accumulate each adjacent pair into one signed 32-bit output.\n    // - Preserve lane order so output pair k maps to input lanes [2k, 2k+1].\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        lane_base = pair_index << 1;\n\n        product0 = lhs_i16[lane_base] * rhs_i16[lane_base];\n        product1 = lhs_i16[lane_base + 1] * rhs_i16[lane_base + 1];\n\n        dst_i32[pair_index] = product0 + product1;\n    }\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0HSumI32PairsAVX2(I32 *pairs_i32,\n                         I64 pairs_len,\n                         I64 *out_sum_i64)\n{\n    I64 pair_index;\n    I64 running_sum;\n    I64 term;\n\n    if (!pairs_i32 || !out_sum_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n    if (pairs_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Horizontal reduction contract:\n    // - Sum all 16 pairwise I32 partial products into one signed I64 scalar.\n    // - Preserve deterministic lane order (0..15) for auditability parity\n    //   against the scalar reference path.\n    // - Explicit overflow checks keep reduction safe if this helper is reused\n    //   for wider accumulation streams in future kernels.\n    running_sum = 0;\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        term = (I64)pairs_i32[pair_index];\n\n        if (term > 0 && running_sum > Q8_0_AVX2_I64_MAX - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (term < 0 && running_sum < Q8_0_AVX2_I64_MIN - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n\n        running_sum += term;\n    }\n\n    *out_sum_i64 = running_sum;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotI16LanesAVX2(I16 *lhs_i16,\n                        I64 lhs_len,\n                        I16 *rhs_i16,\n                        I64 rhs_len,\n                        I64 *out_dot_i64)\n{\n    I32 pairs_i32[Q8_0_AVX2_PAIR_COUNT];\n    I64 dot_i64;\n    I32 status;\n\n    if (!lhs_i16 || !rhs_i16 || !out_dot_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    // Compose the lane-dot from the two audited AVX2-shape primitives:\n    // 1) `vpmaddwd`-equivalent pairwise multiply-add over 32 I16 lanes.\n    // 2) Horizontal sum over 16 I32 pair partials into one I64 scalar.\n    // Keeping this composition explicit preserves bit-level auditability while\n    // allowing future inline-asm replacement of each stage independently.\n    status = Q8_0MulI16LanesToI32PairsAVX2(lhs_i16,\n                                           lhs_len,\n                                           rhs_i16,\n                                           rhs_len,\n                                           pairs_i32,\n                                           Q8_0_AVX2_PAIR_COUNT);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    status = Q8_0HSumI32PairsAVX2(pairs_i32,\n                                  Q8_0_AVX2_PAIR_COUNT,\n                                  &dot_i64);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    *out_dot_i64 = dot_i64;\n    return Q8_0_AVX2_OK;\n}\n#!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0 integer-only dot product semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ8_0_VALUES_PER_BLOCK = 32\nQ8_0_PACKED_BYTES = 32\n\nQ8_0_OK = 0\nQ8_0_ERR_NULL_PTR = 1\nQ8_0_ERR_BAD_DST_LEN = 2\nQ8_0_ERR_OVERFLOW = 3\nQ8_0_I64_MAX = (1 << 63) - 1\nQ8_0_I64_MIN = -(1 << 63)\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    round_bias = 1 << (shift - 1)\n    return (value + round_bias) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef f16_to_q16(fp16_bits: int) -> int:\n    sign_bit = (fp16_bits >> 15) & 1\n    exponent_bits = (fp16_bits >> 10) & 0x1F\n    fraction_bits = fp16_bits & 0x03FF\n\n    if exponent_bits == 0:\n        if fraction_bits == 0:\n            return 0\n        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n        return -magnitude_q16 if sign_bit else magnitude_q16\n\n    if exponent_bits == 0x1F:\n        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n\n    mantissa = 1024 + fraction_bits\n    shift_amount = exponent_bits - 9\n    if shift_amount >= 0:\n        magnitude_q16 = mantissa << shift_amount\n    else:\n        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n\n    return -magnitude_q16 if sign_bit else magnitude_q16\n\n\ndef half_bits(value: float) -> int:\n    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n\n\ndef pack_signed(values: list[int]) -> bytes:\n    assert len(values) == Q8_0_PACKED_BYTES\n    return bytes((v + 256) % 256 for v in values)\n\n\ndef unpack_signed(qs: bytes) -> list[int]:\n    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n\n\ndef dot_product_block_q32(\n    lhs_scale_fp16: int,\n    lhs_qs: bytes,\n    rhs_scale_fp16: int,\n    rhs_qs: bytes,\n) -> tuple[int, int]:\n    if len(lhs_qs) != Q8_0_PACKED_BYTES or len(rhs_qs) != Q8_0_PACKED_BYTES:\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    lhs_signed = unpack_signed(lhs_qs)\n    rhs_signed = unpack_signed(rhs_qs)\n\n    q_dot_q0 = 0\n    for lhs_q, rhs_q in zip(lhs_signed, rhs_signed):\n        q_dot_q0 += lhs_q * rhs_q\n\n    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n    dot_q32 = lhs_scale_q16 * rhs_scale_q16 * q_dot_q0\n    return Q8_0_OK, dot_q32\n\n\ndef dot_product_blocks_q32(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    total = 0\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        if err != Q8_0_OK:\n            return err, 0\n        total += block_dot\n\n    return Q8_0_OK, total\n\n\ndef try_add_i64(lhs: int, rhs: int) -> tuple[bool, int]:\n    if rhs > 0 and lhs > Q8_0_I64_MAX - rhs:\n        return False, 0\n    if rhs < 0 and lhs < Q8_0_I64_MIN - rhs:\n        return False, 0\n    return True, lhs + rhs\n\n\ndef dot_product_blocks_q32_checked(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    total = 0\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        if err != Q8_0_OK:\n            return err, 0\n\n        ok, checked_sum = try_add_i64(total, block_dot)\n        if not ok:\n            return Q8_0_ERR_OVERFLOW, 0\n        total = checked_sum\n\n    return Q8_0_OK, total\n\n\ndef dot_q32_to_q16(dot_q32: int) -> int:\n    return round_shift_right_signed(dot_q32, 16)\n\n\ndef dot_product_blocks_q16_accumulate(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n    initial_accum_q16: int,\n) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    total_q16 = initial_accum_q16\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot_q32 = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        if err != Q8_0_OK:\n            return err, 0\n        total_q16 += dot_q32_to_q16(block_dot_q32)\n\n    return Q8_0_OK, total_q16\n\n\ndef dot_product_blocks_q16_accumulate_checked(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n    initial_accum_q16: int,\n) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    total_q16 = initial_accum_q16\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot_q32 = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        if err != Q8_0_OK:\n            return err, 0\n\n        block_dot_q16 = dot_q32_to_q16(block_dot_q32)\n        ok, checked_sum = try_add_i64(total_q16, block_dot_q16)\n        if not ok:\n            return Q8_0_ERR_OVERFLOW, 0\n        total_q16 = checked_sum\n\n    return Q8_0_OK, total_q16\n\n\ndef dot_row_blocks_q16(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n) -> tuple[int, int]:\n    return dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n\n\ndef dot_row_blocks_q16_checked(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n) -> tuple[int, int]:\n    return dot_product_blocks_q16_accumulate_checked(lhs_blocks, rhs_blocks, 0)\n\n\ndef dot_rows_q16_matrix_vector(\n    matrix_blocks: list[tuple[int, bytes]],\n    row_count: int,\n    row_stride_blocks: int,\n    vec_blocks: list[tuple[int, bytes]],\n    vec_block_count: int,\n) -> tuple[int, list[int]]:\n    if row_count < 0 or row_stride_blocks < 0 or vec_block_count < 0:\n        return Q8_0_ERR_BAD_DST_LEN, []\n    if row_count > 0 and row_stride_blocks < vec_block_count:\n        return Q8_0_ERR_BAD_DST_LEN, []\n\n    out_rows_q16 = [0] * row_count\n    for row_index in range(row_count):\n        row_base = row_index * row_stride_blocks\n        row_slice = matrix_blocks[row_base : row_base + vec_block_count]\n        if len(row_slice) != vec_block_count:\n            return Q8_0_ERR_BAD_DST_LEN, []\n\n        err, row_dot_q16 = dot_row_blocks_q16(row_slice, vec_blocks[:vec_block_count])\n        if err != Q8_0_OK:\n            return err, []\n\n        out_rows_q16[row_index] = row_dot_q16\n\n    return Q8_0_OK, out_rows_q16\n\n\ndef dot_rows_q16_matrix_vector_checked(\n    matrix_blocks: list[tuple[int, bytes]],\n    matrix_block_capacity: int,\n    row_count: int,\n    row_stride_blocks: int,\n    vec_blocks: list[tuple[int, bytes]],\n    vec_block_capacity: int,\n    vec_block_count: int,\n) -> tuple[int, list[int]]:\n    if matrix_block_capacity < 0 or vec_block_capacity < 0:\n        return Q8_0_ERR_BAD_DST_LEN, []\n    if row_count < 0 or row_stride_blocks < 0 or vec_block_count < 0:\n        return Q8_0_ERR_BAD_DST_LEN, []\n    if row_count > 0 and row_stride_blocks < vec_block_count:\n        return Q8_0_ERR_BAD_DST_LEN, []\n    if vec_block_count > vec_block_capacity:\n        return Q8_0_ERR_BAD_DST_LEN, []\n\n    required_matrix_blocks = row_count * row_stride_blocks\n    if required_matrix_blocks > Q8_0_I64_MAX:\n        return Q8_0_ERR_OVERFLOW, []\n    if required_matrix_blocks > matrix_block_capacity:\n        return Q8_0_ERR_BAD_DST_LEN, []\n\n    out_rows_q16 = [0] * row_count\n    for row_index in range(row_count):\n        row_base = row_index * row_stride_blocks\n        if row_base > Q8_0_I64_MAX:\n            return Q8_0_ERR_OVERFLOW, []\n\n        row_slice = matrix_blocks[row_base : row_base + vec_block_count]\n        if len(row_slice) != vec_block_count:\n            return Q8_0_ERR_BAD_DST_LEN, []\n\ntest_q4_0_dot.py\ntest_q4_0_q8_0_dot_kernel.py\ntest_q4_0_q8_0_matmul_tiled_checked.py\ntest_q8_0_avx2_dot_lanes.py\ntest_q8_0_avx2_hsum_pairs.py\ntest_q8_0_avx2_mul_pairs.py\ntest_q8_0_avx2_pack.py\ntest_q8_0_dequant.py\ntest_q8_0_dot.py\ntest_q8_0_dot_matrix_vector.py\ntest_q8_0_dot_matrix_vector_checked.py\ntest_q8_0_matmul_tiled_checked.py\n","exit_code":0,"status":"completed"}}
