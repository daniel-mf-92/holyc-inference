ath/softmax.HC:553:// Checked composed helper for alias-permitted split-phase softmax\nsrc/math/softmax.HC:568:I32 FPQ16SoftmaxFromPreclampedCheckedWithSumOut(I64 *preclamped_logits_q16,\nsrc/math/softmax.HC:582:    status = FPQ16SoftmaxExpPhaseFromPreclampedChecked(preclamped_logits_q16,\nsrc/math/softmax.HC:594:    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\nsrc/math/softmax.HC:600:    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\nsrc/math/softmax.HC:606:U0 FPQ16Softmax(I64 *logits, I64 *probs, I64 count)\ntests/test_softmax_exp_phase_from_preclamped_no_alias_checked.py:2:\"\"\"Reference checks for FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked semantics.\"\"\"\ntests/test_softmax_normalize_phase_no_alias_checked.py:2:\"\"\"Reference checks for FPQ16SoftmaxNormalizePhaseNoAliasChecked semantics.\"\"\"\ntests/test_rope_q16_validate_head_range_span_for_dim.py:2:\"\"\"Reference checks for RoPEQ16ValidateHeadRangeSpanForDimChecked semantics.\"\"\"\ntests/test_rmsnorm_q16_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormChecked and compute-inv helper semantics.\"\"\"\ntests/test_softmax_normalize_phase_checked.py:2:\"\"\"Reference checks for FPQ16SoftmaxNormalizePhaseChecked semantics.\"\"\"\ntests/test_q8_0_avx2_rows_q32.py:2:\"\"\"Reference checks for Q8_0DotRowsAVX2Q32Checked semantics.\"\"\"\ntests/test_rope_q16_rotate_head_range_token_window.py:2:\"\"\"Reference checks for RoPEQ16RotateHeadRangeByTokenWindowPreflightedChecked.\"\"\"\ntests/test_fixedpoint_q16_muldiv_array_checked.py:2:\"\"\"Reference checks for FPQ16MulDivArrayRoundedChecked semantics.\"\"\"\ntests/test_softmax_from_preclamped_no_alias_checked.py:2:\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedNoAliasChecked semantics.\"\"\"\ntests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked semantics.\"\"\"\ntests/test_rope_q16_rotate_head_range_preflighted_position.py:2:\"\"\"Reference checks for RoPEQ16RotateHeadRangeByPositionPreflightedChecked semantics.\"\"\"\ntests/test_q8_0_matmul_tiled_row_slice_preflight.py:4:Targets IQ-132 and `Q8_0MatMulTiledValidateRowSliceChecked` semantics:\ntests/test_q8_0_avx2_blocks_q32_to_q16.py:2:\"\"\"Reference checks for Q8_0DotBlocksAVX2Q32ToQ16Checked semantics.\"\"\"\ntests/test_q8_0_matmul_tiled_avx2_q32.py:2:\"\"\"Reference checks for Q8_0MatMulTiledAVX2Q32Checked semantics.\"\"\"\ntests/test_q8_0_matmul_tiled_row_base_preflight.py:4:Targets IQ-129 and `Q8_0MatMulTiledComputeRowBaseChecked` semantics:\ntests/test_rmsnorm_apply_inv_denom_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormApplyInvDenomChecked semantics.\"\"\"\ntests/test_intexp_exp_array_checked.py:2:\"\"\"Reference checks for FPQ16ExpArrayChecked semantics.\"\"\"\ntests/test_gguf_header_validate_and_size_checked.py:2:\"\"\"Reference checks for GGUFHeaderValidateAndSizeChecked semantics.\"\"\"\ntests/test_q8_0_matmul_tiled_avx2_q16.py:2:\"\"\"Reference checks for Q8_0MatMulQ16TiledAVX2Checked semantics.\"\"\"\ntests/test_q4_0_q8_0_avx2_blocks_q32.py:2:\"\"\"Reference checks for Q4_0Q8_0DotBlocksAVX2Q32Checked semantics.\"\"\"\ntests/test_intexp_exp_array_no_alias_checked.py:2:\"\"\"Reference checks for FPQ16ExpArrayCheckedNoAliasChecked semantics.\"\"\"\ntests/test_fixedpoint_q16_muldiv_positive_int_checked.py:2:\"\"\"Reference checks for FPQ16MulDivRoundedByPositiveIntChecked semantics.\"\"\"\ntests/test_fixedpoint_q16_muldiv_positive_int_from_q16den_checked.py:2:\"\"\"Reference checks for FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked.\"\"\"\ntests/test_intexp_exp_array_from_clamped_input_checked.py:2:\"\"\"Reference checks for FPQ16ExpArrayFromClampedInputChecked semantics.\"\"\"\ntests/test_rmsnorm_apply_inv_denom_weighted_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormApplyInvDenomWeightedChecked semantics.\"\"\"\ntests/test_rope_q16_validate_head_range_capacity.py:2:\"\"\"Reference checks for RoPEQ16ValidateHeadRangeCapacityChecked semantics.\"\"\"\ntests/test_q8_0_avx2_rows_q32_to_q16.py:2:\"\"\"Reference checks for Q8_0DotRowsAVX2Q32ToQ16Checked semantics.\"\"\"\ntests/test_q4_0_q8_0_matmul_tiled_avx2_q32.py:2:\"\"\"Reference checks for Q4_0Q8_0MatMulQ32TiledAVX2Checked semantics.\"\"\"\ntests/test_gguf_header_parse_checked.py:2:\"\"\"Reference checks for GGUFHeaderParseChecked semantics.\"\"\"\ntests/test_rmsnorm_apply_inv_denom_weighted_auto_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormApplyInvDenomWeightedAutoChecked semantics.\"\"\"\ntests/test_rmsnorm_q16_checked_inplace.py:2:\"\"\"Reference checks for FPQ16RMSNormCheckedInPlace semantics.\"\"\"\ntests/test_softmax_exp_phase_from_preclamped_checked.py:2:\"\"\"Reference checks for FPQ16SoftmaxExpPhaseFromPreclampedChecked semantics.\"\"\"\ntests/test_fixedpoint_q16_muldiv_checked.py:2:\"\"\"Reference checks for FPQ16MulDivRoundedChecked one-rounding semantics.\"\"\"\ntests/test_softmax_from_preclamped_no_alias_checked_with_sum_out.py:2:\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedNoAliasCheckedWithSumOut semantics.\"\"\"\ntests/test_softmax_from_preclamped_checked.py:2:\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedChecked semantics.\"\"\"\ntests/test_q8_0_matmul_tiled_rhs_base_preflight.py:4:Targets IQ-128 and `Q8_0MatMulTiledComputeRhsColBaseChecked` semantics:\ntests/test_softmax_from_preclamped_checked_with_sum_out.py:2:\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedCheckedWithSumOut semantics.\"\"\"\ntests/test_rope_q16_validate_head_span_for_dim.py:2:\"\"\"Reference checks for RoPEQ16ValidateHeadSpanForDimChecked semantics.\"\"\"\ntests/test_q8_0_avx2_blocks_q32.py:2:\"\"\"Reference checks for Q8_0DotBlocksAVX2Q32Checked semantics.\"\"\"\ntests/test_intexp_exp_from_clamped_input_checked.py:2:\"\"\"Reference checks for FPQ16ExpFromClampedInputChecked semantics.\"\"\"\ntests/test_gguf_header_parse.py:2:\"\"\"Reference checks for GGUFHeaderParseChecked fixed-header decode semantics.\"\"\"\ntests/test_intexp_clamp_to_input_domain_checked.py:2:\"\"\"Reference checks for FPQ16ExpClampToInputDomainChecked semantics.\"\"\"\ntests/test_intexp_clamp_array_to_input_domain_checked.py:2:\"\"\"Reference checks for FPQ16ExpClampArrayToInputDomainChecked semantics.\"\"\"\ntests/test_rope_q16_rotate_head_range_position_strided.py:2:\"\"\"Reference checks for RoPEQ16RotateHeadRangeByPositionCheckedStrided semantics.\"\"\"\ntests/test_intexp_split_base2_from_clamped_input_checked.py:2:\"\"\"Reference checks for FPQ16ExpSplitBase2FromClampedInputChecked semantics.\"\"\"\n--- softmax.HC ---\n// softmax.HC\n// Integer-only Q16.16 softmax for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n#define U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\nI64 FPQ16Exp(I64 x);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Ln(I64 x_q16);\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16);\nI32 FPQ16ExpArrayFromClampedInputChecked(I64 *input_q16,\n                                         I64 *output_q16,\n                                         I64 count);\nI32 FPQ16ExpArrayCheckedNoAliasChecked(I64 *input_q16,\n                                       I64 *output_q16,\n                                       I64 count);\nI32 FPQ16SoftmaxFromPreclampedNoAliasCheckedWithSumOut(I64 *preclamped_logits_q16,\n                                                       I64 *exp_lanes_q16,\n                                                       I64 lane_count,\n                                                       I64 *probs_q16,\n                                                       I64 *out_exp_sum_q16);\n\n// Checked softmax split-phase helper for pre-clamped logits.\n// Phase performed here:\n//   1) exp_lanes_q16[i] = exp(preclamped_logits_q16[i])\n//   2) out_exp_sum_q16  = sum_i exp_lanes_q16[i] (checked I64 add)\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - preclamped_logits_q16 and exp_lanes_q16 must each address lane_count I64s\n//   - Any I64 accumulation overflow returns FP_Q16_ERR_OVERFLOW\n// Notes:\n//   - Pre-clamped domain validation and lane exp math are delegated to\n//     FPQ16ExpArrayFromClampedInputChecked so scalar/vector exp semantics stay\n//     centralized and auditable.\nI32 FPQ16SoftmaxExpPhaseFromPreclampedChecked(I64 *preclamped_logits_q16,\n                                              I64 *exp_lanes_q16,\n                                              I64 lane_count,\n                                              I64 *out_exp_sum_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !out_exp_sum_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Empty vectors are valid: no lanes, zero sum.\n    if (!lane_count)\n    {\n        *out_exp_sum_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Guard pointer-span arithmetic before any indexed access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)preclamped_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    status = FPQ16ExpArrayFromClampedInputChecked(preclamped_logits_q16,\n                                                  exp_lanes_q16,\n                                                  lane_count);\n    if (status)\n        return status;\n\n    exp_sum_q16 = 0;\n    for (i = 0; i < lane_count; i++)\n    {\n        if (exp_lanes_q16[i] > (I64_MAX_VALUE - exp_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        exp_sum_q16 += exp_lanes_q16[i];\n    }\n\n    *out_exp_sum_q16 = exp_sum_q16;\n    return FP_Q16_OK;\n}\n\n// Checked no-alias softmax exp-phase helper for immutable-logit callers.\n// Phase performed here:\n//   1) exp_lanes_q16[i] = exp(preclamped_logits_q16[i])\n//   2) out_exp_sum_q16  = sum_i exp_lanes_q16[i] (checked I64 add)\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - preclamped_logits_q16 and exp_lanes_q16 must each address lane_count I64s\n//   - preclamped_logits_q16 and exp_lanes_q16 must be disjoint buffers\n// Notes:\n//   - This reuses shared checked span+sum logic from\n//     FPQ16SoftmaxExpPhaseFromPreclampedChecked so no-alias and alias-permitted\n//     callers stay bit-identical other than explicit alias rejection.\nI32 FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n                                                     I64 *exp_lanes_q16,\n                                                     I64 lane_count,\n                                                     I64 *out_exp_sum_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !out_exp_sum_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (preclamped_logits_q16 == exp_lanes_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Empty vectors are valid: no lanes, zero sum.\n    if (!lane_count)\n    {\n        *out_exp_sum_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Guard pointer-span arithmetic before any indexed access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)preclamped_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    status = FPQ16ExpArrayCheckedNoAliasChecked(preclamped_logits_q16,\n                                                exp_lanes_q16,\n                                                lane_count);\n    if (status)\n        return status;\n\n    exp_sum_q16 = 0;\n    for (i = 0; i < lane_count; i++)\n    {\n        if (exp_lanes_q16[i] > (I64_MAX_VALUE - exp_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        exp_sum_q16 += exp_lanes_q16[i];\n    }\n\n    *out_exp_sum_q16 = exp_sum_q16;\n    return FP_Q16_OK;\n}\n\n// Checked softmax split-phase normalization helper.\n// Phase performed here:\n//   1) probs_q16[i] = round_half_up(exp_lanes_q16[i] / exp_sum_q16)\n//   2) Deterministic remainder correction to force sum(probs_q16) == 1.0_q16\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - exp_sum_q16 must be strictly positive\n//   - Input/output buffers must each address lane_count I64s\n// Notes:\n//   - Uses FPQ16MulDivRoundedChecked with b=1.0_q16 to keep one-rounding,\n//     auditable fixed-point divide semantics.\n//   - Remainder correction is deterministic: positive remainder goes to the\n//     max-exp lane; negative remainder is removed in stable lane order\n//     (max lane first, then wrap) without allowing negative probabilities.\nI32 FPQ16SoftmaxNormalizePhaseChecked(I64 *exp_lanes_q16,\n                                      I64 lane_count,\n                                      I64 exp_sum_q16,\n                                      I64 *probs_q16)\n{\n    I64 i;\n    I64 pass;\n    I64 idx;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 prob_q16;\n    I64 prob_sum_q16;\n    I64 diff_q16;\n    I64 remaining_q16;\n    I64 take_q16;\n    I64 max_exp_q16;\n    I64 max_exp_index;\n    I32 status;\n\n    if (!exp_lanes_q16 || !probs_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (exp_sum_q16 <= 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic before indexed lane access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)probs_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Normalize lanes and keep running probability sum for remainder fixup.\n    max_exp_q16 = exp_lanes_q16[0];\n    max_exp_index = 0;\n    prob_sum_q16 = 0;\n\n    for (i = 0; i < lane_count; i++)\n    {\n        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[i],\n                                           FP_Q16_ONE,\n                                           exp_sum_q16,\n                                           &prob_q16);\n        if (status)\n            return status;\n\n        probs_q16[i] = prob_q16;\n\n        if (prob_q16 > (I64_MAX_VALUE - prob_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        prob_sum_q16 += prob_q16;\n\n        if (exp_lanes_q16[i] > max_exp_q16)\n        {\n            max_exp_q16 = exp_lanes_q16[i];\n            max_exp_index = i;\n        }\n    }\n\n    diff_q16 = FP_Q16_ONE - prob_sum_q16;\n    if (!diff_q16)\n        return FP_Q16_OK;\n\n    // If sum is low, add full residual to argmax lane.\n    if (diff_q16 > 0)\n    {\n        if (probs_q16[max_exp_index] > (I64_MAX_VALUE - diff_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        probs_q16[max_exp_index] += diff_q16;\n        return FP_Q16_OK;\n    }\n\n    // If sum is