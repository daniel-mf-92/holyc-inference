\n   535\t                {\n   536\t                    if (!Q8_0MatMulTryMulI64NonNeg(col_index, rhs_col_stride_blocks, &rhs_col_base))\n   537\t                        return Q8_0_MATMUL_ERR_OVERFLOW;\n   538\t                    status = Q8_0MatMulTiledComputeOutIndexChecked(out_row_base,\n   539\t                                                                   col_index,\n   540\t                                                                   &out_index);\n   541\t                    if (status != Q8_0_MATMUL_OK)\n   542\t                        return status;\n   543\t\n   544\t                    rhs_col_ptr = &rhs_col_blocks[rhs_col_base];\n   545\t                    status = Q8_0DotBlocksAVX2Q32Checked(lhs_row_ptr,\n   546\t                                                         rhs_col_ptr,\n   547\t                                                         k_block_count,\n   548\t                                                         &cell_dot_q32);\n   549\t                    if (status != Q8_0_MATMUL_OK)\n   550\t                        return status;\n   551\t\n   552\t                    out_cells_q32[out_index] = cell_dot_q32;\n   553\t                }\n   554\t            }\n   555\t\n   556\t            col_tile_start = col_tile_end;\n   557\t        }\n   558\t\n   559\t        row_tile_start = row_tile_end;\n   560\t    }\n   561\t\n   562\t    return Q8_0_MATMUL_OK;\n   563\t}\n   564\t\n   565\tI32 Q8_0MatMulQ16TiledAVX2Checked(\n   566\t    Q8_0Block *lhs_blocks,\n   567\t    I64 lhs_block_capacity,\n   568\t    I64 row_count,\n   569\t    I64 lhs_row_stride_blocks,\n   570\t    Q8_0Block *rhs_col_blocks,\n   571\t    I64 rhs_block_capacity,\n   572\t    I64 col_count,\n   573\t    I64 rhs_col_stride_blocks,\n   574\t    I64 k_block_count,\n   575\t    I64 tile_rows,\n   576\t    I64 tile_cols,\n   577\t    I64 *out_cells_q16,\n   578\t    I64 out_cell_capacity,\n   579\t    I64 out_row_stride_cells)\n   580\t{\n   581\t    I64 lhs_required_blocks;\n   582\t    I64 rhs_required_blocks;\n   583\t    I64 out_required_cells;\n   584\t    I64 row_tile_start;\n   585\t    I64 col_tile_start;\n   586\t    I64 row_tile_end;\n   587\t    I64 col_tile_end;\n   588\t    I64 row_index;\n   589\t    I64 col_index;\n   590\t    I64 lhs_row_base;\n   591\t    I64 rhs_col_base;\n   592\t    I64 out_row_base;\n   593\t    I64 out_index;\n   594\t    I64 cell_dot_q16;\n   595\t    Q8_0Block *lhs_row_ptr;\n   596\t    Q8_0Block *rhs_col_ptr;\n   597\t    I32 status;\n   598\t\n   599\t    status = Q8_0MatMulTiledValidateArgsChecked(lhs_blocks,\n   600\t                                                lhs_block_capacity,\n   601\t                                                row_count,\n   602\t                                                lhs_row_stride_blocks,\n   603\t                                                rhs_col_blocks,\n   604\t                                                rhs_block_capacity,\n   605\t                                                col_count,\n   606\t                                                rhs_col_stride_blocks,\n   607\t                                                k_block_count,\n   608\t                                                tile_rows,\n   609\t                                                tile_cols,\n   610\t                                                out_cells_q16,\n   611\t                                                out_cell_capacity,\n   612\t                                                out_row_stride_cells,\n   613\t                                                &lhs_required_blocks,\n   614\t                                                &rhs_required_blocks,\n   615\t                                                &out_required_cells);\n   616\t    if (status != Q8_0_MATMUL_OK)\n   617\t        return status;\n   618\t\n   619\t    // Tiled traversal mirrors Q32 AVX2 path but stores Q16 outputs.\n   620\t    // Each cell runs one che