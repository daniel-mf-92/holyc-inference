   42\t        return TRUE;\n    43\t    }\n    44\t\n    45\t    if (lhs > Q8_0_MATMUL_I64_MAX / rhs)\n    46\t        return FALSE;\n    47\t\n    48\t    *out_prod = lhs * rhs;\n    49\t    return TRUE;\n    50\t}\n    51\t\n    52\tBool Q8_0MatMulTryAddI64NonNeg(I64 lhs, I64 rhs, I64 *out_sum)\n    53\t{\n    54\t    if (!out_sum)\n    55\t        return FALSE;\n    56\t    if (lhs < 0 || rhs < 0)\n    57\t        return FALSE;\n    58\t    if (lhs > Q8_0_MATMUL_I64_MAX - rhs)\n    59\t        return FALSE;\n    60\t\n    61\t    *out_sum = lhs + rhs;\n    62\t    return TRUE;\n    63\t}\n    64\t\n    65\tI64 Q8_0MatMulMinI64(I64 lhs, I64 rhs)\n    66\t{\n    67\t    if (lhs < rhs)\n    68\t        return lhs;\n    69\t    return rhs;\n    70\t}\n    71\t\n    72\t// Shared checked tile-end math for tiled row/column traversals:\n    73\t//   tile_end = min(tile_start + tile_span, axis_len)\n    74\t// The helper keeps overflow and BAD_LEN behavior identical across\n    75\t// scalar Q16, AVX2 Q32, and AVX2 Q16 entrypoints.\n    76\tI32 Q8_0MatMulTiledComputeTileEndChecked(\n    77\t    I64 tile_start,\n    78\t    I64 tile_span,\n    79\t    I64 axis_len,\n    80\t    I64 *out_tile_end)\n    81\t{\n    82\t    I64 tile_end;\n    83\t\n    84\t    if (!out_tile_end)\n    85\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n    86\t    if (tile_start < 0 || tile_span < 0 || axis_len < 0)\n    87\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    88\t    if (tile_start > axis_len)\n    89\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    90\t\n    91\t    if (!Q8_0MatMulTryAddI64NonNeg(tile_start,\n    92\t                                   tile_span,\n    93\t                                   &tile_end))\n    94\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n    95\t\n    96\t    *out_tile_end = Q8_0MatMulMinI64(tile_end,\n    97\t                                     axis_len);\n    98\t    return Q8_0_MATMUL_OK;\n    99\t}\n   100\t\n   101\t// Shared tile-shape contract f