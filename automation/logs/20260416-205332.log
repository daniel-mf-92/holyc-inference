eg(col_index, rhs_col_stride_blocks, &rhs_col_base))\n   656\t                        return Q8_0_MATMUL_ERR_OVERFLOW;\n   657\t                    status = Q8_0MatMulTiledComputeOutIndexChecked(out_row_base,\n   658\t                                                                   col_index,\n   659\t                                                                   &out_index);\n   660\t                    if (status != Q8_0_MATMUL_OK)\n   661\t                        return status;\n   662\t\n   663\t                    rhs_col_ptr = &rhs_col_blocks[rhs_col_base];\n   664\t                    status = Q8_0DotBlocksAVX2Q32ToQ16Checked(lhs_row_ptr,\n   665\t                                                              rhs_col_ptr,\n   666\t                                                              k_block_count,\n   667\t                                                              &cell_dot_q16);\n   668\t                    if (status != Q8_0_MATMUL_OK)\n   669\t                        return status;\n   670\t\n   671\t                    out_cells_q16[out_index] = cell_dot_q16;\n   672\t                }\n   673\t            }\n   674\t\n   675\t            col_tile_start = col_tile_end;\n   676\t        }\n   677\t\n   678\t        row_tile_start = row_tile_end;\n   679\t    }\n   680\t\n   681\t    return Q8_0_MATMUL_OK;\n   682\t}\n","exit_code":0,"status":"completed"}}
