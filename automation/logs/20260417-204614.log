UFMetadataReadU64LECheckedNoPartial(buf,\n1931:    err = GGUFMetadataReadU64LECheckedNoPartial(buf,\n2083:I32 GGUFMetadataReadI32QuadChecked(U8 *buf,\n2156:    return GGUFMetadataReadI64LECheckedNoPartial(buf,\n2166:I32 GGUFMetadataReadI64LECheckedNoPartial(U8 *buf,\n2199:I32 GGUFMetadataReadI64PairCheckedNoPartial(U8 *buf,\n2219:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n2227:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n2244:I32 GGUFMetadataReadI64TripleCheckedNoPartial(U8 *buf,\n2266:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n2274:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n2282:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n2309:    return GGUFMetadataReadF32BitsLECheckedNoPartial(buf,\n2319:I32 GGUFMetadataReadF32BitsLECheckedNoPartial(U8 *buf,\n2456:I32 GGUFMetadataReadF32BitsQuadChecked(U8 *buf,\n2589:I32 GGUFMetadataReadF64BitsTripleChecked(U8 *buf,\n2777:I32 GGUFMetadataReadBoolQuadChecked(U8 *buf,\n---\n// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n#define GGUF_META_PARSE_ERR_NOT_FOUND 9\n#define GGUF_META_PARSE_ERR_TYPE_MISMATCH 10\n\n#define GGUF_META_TABLE_OK 0\n#define GGUF_META_TABLE_ERR_NULL_PTR 1\n#define GGUF_META_TABLE_ERR_BAD_PARAM 2\n#define GGUF_META_TABLE_ERR_OVERFLOW 3\n#define GGUF_META_TABLE_ERR_OUT_OF_BOUNDS 4\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor);\n\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value);\n\nI32 GGUFMetadataReadI8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              I8 *out_value);\n\nI32 GGUFMetadataReadI8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second);\n\nI32 GGUFMetadataReadI8TripleChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    I8 *out_first,\n                                    I8 *out_second,\n                                    I8 *out_third);\n\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second);\n\nI32 GGUFMetadataReadU8TripleChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    U8 *out_first,\n                                    U8 *out_second,\n                                    U8 *out_third);\n\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U16 *out_value);\n\nI32 GGUFMetadataReadU16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out_second);\n\nI32 GGUFMetadataReadU16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U16 *out_first,\n                                     U16 *out_second,\n                                     U16 *out_third);\n\nI32 GGUFMetadataReadU16QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out_second,\n                                   U16 *out_third,\n                                   U16 *out_fourth);\n\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value);\n\nI32 GGUFMetadataReadI16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second);\n\nI32 GGUFMetadataReadI16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     I16 *out_first,\n                                     I16 *out_second,\n                                     I16 *out_third);\n\nI32 GGUFMetadataReadI16QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second,\n                                   I16 *out_third,\n                                   I16 *out_fourth);\n\nI32 GGUFMetadataReadU32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U32 *out_value);\n\nI32 GGUFMetadataReadU32PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U6