_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\n\nI32 Q8_0MulI16LanesToI32PairsAVX2(I16 *lhs_i16,\n                                  I64 lhs_len,\n                                  I16 *rhs_i16,\n                                  I64 rhs_len,\n                                  I32 *dst_i32,\n                                  I64 dst_len)\n{\n    I64 pair_index;\n    I64 lane_base;\n    I32 product0;\n    I32 product1;\n\n    if (!lhs_i16 || !rhs_i16 || !dst_i32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (lhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Contract mirrors AVX2 `vpmaddwd` lane behavior used by quantized dot kernels:\n    // - Multiply lane pairs independently in signed 16-bit domain.\n    // - Accumulate each adjacent pair into one signed 32-bit output.\n    // - Preserve lane order so output pair k maps to input lanes [2k, 2k+1].\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        lane_base = pair_index << 1;\n\n        product0 = lhs_i16[lane_base] * rhs_i16[lane_base];\n        product1 = lhs_i16[lane_base + 1] * rhs_i16[lane_base + 1];\n\n        dst_i32[pair_index] = product0 + product1;\n    }\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0HSumI32PairsAVX2(I32 *pairs_i32,\n                         I64 pairs_len,\n                         I64 *out_sum_i64)\n{\n    I64 pair_index;\n    I64 running_sum;\n    I64 term;\n\n    if (!pairs_i32 || !out_sum_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n    if (pairs_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Horizontal reduction contract:\n    // - Sum all 16 pairwise I32 partial products into one signed I64 scalar.\n    // - Preserve deterministic lane order (0..15) for auditability parity\n    //   against the scalar reference path.\n    // - Explicit overflow checks keep reduction safe if this helper is reused\n    //   for wider accumulation streams in future kernels.\n    running_sum = 0;\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        term = (I64)pairs_i32[pair_index];\n\n        if (term > 0 && running_sum > Q8_0_AVX2_I64_MAX - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (term < 0 && running_sum < Q8_0_AVX2_I64_MIN - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n\n        running_sum += term;\n    }\n\n    *out_sum_i64 = running_sum;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotI16LanesAVX2(I16 *lhs_i16,\n                        I64 lhs_len,\n                        I16 *rhs_i16,\n                        I64 rhs_len,\n                        I64 *out_dot_i64)\n{\n    I32 pairs_i32[Q8_0_AVX2_PAIR_COUNT];\n    I64 dot_i64;\n    I32 status;\n\n    if (!lhs_i16 || !rhs_i16 || !out_dot_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    // Compose the lane-dot from the two audited AVX2-shape primitives:\n    // 1) `vpmaddwd`-equivalent pairwise multiply-add over 32 I16 lanes.\n    // 2) Horizontal sum over 16 I32 pair partials into one I64 scalar.\n    // Keeping this composition explicit preserves bit-level auditability while\n    // allowing future inline-asm replacement of each stage independently.\n    status = Q8_0MulI16LanesToI32PairsAVX2(lhs_i16,\n                                           lhs_len,\n                                           rhs_i16,\n                                           rhs_len,\n                                           pairs_i32,\n                                           Q8_0_AVX2_PAIR_COUNT);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    status = Q8_0HSumI32PairsAVX2(pairs_i32,\n                                  Q8_0_AVX2_PAIR_COUNT,\n                                  &dot_i64);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    *out_dot_i64 = dot_i64;\n    return Q8_0_AVX2_OK;\n}\n---\n        32767,\n        -30000,\n        29999,\n        -20000,\n        19999,\n        -16384,\n        16383,\n        -8192,\n        8191,\n        -4096,\n        4095,\n        -2048,\n        2047,\n        -1024,\n        1023,\n        -512,\n        511,\n        -255,\n        254,\n        -128,\n        127,\n        -64,\n        63,\n        -32,\n        31,\n        -16,\n        15,\n        -8,\n        7,\n        -2,\n        1,\n    ]\n    rhs = [\n        1,\n        -2,\n        7,\n        -8,\n        15,\n        -16,\n        31,\n        -32,\n        63,\n        -64,\n        127,\n        -128,\n        254,\n        -255,\n        511,\n        -512,\n        1023,\n        -1024,\n        2047,\n        -2048,\n        4095,\n        -4096,\n        8191,\n        -8192,\n        16383,\n        -16384,\n        19999,\n        -20000,\n        29999,\n        -30000,\n        32767,\n        -32768,\n    ]\n\n    err_pairs, pair_terms = q8_0_mul_i16_lanes_to_i32_pairs_avx2(lhs, rhs)\n    assert err_pairs == Q8_0_AVX2_OK\n\n    err_hsum, reduced = q8_0_hsum_i32_pairs_avx2(pair_terms)\n    assert err_hsum == Q8_0_AVX2_OK\n\n    err_dot, direct_dot = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n    assert err_dot == Q8_0_AVX2_OK\n\n    assert reduced == direct_dot\n    assert direct_dot == sum(int(a) * int(b) for a, b in zip(lhs, rhs))\n\n\ndef test_lane_order_mismatch_changes_dot_predictably() -> None:\n    # Dot helper must preserve lane order: rotating one side changes output.\n    lhs = list(range(-16, 16))\n    rhs = [v * 3 for v in range(-16, 16)]\n\n    err_base, base_dot = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n    assert err_base == Q8_0_AVX2_OK\n\n    rotated_rhs = rhs[1:] + rhs[:1]\n    err_rot, rot_dot = q8_0_dot_i16_lanes_avx2(lhs, rotated_rhs)\n    assert err_rot == Q8_0_AVX2_OK\n\n    assert base_dot == sum(int(a) * int(b) for a, b in zip(lhs, rhs))\n    assert rot_dot == sum(int(a) * int(b) for a, b in zip(lhs, rotated_rhs))\n    assert rot_dot != base_dot\n\n\ndef test_reduction_overflow_probe_path() -> None:\n    # Lane dot itself cannot overflow I64 with 16 I32 terms, but the reduction\n    # helper is designed for future wider streams and must keep guards correct.\n    probe = [0] * Q8_0_AVX2_PAIR_COUNT\n    probe[0] = Q8_0_AVX2_I64_MAX\n    probe[1] = 1\n\n    err, _ = q8_0_hsum_i32_pairs_avx2(probe)\n    assert err == Q8_0_AVX2_ERR_OVERFLOW\n\n    probe[0] = Q8_0_AVX2_I64_MIN\n    probe[1] = -1\n    err, _ = q8_0_hsum_i32_pairs_avx2(probe)\n    assert err == Q8_0_AVX2_ERR_OVERFLOW\n\n\ndef test_len_and_null_errors() -> None:\n    err, _ = q8_0_dot_i16_lanes_avx2(None, [0] * 32)\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n    err, _ = q8_0_dot_i16_lanes_avx2([0] * 32, None)\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n    err, _ = q8_0_dot_i16_lanes_avx2([0] * 31, [0] * 32)\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n    err, _ = q8_0_dot_i16_lanes_avx2([0] * 32, [0] * 31)\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n\ndef run() -> None:\n    test_known_signed_edge_contract()\n    test_randomized_matches_scalar_reference()\n    test_lane_order_invariant_pair_sensitivity()\n    test_pair_grouping_contract_matches_mul_then_hsum()\n    test_lane_order_mismatch_changes_dot_predictably()\n    test_reduction_overflow_probe_path()\n    test_len_and_null_errors()\n    print(\"q8_0_avx2_dot_lanes_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_18","type":"reasoning","text":"**Implementing IQ-106 Functionality**\n\nI need to implement the IQ-106 function in the file q8_0_avx2.HC. This might mean creating a new file or extending an existing one. I also want to inspect the current quantization in q8_0.HC/dot for scale conversion, especially looking for function names and constants related to q16 rounding that I can mimic. It might be useful to check out q8_0_dot.HC for any checked functions as well."}}
