{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/quant/q8_0_avx2.HC; echo '---'; sed -n '260,520p' src/quant/q8_0_avx2.HC; echo '---'; sed -n '1,260p' tests/test_q8_0_avx2_dot_lanes.py\"","aggregated_output":"// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n#define Q8_0_AVX2_PAIR_COUNT         16\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n#define Q8_0_AVX2_ERR_OVERFLOW       3\n\n#define Q8_0_AVX2_I64_MAX            0x7FFFFFFFFFFFFFFF\n#define Q8_0_AVX2_I64_MIN            (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nI32 Q8_0Pack32ToI16LanesAVX2(I8 *src_q8, I64 src_len, I16 *dst_i16, I64 dst_len)\n{\n    I64 lane;\n\n    if (!src_q8 || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (src_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Lane contract:\n    //   dst_i16[i] = SignExtend16(src_q8[i]) for i in [0, 31]\n    // This exact order matches the two AVX2 16-lane halves that would be\n    // produced by widening bytes 0..15 then 16..31.\n    for (lane = 0; lane < Q8_0_AVX2_VALUES_PER_BLOCK; ++lane)\n        dst_i16[lane] = (I16)src_q8[lane];\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0PackBlockToI16LanesAVX2(Q8_0Block *block, I16 *dst_i16, I64 dst_len)\n{\n    if (!block || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    return Q8_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\n\nI32 Q8_0MulI16LanesToI32PairsAVX2(I16 *lhs_i16,\n                                  I64 lhs_len,\n                                  I16 *rhs_i16,\n                                  I64 rhs_len,\n                                  I32 *dst_i32,\n                                  I64 dst_len)\n{\n    I64 pair_index;\n    I64 lane_base;\n    I32 product0;\n    I32 product1;\n\n    if (!lhs_i16 || !rhs_i16 || !dst_i32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (lhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Contract mirrors AVX2 `vpmaddwd` lane behavior used by quantized dot kernels:\n    // - Multiply lane pairs independently in signed 16-bit domain.\n    // - Accumulate each adjacent pair into one signed 32-bit output.\n    // - Preserve lane order so output pair k maps to input lanes [2k, 2k+1].\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        lane_base = pair_index << 1;\n\n        product0 = lhs_i16[lane_base] * rhs_i16[lane_base];\n        product1 = lhs_i16[lane_base + 1] * rhs_i16[lane_base + 1];\n\n        dst_i32[pair_index] = product0 + product1;\n    }\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0HSumI32PairsAVX2(I32 *pairs_i32,\n                         I64 pairs_len,\n                         I64 *out_sum_i64)\n{\n    I64 pair_index;\n    I64 running_sum;\n    I64 term;\n\n    if (!pairs_i32 || !out_sum_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n    if (pairs_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Horizontal reduction contract:\n    // - Sum all 16 pairwise I32 partial products into one signed I64 scalar.\n    // - Preserve deterministic lane order (0..15) for auditability parity\n    //   against the scalar reference path.\n    // - Explicit overflow checks keep reduction safe if this helper is reused\n    //   for wider accumulation streams in future kernels.\n    running_sum = 0;\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        term = (I64)pairs_i32[pair_index];\n\n        if (term > 0 && running_sum > Q8_0_AVX2_I64_MAX - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (term < 0 && running_sum < Q8_0_AVX2_I64_MIN - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n\n        running_sum += term;\n    }\n\n    *out_sum_i64 = running_sum;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotI16LanesAVX2(I16 *lhs_i16,\n                        I64 lhs_len,\n                        I16 *rhs_i16,\n                        I64 rhs_len,\n                        I64 *out_dot_i64)\n{\n    I32 pairs_i32[Q8_0_AVX2_PAIR_COUNT];\n    I64 dot_i64;\n    I32 status;\n\n    if (!lhs_i16 || !rhs_i16 || !out_dot_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    // Compose the lane-dot from the two audited AVX2-shape primitives:\n    // 1) `vpmaddwd`-equivalent pairwise multiply-add over 32 I16 lanes.\n    // 2) Horizontal sum over 16 I32 pair partials into one I64 scalar.\n    // Keeping this composition explicit preserves bit-level auditability while\n    // allowing future inline-asm replacement of each stage independently.\n    status = Q8_0MulI16LanesToI32PairsAVX2(lhs_i16,\n                                           lhs_len,\n                                           rhs_i16,\n                                           rhs_len,\n                                           pairs_i32,\n                                           Q8_0_AVX2_PAIR_COUNT);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    status = Q8_0HSumI32PairsAVX2(pairs_i32,\n                                  Q8_0_AVX2_PAIR_COUNT,\n                                  &dot_i64);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    *out_dot_i64 = dot_i64;\n    return Q8_0_AVX2_OK;\n}\n---\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0 AVX2-style composed 32-lane I16 dot helper.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nQ8_0_AVX2_VALUES_PER_BLOCK = 32\nQ8_0_AVX2_PAIR_COUNT = 16\n\nQ8_0_AVX2_OK = 0\nQ8_0_AVX2_ERR_NULL_PTR = 1\nQ8_0_AVX2_ERR_BAD_LEN = 2\nQ8_0_AVX2_ERR_OVERFLOW = 3\n\nQ8_0_AVX2_I64_MAX = (1 << 63) - 1\nQ8_0_AVX2_I64_MIN = -(1 << 63)\n\n\ndef q8_0_mul_i16_lanes_to_i32_pairs_avx2(lhs_i16, rhs_i16):\n    if lhs_i16 is None or rhs_i16 is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, []\n    if len(lhs_i16) < Q8_0_AVX2_VALUES_PER_BLOCK:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n    if len(rhs_i16) < Q8_0_AVX2_VALUES_PER_BLOCK:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n\n    out = [0] * Q8_0_AVX2_PAIR_COUNT\n    for pair_index in range(Q8_0_AVX2_PAIR_COUNT):\n        lane_base = pair_index * 2\n        out[pair_index] = (\n            int(lhs_i16[lane_base]) * int(rhs_i16[lane_base])\n            + int(lhs_i16[lane_base + 1]) * int(rhs_i16[lane_base + 1])\n        )\n    return Q8_0_AVX2_OK, out\n\n\ndef q8_0_hsum_i32_pairs_avx2(pairs_i32):\n    if pairs_i32 is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, 0\n    if len(pairs_i32) < Q8_0_AVX2_PAIR_COUNT:\n        return Q8_0_AVX2_ERR_BAD_LEN, 0\n\n    running_sum = 0\n    for pair_index in range(Q8_0_AVX2_PAIR_COUNT):\n        term = int(pairs_i32[pair_index])\n        if term > 0 and running_sum > Q8_0_AVX2_I64_MAX - term:\n            return Q8_0_AVX2_ERR_OVERFLOW, 0\n        if term < 0 and running_sum < Q8_0_AVX2_I64_MIN - term:\n            return Q8_0_AVX2_ERR_OVERFLOW, 0\n        running_sum += term\n    return Q8_0_AVX2_OK, running_sum\n\n\ndef q8_0_dot_i16_lanes_avx2(lhs_i16, rhs_i16):\n    if lhs_i16 is None or rhs_i16 is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, 0\n\n    err_pairs, pairs = q8_0_mul_i16_lanes_to_i32_pairs_avx2(lhs_i16, rhs_i16)\n    if err_pairs != Q8_0_AVX2_OK:\n        return err_pairs, 0\n\n    return q8_0_hsum_i32_pairs_avx2(pairs)\n\n\ndef test_known_signed_edge_contract() -> None:\n    lhs = [\n        -32768,\n        -30000,\n        -20000,\n        -16384,\n        -8192,\n        -4096,\n        -2048,\n        -1024,\n        -512,\n        -255,\n        -128,\n        -64,\n        -1,\n        0,\n        1,\n        2,\n        3,\n        7,\n        15,\n        31,\n        63,\n        127,\n        255,\n        511,\n        1023,\n        2047,\n        4095,\n        8191,\n        12000,\n        16384,\n        25000,\n        32767,\n    ]\n    rhs = list(reversed(lhs))\n\n    err, got = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n    assert err == Q8_0_AVX2_OK\n    assert got == sum(int(a) * int(b) for a, b in zip(lhs, rhs))\n\n\ndef test_randomized_matches_scalar_reference() -> None:\n    rng = random.Random(20260416)\n\n    for _ in range(4000):\n        lhs = [rng.randint(-32768, 32767) for _ in range(32)]\n        rhs = [rng.randint(-32768, 32767) for _ in range(32)]\n\n        err, got = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n        assert err == Q8_0_AVX2_OK\n        assert got == sum(int(a) * int(b) for a, b in zip(lhs, rhs))\n\n\ndef test_lane_order_invariant_pair_sensitivity() -> None:\n    lhs = [0] * 32\n    rhs = [0] * 32\n\n    lhs[6] = 1234\n    rhs[6] = -321\n\n    err, got = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n    assert err == Q8_0_AVX2_OK\n    assert got == -396114\n\n    # Move same magnitudes to adjacent lane: result should be identical scalar dot.\n    lhs2 = [0] * 32\n    rhs2 = [0] * 32\n    lhs2[7] = 1234\n    rhs2[7] = -321\n\n    err, got2 = q8_0_dot_i16_lanes_avx2(lhs2, rhs2)\n    assert err == Q8_0_AVX2_OK\n    assert got2 == -396114\n\n\ndef test_pair_grouping_contract_matches_mul_then_hsum() -> None:\n    # Adversarial signed edge pattern keeps every pair distinct so lane grouping\n    # bugs show up immediately (wrong lane stride/order changes pair sequence).\n    lhs = [\n        -32768,\n        32767,\n        -30000,\n        29999,\n        -20000,\n        19999,\n        -16384,\n        16383,\n        -8192,\n        8191,\n        -4096,\n        4095,\n        -2048,\n        2047,\n        -1024,\n        1023,\n        -512,\n        511,\n        -255,\n        254,\n        -128,\n        127,\n        -64,\n        63,\n        -32,\n        31,\n        -16,\n        15,\n        -8,\n        7,\n        -2,\n        1,\n    ]\n    rhs = [\n        1,\n        -2,\n        7,\n        -8,\n        15,\n        -16,\n        31,\n        -32,\n        63,\n        -64,\n        127,\n        -128,\n        254,\n        -255,\n        511,\n        -512,\n        1023,\n        -1024,\n        2047,\n        -2048,\n        4095,\n        -4096,\n        8191,\n        -8192,\n        16383,\n        -16384,\n        19999,\n        -20000,\n        29999,\n        -30000,\n        32767,\n        -32768,\n    ]\n\n    err_pairs, pair_terms = q8_0_mul_i16_lanes_to_i32_pairs_avx2(lhs, rhs)\n    assert err_pairs == Q8_0_AVX2_OK\n\n    err_hsum, reduced = q8_0_hsum_i32_pairs_avx2(pair_terms)\n    assert err_hsum == Q8_0_AVX2_OK\n\n    err_dot, direct_dot = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n    assert err_dot == Q8_0_AVX2_OK\n\n    assert reduced == direct_dot\n    assert direct_dot == sum(int(a) * int(b) for a, b in zip(lhs, rhs))\n\n\ndef test_lane_order_mismatch_changes_dot_predictably() -> None:\n    # Dot helper must preserve lane order: rotating one side changes output.\n    lhs = list(range(-16, 16))\n    rhs = [v * 3 for v in range(-16, 16)]\n\n    err_base, base_dot = q8_0_dot_i16_lanes_avx2(lhs, rhs)\n    assert err_base == Q8_0_AVX2_OK\n\n    rotated_rhs = rhs[1:] + rhs[:1]\n    err_rot, rot_dot = q8_0_dot_i16_lanes_avx2(lhs, rotated_rhs)\n    assert err_rot == Q8_0_AVX2_OK\n\n    assert base_dot == sum(int(a) * int(b) for a, b in zip(lhs, rhs))\n    assert rot_dot == sum(int(a) * int(b) for a, b in zip(lhs, rotated_rhs))\n    assert rot_dot != base_dot\n\n\ndef test_reduction_overflow_probe_path() -> None:\n    # Lane dot itself cannot overflow I64 with 16 I32 terms, but the reduction\n    # helper is designed for future wider streams and must keep guards correct.\n    probe = [0] * Q8_0_AVX2_PAIR_COUNT\n    probe[0] = Q8_0_AVX2_I64_MAX\n    probe[1] = 1\n\n    err, _ = q8_0_hsum_i32_pairs_avx2(probe)\n    assert err == Q8_0_AVX2_ERR_OVERFLOW\n\n    probe[0] = Q8_0_AVX2_I64_MIN\n    probe[1] = -1\n    err, _ = q8_0_hsum_i32_pairs_avx2(probe)\n    assert err == Q8_0_AVX2_ERR_OVERFLOW\n\n\ndef test_len_and_null_errors() -> None:\n","exit_code":0,"status":"completed"}}
