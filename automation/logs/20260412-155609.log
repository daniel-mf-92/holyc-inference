{"type":"item.completed","item":{"id":"item_29","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/quant/q4_0_q8_0_dot.HC | sed -n '1,220p'; echo '---'; nl -ba tests/test_q4_0_q8_0_dot_kernel.py | sed -n '1,260p'; echo '---'; rg -n \\\"IQ-030|loop-017\\\" MASTER_TASKS.md\"","aggregated_output":"     1\t// q4_0_q8_0_dot.HC\n     2\t// Naive integer-only mixed Q4_0 x Q8_0 dot kernels for TempleOS.\n     3\t//\n     4\t// Math:\n     5\t//   Q4_0 decode: x_i = d4 * (q4_i - 8)\n     6\t//   Q8_0 decode: y_i = d8 * q8_i\n     7\t//\n     8\t// Integer HolyC form:\n     9\t//   d4_q16   = Round(d4 * 2^16)\n    10\t//   d8_q16   = Round(d8 * 2^16)\n    11\t//   dot_q32  = Sum(x_q16 * y_q16)\n    12\t//            = (d4_q16 * d8_q16) * Sum(q4_signed_i * q8_signed_i)\n    13\t//\n    14\t// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n    15\t\n    16\t#define Q4_0_VALUES_PER_BLOCK 32\n    17\t#define Q4_0_PACKED_BYTES     16\n    18\t#define Q8_0_VALUES_PER_BLOCK 32\n    19\t#define Q8_0_PACKED_BYTES     32\n    20\t\n    21\t#define Q4_0_Q8_0_OK               0\n    22\t#define Q4_0_Q8_0_ERR_NULL_PTR     1\n    23\t#define Q4_0_Q8_0_ERR_BAD_DST_LEN  2\n    24\t\n    25\tclass Q4_0Block\n    26\t{\n    27\t    U16 d_fp16;\n    28\t    U8 qs[Q4_0_PACKED_BYTES];\n    29\t};\n    30\t\n    31\tclass Q8_0Block\n    32\t{\n    33\t    U16 d_fp16;\n    34\t    I8 qs[Q8_0_PACKED_BYTES];\n    35\t};\n    36\t\n    37\tI64 Q4_0_Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n    38\t{\n    39\t    I64 round_bias;\n    40\t\n    41\t    if (shift <= 0)\n    42\t        return value;\n    43\t\n    44\t    round_bias = 1 << (shift - 1);\n    45\t    return (value + round_bias) >> shift;\n    46\t}\n    47\t\n    48\tI64 Q4_0_Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n    49\t{\n    50\t    if (shift <= 0)\n    51\t        return value;\n    52\t\n    53\t    if (value >= 0)\n    54\t        return Q4_0_Q8_0RoundShiftRightUnsigned(value, shift);\n    55\t\n    56\t    return -Q4_0_Q8_0RoundShiftRightUnsigned(-value, shift);\n    57\t}\n    58\t\n    59\tI64 Q4_0_Q8_0F16ToQ16(U16 fp16_bits)\n    60\t{\n    61\t    I64 sign_bit;\n    62\t    I64 exponent_bits;\n    63\t    I64 fraction_bits;\n    64\t    I64 mantissa;\n    65\t    I64 shift_amount;\n    66\t    I64 magnitude_q16;\n    67\t\n    68\t    sign_bit = (fp16_bits >> 15) & 1;\n    69\t    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    70\t    fraction_bits = fp16_bits & 0x03FF;\n    71\t\n    72\t    if (!exponent_bits)\n    73\t    {\n    74\t        if (!fraction_bits)\n    75\t            return 0;\n    76\t\n    77\t        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n    78\t        if (sign_bit)\n    79\t            return -magnitude_q16;\n    80\t        return magnitude_q16;\n    81\t    }\n    82\t\n    83\t    if (exponent_bits == 0x1F)\n    84\t    {\n    85\t        if (sign_bit)\n    86\t            return -0x3FFFFFFFFFFFFFFF;\n    87\t        return 0x3FFFFFFFFFFFFFFF;\n    88\t    }\n    89\t\n    90\t    mantissa = 1024 + fraction_bits;\n    91\t    shift_amount = exponent_bits - 9;\n    92\t\n    93\t    if (shift_amount >= 0)\n    94\t        magnitude_q16 = mantissa << shift_amount;\n    95\t    else\n    96\t        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n    97\t\n    98\t    if (sign_bit)\n    99\t        return -magnitude_q16;\n   100\t    return magnitude_q16;\n   101\t}\n   102\t\n   103\tI64 Q4_0_Q8_0NibbleToSigned(U8 packed, Bool upper_nibble)\n   104\t{\n   105\t    I64 q_unsigned;\n   106\t\n   107\t    if (upper_nibble)\n   108\t        q_unsigned = (packed >> 4) & 0x0F;\n   109\t    else\n   110\t        q_unsigned = packed & 0x0F;\n   111\t\n   112\t    return q_unsigned - 8;\n   113\t}\n   114\t\n   115\tI32 Q4_0_Q8_0DotProductBlockQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 *out_dot_q32)\n   116\t{\n   117\t    I64 lhs_scale_q16;\n   118\t    I64 rhs_scale_q16;\n   119\t    I64 scale_prod_q32;\n   120\t    I64 byte_index;\n   121\t    I64 q_dot_q0;\n   122\t    U8 packed_q4;\n   123\t\n   124\t    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n   125\t        return Q4_0_Q8_0_ERR_NULL_PTR;\n   126\t\n   127\t    lhs_scale_q16 = Q4_0_Q8_0F16ToQ16(lhs_q4->d_fp16);\n   128\t    rhs_scale_q16 = Q4_0_Q8_0F16ToQ16(rhs_q8->d_fp16);\n   129\t    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n   130\t\n   131\t    // q_dot_q0 = Sum(q4_signed_i * q8_signed_i).\n   132\t    // Q4 stores two values per byte, so map each nibble to one Q8 lane.\n   133\t    q_dot_q0 = 0;\n   134\t    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n   135\t    {\n   136\t        packed_q4 = lhs_q4->qs[byte_index];\n   137\t\n   138\t        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, FALSE) * rhs_q8->qs[(byte_index << 1)];\n   139\t        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, TRUE) * rhs_q8->qs[(byte_index << 1) + 1];\n   140\t    }\n   141\t\n   142\t    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n   143\t    return Q4_0_Q8_0_OK;\n   144\t}\n   145\t\n   146\tI32 Q4_0_Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n   147\t{\n   148\t    I64 block_index;\n   149\t    I64 block_dot_q32;\n   150\t    I64 total_dot_q32;\n   151\t    I32 status;\n   152\t\n   153\t    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n   154\t        return Q4_0_Q8_0_ERR_NULL_PTR;\n   155\t    if (block_count < 0)\n   156\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n   157\t\n   158\t    total_dot_q32 = 0;\n   159\t    for (block_index = 0; block_index < block_count; ++block_index)\n   160\t    {\n   161\t        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n   162\t        if (status != Q4_0_Q8_0_OK)\n   163\t            return status;\n   164\t\n   165\t        total_dot_q32 += block_dot_q32;\n   166\t    }\n   167\t\n   168\t    *out_dot_q32 = total_dot_q32;\n   169\t    return Q4_0_Q8_0_OK;\n   170\t}\n   171\t\n   172\tI64 Q4_0_Q8_0DotQ32ToQ16(I64 dot_q32)\n   173\t{\n   174\t    return Q4_0_Q8_0RoundShiftRightSigned(dot_q32, 16);\n   175\t}\n---\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for integer mixed Q4_0 x Q8_0 dot-product semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\timport struct\n     8\t\n     9\tQ4_0_PACKED_BYTES = 16\n    10\tQ8_0_PACKED_BYTES = 32\n    11\t\n    12\tQ4_0_Q8_0_OK = 0\n    13\tQ4_0_Q8_0_ERR_NULL_PTR = 1\n    14\tQ4_0_Q8_0_ERR_BAD_DST_LEN = 2\n    15\t\n    16\t\n    17\tdef round_shift_right_unsigned(value: int, shift: int) -> int:\n    18\t    if shift <= 0:\n    19\t        return value\n    20\t    round_bias = 1 << (shift - 1)\n    21\t    return (value + round_bias) >> shift\n    22\t\n    23\t\n    24\tdef round_shift_right_signed(value: int, shift: int) -> int:\n    25\t    if shift <= 0:\n    26\t        return value\n    27\t    if value >= 0:\n    28\t        return round_shift_right_unsigned(value, shift)\n    29\t    return -round_shift_right_unsigned(-value, shift)\n    30\t\n    31\t\n    32\tdef f16_to_q16(fp16_bits: int) -> int:\n    33\t    sign_bit = (fp16_bits >> 15) & 1\n    34\t    exponent_bits = (fp16_bits >> 10) & 0x1F\n    35\t    fraction_bits = fp16_bits & 0x03FF\n    36\t\n    37\t    if exponent_bits == 0:\n    38\t        if fraction_bits == 0:\n    39\t            return 0\n    40\t        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n    41\t        return -magnitude_q16 if sign_bit else magnitude_q16\n    42\t\n    43\t    if exponent_bits == 0x1F:\n    44\t        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n    45\t\n    46\t    mantissa = 1024 + fraction_bits\n    47\t    shift_amount = exponent_bits - 9\n    48\t    if shift_amount >= 0:\n    49\t        magnitude_q16 = mantissa << shift_amount\n    50\t    else:\n    51\t        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n    52\t\n    53\t    return -magnitude_q16 if sign_bit else magnitude_q16\n    54\t\n    55\t\n    56\tdef half_bits(value: float) -> int:\n    57\t    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n    58\t\n    59\t\n    60\tdef nibble_to_signed(packed: int, upper_nibble: bool) -> int:\n    61\t    if upper_nibble:\n    62\t        q_unsigned = (packed >> 4) & 0x0F\n    63\t    else:\n    64\t        q_unsigned = packed & 0x0F\n    65\t    return q_unsigned - 8\n    66\t\n    67\t\n    68\tdef unpack_q4_signed(qs: bytes) -> list[int]:\n    69\t    out: list[int] = []\n    70\t    for packed in qs:\n    71\t        out.append(nibble_to_signed(packed, False))\n    72\t        out.append(nibble_to_signed(packed, True))\n    73\t    return out\n    74\t\n    75\t\n    76\tdef unpack_q8_signed(qs: bytes) -> list[int]:\n    77\t    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n    78\t\n    79\t\n    80\tdef pack_q4_from_signed(vals: list[int]) -> bytes:\n    81\t    assert len(vals) == 32\n    82\t    out = bytearray()\n    83\t    for idx in range(0, 32, 2):\n    84\t        lo = vals[idx] + 8\n    85\t        hi = vals[idx + 1] + 8\n    86\t        assert 0 <= lo <= 15 and 0 <= hi <= 15\n    87\t        out.append((lo & 0x0F) | ((hi & 0x0F) << 4))\n    88\t    return bytes(out)\n    89\t\n    90\t\n    91\tdef pack_q8_signed(vals: list[int]) -> bytes:\n    92\t    assert len(vals) == 32\n    93\t    return bytes((v + 256) % 256 for v in vals)\n    94\t\n    95\t\n    96\tdef dot_product_block_q32(lhs_scale_fp16: int, lhs_q4: bytes, rhs_scale_fp16: int, rhs_q8: bytes) -> tuple[int, int]:\n    97\t    if len(lhs_q4) != Q4_0_PACKED_BYTES or len(rhs_q8) != Q8_0_PACKED_BYTES:\n    98\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n    99\t\n   100\t    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   101\t    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n   102\t    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16\n   103\t\n   104\t    lhs_signed = unpack_q4_signed(lhs_q4)\n   105\t    rhs_signed = unpack_q8_signed(rhs_q8)\n   106\t    q_dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n   107\t    return Q4_0_Q8_0_OK, scale_prod_q32 * q_dot_q0\n   108\t\n   109\t\n   110\tdef dot_product_blocks_q32(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n   111\t    if len(lhs_blocks) != len(rhs_blocks):\n   112\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n   113\t\n   114\t    total = 0\n   115\t    for (l_scale, l_q4), (r_scale, r_q8) in zip(lhs_blocks, rhs_blocks):\n   116\t        err, block_dot = dot_product_block_q32(l_scale, l_q4, r_scale, r_q8)\n   117\t        if err != Q4_0_Q8_0_OK:\n   118\t            return err, 0\n   119\t        total += block_dot\n   120\t\n   121\t    return Q4_0_Q8_0_OK, total\n   122\t\n   123\t\n   124\tdef dot_q32_to_q16(dot_q32: int) -> int:\n   125\t    return round_shift_right_signed(dot_q32, 16)\n   126\t\n   127\t\n   128\tdef test_identity_mixed_block() -> None:\n   129\t    lhs_scale_fp16 = half_bits(1.0)\n   130\t    rhs_scale_fp16 = half_bits(1.0)\n   131\t\n   132\t    q4_signed = [((idx % 16) - 8) for idx in range(32)]\n   133\t    q8_signed = q4_signed[:]\n   134\t\n   135\t    lhs_q4 = pack_q4_from_signed(q4_signed)\n   136\t    rhs_q8 = pack_q8_signed(q8_signed)\n   137\t\n   138\t    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n   139\t    assert err == Q4_0_Q8_0_OK\n   140\t\n   141\t    expected_q0 = sum(v * v for v in q4_signed)\n   142\t    expected_q32 = (1 << 16) * (1 << 16) * expected_q0\n   143\t    assert got_q32 == expected_q32\n   144\t    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n   145\t\n   146\t\n   147\tdef test_random_blocks_match_integer_reference() -> None:\n   148\t    rng = random.Random(20260412)\n   149\t\n   150\t    for _ in range(500):\n   151\t        lhs_scale = rng.uniform(-4.0, 4.0)\n   152\t        rhs_scale = rng.uniform(-4.0, 4.0)\n   153\t\n   154\t        lhs_scale_fp16 = half_bits(lhs_scale)\n   155\t        rhs_scale_fp16 = half_bits(rhs_scale)\n   156\t\n   157\t        q4_signed = [rng.randrange(-8, 8) for _ in range(32)]\n   158\t        q8_signed = [rng.randrange(-128, 128) for _ in range(32)]\n   159\t\n   160\t        lhs_q4 = pack_q4_from_signed(q4_signed)\n   161\t        rhs_q8 = pack_q8_signed(q8_signed)\n   162\t\n   163\t        err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n   164\t        assert err == Q4_0_Q8_0_OK\n   165\t\n   166\t        expected_q0 = sum(a * b for a, b in zip(q4_signed, q8_signed))\n   167\t        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   168\t        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n   169\t        expected_q32 = lhs_scale_q16 * rhs_scale_q16 * expected_q0\n   170\t        assert got_q32 == expected_q32\n   171\t\n   172\t        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n   173\t        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n   174\t        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * expected_q0 * (1 << 32))\n   175\t\n   176\t        # Integer path rounds scales once to Q16 then multiplies.\n   177\t        assert abs(got_q32 - expected_float_q32) <= 70_000_000\n   178\t\n   179\t\n   180\tdef test_multiblock_accumulation() -> None:\n   181\t    b0 = (half_bits(0.75), pack_q4_from_signed([((i % 8) - 4) for i in range(32)]))\n   182\t    b1 = (half_bits(-0.5), pack_q4_from_signed([4 - (i % 8) for i in range(32)]))\n   183\t\n   184\t    r0 = (half_bits(1.25), pack_q8_signed([((i % 11) - 5) * 3 for i in range(32)]))\n   185\t    r1 = (half_bits(-1.5), pack_q8_signed([7 - (i % 13) for i in range(32)]))\n   186\t\n   187\t    err, total = dot_product_blocks_q32([b0, b1], [r0, r1])\n   188\t    assert err == Q4_0_Q8_0_OK\n   189\t\n   190\t    _, part0 = dot_product_block_q32(*b0, *r0)\n   191\t    _, part1 = dot_product_block_q32(*b1, *r1)\n   192\t    assert total == part0 + part1\n   193\t\n   194\t\n   195\tdef test_error_on_bad_lengths() -> None:\n   196\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 15, half_bits(1.0), b\"\\x00\" * 32)\n   197\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   198\t\n   199\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 16, half_bits(1.0), b\"\\x00\" * 31)\n   200\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   201\t\n   202\t\n   203\tdef run() -> None:\n   204\t    test_identity_mixed_block()\n   205\t    test_random_blocks_match_integer_reference()\n   206\t    test_multiblock_accumulation()\n   207\t    test_error_on_bad_lengths()\n   208\t    print(\"q4_0_q8_0_dot_kernel_reference_checks=ok\")\n   209\t\n   210\t\n   211\tif __name__ == \"__main__\":\n   212\t    run()\n---\n218:- [x] IQ-030 Implement mixed Q4_0 x Q8_0 dot product kernel in `src/quant/q4_0_q8_0_dot.HC` (WS3-05)\n243:| 2026-04-12 | loop-017 | IQ-030 Q4_0 x Q8_0 mixed dot | done | Added `src/quant/q4_0_q8_0_dot.HC` mixed integer dot kernels; validated with `python3 tests/test_q4_0_q8_0_dot_kernel.py && python3 tests/test_q4_0_dot.py && python3 tests/test_q8_0_dot.py` (`q4_0_q8_0_dot_kernel_reference_checks=ok`, `q4_0_dot_reference_checks=ok`, `q8_0_dot_reference_checks=ok`) |\n","exit_code":0,"status":"completed"}}
