_start, abs_end = tensor_index_to_abs_range(\n            original_idx,\n            starts,\n            ends,\n            inverse_map,\n        )\n        assert err == GGUF_TDBASE_OK\n        sorted_pos = inverse_map[original_idx]\n        assert abs_start == starts[sorted_pos]\n        assert abs_end == ends[sorted_pos]\n\n\ndef test_tensor_index_to_abs_range_random_permutations() -> None:\n    rng = random.Random(764141)\n\n    for _ in range(400):\n        count = rng.randint(1, 24)\n        starts: list[int] = []\n        ends: list[int] = []\n\n        cursor = rng.randint(0, 32) * 32\n        for _ in range(count):\n            cursor += rng.randint(0, 3) * 32\n            span = max(32, rng.randint(1, 8) * 32)\n            starts.append(cursor)\n            ends.append(cursor + span)\n            cursor += span\n\n        sorted_idx = list(range(count))\n        rng.shuffle(sorted_idx)\n        inverse_map = [0] * count\n\n        err, bad = build_tensor_sorted_position_map(sorted_idx, inverse_map)\n        assert err == GGUF_TDBASE_OK\n        assert bad == 0\n\n        for original_idx in range(count):\n            err, abs_start, abs_end = tensor_index_to_abs_range(\n                original_idx,\n                starts,\n                ends,\n                inverse_map,\n            )\n            assert err == GGUF_TDBASE_OK\n            sorted_pos = inverse_map[original_idx]\n            assert abs_start == starts[sorted_pos]\n            assert abs_end == ends[sorted_pos]\n\n\ndef test_tensor_index_to_abs_range_random_adversarial() -> None:\n    rng = random.Random(764151)\n\n    for _ in range(320):\n        count = rng.randint(2, 24)\n        starts: list[int] = []\n        ends: list[int] = []\n\n        cursor = rng.randint(0, 32) * 32\n        for _ in range(count):\n            cursor += rng.randint(0, 2) * 32\n            span = max(32, rng.randint(1, 7) * 32)\n            starts.append(cursor)\n            ends.append(cursor + span)\n            cursor += span\n\n        sorted_idx = list(range(count))\n        rng.shuffle(sorted_idx)\n        inverse_map = [0] * count\n\n        err, bad = build_tensor_sorted_position_map(sorted_idx, inverse_map)\n        assert err == GGUF_TDBASE_OK\n        assert bad == 0\n\n        case = rng.randint(0, 2)\n        if case == 0:\n            bad_tensor = rng.randint(0, count - 1)\n            inverse_map[bad_tensor] = count + rng.randint(0, 7)\n            err, abs_start, abs_end = tensor_index_to_abs_range(\n                bad_tensor,\n                starts,\n                ends,\n                inverse_map,\n            )\n            assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n            assert abs_start == 0\n            assert abs_end == 0\n        elif case == 1:\n            bad_pos = rng.randint(0, count - 1)\n            starts[bad_pos] = ends[bad_pos] + rng.randint(1, 32)\n            orig = sorted_idx[bad_pos]\n            err, abs_start, abs_end = tensor_index_to_abs_range(\n                orig,\n                starts,\n                ends,\n                inverse_map,\n            )\n            assert err == GGUF_TDBASE_ERR_OVERFLOW\n            assert abs_start == 0\n            assert abs_end == 0\n        else:\n            bad_tensor = count + rng.randint(0, 5)\n            err, abs_start, abs_end = tensor_index_to_abs_range(\n                bad_tensor,\n                starts,\n                ends,\n                inverse_map,\n            )\n            assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n            assert abs_start == 0\n            assert abs_end == 0\n\n\n'''\nif insert_tests_after not in s:\n    raise SystemExit('test insertion anchor not found')\ns = s.replace(insert_tests_after, new_tests, 1)\n\nrun_anchor = '''    test_validate_sorted_position_map_with_built_index()\n    test_validate_sorted_position_map_random_permutations()\n    test_validate_sorted_position_map_random_adversarial()\n    print(\\\"gguf_tensor_data_base_reference_checks=ok\\\")\n'''\nrun_new = '''    test_validate_sorted_position_map_with_built_index()\n    test_validate_sorted_position_map_random_permutations()\n    test_validate_sorted_position_map_random_adversarial()\n    test_tensor_index_to_abs_range_happy_path()\n    test_tensor_index_to_abs_range_rejects_bad_lengths()\n    test_tensor_index_to_abs_range_rejects_out_of_bounds_index()\n    test_tensor_index_to_abs_range_rejects_bad_inverse_map_slot()\n    test_tensor_index_to_abs_range_rejects_malformed_range()\n    test_tensor_index_to_abs_range_with_built_offset_index()\n    test_tensor_index_to_abs_range_random_permutations()\n    test_tensor_index_to_abs_range_random_adversarial()\n    print(\\\"gguf_tensor_data_base_reference_checks=ok\\\")\n'''\nif run_anchor not in s:\n    raise SystemExit('run anchor not found')\ns = s.replace(run_anchor, run_new, 1)\n\np.write_text(s)\nprint('updated', p)\nPY\"","aggregated_output":"test insertion anchor not found\n","exit_code":1,"status":"failed"}}
