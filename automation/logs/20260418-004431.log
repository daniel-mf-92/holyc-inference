l while preserving explicit no-partial commit semantics.\n    err = GGUFMetadataReadU32QuadChecked(buf,\n                                         buf_nbytes,\n                                         &cur,\n                                         table_end,\n                                         &first,\n                                         &second,\n                                         &third,\n                                         &fourth);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *out_fourth = fourth;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Canonical default-end wrapper for fixed-layout U32-quad metadata records.\n// Contract: preserves exact checked U32-quad semantics by pinning table_end to\n// buf_nbytes and delegating to GGUFMetadataReadU32QuadChecked.\nI32 GGUFMetadataReadU32QuadCheckedDefault(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U32 *out_first,\n                                          U32 *out_second,\n                                          U32 *out_third,\n                                          U32 *out_fourth)\n{\n    return GGUFMetadataReadU32QuadChecked(buf,\n                                          buf_nbytes,\n                                          cursor,\n                                          buf_nbytes,\n                                          out_first,\n                                          out_second,\n                                          out_third,\n                                          out_fourth);\n}\n\n// Checked little-endian U64 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *