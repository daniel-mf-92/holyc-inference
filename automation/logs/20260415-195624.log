        U64 *out_abs_end,\n  1832\t                                         U64 *out_offset_in_tensor)\n  1833\t{\n  1834\t    U64 abs_offset;\n  1835\t    I64 err;\n  1836\t\n  1837\t    if (!out_offset_in_tensor || !out_abs_start || !out_abs_end)\n  1838\t        return GGUF_TDBASE_ERR_NULL_PTR;\n  1839\t\n  1840\t    // Keep deterministic outputs for parser/runtime callers on every failure.\n  1841\t    *out_abs_start = 0;\n  1842\t    *out_abs_end = 0;\n  1843\t    *out_offset_in_tensor = 0;\n  1844\t\n  1845\t    // Translate relative payload offset with explicit GGUF alignment checks.\n  1846\t    err = GGUFTensorDataBaseOffset(tensor_data_base,\n  1847\t                                   tensor_rel_offset,\n  1848\t                                   alignment,\n  1849\t                                   &abs_offset);\n  1850\t    if (err != GGUF_TDBASE_OK)\n  1851\t        return err;\n  1852\t\n  1853\t    // Reuse checked index+absolute helper to keep tensor-index table\n  1854\t    // validation and [start,end) containment semantics centralized.\n  1855\t    return GGUFTensorLookupByIndexWithInnerOffset(tensor_index,\n  1856\t                                                  abs_offset,\n  1857\t                                                  tensor_count,\n  1858\t                                                  tensor_abs_starts,\n  1859\t                                                  tensor_abs_ends,\n  1860\t                                                  sorted_position_by_tensor,\n  1861\t                                                  out_abs_start,\n  1862\t                                                  out_abs_end,\n  1863\t                                                  out_offset_in_tensor);\n  1864\t}\n  1865\t\n  1866\tI64 GGUFTensorLookupSpanByAbsRange(U64 span_abs_start,\n  1867\t                                   U64 span_abs_end,\n  1868\t                                   U64 tensor_count,\n  1869\t                                   U64 *tensor_abs_starts,\n  1870\t                                   U64 *tensor_abs_ends,\n  1871\t                                   U64 *sorted_tensor_indices,\n  1872\t                                   U64 *out_tensor_index,\n  1873\t                                   U64 *out_tensor_abs_start,\n  1874\t                                   U64 *out_tensor_abs_end,\n  1875\t                                   U64 *out_span_start_in_tensor,\n  1876\t                                   U64 *out_span_end_in_tensor)\n  1877\t{\n  1878\t    U64 tensor_index;\n  1879\t    U64 tensor_abs_start;\n  1880\t    U64 tensor_abs_end;\n  1881\t    I64 err;\n  1882\t\n  1883\t    if (!out_tensor_index || !out_tensor_abs_start || !out_tensor_abs_end ||\n  1884\t        !out_span_start_in_tensor || !out_span_end_in_tensor)\n  1885\t        return GGUF_TDBASE_ERR_NULL_PTR;\n  1886\t\n  1887\t    // Deterministic outputs for all failure paths.\n  1888\t    *out_tensor_index = 0;\n  1889\t    *out_tensor_abs_start = 0;\n  1890\t    *out_tensor_abs_end = 0;\n  1891\t    *out_span_start_in_tensor = 0;\n  1892\t    *out_span_end_in_tensor = 0;\n  1893\t\n  1894\t    // Half-open ranges require end >= start; treat underflowed caller windows\n  1895\t    // as malformed arithmetic from upstream size/offset math.\n  1896\t    if (span_abs_end < span_abs_start)\n  1897\t        return GGUF_TDBASE_ERR_OVERFLOW;\n  1898\t\n  1899\t    // Resolve the window start into a containing tensor span.\n  1900\t    err = GGUFTensorLookupByAbsOffset(span_abs_start,\n  1901\t                                      tensor_count,\n  1902\t                                      tensor_abs_starts,\n  1903\t                                      tensor_abs_ends,\n  1904\t                                      sorted_tensor_indices,\n  1905\t                                      &tensor_index,\n  1906\t                                      &tensor_abs_start,\n  1907\t                                      &tensor_abs_end);\n  1908\t    if (err != GGUF_TDBASE_OK)\n  1909\t        return err;\n  1910\t\n  1911\t    // Entire caller window must remain inside the same tensor payload.\n  1912\t    if (span_abs_end > tensor_abs_end)\n  1913\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1914\t\n  1915\t    *out_tensor_index = tensor_index;\n  1916\t    *out_tensor_abs_start = tensor_abs_start;\n  1917\t    *out_tensor_abs_end = tensor_abs_end;\n  1918\t    *out_span_start_in_tensor = span_abs_start - tensor_abs_start;\n  1919\t    *out_span_end_in_tensor = span_abs_end - tensor_abs_start;\n  1920\t    return GGUF_TDBASE_OK;\n  1921\t}\n  1922\t\n  1923\tI64 GGUFTensorLookupSpanByRelRange(U64 span_rel_start,\n  1924\t                                   U64 span_rel_end,\n  1925\t                                   U64 tensor_data_base,\n  1926\t                                   U32 alignment,\n  1927\t                                   U64 tensor_count,\n  1928\t                                   U64 *tensor_abs_starts,\n  1929\t                                   U64 *tensor_abs_ends,\n  1930\t                                   U64 *sorted_tensor_indices,\n  1931\t                                   U64 *out_tensor_index,\n  1932\t                                   U64 *out_tensor_abs_start,\n  1933\t                                   U64 *out_tensor_abs_end,\n  1934\t                                   U64 *out_span_start_in_tensor,\n  1935\t                                   U64 *out_span_end_in_tensor)\n  1936\t{\n  1937\t    U64 span_abs_start;\n  1938\t    U64 span_abs_end;\n  1939\t    I64 err;\n  1940\t\n  1941\t    if (!out_tensor_index || !out_tensor_abs_start || !out_tensor_abs_end ||\n  1942\t        !out_span_start_in_tensor || !out_span_end_in_tensor)\n  1943\t        return GGUF_TDBASE_ERR_NULL_PTR;\n  1944\t\n  1945\t    // Deterministic outputs for all failure paths.\n  1946\t    *out_tensor_index = 0;\n  1947\t    *out_tensor_abs_start = 0;\n  1948\t    *out_tensor_abs_end = 0;\n  1949\t    *out_span_start_in_tensor = 0;\n  1950\t    *out_span_end_in_tensor = 0;\n  1951\t\n  1952\t    // Keep half-open range arithmetic explicit in relative space before\n  1953\t    // translating to absolute offsets. This catches underflow windows early.\n  1954\t    if (span_rel_end < span_rel_start)\n  1955\t        return GGUF_TDBASE_ERR_OVERFLOW;\n  1956\t\n  1957\t    // Translate relative range boundaries to absolute file offsets with\n  1958\t    // GGUF alignment checks and overflow guards.\n  1959\t    err = GGUFTensorDataBaseOffset(tensor_data_base,\n  1960\t                                   span_rel_start,\n  1961\t                                   alignment,\n  1962\t                                   &span_abs_start);\n  1963\t    if (err != GGUF_TDBASE_OK)\n  1964\t        return err;\n  1965\t\n  1966\t    err = GGUFTensorDataBaseOffset(tensor_data_base,\n  1967\t                                   span_rel_end,\n  1968\t                                   alignment,\n  1969\t                                   &span_abs_end);\n  1970\t    if (err != GGUF_TDBASE_OK)\n  1971\t        return err;\n  1972\t\n  1973\t    // Reuse checked absolute-range resolver so window containment and\n  1974\t    // in-tensor span math stay centralized and consistent.\n  1975\t    return GGUFTensorLookupSpanByAbsRange(span_abs_start,\n  1976\t                                          span_abs_end,\n  1977\t                                          tensor_count,\n  1978\t                                          tensor_abs_starts,\n  1979\t                                          tensor_abs_ends,\n  1980\t                                          sorted_tensor_indices,\n  1981\t                                          out_tensor_index,\n  1982\t                                          out_tensor_abs_start,\n  1983\t                                          out_tensor_abs_end,\n  1984\t                                          out_span_start