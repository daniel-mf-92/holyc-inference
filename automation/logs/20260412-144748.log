{"type":"item.started","item":{"id":"item_13","type":"command_execution","command":"/bin/zsh -lc 'apply_patch \"*** Begin Patch\n*** Add File: src/math/intsqrt.HC\n+// intsqrt.HC\n+// Integer square-root helpers for Q16.16 fixed-point inference math.\n+\n+#define FP_Q16_SHIFT 16\n+#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n+\n+U64 IntSqrtU64(U64 x)\n+{\n+    U64 res;\n+    U64 bit;\n+\n+    res = 0;\n+    bit = 1 << 62;\n+\n+    while (bit > x)\n+        bit >>= 2;\n+\n+    while (bit)\n+    {\n+        if (x >= res + bit)\n+        {\n+            x -= res + bit;\n+            res = (res >> 1) + bit;\n+        }\n+        else\n+            res >>= 1;\n+\n+        bit >>= 2;\n+    }\n+\n+    return res;\n+}\n+\n+I64 FPQ16Sqrt(I64 x)\n+{\n+    U64 shifted;\n+\n+    if (x <= 0)\n+        return 0;\n+\n+    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n+        shifted = I64_MAX_VALUE;\n+    else\n+        shifted = ((U64)x) << FP_Q16_SHIFT;\n+\n+    return IntSqrtU64(shifted);\n+}\n*** End Patch\"'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
