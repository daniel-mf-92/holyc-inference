{"type":"item.started","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport math, random\n\nFP_Q16_SHIFT = 16\nI64_MAX_VALUE = 0x7FFFFFFFFFFFFFFF\n\ndef int_sqrt_u64(x: int) -> int:\n    res = 0\n    bit = 1 << 62\n    while bit > x:\n        bit >>= 2\n    while bit:\n        if x >= res + bit:\n            x -= res + bit\n            res = (res >> 1) + bit\n        else:\n            res >>= 1\n        bit >>= 2\n    return res\n\ndef fp_q16_sqrt(x: int) -> int:\n    if x <= 0:\n        return 0\n    if x > (I64_MAX_VALUE >> FP_Q16_SHIFT):\n        shifted = I64_MAX_VALUE\n    else:\n        shifted = x << FP_Q16_SHIFT\n    return int_sqrt_u64(shifted)\n\n# Exactness checks for integer sqrt\nfor n in [0, 1, 2, 3, 4, 15, 16, 17, 10**6, (1<<63)-1]:\n    got = int_sqrt_u64(n)\n    exp = math.isqrt(n)\n    assert got == exp, (n, got, exp)\n\n# Random checks for Q16 sqrt approximation quality\nmax_abs_err = 0.0\nmax_rel_err = 0.0\nfor _ in range(5000):\n    real = random.uniform(0.0, 1024.0)\n    x_q16 = int(round(real * (1 << FP_Q16_SHIFT)))\n    y_q16 = fp_q16_sqrt(x_q16)\n    got = y_q16 / float(1 << FP_Q16_SHIFT)\n    exp = math.sqrt(real)\n    abs_err = abs(got - exp)\n    rel_err = abs_err / exp if exp > 1e-12 else 0.0\n    max_abs_err = max(max_abs_err, abs_err)\n    max_rel_err = max(max_rel_err, rel_err)\n\nprint(f\\\"intsqrt_exact_checks=ok\\\")\nprint(f\\\"fpq16_sqrt_random_samples=5000 max_abs_err={max_abs_err:.8f} max_rel_err={max_rel_err:.6%}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
