3\tBool GGUFTensorReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n   114\t{\n   115\t    I64 c;\n   116\t\n   117\t    if (!cursor || !out)\n   118\t        return FALSE;\n   119\t\n   120\t    c = *cursor;\n   121\t    if (!GGUFTensorCanRead(buf, size, c, 8))\n   122\t        return FALSE;\n   123\t\n   124\t    *out = (U64)buf[c]\n   125\t         | ((U64)buf[c + 1] << 8)\n   126\t         | ((U64)buf[c + 2] << 16)\n   127\t         | ((U64)buf[c + 3] << 24)\n   128\t         | ((U64)buf[c + 4] << 32)\n   129\t         | ((U64)buf[c + 5] << 40)\n   130\t         | ((U64)buf[c + 6] << 48)\n   131\t         | ((U64)buf[c + 7] << 56);\n   132\t\n   133\t    *cursor = c + 8;\n   134\t    return TRUE;\n   135\t}\n   136\t\n   137\tBool GGUFTensorTypeKnown(U32 t)\n   138\t{\n   139\t    switch (t)\n   140\t    {\n   141\t        case GGML_TYPE_F32:\n   142\t        case GGML_TYPE_F16:\n   143\t        case GGML_TYPE_Q4_0:\n   144\t        case GGML_TYPE_Q4_1:\n   145\t        case GGML_TYPE_Q5_0:\n   146\t        case GGML_TYPE_Q5_1:\n   147\t        case GGML_TYPE_Q8_0:\n   148\t        case GGML_TYPE_Q8_1:\n   149\t        case GGML_TYPE_Q2_K:\n   150\t        case GGML_TYPE_Q3_K:\n   151\t        case GGML_TYPE_Q4_K:\n   152\t        case GGML_TYPE_Q5_K:\n   153\t        case GGML_TYPE_Q6_K:\n   154\t        case GGML_TYPE_Q8_K:\n   155\t        case GGML_TYPE_IQ2_XXS:\n   156\t        case GGML_TYPE_IQ2_XS:\n   157\t        case GGML_TYPE_IQ3_XXS:\n   158\t        case GGML_TYPE_IQ1_S:\n   159\t        case GGML_TYPE_IQ4_NL:\n   160\t        case GGML_TYPE_IQ3_S:\n   161\t        case GGML_TYPE_IQ2_S:\n   162\t        case GGML_TYPE_IQ4_XS:\n   163\t        case GGML_TYPE_I8:\n   164\t        case GGML_TYPE_I16:\n   165\t        case GGML_TYPE_I32:\n   166\t        case GGML_TYPE_I64:\n   167\t        case GGML_TYPE_F64:\n   168\t        case GGML_TYPE_IQ1_M:\n   169\t        case GGML_TYPE_BF16:\n   170\t        case GGML_TYPE_Q4_0_4_4:\n   171\t        case GGML_TYPE_Q4_0_4_8:\n   172\t        case GGML_TYPE_Q4_0_8_8:\n   173\t        case GGML_TYPE_TQ1_0:\n   174\t        case GGML_TYPE_TQ2_0:\n   175\t            return TRUE;\n   176\t    }\n   177\t\n   178\t    return FALSE;\n   179\t}\n   180\t\n   181\tU0 GGUFTensorZeroString(GGUFTensorString *s)\n   182\t{\n   183\t    if (!s)\n   184\t        return;\n   185\t    s->len = 0;\n   186\t    s->data = NULL;\n   187\t}\n   188\t\n   189\tU0 GGUFTensorZeroInfo(GGUFTensorInfo *ti)\n   190\t{\n   191\t    I64 i;\n   192\t\n   193\t    if (!ti)\n   194\t        return;\n   195\t\n   196\t    GGUFTensorZeroString(&ti->name);\n   197\t    ti->n_dims = 0;\n   198\t    for (i = 0; i < GGUF_TENSOR_MAX_DIMS; ++i)\n   199\t        ti->dims[i] = 0;\n   200\t    ti->n_elements = 0;\n   201\t    ti->ggml_type = 0;\n   202\t    ti->offset = 0;\n   203\t}\n   204\t\n   205\tU0 GGUFTensorFreeString(GGUFTensorString *s)\n   206\t{\n   207\t    if (!s)\n   208\t        return;\n   209\t\n   210\t    if (s->data)\n   211\t        Free(s->data);\n   212\t\n   213\t    s->data = NULL;\n   214\t    s->len = 0;\n   215\t}\n   216\t\n   217\tU0 GGUFFreeTensorTable(GGUFTensorTable *table)\n   218\t{\n   219\t    U64 i;\n   220\t\n   221\t    if (!table)\n   222\t        return;\n   223\t\n   224\t    if (!table->items)\n   225\t    {\n   226\t        table->count = 0;\n   227\t        return;\n   228\t    }\n   229\t\n   230\t    for (i = 0; i < table->count; ++i)\n   231\t        GGUFTensorFreeString(&table->items[i].name);\n   232\t\n   233\t    Free(table->items);\n   234\t    table->items = NULL;\n   235\t    table->count = 0;\n   236\t}\n   237\t\n   238\tI64 GGUFTensorReadString(U8 *buf, I64 size, I64 *cursor, GGUFTensorString *out)\n   239\t{\n   240\t    U64 len;\n   241\t    I64 c;\n   242\t    U8 *dst;\n   243\t    I64 i;\n   244\t\n   245\t    if (!cursor || !out)\n   246\t        return GGUF_TENSOR_PARSE_ERR_NULL_PTR;\n   247\t\n   248\t    GGUFTensorZeroString(out);\n   249\t\n   250\t    if (!GGUFTensorReadU64LE(buf, size, cursor, &len))\n   251\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n   252\t    if (len > GGUF_TENSOR_MAX_NAME_BYTES)\n   253\t        return GGUF_TENSOR_PARSE_ERR_BAD_NAME_LEN;\n   254\t\n   255\t    c = *cursor;\n   256\t    if (!GGUFTensorCanRead(buf, size, c, len))\n   257\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n   258\t\n   259\t    dst = MAlloc(len + 1);\n   260\t    if (!dst)\n   260\t    if (!dst)\n   261\t        return GGUF_TENSOR_PARSE_ERR_ALLOC;\n   262\t\n   263\t    for (i = 0; i < len; ++i)\n   264\t        dst[i] = buf[c + i];\n   265\t    dst[len] = 0;\n   266\t\n   267\t    *cursor = c + len;\n   268\t\n   269\t    out->len = len;\n   270\t    out->data = dst;\n   271\t    return GGUF_TENSOR_PARSE_OK;\n   272\t}\n   273\t\n   274\tI64 GGUFTensorParseOne(U8 *buf, I64 size, I64 *cursor, GGUFTensorInfo *out)\n   275\t{\n   276\t    U32 n_dims;\n   277\t    U64 dim;\n   278\t    U64 prod;\n   279\t    U32 ggml_type;\n   280\t    U64 offset;\n   281\t    I64 err;\n   282\t    U32 i;\n   283\t\n   284\t    if (!cursor || !out)\n   285\t        return GGUF_TENSOR_PARSE_ERR_NULL_PTR;\n   286\t\n   287\t    GGUFTensorZeroInfo(out);\n   288\t\n   289\t    err = GGUFTensorReadString(buf, size, cursor, &out->name);\n   290\t    if (err != GGUF_TENSOR_PARSE_OK)\n   291\t        return err;\n   292\t\n   293\t    if (!GGUFTensorReadU32LE(buf, size, cursor, &n_dims))\n   294\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n   295\t    if (!n_dims || n_dims > GGUF_TENSOR_MAX_DIMS)\n   296\t        return GGUF_TENSOR_PARSE_ERR_BAD_DIMS;\n   297\t\n   298\t    // The tensor element count is the exact product of dims. Keep this explicit\n   299\t    // and overflow-checked so later offset math is auditable and safe.\n   300\t    prod = 1;\n   301\t    for (i = 0; i < n_dims; ++i)\n   302\t    {\n   303\t        if (!GGUFTensorReadU64LE(buf, size, cursor, &dim))\n   304\t            return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n   305\t        if (!dim)\n   306\t            return GGUF_TENSOR_PARSE_ERR_BAD_DIM_SIZE;\n   307\t        if (prod > 0xFFFFFFFFFFFFFFFF / dim)\n   308\t            return GGUF_TENSOR_PARSE_ERR_DIM_OVERFLOW;\n   309\t\n   310\t        out->dims[i] = dim;\n   311\t        prod *= dim;\n   312\t    }\n   313\t\n   314\t    if (!GGUFTensorReadU32LE(buf, size, cursor, &ggml_type))\n   315\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n   316\t    if (!GGUFTensorTypeKnown(ggml_type))\n   317\t        return GGUF_TENSOR_PARSE_ERR_BAD_TYPE;\n   318\t\n   319\t    if (!GGUFTensorReadU64LE(buf, size, cursor, &offset))\n   320\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n   321\t\n   322\t    out->n_dims = n_dims;\n   323\t    out->n_elements = prod;\n   324\t    out->ggml_type = ggml_type;\n   325\t    out->offset = offset;\n   326\t\n   327\t    return GGUF_TENSOR_PARSE_OK;\n   328\t}\n   329\t\n   330\tI64 GGUFParseTensorInfo(U8 *buf,\n   331\t                        I64 size,\n   332\t                        U64 tensor_count,\n   333\t                        GGUFTensorTable *out,\n   334\t                        I64 *cursor)\n   335\t{\n   336\t    GGUFTensorInfo *items;\n   337\t    U64 i;\n   338\t    I64 err;\n   339\t\n   340\t    if (!buf || !out || !cursor)\n   341\t        return GGUF_TENSOR_PARSE_ERR_NULL_PTR;\n   342\t    if (!tensor_count || tensor_count > GGUF_TENSOR_MAX_COUNT)\n   343\t        return GGUF_TENSOR_PARSE_ERR_BAD_COUNT;\n   344\t\n   345\t    out->count = 0;\n   346\t    out->items = NULL;\n   347\t\n   348\t    items = MAlloc(sizeof(GGUFTensorInfo) * tensor_count);\n   349\t    if (!items)\n   350\t        return GGUF_TENSOR_PARSE_ERR_ALLOC;\n   351\t\n   352\t    for (i = 0; i < tensor_count; ++i)\n   353\t        GGUFTensorZeroInfo(&items[i]);\n   354\t\n   355\t    out->items = items;\n   356\t\n   357\t    for (i = 0; i < tensor_count; ++i)\n   358\t    {\n   359\t        err = GGUFTensorParseOne(buf, size, cursor, &items[i]);\n   360\t        if (err != GGUF_TENSOR_PARSE_OK)\n   361\t        {\n   362\t            out->count = tensor_count;\n   363\t            GGUFFreeTensorTable(out);\n   364\t            return err;\n   365\t        }\n   366\t    }\n   367\t\n   368\t    out->count = tensor_count;\n   369\t    return GGUF_TENSOR_PARSE_OK;\n   370\t}\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for GGUF tensor-info parsing semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport struct\n     7\t\n     8\tGGUF_TENSOR_PARSE_OK = 0\n     9\tGGUF_TENSOR_PARSE_ERR_NULL_PTR = 1\n    10\tGGUF_TENSOR_PARSE_ERR_TRUNCATED = 2\n    11\tGGUF_TENSOR_PARSE_ERR_BAD_COUNT = 3\n    12\tGGUF_TENSOR_PARSE_ERR_BAD_NAME_LEN = 4\n    13\tGGUF_TENSOR_PARSE_ERR_BAD_DIMS = 5\n    14\tGGUF_TENSOR_PARSE_ERR_BAD_DIM_SIZE = 6\n    15\tGGUF_TENSOR_PARSE_ERR_DIM_OVERFLOW = 7\n    16\tGGUF_TENSOR_PARSE_ERR_BAD_TYPE = 8\n    17\t\n    18\tGGUF_TENSOR_MAX_DIMS = 8\n    19\tU64_MAX = (1 << 64) - 1\n    20\t\n    21\tKNOWN_TYPES = {\n    22\t    0,\n    23\t    1,\n    24\t    2,\n    25\t    3,\n    26\t    6,\n    27\t    7,\n    28\t    8,\n    29\t    9,\n    30\t    10,\n    31\t    11,\n    32\t    12,\n    33\t    13,\n    34\t    14,\n    35\t    15,\n    36\t    16,\n    37\t    17,\n    38\t    18,\n    39\t    19,\n    40\t    20,\n    41\t    21,\n    42\t    22,\n    43\t    23,\n    44\t    24,\n    45\t    25,\n    46\t    26,\n    47\t    27,\n    48\t    28,\n    49\t    29,\n    50\t    30,\n    51\t    31,\n    52\t    32,\n    53\t    33,\n    54\t    34,\n    55\t    35,\n    56\t}\n    57\t\n    58\t\n    59\tdef u32(v: int) -> bytes:\n    60\t    return struct.pack(\"<I\", v)\n    61\t\n    62\t\n    63\tdef u64(v: int) -> bytes:\n    64\t    return struct.pack(\"<Q\", v)\n    65\t\n    66\t\n    67\tdef gguf_string(s: str) -> bytes:\n    68\t    raw = s.encode(\"utf-8\")\n    69\t    return u64(len(raw)) + raw\n    70\t\n    71\t\n    72\tdef tensor_entry(name: str, dims: list[int], ggml_type: int, offset: int) -> bytes:\n    73\t    payload = [gguf_string(name), u32(len(dims))]\n    74\t    payload.extend(u64(d) for d in dims)\n    75\t    payload.extend([u32(ggml_type), u64(offset)])\n    76\t    return b\"\".join(payload)\n    77\t\n    78\t\n    79\tdef parse_one(buf: bytes, cursor: int):\n    80\t    if cursor + 8 > len(buf):\n    81\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED, cursor, None\n    82\t    (name_len,) = struct.unpack_from(\"<Q\", buf, cursor)\n    83\t    cursor += 8\n    84\t\n    85\t    if cursor + name_len > len(buf):\n    86\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED, cursor, None\n    87\t    name = buf[cursor : cursor + name_len].decode(\"utf-8\")\n    88\t    cursor += name_len\n    89\t\n    90\t    if cursor + 4 > len(buf):\n    91\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED, cursor, None\n    92\t    (n_dims,) = struct.unpack_from(\"<I\", buf, cursor)\n    93\t    cursor += 4\n    94\t\n    95\t    if n_dims == 0 or n_dims > GGUF_TENSOR_MAX_DIMS:\n    96\t        return GGUF_TENSOR_PARSE_ERR_BAD_DIMS, cursor, None\n    97\t\n    98\t    dims: list[int] = []\n    99\t    n_elements = 1\n   100\t    for _ in range(n_dims):\n   101\t        if cursor + 8 > len(buf):\n   102\t            return GGUF_TENSOR_PARSE_ERR_TRUNCATED, cursor, None\n   103\t        (dim,) = struct.unpack_from(\"<Q\", buf, cursor)\n   104\t        cursor += 8\n   105\t        if dim == 0:\n   106\t            return GGUF_TENSOR_PARSE_ERR_BAD_DIM_SIZE, cursor, None\n   107\t        if n_elements > U64_MAX // dim:\n   108\t            return GGUF_TENSOR_PARSE_ERR_DIM_OVERFLOW, cursor, None\n   109\t\n   110\t        dims.append(dim)\n   111\t        n_elements *= dim\n   112\t\n   113\t    if cursor + 4 > len(buf):\n   114\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED, cursor, None\n   115\t    (ggml_type,) = struct.unpack_from(\"<I\", buf, cursor)\n   116\t    cursor += 4\n   117\t    if ggml_type not in KNOWN_TYPES:\n   118\t        return GGUF_TENSOR_PARSE_ERR_BAD_TYPE, cursor, None\n   119\t\n   120\t    if cursor + 8 > len(buf):\n   121\t        return GGUF_TENSOR_PARSE_ERR_TRUNCATED, cursor, None\n   122\t    (offset,) = struct.unpack_from(\"<Q\", buf, cursor)\n   123\t    cursor += 8\n   124\t\n   125\t    return (\n   126\t        GGUF_TENSOR_PARSE_OK,\n   127\t        cursor,\n   128\t        {\n   129\t            \"name\": name,\n   130\t            \"n_dims\": n_dims,\n   131\t            \"dims\": dims,\n   132\t            \"n_elements\": n_elements,\n   133\t            \"ggml_type\": ggml_type,\n   134\t            \"offset\": offset,\n   135\t        },\n   136\t    )\n   137\t\n   138\t\n   139\tdef parse_table(buf: bytes, count: int):\n   140\t    if count <= 0:\n   141\t        return GGUF_TENSOR_PARSE_ERR_BAD_COUNT, 0, []\n   142\t\n   143\t    cursor = 0\n   144\t    items = []\n   145\t    for _ in range(count):\n   146\t        err, cursor, item = parse_one(buf, cursor)\n   147\t        if err != GGUF_TENSOR_PARSE_OK:\n   148\t            return err, cursor, items\n   149\t        items.append(item)\n   150\t\n   151\t    return GGUF_TENSOR_PARSE_OK, cursor, items\n   152\t\n   153\t\n   154\tdef test_tensor_table_success() -> None:\n   155\t    buf = b\"\".join(\n   156\t        [\n   157\t            tensor_entry(\"token_embd.weight\", [32000, 2048], 2, 0),\n   158\t            tensor_entry(\"blk.0.attn_q.weight\", [2048, 2048], 8, 917504),\n   159\t        ]\n   160\t    )\n   161\t\n   162\t    err, cursor, items = parse_table(buf, 2)\n   163\t    assert err == GGUF_TENSOR_PARSE_OK\n   164\t    assert cursor == len(buf)\n   165\t    assert len(items) == 2\n   166\t    assert items[0][\"name\"] == \"token_embd.weight\"\n   167\t    assert items[0][\"n_elements\"] == 32000 * 2048\n   168\t    assert items[1][\"ggml_type\"] == 8\n   169\t\n   170\t\n   171\tdef test_reject_bad_dims_count() -> None:\n   172\t    bad = gguf_string(\"bad\") + u32(0)\n   173\t    err, _cursor, _items = parse_table(bad, 1)\n   174\t    assert err == GGUF_TENSOR_PARSE_ERR_BAD_DIMS\n   175\t\n   176\t\n   177\tdef test_reject_dim_overflow() -> None:\n   178\t    huge = tensor_entry(\"overflow\", [1 << 63, 3], 2, 0)\n   179\t    err, _cursor, _items = parse_table(huge, 1)\n   180\t    assert err == GGUF_TENSOR_PARSE_ERR_DIM_OVERFLOW\n   181\t\n   182\t\n   183\tdef test_reject_unknown_type() -> None:\n   184\t    bad_type = tensor_entry(\"type.bad\", [64, 64], 999, 0)\n   185\t    err, _cursor, _items = parse_table(bad_type, 1)\n   186\t    assert err == GGUF_TENSOR_PARSE_ERR_BAD_TYPE\n   187\t\n   188\t\n   189\tdef test_truncation_detected() -> None:\n   190\t    trunc = tensor_entry(\"trunc\", [128, 128], 2, 17)[:-5]\n   191\t    err, _cursor, _items = parse_table(trunc, 1)\n   192\t    assert err == GGUF_TENSOR_PARSE_ERR_TRUNCATED\n   193\t\n   194\t\n   195\tdef run() -> None:\n   196\t    test_tensor_table_success()\n   197\t    test_reject_bad_dims_count()\n   198\t    test_reject_dim_overflow()\n   199\t    test_reject_unknown_type()\n   200\t    test_truncation_detected()\n   201\t    print(\"gguf_tensorinfo_reference_checks=ok\")\n   202\t\n   203\t\n   204\tif __name__ == \"__main__\":\n   205\t    run()\n   176\t- [x] IQ-004 Write LLaMA architecture reference doc at `docs/LLAMA_ARCH.md` (WS0-04)\n   177\t- [x] IQ-005 Implement fixed-point multiply/divide helpers in `src/math/fixedpoint.HC` (WS1-01)\n   178\t- [x] IQ-006 Implement integer exp approximation in `src/math/intexp.HC` (WS1-02)\n   179\t- [x] IQ-007 Implement integer sqrt approximation in `src/math/intsqrt.HC` (WS1-02)\n   180\t- [x] IQ-008 Implement integer softmax in `src/math/softmax.HC` (WS1-03)\n   181\t- [x] IQ-009 Implement RMSNorm (integer path) in `src/math/rmsnorm.HC` (WS1-04)\n   182\t- [x] IQ-010 Implement GGUF magic/version/header parser in `src/gguf/header.HC` (WS2-01)\n   183\t- [x] IQ-011 Implement GGUF metadata