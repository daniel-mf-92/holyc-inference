{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"ls -R src; sed -n '1,260p' src/gguf/header.HC; sed -n '1,340p' src/gguf/metadata.HC\"","aggregated_output":"gguf\nmath\n\nsrc/gguf:\nheader.HC\nmetadata.HC\n\nsrc/math:\nfixedpoint.HC\nintexp.HC\nintsqrt.HC\nrmsnorm.HC\nsoftmax.HC\n// header.HC\n// GGUF header parser for HolyC inference runtime.\n\n#define GGUF_MAGIC_U32 0x46554747\n#define GGUF_VERSION_V2 2\n#define GGUF_VERSION_V3 3\n\n#define GGUF_PARSE_OK 0\n#define GGUF_PARSE_ERR_NULL_PTR 1\n#define GGUF_PARSE_ERR_TRUNCATED 2\n#define GGUF_PARSE_ERR_BAD_MAGIC 3\n#define GGUF_PARSE_ERR_BAD_VERSION 4\n#define GGUF_PARSE_ERR_BAD_COUNT 5\n\nclass GGUFHeader\n{\n    U32 magic;\n    U32 version;\n    U64 tensor_count;\n    U64 metadata_kv_count;\n};\n\nBool GGUFCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n{\n    if (!buf)\n        return FALSE;\n    if (size < 0 || cursor < 0 || need < 0)\n        return FALSE;\n    if (cursor > size)\n        return FALSE;\n    if (need > size - cursor)\n        return FALSE;\n    return TRUE;\n}\n\nBool GGUFReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nI64 GGUFParseHeader(U8 *buf, I64 size, GGUFHeader *out, I64 *cursor)\n{\n    I64 c;\n    U32 magic;\n    U32 version;\n    U64 tensor_count;\n    U64 metadata_kv_count;\n\n    if (!buf || !out || !cursor)\n        return GGUF_PARSE_ERR_NULL_PTR;\n\n    c = *cursor;\n\n    if (!GGUFReadU32LE(buf, size, &c, &magic))\n        return GGUF_PARSE_ERR_TRUNCATED;\n    if (magic != GGUF_MAGIC_U32)\n        return GGUF_PARSE_ERR_BAD_MAGIC;\n\n    if (!GGUFReadU32LE(buf, size, &c, &version))\n        return GGUF_PARSE_ERR_TRUNCATED;\n    if (version != GGUF_VERSION_V2 && version != GGUF_VERSION_V3)\n        return GGUF_PARSE_ERR_BAD_VERSION;\n\n    if (!GGUFReadU64LE(buf, size, &c, &tensor_count))\n        return GGUF_PARSE_ERR_TRUNCATED;\n    if (!GGUFReadU64LE(buf, size, &c, &metadata_kv_count))\n        return GGUF_PARSE_ERR_TRUNCATED;\n\n    if (!tensor_count)\n        return GGUF_PARSE_ERR_BAD_COUNT;\n\n    out->magic = magic;\n    out->version = version;\n    out->tensor_count = tensor_count;\n    out->metadata_kv_count = metadata_kv_count;\n\n    *cursor = c;\n    return GGUF_PARSE_OK;\n}\n// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nBool GGUFMetaCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n{\n    if (!buf)\n        return FALSE;\n    if (size < 0 || cursor < 0 || need < 0)\n        return FALSE;\n    if (cursor > size)\n        return FALSE;\n    if (need > size - cursor)\n        return FALSE;\n    return TRUE;\n}\n\nBool GGUFMetaReadU8(U8 *buf, I64 size, I64 *cursor, U8 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 1))\n        return FALSE;\n\n    *out = buf[c];\n    *cursor = c + 1;\n    return TRUE;\n}\n\nBool GGUFMetaReadU16LE(U8 *buf, I64 size, I64 *cursor, U16 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 2))\n        return FALSE;\n\n    *out = (U16)buf[c]\n         | ((U16)buf[c + 1] << 8);\n\n    *cursor = c + 2;\n    return TRUE;\n}\n\nBool GGUFMetaReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFMetaReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nBool GGUFMetaTypeSupported(U32 type)\n{\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n        case GGUF_TYPE_BOOL:\n        case GGUF_TYPE_STRING:\n        case GGUF_TYPE_ARRAY:\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            return TRUE;\n    }\n\n    return FALSE;\n}\n\nU0 GGUFMetaZeroString(GGUFString *s)\n{\n    if (!s)\n        return;\n    s->len = 0;\n    s->data = NULL;\n}\n\nU0 GGUFMetaZeroValue(GGUFMetaValue *v)\n{\n    if (!v)\n        return;\n\n    v->type = 0;\n    v->u64 = 0;\n    v->i64 = 0;\n    v->b = FALSE;\n    GGUFMetaZeroString(&v->str);\n    v->array_elem_type = 0;\n    v->array_len = 0;\n    v->array_payload_off = 0;\n    v->array_payload_bytes = 0;\n}\n\nU0 GGUFMetaZeroKV(GGUFMetadataKV *kv)\n{\n    if (!kv)\n        return;\n    GGUFMetaZeroString(&kv->key);\n    GGUFMetaZeroValue(&kv->value);\n}\n\nU0 GGUFMetaFreeString(GGUFString *s)\n{\n    if (!s)\n        return;\n\n    if (s->data)\n        Free(s->data);\n\n    s->data = NULL;\n    s->len = 0;\n}\n\nI64 GGUFMetaReadString(U8 *buf, I64 size, I64 *cursor, GGUFString *out)\n{\n    U64 len;\n    I64 c;\n    U8 *dst;\n    I64 i;\n\n    if (!cursor || !out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    GGUFMetaZeroString(out);\n\n    if (!GGUFMetaReadU64LE(buf, size, cursor, &len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (len > GGUF_MAX_STRING_BYTES)\n        return GGUF_META_PARSE_ERR_BAD_STRING_LEN;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n\n    dst = MAlloc(len + 1);\n    if (!dst)\n        return GGUF_META_PARSE_ERR_ALLOC;\n\n    for (i = 0; i < len; ++i)\n        dst[i] = buf[c + i];\n    dst[len] = 0;\n\n    *cursor = c + len;\n\n    out->len = len;\n    out->data = dst;\n    return GGUF_META_PARSE_OK;\n}\n\nI64 GGUFMetaSkipValueByType(U8 *buf, I64 size, I64 *cursor, U32 type)\n{\n    U8 u8v;\n    U16 u16v;\n    U32 u32v;\n    U64 u64v;\n    U32 elem_type;\n    U64 elem_count;\n    U64 i;\n    I64 err;\n\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_BOOL:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_STRING:\n            {\n                GGUFString tmp;\n\n                err = GGUFMetaReadString(buf, size, cursor, &tmp);\n                if (err != GGUF_META_PARSE_OK)\n                    return err;\n                GGUFMetaFreeString(&tmp);\n                return GGUF_META_PARSE_OK;\n            }\n\n        case GGUF_TYPE_ARRAY:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            if (elem_type == GGUF_TYPE_ARRAY)\n                return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n            if (!GGUFMetaTypeSupported(elem_type))\n                return GGUF_META_PARSE_ERR_BAD_TYPE;\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n                return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n\n            for (i = 0; i < elem_count; ++i)\n            {\n                err = GGUFMetaSkipValueByType(buf, size, cursor, elem_type);\n                if (err != GGUF_META_PARSE_OK)\n                    return err;\n            }\n\n            return GGUF_META_PARSE_OK;\n    }\n\n    return GGUF_META_PARSE_ERR_BAD_TYPE;\n}\n","exit_code":0,"status":"completed"}}
