uf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    Bool *out_first,\n                                    Bool *out_second);\n\nI32 GGUFMetadataReadStringLenU64Checked(U8 *buf,\n                                        U64 buf_nbytes,\n                                        U64 *cursor,\n                                        U64 table_end,\n                                        U64 *out_len);\n\nI32 GGUFMetadataReadStringU64HeaderAndBoundsChecked(U8 *buf,\n                                                    U64 buf_nbytes,\n                                                    U64 *cursor,\n                                                    U64 table_end,\n                                                    U64 *out_len,\n                                                    U64 *out_payload_end);\n\nI32 GGUFMetadataReadStringBytesChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U64 str_len,\n                                       U8 *out_bytes,\n                                       U64 out_nbytes);\n\nI32 GGUFMetadataReadStringChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_bytes,\n                                  U64 out_nbytes,\n                                  U64 *out_len);\n\nI32 GGUFMetadataReadKeyStringChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U8 *out_key_bytes,\n                                     U64 out_key_nbytes,\n                                     U64 *out_key_len);\n\nI32 GGUFMetadataReadArrayHeaderChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U32 *out_elem_type,\n---\n    U64 cur;\n    U32 first_bits;\n    U32 second_bits;\n    U32 third_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_first_bits || !out_second_bits || !out_third_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode each lane through the canonical float32-bit checked reader so\n    // triple decode preserves identical bounds/overflow/no-partial-write rules.\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &first_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &second_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &third_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first_bits = first_bits;\n    *out_second_bits = second_bits;\n    *out_third_bits = third_bits;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian FLOAT64 bit-pattern metadata reader.\n// Runtime remains integer-only: the 64-bit payload is returned as raw bits\n// so callers