RAM\n    if cursor > (U64_MAX - need):\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_next_cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_array_payload_span_validate_checked(\n    payload_start: int,\n    payload_bytes: int,\n    table_end: int,\n    buf_nbytes: int,\n    out_payload_end_ref: list[int] | None,\n) -> int:\n    if out_payload_end_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    payload_end_ref = [0]\n    err = gguf_metadata_cursor_can_advance_checked(\n        payload_start,\n        payload_bytes,\n        table_end,\n        payload_end_ref,\n    )\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    payload_end = payload_end_ref[0]\n    if payload_end > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_payload_end_ref[0] = payload_end\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_array_payload_span_from_fixed_type_checked(\n    elem_type: int,\n    elem_count: int,\n    payload_start: int,\n    table_end: int,\n    buf_nbytes: int,\n    out_payload_bytes_ref: list[int] | None,\n    out_payload_end_ref: list[int] | None,\n) -> int:\n    if out_payload_bytes_ref is None or out_payload_end_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    elem_width_ref = [0]\n    err = gguf_metadata_array_fixed_elem_width_bytes_checked(elem_type, elem_width_ref)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    payload_bytes_ref = [0]\n    err = gguf_metadata_array_fixed_payload_bytes_checked(\n        elem_count,\n        elem_width_ref[0],\n        payload_bytes_ref,\n    )\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    payload_end_ref = [0]\n    err = gguf_metadata_array_payload_span_validate_checked(\n        payload_start,\n        payload_bytes_ref[0],\n        table_end,\n        buf_nbytes,\n        payload_end_ref,\n    )\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_payload_bytes_ref[0] = payload_bytes_ref[0]\n    out_payload_end_ref[0] = payload_end_ref[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_out_ptrs_no_partial_write() -> None:\n    out_bytes = [111]\n    out_end = [222]\n\n    err = gguf_metadata_array_payload_span_from_fixed_type_checked(\n        GGUF_TYPE_UINT8,\n        1,\n        0,\n        10,\n        10,\n        None,\n        out_end,\n    )\n    assert err == GGUF_META_TABLE_ERR_NULL_PTR\n    assert out_end[0] == 222\n\n    err = gguf_metadata_array_payload_span_from_fixed_type_checked(\n        GGUF_TYPE_UINT8,\n        1,\n        0,\n        10,\n        10,\n        out_bytes,\n        None,\n    )\n    assert err == GGUF_META_TABLE_ERR_NULL_PTR\n    assert out_bytes[0] == 111\n\n\ndef test_reject_variable_width_types() -> None:\n    out_bytes = [333]\n    out_end = [444]\n\n    for elem_type in (GGUF_TYPE_STRING, GGUF_TYPE_ARRAY, 13, 0xFFFF):\n        out_bytes[0] = 333\n        out_end[0] = 444\n        err = gguf_metadata_array_payload_span_from_fixed_type_checked(\n            elem_type,\n            8,\n            16,\n            4096,\n            4096,\n            out_bytes,\n            out_end,\n        )\n        assert err == GGUF_META_TABLE_ERR_BAD_PARAM\n        assert out_bytes[0] == 333\n        assert out_end[0] == 444\n\n\ndef test_mul_overflow_passthrough() -> None:\n    out_bytes = [555]\n    out_end = [666]\n\n    err = gguf_metadata_array_payload_span_from_fixed_type_checked(\n        GGUF_TYPE_UINT64,\n        I64_MAX,\n        0,\n        I64_MAX,\n        I64_MAX,\n        out_bytes,\n        out_end,\n    )\n    assert err == GGUF_META_TABLE_ERR_OVERFLOW\n    assert out_bytes[0] == 555\n    assert out_end[0] == 666\n\n\ndef test_span_validate_passthrough_no_partial_write() -> None:\n    out_bytes = [777]\n    out_end = [888]\n\n    err = gguf_metadata_array_payload_span_from_fixed_type_checked(\n        GGUF_TYPE_UINT32,\n        8,\n        100,\n            break;\n\n        // Variable-width element payloads require non-fixed decoding paths.\n        case GGUF_TYPE_STRING:\n        case GGUF_TYPE_ARRAY:\n        default:\n            return GGUF_META_TABLE_ERR_BAD_PARAM;\n    }\n\n    *out_elem_width_bytes = width_bytes;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked multiplication helper used by metadata table math where callers keep\n// cursor/index values in positive I64 space.\n// Contract: writes `*out_product` only on success.\nI32 GGUFMetadataMulU64Checked(U64 lhs,\n                              U64 rhs,\n                              U64 *out_product)\n{\n    U64 product;\n\n    if (!out_product)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep table/index arithmetic in positive I64 space for compatibility with\n    // parser entrypoints that route through signed cursors.\n    if (lhs > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (rhs > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (rhs && lhs > (0xFFFFFFFFFFFFFFFF / rhs))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    product = lhs * rhs;\n    if (product > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    *out_product = product;\n    return GGUF_META_TABLE_OK;\n}\n\n// Compute fixed-width metadata ARRAY payload bytes (`elem_count*elem_width`).\n// Intended for callers that first validate/resolve fixed element widths, then\n// compose this payload-byte result with payload-span validation helpers.\n// Contract: writes `*out_payload_bytes` only on success.\nI32 GGUFMetadataArrayFixedPayloadBytesChecked(U64 elem_count,\n                                              U64 elem_width_bytes,\n                                              U64 *out_payload_bytes)\n{\n    U64 payload_bytes;\n    I32 err;\n\n    if (!out_payload_bytes)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Compose through shared checked multiply guards so all fixed-width array\n    // payload math follows one overflow/sign-domain contract.\n    err = GGUFMetadataMulU64Checked(elem_count,\n                                    elem_width_bytes,\n                                    &payload_bytes);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_payload_bytes = payload_bytes;\n    return GGUF_META_TABLE_OK;\n}\n\n// Compose fixed-width metadata ARRAY payload-byte math and validated payload\n// span bounds in one checked helper for array decode entrypoints.\n// Contract: output pointers are written only on success.\nI32 GGUFMetadataArrayPayloadSpanFromFixedTypeChecked(U32 elem_type,\n                                                     U64 elem_count,\n                                                     U64 payload_start,\n                                                     U64 table_end,\n                                                     U64 buf_nbytes,\n                                                     U64 *out_payload_bytes,\n                                                     U64 *out_payload_end)\n{\n    U64 elem_width_bytes;\n    U64 payload_bytes;\n    U64 payload_end;\n    I32 err;\n\n    if (!out_payload_bytes || !out_payload_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Resolve canonical fixed element width; variable-width tags are rejected\n    // here so callers never apply fixed `count*width` math to STRING/ARRAY.\n    err = GGUFMetadataArrayFixedElemWidthBytesChecked(elem_type,\n                                                      &elem_width_bytes);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Compute fixed payload bytes through shared checked multiply helper.\n    err = GGUFMetadataArrayFixedPayloadBytesChecked(elem_count,\n                                                    elem_width_bytes,\n                                                    &payload_bytes);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Validate `[payload_start, payload_start + payload_bytes)` against table\n    // window and backing buffer bounds before decode loops consume payload.\n    err = GGUFMetadataArrayPayloadSpanValidateChecked(payload_start,\n                                                      payload_bytes,\n                                                      table_end,\n                                                      buf_nbytes,\n                                                      &payload_end);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_payload_bytes = payload_bytes;\n    *out_payload_end = payload_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked 1-byte metadata reader used by table-backed decoders.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value)\n{\n    U64 cur;\n    U64 next_cursor;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep data-plane indexing in positive I64 space to match parser cursor\n    // contracts used across GGUF metadata entrypoints.\n    if (buf_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    cur = *cursor;\n    err = GGUFMetadataCursorCanAdvanceChecked(cur, 1, table_end, &next_cursor);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // The metadata span must live inside the provided byte buffer.\n    if (next_cursor > buf_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_value = buf[cur];\n    *cursor = next_cursor;\n    return GGUF_META_TABLE_OK;\n}\n\n","exit_code":0,"status":"completed"}}
