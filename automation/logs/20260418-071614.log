n in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor);\n\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value);\n\nI32 GGUFMetadataReadI8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              I8 *out_value);\n\nI32 GGUFMetadataReadI8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second);\n\nI32 GGUFMetadataReadI8TripleChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    I8 *out_first,\n                                    I8 *out_second,\n                                    I8 *out_third);\n\nI32 GGUFMetadataReadI8TripleCheckedNoPartial(U8 *buf,\n                                             U64 buf_nbytes,\n                                             U64 *cursor,\n                                             U64 table_end,\n                                             I8 *out_first,\n                                             I8 *out_second,\n                                             I8 *out_third);\n\nI32 GGUFMetadataReadI8TripleCheckedDefault(U8 *buf,\n                                           U64 buf_nbytes,\n                                           U64 *cursor,\n                                           I8 *out_first,\n                                           I8 *out_second,\n                                           I8 *out_third);\n\nI32 GGUFMetadataReadI8QuadChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second,\n                                  I8 *out_third,\n                                  I8 *out_fourth);\n\nI32 GGUFMetadataReadI8QuadCheckedNoPartial(U8 *buf,\n                                           U64 buf_nbytes,\n                                           U64 *cursor,\n                                           U64 table_end,\n                                           I8 *out_first,\n                                           I8 *out_second,\n                                           I8 *out_third,\n                                           I8 *out_fourth);\n\nI32 GGUFMetadataReadI8QuadCheckedNoPartialDefault(U8 *buf,\n                                                  U64 buf_nbytes,\n                                                  U64 *cursor,\n                                                  I8 *out_first,\n                                                  I8 *out_second,\n                                                  I8 *out_third,\n                                                  I8 *out_fourth);\n\nI32 GGUFMetadataReadI8QuadCheckedDefault(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n                                         I8 *out_first,\n                                         I8 *out_second,\n                                         I8 *out_third,\n                                         I8 *out_fourth);\n\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second);\n\nI32 GGUFMetadataReadU8PairCheckedDefault(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n                                         U8 *out_first,\n                                         U8 *out_second);\n\nI32 GGUFMetadataReadU8TripleChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    U8 *out_first,\n                                    U8 *out_second,\n                                    U8 *out_third);\n\nI32 GGUFMetadataReadU8QuadChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second,\n                                  U8 *out_third,\n                                  U8 *out_fourth);\n\nI32 GGUFMetadataReadU8QuadCheckedNoPartial(U8 *buf,\n                                           U64 buf_nbytes,\n                                           U64 *cursor,\n                                           U64 table_end,\n                                           U8 *out_first,\n                                           U8 *out_second,\n                                           U8 *out_third,\n                                           U8 *out_fourth);\n\nI32 GGUFMetadataReadU8QuadCheckedDefault(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n                                         U8 *out_first,\n                                         U8 *out_second,\n                                         U8 *out_third,\n                                         U8 *out_fourth);\n\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U16 *out_value);\n\nI32 GGUFMetadataReadU16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out_second);\n\nI32 GGUFMetadataReadU16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U16 *out_first,\n                                     U16 *out_second,\n                                     U16 *out_third);\n\nI32 GGUFMetadataReadU16TripleCheckedNoPartial(U8 *buf,\n                                              U64 buf_nbytes,\n                                              U64 *cursor,\n                                              U64 table_end,\n                                              U16 *out_first,\n                                              U16 *out_second,\n                                              U16 *out_third);\n\nI32 GGUFMetadataReadU16TripleCheckedDefault(U8 *buf,\n                                            U64 buf_nbytes,\n                                            U64 *cursor,\n                                            U16 *out_first,\n                                            U16 *out_second,\n                                            U16 *out_third);\n\nI32 GGUFMetadataReadU16QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out_second,\n                                   U16 *out_third,\n                                   U16 *out_fourth);\n\nI32 GGUFMetadataReadU16QuadCheckedNoPartial(U8 *buf,\n                                            U64 buf_nbytes,\n                                            U64 *cursor,\n                                            U64 table_end,\n                                            U16 *out_first,\n                                            U16 *out_second,\n                                            U16 *out_third,\n                                            U16 *out_fourth);\n\nI32 GGUFMetadataReadU16QuadCheckedNoPartialDefault(U8 *buf,\n                                                   U64 buf_nbytes,\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadI8TripleChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU8_MASK = (1 << 8) - 1\n\n\ndef reinterpret_u8_as_i8(value: int) -> int:\n    value &= U8_MASK\n    if value >= (1 << 7):\n        return value - (1 << 8)\n    return value\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_i8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    raw_u8 = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, raw_u8)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = reinterpret_u8_as_i8(raw_u8[0])\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_i8_triple_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_first_ref: list[int] | None,\n    out_second_ref: list[int] | None,\n    out_third_ref: list[int] | None,\n) -> int:\n    if (\n        buf is None\n        or cursor_ref is None\n        or out_first_ref is None\n        or out_second_ref is None\n        or out_third_ref is None\n    ):\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    first = [0]\n    second = [0]\n    third = [0]\n\n    err = gguf_metadata_read_i8_checked(buf, buf_nbytes, cur, table_end, first)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_i8_checked(buf, buf_nbytes, cur, table_end, second)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_i8_checked(buf, buf_nbytes, cur, table_end, third)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_first_ref[0] = first[0]\n    out_second_ref[0] = second[0]\n    out_third_ref[0] = third[0]\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [1]\n    out_first = [11]\n    out_second = [22]\n    out_third = [33]\n\n    assert (\n        gguf_metadata_read_i8_triple_checked(\n            None,\n            4,\n            cursor,\n            4,\n            out_first,\n            out_second,\n            out_third,\n        )\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_first == [11]\n    assert out_second == [22]\n    assert out_third == [33]\n\n\ndef test_short_read_does_not_commit_outputs_or_cursor() -> None:\n    buf = [0x7F, 0x80, 0xFF]\n    cursor = [1]\n    out_first = [101]\n    out_second = [202]\n    out_third = [99]\n\n    err = gguf_metadata_read_i8_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [1]\n    assert out_first == [101]\n    assert out_second == [202]\n    assert out_third == [99]\n\n\ndef test_success_reads_three_i8_and_advances() -> None:\n    buf = [0x10, 0x7F, 0x80, 0xFF, 0x01]\n    cursor = [1]\n    out_first = [0]\n    out_second = [0]\n    out_third = [0]\n\n    err = gguf_metadata_read_i8_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_OK\n    assert out_first[0] == 127\n    assert out_second[0] == -128\n    assert out_third[0] == -1\n    assert cursor[0] == 4\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_254)\n\n    for _ in range(7000):\n        n = rng.randint(1, 320)\n        table_end = rng.randint(0, n)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out_first = [11]\n        out_second = [22]\n        out_third = [33]\n\n        err = gguf_metadata_read_i8_triple_checked(\n            buf,\n            n,\n            cursor,\n            table_end,\n            out_first,\n            out_second,\n            out_third,\n        )\n\n        if cursor0 + 3 <= table_end and cursor0 + 3 <= n:\n            assert err == GGUF_META_TABLE_OK\n            assert out_first[0] == reinterpret_u8_as_i8(buf[cursor0])\n            assert out_second[0] == reinterpret_u8_as_i8(buf[cursor0 + 1])\n            assert out_third[0] == reinterpret_u8_as_i8(buf[cursor0 + 2])\n            assert cursor[0] == cursor0 + 3\n        else:\n            assert err in (\n                GGUF_META_TABLE_ERR_OUT_OF_BOUNDS,\n                GGUF_META_TABLE_ERR_BAD_PARAM,\n                GGUF_META_TABLE_ERR_OVERFLOW,\n            )\n            assert out_first[0] == 11\n            assert out_second[0] == 22\n            assert out_third[0] == 33\n            assert cursor[0] == cursor0\n\n\nif __name__ == \"__main__\":\n    test_null_ptr_and_no_partial_write()\n    test_short_read_does_not_commit_outputs_or_cursor()\n    test_success_reads_three_i8_and_advances()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_i8_triple_checked_reference_checks=ok\")\n","exit_code":0,"status":"completed"}}
