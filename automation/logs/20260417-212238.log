shared checked scalar staging and commits all outputs + cursor only\n// after all four lanes pass (strict no-partial-write tuple semantics).\nI32 GGUFMetadataReadF64BitsQuadChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U64 *out_first_bits,\n                                       U64 *out_second_bits,\n                                       U64 *out_third_bits,\n                                       U64 *out_fourth_bits)\n{\n    U64 cur;\n    U64 first_bits;\n    U64 second_bits;\n    U64 third_bits;\n    U64 fourth_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_first_bits || !out_second_bits || !out_third_bits || !out_fourth_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage three lanes through triple composition to preserve canonical\n    // bounds/cursor behavior while avoiding duplicate decode math.\n    err = GGUFMetadataReadF64BitsTripleChecked(buf,\n                                               buf_nbytes,\n                                               &cur,\n                                               table_end,\n                                               &first_bits,\n                                               &second_bits,\n                                               &third_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Stage the fourth lane through canonical scalar decoding. Outputs +\n    // cursor commit only after this succeeds (strict no-partial semantics).\n    err = GGUFMetadataReadF64BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &fourth_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first_bits = first_bits;\n    *out_second_bits = second_bits;\n    *out_third_bits = third_bits;\n    *out_fourth_bits = fourth_bits;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked metadata BOOL reader (`U8 in {0,1}`).\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadBoolChecked(U8 *buf,\n                                U64 buf_nbytes,\n                                U64 *cursor,\n                                U64 table_end,\n                                Bool *out_value)\n{\n    U64 cur;\n    U8 raw_u8;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared checked byte reader so bool decode inherits\n    // canonical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &raw_u8);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // GGUF bool payloads are strict 0/1 in one byte.\n    if (raw_u8 > 1)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    *out_value = (raw_u8 != 0);\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked metadata BOOL pair reader (`U8 in {0,1}` for each lane).\n// Contract: decodes two sequential BOOL payloads through shared checked bool\n// reader staging and commits both outputs + cursor only after both lanes pass\n// canonical validation (strict no-partial-write tuple semantics).\n","exit_code":0,"status":"completed"}}
