ETA_TABLE_OK\n            first_u32 = (\n                buf[cursor0]\n                | (buf[cursor0 + 1] << 8)\n                | (buf[cursor0 + 2] << 16)\n                | (buf[cursor0 + 3] << 24)\n            )\n            second_u32 = (\n                buf[cursor0 + 4]\n                | (buf[cursor0 + 5] << 8)\n                | (buf[cursor0 + 6] << 16)\n                | (buf[cursor0 + 7] << 24)\n            )\n            assert out_first[0] == _to_i32(first_u32)\n            assert out_second[0] == _to_i32(second_u32)\n            assert cursor[0] == cursor0 + 8\n        else:\n            assert err in (\n                GGUF_META_TABLE_ERR_BAD_PARAM,\n                GGUF_META_TABLE_ERR_OVERFLOW,\n                GGUF_META_TABLE_ERR_OUT_OF_BOUNDS,\n            )\n            assert out_first[0] == 11111\n            assert out_second[0] == 22222\n            assert cursor[0] == cursor0\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_second_scalar_fail_does_not_commit_first_or_cursor()\n    test_success_reads_two_i32_and_advances()\n    test_overflow_passthrough_and_no_commit()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_i32_pair_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\nPY'","aggregated_output":"","exit_code":0,"status":"completed"}}
