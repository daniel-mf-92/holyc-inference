lama.rope.freq_base_train\")\ntests/test_rope_q16_angle_step.py:119:def rope_q16_from_int_checked(value: int) -> tuple[int, int]:\ntests/test_rope_q16_angle_step.py:125:def rope_q16_mul_checked(lhs_q16: int, rhs_q16: int) -> tuple[int, int]:\ntests/test_rope_q16_angle_step.py:132:def rope_q16_div_checked(num_q16: int, den_q16: int) -> tuple[int, int]:\ntests/test_rope_q16_angle_step.py:171:def rope_q16_angle_step_checked(freq_base_q16: int, head_dim: int, pair_index: int) -> tuple[int, int]:\ntests/test_rope_q16_angle_step.py:187:    err, two_i_q16 = rope_q16_from_int_checked(two_i)\ntests/test_rope_q16_angle_step.py:191:    err, head_dim_q16 = rope_q16_from_int_checked(head_dim)\ntests/test_rope_q16_angle_step.py:195:    err, ratio_q16 = rope_q16_div_checked(two_i_q16, head_dim_q16)\ntests/test_rope_q16_angle_step.py:203:    err, exponent_mag_q16 = rope_q16_mul_checked(ratio_q16, ln_base_q16)\ntests/test_rope_q16_angle_step.py:215:    assert rope_q16_angle_step_checked(0, 128, 0)[0] == ROPE_Q16_ERR_DOMAIN\ntests/test_rope_q16_angle_step.py:216:    assert rope_q16_angle_step_checked(-1, 128, 0)[0] == ROPE_Q16_ERR_DOMAIN\ntests/test_rope_q16_angle_step.py:219:    assert rope_q16_angle_step_checked(base_q16, 0, 0)[0] == ROPE_Q16_ERR_BAD_PARAM\ntests/test_rope_q16_angle_step.py:220:    assert rope_q16_angle_step_checked(base_q16, 127, 0)[0] == ROPE_Q16_ERR_BAD_PARAM\ntests/test_rope_q16_angle_step.py:221:    assert rope_q16_angle_step_checked(base_q16, 128, -1)[0] == ROPE_Q16_ERR_BAD_PARAM\ntests/test_rope_q16_angle_step.py:222:    assert rope_q16_angle_step_checked(base_q16, 128, 64)[0] == ROPE_Q16_ERR_BAD_PARAM\ntests/test_rope_q16_angle_step.py:227:    err, step_q16 = rope_q16_angle_step_checked(base_q16, 128, 0)\ntests/test_rope_q16_angle_step.py:237:        err, step_q16 = rope_q16_angle_step_checked(base_q16, 128, pair_index)\ntests/test_rope_q16_angle_step.py:251:        err, step_q16 = rope_q16_angle_step_checked(base_q16, head_dim, pair_index)\ntests/test_rope