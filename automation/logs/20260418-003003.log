bits,\n                                       U64 *out_second_bits)\n{\n    U64 cur;\n    U64 first_bits;\n    U64 second_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_first_bits || !out_second_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage both float64 lanes through the canonical checked scalar reader so\n    // pair decode preserves identical bounds/overflow/no-partial-write rules.\n    err = GGUFMetadataReadF64BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &first_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadF64BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &second_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first_bits = first_bits;\n    *out_second_bits = second_bits;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked metadata FLOAT64 raw-bit triple reader.\n// Contract: decodes three sequential little-endian FLOAT64 payload bit-patterns\n// through shared checked scalar staging and commits all outputs + cursor only\n// after all three lanes pass (strict no-partial-write tuple semantics).\nI32 GGUFMetadataReadF64BitsTripleChecked(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n                                         U64 table_end,\n                                         U64 *out_first_bits,\n                                         U64 *out_second_bits,\n                                         U64 *out_third_bits)\n{\n    U64 cur;\n    U64 first_bits;\n    U64 second_bits;\n    U64 third_bit