{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' src/quant/q8_0.HC; echo '---'; sed -n '1,220p' tests/test_q8_0_dequant.py\"","aggregated_output":"// q8_0.HC\n// Q8_0 block layout + integer-only dequantization helpers for TempleOS.\n//\n// GGML Q8_0 block layout (34 bytes total):\n//   - d_fp16 : fp16 scale\n//   - qs[32] : signed 8-bit quantized values\n//\n// Decode equation (reference):\n//   x = d * q\n//\n// Integer HolyC form:\n//   d_q16 = Round(d_fp16 * 2^16)\n//   x_q16 = d_q16 * q_signed\n//\n// Runtime path is integer-only after one fp16->Q16 conversion per block.\n\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n#define Q8_0_BLOCK_BYTES      34\n\n#define Q8_0_OK               0\n#define Q8_0_ERR_NULL_PTR     1\n#define Q8_0_ERR_BAD_DST_LEN  2\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    // Subnormal and zero:\n    // value = fraction * 2^-24, so Q16 = fraction * 2^-8.\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    // INF/NAN: saturate instead of trapping.\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    // Normal numbers:\n    // value = (1024 + fraction) * 2^(exp-25)\n    // Q16  = (1024 + fraction) * 2^(exp-9)\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0UnpackBlockSigned(Q8_0Block *block, I64 *dst_signed, I64 dst_len)\n{\n    I64 index;\n\n    if (!block || !dst_signed)\n        return Q8_0_ERR_NULL_PTR;\n    if (dst_len < Q8_0_VALUES_PER_BLOCK)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    for (index = 0; index < Q8_0_VALUES_PER_BLOCK; ++index)\n        dst_signed[index] = block->qs[index];\n\n    return Q8_0_OK;\n}\n\nI32 Q8_0DequantizeBlockQ16(Q8_0Block *block, I64 *dst_q16, I64 dst_len)\n{\n    I64 scale_q16;\n    I64 index;\n\n    if (!block || !dst_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (dst_len < Q8_0_VALUES_PER_BLOCK)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    scale_q16 = Q8_0F16ToQ16(block->d_fp16);\n\n    // Explicit element-wise integer decode keeps math auditable:\n    // x_q16 = d_q16 * q_signed.\n    for (index = 0; index < Q8_0_VALUES_PER_BLOCK; ++index)\n        dst_q16[index] = scale_q16 * block->qs[index];\n\n    return Q8_0_OK;\n}\n\nI32 Q8_0DequantizeBlocksQ16(Q8_0Block *blocks, I64 block_count, I64 *dst_q16, I64 dst_len)\n{\n    I64 block_index;\n    I64 dst_offset;\n    I32 status;\n\n    if (!blocks || !dst_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n    if (dst_len < block_count * Q8_0_VALUES_PER_BLOCK)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    dst_offset = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DequantizeBlockQ16(&blocks[block_index], &dst_q16[dst_offset], Q8_0_VALUES_PER_BLOCK);\n        if (status != Q8_0_OK)\n            return status;\n\n        dst_offset += Q8_0_VALUES_PER_BLOCK;\n    }\n\n    return Q8_0_OK;\n}\n\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0 unpack + integer Q16 dequant semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ8_0_VALUES_PER_BLOCK = 32\nQ8_0_PACKED_BYTES = 32\n\nQ8_0_OK = 0\nQ8_0_ERR_NULL_PTR = 1\nQ8_0_ERR_BAD_DST_LEN = 2\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    round_bias = 1 << (shift - 1)\n    return (value + round_bias) >> shift\n\n\ndef f16_to_q16(fp16_bits: int) -> int:\n    sign_bit = (fp16_bits >> 15) & 1\n    exponent_bits = (fp16_bits >> 10) & 0x1F\n    fraction_bits = fp16_bits & 0x03FF\n\n    if exponent_bits == 0:\n        if fraction_bits == 0:\n            return 0\n        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n        return -magnitude_q16 if sign_bit else magnitude_q16\n\n    if exponent_bits == 0x1F:\n        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n\n    mantissa = 1024 + fraction_bits\n    shift_amount = exponent_bits - 9\n\n    if shift_amount >= 0:\n        magnitude_q16 = mantissa << shift_amount\n    else:\n        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n\n    return -magnitude_q16 if sign_bit else magnitude_q16\n\n\ndef unpack_block_signed(qs: bytes):\n    if len(qs) != Q8_0_PACKED_BYTES:\n        return Q8_0_ERR_BAD_DST_LEN, []\n    return Q8_0_OK, [struct.unpack(\"<b\", bytes([x]))[0] for x in qs]\n\n\ndef dequantize_block_q16(scale_fp16: int, qs: bytes):\n    if len(qs) != Q8_0_PACKED_BYTES:\n        return Q8_0_ERR_BAD_DST_LEN, []\n\n    out = [0] * Q8_0_VALUES_PER_BLOCK\n    scale_q16 = f16_to_q16(scale_fp16)\n    signed = [struct.unpack(\"<b\", bytes([x]))[0] for x in qs]\n\n    for idx, q in enumerate(signed):\n        out[idx] = scale_q16 * q\n\n    return Q8_0_OK, out\n\n\ndef half_bits(value: float) -> int:\n    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n\n\ndef test_unpack_signed_bytes() -> None:\n    signed = list(range(-16, 16))\n    qs = bytes((v + 256) % 256 for v in signed)\n    err, out = unpack_block_signed(qs)\n    assert err == Q8_0_OK\n    assert out == signed\n\n\ndef test_dequant_known_scale() -> None:\n    scale_fp16 = half_bits(0.25)\n    signed = [\n        -128,\n        -96,\n        -64,\n        -32,\n        -16,\n        -8,\n        -4,\n        -2,\n        -1,\n        0,\n        1,\n        2,\n        4,\n        8,\n        16,\n        32,\n        48,\n        56,\n        64,\n        72,\n        80,\n        88,\n        96,\n        104,\n        112,\n        120,\n        121,\n        122,\n        123,\n        124,\n        125,\n        127,\n    ]\n    qs = bytes((v + 256) % 256 for v in signed)\n\n    err, out_q16 = dequantize_block_q16(scale_fp16, qs)\n    assert err == Q8_0_OK\n\n    expected_q16 = [round(0.25 * q * (1 << 16)) for q in signed]\n    assert out_q16 == expected_q16\n\n\ndef test_fp16_to_q16_matches_float_rounding_for_finite_values() -> None:\n    finite_values = [\n        0.0,\n        1.0,\n        -1.0,\n        0.5,\n        -0.5,\n        2.0,\n        -2.0,\n        1.5,\n        -3.25,\n        0.125,\n        -0.03125,\n    ]\n\n    for value in finite_values:\n        bits = half_bits(value)\n        got = f16_to_q16(bits)\n        expected = round(value * (1 << 16))\n        assert got == expected\n\n\ndef test_random_blocks_match_reference_float_path() -> None:\n    rng = random.Random(4242)\n\n    for _ in range(200):\n        scale = rng.uniform(-4.0, 4.0)\n        scale_fp16 = half_bits(scale)\n        scale_q16 = f16_to_q16(scale_fp16)\n\n        signed_vals = [rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)]\n        qs = bytes((v + 256) % 256 for v in signed_vals)\n\n        err, out_q16 = dequantize_block_q16(scale_fp16, qs)\n        assert err == Q8_0_OK\n\n        scale_from_half = struct.unpack(\"<e\", struct.pack(\"<H\", scale_fp16))[0]\n\n        expected_int = [scale_q16 * q for q in signed_vals]\n        expected_float = [round(scale_from_half * q * (1 << 16)) for q in signed_vals]\n\n        assert out_q16 == expected_int\n\n        # Integer path rounds scale once per block; float path rounds per element.\n        for got, want in zip(out_q16, expected_float):\n            assert abs(got - want) <= 128\n\n\ndef test_error_on_bad_input_length() -> None:\n    err, _ = unpack_block_signed(b\"\\x00\" * 31)\n    assert err == Q8_0_ERR_BAD_DST_LEN\n\n    err, _ = dequantize_block_q16(half_bits(1.0), b\"\\x00\" * 31)\n    assert err == Q8_0_ERR_BAD_DST_LEN\n\n\ndef run() -> None:\n    test_unpack_signed_bytes()\n    test_dequant_known_scale()\n    test_fp16_to_q16_matches_float_rounding_for_finite_values()\n    test_random_blocks_match_reference_float_path()\n    test_error_on_bad_input_length()\n    print(\"q8_0_dequant_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_22","type":"reasoning","text":"**Implementing AVX2 helper logic**\n\nI need to implement an AVX2 helper in the .HC format and test it, possibly using a Python parity harness for lane pack semantics. It seems the AVX2 intrinsics in HolyC are uncertain and the repo might not compile yet. I can create logic without actual assembly by using a scalar fallback for an “AVX2 lane-pack helper.” I’ll include placeholders and comments about future assembly implementations. I’ll also create a test file and ensure we progress with our queue items as planned.\n**Developing the DB insert and AVX2 helper**\n\nI need to include a central database insert and will execute an SQLite command. Running a TempleOS VM compilation might be optional but could be resource-intensive. The user mentioned that I can SSH compile, but that’s not mandatory for validation related to changes. I could just run Python tests instead or conduct a local test. \n\nNext, I’ll inspect the existing test naming and runner prints, and then create a run() function for checks. I’ll craft the q8_0_avx2.HC file to include necessary constants and functions to handle the AVX2 lane-pack helper, focusing on proper validation and output design.\n**Creating the AVX2 helper and testing**\n\nI’m thinking about adding a helper function that returns `out_lo_16` and `out_hi_16`. I should check if future matrix multiplication needs a function signature with two 16-lane vectors. It might be easier to use contiguous 32 I16 arrays. Inline comments are necessary to explain the math and the algorithm involved.\n\nNext, I’ll create a host test in the tests/test_q8_0_avx2_pack.py file. This will include defining constants, a reference function for byte conversions, and deterministic patterns for tests. I’ll also consider integrating the q8 block pack and possibly reusing the pack_signed helper from test_q8_0_dot while ensuring it remains standalone."}}
{"type":"item.started","item":{"id":"item_23","type":"command_execution","command":"/bin/zsh -lc \"cat > src/quant/q8_0_avx2.HC <<'EOF'\n// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (\"'`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nI32 Q8_0Pack32ToI16LanesAVX2(I8 *src_q8, I64 src_len, I16 *dst_i16, I64 dst_len)\n{\n    I64 lane;\n\n    if (!src_q8 || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (src_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Lane contract:\n    //   dst_i16[i] = SignExtend16(src_q8[i]) for i in [0, 31]\n    // This exact order matches the two AVX2 16-lane halves that would be\n    // produced by widening bytes 0..15 then 16..31.\n    for (lane = 0; lane < Q8_0_AVX2_VALUES_PER_BLOCK; ++lane)\n        dst_i16[lane] = (I16)src_q8[lane];\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0PackBlockToI16LanesAVX2(Q8_0Block *block, I16 *dst_i16, I64 dst_len)\n{\n    if (!block || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    return Q8_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\nEOF\n\ncat > tests/test_q8_0_avx2_pack.py <<'\"'EOF'\n#\"'!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0 AVX2-prep 32-byte -> 32xI16 lane packing.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ8_0_AVX2_VALUES_PER_BLOCK = 32\n\nQ8_0_AVX2_OK = 0\nQ8_0_AVX2_ERR_NULL_PTR = 1\nQ8_0_AVX2_ERR_BAD_LEN = 2\n\n\ndef as_i8(byte_value: int) -> int:\n    return struct.unpack(\"<b\", bytes([byte_value & 0xFF]))[0]\n\n\ndef q8_0_pack32_to_i16_lanes_avx2(src_q8: bytes):\n    if src_q8 is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, []\n    if len(src_q8) < Q8_0_AVX2_VALUES_PER_BLOCK:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n\n    out = [0] * Q8_0_AVX2_VALUES_PER_BLOCK\n    for lane in range(Q8_0_AVX2_VALUES_PER_BLOCK):\n        out[lane] = as_i8(src_q8[lane])\n    return Q8_0_AVX2_OK, out\n\n\ndef q8_0_pack_block_to_i16_lanes_avx2(block_qs: bytes):\n    if block_qs is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, []\n    return q8_0_pack32_to_i16_lanes_avx2(block_qs)\n\n\ndef test_known_edge_pattern() -> None:\n    signed = [\n        -128,\n        -127,\n        -64,\n        -33,\n        -32,\n        -17,\n        -16,\n        -9,\n        -8,\n        -2,\n        -1,\n        0,\n        1,\n        2,\n        7,\n        8,\n        9,\n        15,\n        16,\n        17,\n        31,\n        32,\n        33,\n        63,\n        64,\n        65,\n        95,\n        96,\n        97,\n        126,\n        127,\n        -5,\n    ]\n    src = bytes((v + 256) % 256 for v in signed)\n\n    err, packed = q8_0_pack32_to_i16_lanes_avx2(src)\n    assert err == Q8_0_AVX2_OK\n    assert packed == signed\n\n\ndef test_randomized_matches_sign_extend_reference() -> None:\n    rng = random.Random(20260416)\n\n    for _ in range(1200):\n        src = bytes(rng.randrange(0, 256) for _ in range(Q8_0_AVX2_VALUES_PER_BLOCK))\n        err, packed = q8_0_pack32_to_i16_lanes_avx2(src)\n        assert err == Q8_0_AVX2_OK\n\n        expected = [as_i8(value) for value in src]\n        assert packed == expected\n\n\ndef test_block_wrapper_is_identical_to_direct_pack() -> None:\n    rng = random.Random(101)\n\n    for _ in range(256):\n        src = bytes(rng.randrange(0, 256) for _ in range(Q8_0_AVX2_VALUES_PER_BLOCK))\n\n        err_direct, out_direct = q8_0_pack32_to_i16_lanes_avx2(src)\n        err_wrap, out_wrap = q8_0_pack_block_to_i16_lanes_avx2(src)\n\n        assert err_direct == Q8_0_AVX2_OK\n        assert err_wrap == Q8_0_AVX2_OK\n        assert out_wrap == out_direct\n\n\ndef test_len_and_null_errors() -> None:\n    err, _ = q8_0_pack32_to_i16_lanes_avx2(None)\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n    err, _ = q8_0_pack32_to_i16_lanes_avx2(b\"'\"\\\\x00\\\" * 31)\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n    err, _ = q8_0_pack_block_to_i16_lanes_avx2(None)\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n\ndef run() -> None:\n    test_known_edge_pattern()\n    test_randomized_matches_sign_extend_reference()\n    test_block_wrapper_is_identical_to_direct_pack()\n    test_len_and_null_errors()\n    print(\\\"q8_0_avx2_pack_reference_checks=ok\\\")\n\n\nif __name__ == \\\"__main__\\\":\n    run()\nEOF\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/zsh -lc \"cat > src/quant/q8_0_avx2.HC <<'EOF'\n// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (\"'`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nI32 Q8_0Pack32ToI16LanesAVX2(I8 *src_q8, I64 src_len, I16 *dst_i16, I64 dst_len)\n{\n    I64 lane;\n\n    if (!src_q8 || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (src_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Lane contract:\n    //   dst_i16[i] = SignExtend16(src_q8[i]) for i in [0, 31]\n    // This exact order matches the two AVX2 16-lane halves that would be\n    // produced by widening bytes 0..15 then 16..31.\n    for (lane = 0; lane < Q8_0_AVX2_VALUES_PER_BLOCK; ++lane)\n        dst_i16[lane] = (I16)src_q8[lane];\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0PackBlockToI16LanesAVX2(Q8_0Block *block, I16 *dst_i16, I64 dst_len)\n{\n    if (!block || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    return Q8_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\nEOF\n\ncat > tests/test_q8_0_avx2_pack.py <<'\"'EOF'\n#\"'!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0 AVX2-prep 32-byte -> 32xI16 lane packing.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ8_0_AVX2_VALUES_PER_BLOCK = 32\n\nQ8_0_AVX2_OK = 0\nQ8_0_AVX2_ERR_NULL_PTR = 1\nQ8_0_AVX2_ERR_BAD_LEN = 2\n\n\ndef as_i8(byte_value: int) -> int:\n    return struct.unpack(\"<b\", bytes([byte_value & 0xFF]))[0]\n\n\ndef q8_0_pack32_to_i16_lanes_avx2(src_q8: bytes):\n    if src_q8 is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, []\n    if len(src_q8) < Q8_0_AVX2_VALUES_PER_BLOCK:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n\n    out = [0] * Q8_0_AVX2_VALUES_PER_BLOCK\n    for lane in range(Q8_0_AVX2_VALUES_PER_BLOCK):\n        out[lane] = as_i8(src_q8[lane])\n    return Q8_0_AVX2_OK, out\n\n\ndef q8_0_pack_block_to_i16_lanes_avx2(block_qs: bytes):\n    if block_qs is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, []\n    return q8_0_pack32_to_i16_lanes_avx2(block_qs)\n\n\ndef test_known_edge_pattern() -> None:\n    signed = [\n        -128,\n        -127,\n        -64,\n        -33,\n        -32,\n        -17,\n        -16,\n        -9,\n        -8,\n        -2,\n        -1,\n        0,\n        1,\n        2,\n        7,\n        8,\n        9,\n        15,\n        16,\n        17,\n        31,\n        32,\n        33,\n        63,\n        64,\n        65,\n        95,\n        96,\n        97,\n        126,\n        127,\n        -5,\n    ]\n    src = bytes((v + 256) % 256 for v in signed)\n\n    err, packed = q8_0_pack32_to_i16_lanes_avx2(src)\n    assert err == Q8_0_AVX2_OK\n    assert packed == signed\n\n\ndef test_randomized_matches_sign_extend_reference() -> None:\n    rng = random.Random(20260416)\n\n    for _ in range(1200):\n        src = bytes(rng.randrange(0, 256) for _ in range(Q8_0_AVX2_VALUES_PER_BLOCK))\n        err, packed = q8_0_pack32_to_i16_lanes_avx2(src)\n        assert err == Q8_0_AVX2_OK\n\n        expected = [as_i8(value) for value in src]\n        assert packed == expected\n\n\ndef test_block_wrapper_is_identical_to_direct_pack() -> None:\n    rng = random.Random(101)\n\n    for _ in range(256):\n        src = bytes(rng.randrange(0, 256) for _ in range(Q8_0_AVX2_VALUES_PER_BLOCK))\n\n        err_direct, out_direct = q8_0_pack32_to_i16_lanes_avx2(src)\n        err_wrap, out_wrap = q8_0_pack_block_to_i16_lanes_avx2(src)\n\n        assert err_direct == Q8_0_AVX2_OK\n        assert err_wrap == Q8_0_AVX2_OK\n        assert out_wrap == out_direct\n\n\ndef test_len_and_null_errors() -> None:\n    err, _ = q8_0_pack32_to_i16_lanes_avx2(None)\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n    err, _ = q8_0_pack32_to_i16_lanes_avx2(b\"'\"\\\\x00\\\" * 31)\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n    err, _ = q8_0_pack_block_to_i16_lanes_avx2(None)\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n\ndef run() -> None:\n    test_known_edge_pattern()\n    test_randomized_matches_sign_extend_reference()\n    test_block_wrapper_is_identical_to_direct_pack()\n    test_len_and_null_errors()\n    print(\\\"q8_0_avx2_pack_reference_checks=ok\\\")\n\n\nif __name__ == \\\"__main__\\\":\n    run()\nEOF\"","aggregated_output":"","exit_code":0,"status":"completed"}}
