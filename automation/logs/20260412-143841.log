{"type":"item.started","item":{"id":"item_6","type":"command_execution","command":"/bin/zsh -lc \"mkdir -p src/math\ncat > src/math/fixedpoint.HC <<'EOF'\n// fixedpoint.HC\n// Q16.16 fixed-point helpers for integer-only inference math.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define FP_Q16_HALF  (1 << (FP_Q16_SHIFT - 1))\n\nI64 FPQ16Abs(I64 x)\n{\n    if (x < 0)\n        return -x;\n    return x;\n}\n\nI64 FPQ16FromInt(I64 x)\n{\n    return x << FP_Q16_SHIFT;\n}\n\nI64 FPQ16ToInt(I64 x)\n{\n    if (x >= 0)\n        return (x + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-x) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Mul(I64 a, I64 b)\n{\n    I64 prod;\n\n    prod = a * b;\n    if (prod >= 0)\n        return (prod + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-prod) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Div(I64 num, I64 den)\n{\n    I64 sign;\n    I64 abs_num;\n    I64 abs_den;\n    I64 scaled;\n    I64 q;\n\n    if (\"'!den)\n        return 0;\n\n    sign = 1;\n    if (num < 0)\n    {\n        sign = -sign;\n        num = -num;\n    }\n    if (den < 0)\n    {\n        sign = -sign;\n        den = -den;\n    }\n\n    abs_num = num;\n    abs_den = den;\n\n    scaled = abs_num << FP_Q16_SHIFT;\n    q = (scaled + (abs_den >> 1)) / abs_den;\n\n    if (sign < 0)\n        return -q;\n    return q;\n}\nEOF'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
