{"type":"item.started","item":{"id":"item_10","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nFP_Q16_SHIFT = 16\nFP_Q16_HALF = 1 << (FP_Q16_SHIFT - 1)\n\ndef to_q16(x):\n    return int(round(x * (1 << FP_Q16_SHIFT)))\n\ndef mul(a,b):\n    prod = a*b\n    if prod >= 0:\n        return (prod + FP_Q16_HALF) >> FP_Q16_SHIFT\n    return -(((-prod) + FP_Q16_HALF) >> FP_Q16_SHIFT)\n\ndef div(num, den):\n    if den == 0:\n        return 0\n    sign = 1\n    if num < 0:\n        sign = -sign\n        num = -num\n    if den < 0:\n        sign = -sign\n        den = -den\n    scaled = num << FP_Q16_SHIFT\n    q = (scaled + (den >> 1)) // den\n    return -q if sign < 0 else q\n\ncases_mul = [(1.5, 2.25), (-3.0, 0.5), (-1.25, -2.0)]\nfor a,b in cases_mul:\n    aq,bq = to_q16(a), to_q16(b)\n    rq = mul(aq,bq)\n    r = rq / (1<<FP_Q16_SHIFT)\n    exp = a*b\n    assert abs(r-exp) < 1e-4, (a,b,r,exp)\n\ncases_div = [(7.0,2.0), (-7.0,2.0), (5.5,-2.0), (-4.5,-1.5)]\nfor n,d in cases_div:\n    nq,dq = to_q16(n), to_q16(d)\n    rq = div(nq,dq)\n    r = rq / (1<<FP_Q16_SHIFT)\n    exp = n/d\n    assert abs(r-exp) < 1e-4, (n,d,r,exp)\n\nprint('fixedpoint q16 checks: PASS (mul/div rounding and sign)')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
