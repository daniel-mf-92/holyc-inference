{"type":"item.started","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport math, random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\nFP_Q16_HALF = 1 << (FP_Q16_SHIFT - 1)\nEXP_Q16_LN2 = 45426\nEXP_Q16_MAX_INPUT = 655360\nEXP_Q16_MIN_INPUT = -655360\nI64_MAX_VALUE = (1<<63)-1\n\ndef fp_mul(a,b):\n    prod=a*b\n    if prod>=0:\n        return (prod+FP_Q16_HALF)>>FP_Q16_SHIFT\n    return -(((-prod)+FP_Q16_HALF)>>FP_Q16_SHIFT)\n\ndef fp_div(num, den):\n    if den==0:\n        return 0\n    sign=1\n    if num<0:\n        sign=-sign; num=-num\n    if den<0:\n        sign=-sign; den=-den\n    scaled=num<<FP_Q16_SHIFT\n    q=(scaled+(den>>1))//den\n    return -q if sign<0 else q\n\ndef fp_from_int(x):\n    return x<<FP_Q16_SHIFT\n\ndef fp_exp(x):\n    if x>=EXP_Q16_MAX_INPUT:\n        return I64_MAX_VALUE\n    if x<=EXP_Q16_MIN_INPUT:\n        return 0\n    k=x//EXP_Q16_LN2\n    if x<0 and (x%EXP_Q16_LN2):\n        k-=1\n    r=x-(k*EXP_Q16_LN2)\n    r2=fp_mul(r,r)\n    r3=fp_mul(r2,r)\n    r4=fp_mul(r3,r)\n    poly=FP_Q16_ONE + r + r2//2 + r3//6 + r4//24\n    if k>=0:\n        if k>=30:\n            return I64_MAX_VALUE\n        if poly > (I64_MAX_VALUE>>k):\n            return I64_MAX_VALUE\n        return poly<<k\n    if k<=-63:\n        return 0\n    return poly>>(-k)\n\ndef fp_softmax(logits):\n    if not logits:\n        return []\n    max_idx=max(range(len(logits)), key=lambda i: logits[i])\n    max_logit=logits[max_idx]\n    probs=[]\n    exp_sum=0\n    for x in logits:\n        v=fp_exp(x-max_logit)\n        probs.append(v)\n        if exp_sum > I64_MAX_VALUE - v:\n            exp_sum = I64_MAX_VALUE\n        else:\n            exp_sum += v\n    if exp_sum<=0:\n        v=fp_div(FP_Q16_ONE, fp_from_int(len(logits)))\n        return [v]*len(logits)\n    out=[]\n    prob_sum=0\n    for v in probs:\n        p=fp_div(v, exp_sum)\n        out.append(p)\n        prob_sum += p\n    out[max_idx] += FP_Q16_ONE - prob_sum\n    return out\n\nrandom.seed(1337)\nmax_abs_err=0.0\nsum_err_max=0.0\nfor _ in range(200):\n    n=random.randint(2,16)\n    fl=[random.uniform(-8.0,8.0) for _ in range(n)]\n    logits=[int(round(x*FP_Q16_ONE)) for x in fl]\n    got=fp_softmax(logits)\n    # float ref with stability shift\n    mx=max(fl)\n    ex=[math.exp(x-mx) for x in fl]\n    s=sum(ex)\n    ref=[v/s for v in ex]\n    gotf=[v/FP_Q16_ONE for v in got]\n    max_abs_err=max(max_abs_err, max(abs(a-b) for a,b in zip(gotf,ref)))\n    sum_err_max=max(sum_err_max, abs(sum(gotf)-1.0))\n\nprint(f\\\"softmax_q16_checks=ok cases=200 max_abs_err={max_abs_err:.6f} max_sum_err={sum_err_max:.6f}\\\")\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
