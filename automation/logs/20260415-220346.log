{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/quant/q4_0_dot.HC; echo '---'; sed -n '1,280p' tests/test_q4_0_dot.py; echo '---'; sed -n '1,220p' src/quant/q4_0_q8_0_dot.HC; echo '---'; sed -n '1,260p' src/quant/q8_0_dot.HC\"","aggregated_output":"// q4_0_dot.HC\n// Naive integer-only Q4_0 dot product kernels for TempleOS.\n//\n// Math:\n//   For each block, GGML Q4_0 stores 32 4-bit values and one fp16 scale d.\n//   Decode uses: x_i = d * (q_i - 8)\n//\n// Integer HolyC form:\n//   d_q16   = Round(d * 2^16)\n//   q_s     = nibble - 8   (in [-8, 7])\n//   x_q16   = d_q16 * q_s\n//   dot_q32 = Sum(x_q16 * y_q16)\n//           = (dA_q16 * dB_q16) * Sum(qA_s * qB_s)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n\n#define Q4_0_OK               0\n#define Q4_0_ERR_NULL_PTR     1\n#define Q4_0_ERR_BAD_DST_LEN  2\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nI64 Q4_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nI32 Q4_0DotProductBlockQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 nibble_dot_q0;\n    I64 byte_index;\n    U8 lhs_packed;\n    U8 rhs_packed;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q4_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0F16ToQ16(lhs->d_fp16);\n    rhs_scale_q16 = Q4_0F16ToQ16(rhs->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    nibble_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        lhs_packed = lhs->qs[byte_index];\n        rhs_packed = rhs->qs[byte_index];\n\n        nibble_dot_q0 += Q4_0NibbleToSigned(lhs_packed, FALSE) * Q4_0NibbleToSigned(rhs_packed, FALSE);\n        nibble_dot_q0 += Q4_0NibbleToSigned(lhs_packed, TRUE) * Q4_0NibbleToSigned(rhs_packed, TRUE);\n    }\n\n    *out_dot_q32 = scale_prod_q32 * nibble_dot_q0;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotProductBlocksQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q4_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotRowBlocksQ16(Q4_0Block *row_blocks, Q4_0Block *vec_blocks, I64 block_count, I64 *out_dot_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q16;\n    I32 status;\n\n    if (!row_blocks || !vec_blocks || !out_dot_q16)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    // Matmul row kernels usually keep accumulators in Q16 lanes.\n    // Convert each block dot Q32->Q16 with explicit rounding before summation,\n    // so every 32-value block contribution stays auditable and deterministic.\n    total_dot_q16 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0DotProductBlockQ32(&row_blocks[block_index], &vec_blocks[block_index], &block_dot_q32);\n        if (status != Q4_0_OK)\n            return status;\n\n        total_dot_q16 += Q4_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *out_dot_q16 = total_dot_q16;\n    return Q4_0_OK;\n}\n\nI64 Q4_0DotQ32ToQ16(I64 dot_q32)\n{\n    return Q4_0RoundShiftRightSigned(dot_q32, 16);\n}\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for integer Q4_0 dot-product semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ4_0_PACKED_BYTES = 16\nQ4_0_VALUES_PER_BLOCK = 32\n\nQ4_0_OK = 0\nQ4_0_ERR_NULL_PTR = 1\nQ4_0_ERR_BAD_DST_LEN = 2\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    round_bias = 1 << (shift - 1)\n    return (value + round_bias) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef f16_to_q16(fp16_bits: int) -> int:\n    sign_bit = (fp16_bits >> 15) & 1\n    exponent_bits = (fp16_bits >> 10) & 0x1F\n    fraction_bits = fp16_bits & 0x03FF\n\n    if exponent_bits == 0:\n        if fraction_bits == 0:\n            return 0\n        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n        return -magnitude_q16 if sign_bit else magnitude_q16\n\n    if exponent_bits == 0x1F:\n        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n\n    mantissa = 1024 + fraction_bits\n    shift_amount = exponent_bits - 9\n\n    if shift_amount >= 0:\n        magnitude_q16 = mantissa << shift_amount\n    else:\n        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n\n    return -magnitude_q16 if sign_bit else magnitude_q16\n\n\ndef nibble_to_signed(packed: int, upper_nibble: bool) -> int:\n    if upper_nibble:\n        q_unsigned = (packed >> 4) & 0x0F\n    else:\n        q_unsigned = packed & 0x0F\n    return q_unsigned - 8\n\n\ndef half_bits(value: float) -> int:\n    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n\n\ndef dot_product_block_q32(lhs_scale_fp16: int, lhs_qs: bytes, rhs_scale_fp16: int, rhs_qs: bytes):\n    if len(lhs_qs) != Q4_0_PACKED_BYTES or len(rhs_qs) != Q4_0_PACKED_BYTES:\n        return Q4_0_ERR_BAD_DST_LEN, 0\n\n    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16\n\n    nibble_dot_q0 = 0\n    for l_packed, r_packed in zip(lhs_qs, rhs_qs):\n        nibble_dot_q0 += nibble_to_signed(l_packed, False) * nibble_to_signed(r_packed, False)\n        nibble_dot_q0 += nibble_to_signed(l_packed, True) * nibble_to_signed(r_packed, True)\n\n    return Q4_0_OK, scale_prod_q32 * nibble_dot_q0\n\n\ndef dot_q32_to_q16(dot_q32: int) -> int:\n    return round_shift_right_signed(dot_q32, 16)\n\n\ndef dot_row_blocks_q16(lhs_blocks, rhs_blocks):\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q4_0_ERR_BAD_DST_LEN, 0\n\n    total_q16 = 0\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        err, block_q32 = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        if err != Q4_0_OK:\n            return err, 0\n        total_q16 += dot_q32_to_q16(block_q32)\n\n    return Q4_0_OK, total_q16\n\n\ndef unpack_signed(qs: bytes) -> list[int]:\n    out: list[int] = []\n    for packed in qs:\n        out.append((packed & 0x0F) - 8)\n        out.append(((packed >> 4) & 0x0F) - 8)\n    return out\n\n\ndef test_identity_block() -> None:\n    lhs_scale_fp16 = half_bits(1.0)\n    rhs_scale_fp16 = half_bits(1.0)\n\n    vals = list(range(16)) * 2\n    lhs_qs = bytes((vals[i] & 0x0F) | ((vals[i + 1] & 0x0F) << 4) for i in range(0, 32, 2))\n    rhs_qs = lhs_qs\n\n    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_qs, rhs_scale_fp16, rhs_qs)\n    assert err == Q4_0_OK\n\n    signed = [v - 8 for v in vals]\n    expected_dot_q0 = sum(x * x for x in signed)\n    expected_q32 = (1 << 16) * (1 << 16) * expected_dot_q0\n    assert got_q32 == expected_q32\n    assert dot_q32_to_q16(got_q32) == expected_dot_q0 * (1 << 16)\n\n\ndef test_opposite_sign_scales() -> None:\n    lhs_scale_fp16 = half_bits(0.5)\n    rhs_scale_fp16 = half_bits(-2.0)\n    lhs_qs = bytes([0x10, 0x32, 0x54, 0x76, 0x98, 0xBA, 0xDC, 0xFE] * 2)\n    rhs_qs = bytes(reversed(lhs_qs))\n\n    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_qs, rhs_scale_fp16, rhs_qs)\n    assert err == Q4_0_OK\n\n    lhs_signed = unpack_signed(lhs_qs)\n    rhs_signed = unpack_signed(rhs_qs)\n    dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n\n    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n    expected_q32 = lhs_scale_q16 * rhs_scale_q16 * dot_q0\n    assert got_q32 == expected_q32\n\n\ndef test_random_blocks_match_float_reference_bounds() -> None:\n    rng = random.Random(20260412)\n\n    for _ in range(400):\n        lhs_scale = rng.uniform(-4.0, 4.0)\n        rhs_scale = rng.uniform(-4.0, 4.0)\n        lhs_scale_fp16 = half_bits(lhs_scale)\n        rhs_scale_fp16 = half_bits(rhs_scale)\n\n        lhs_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n        rhs_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n\n        err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_qs, rhs_scale_fp16, rhs_qs)\n        assert err == Q4_0_OK\n\n        lhs_signed = unpack_signed(lhs_qs)\n        rhs_signed = unpack_signed(rhs_qs)\n        dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n\n        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n        expected_int_path_q32 = lhs_scale_q16 * rhs_scale_q16 * dot_q0\n        assert got_q32 == expected_int_path_q32\n\n        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * dot_q0 * (1 << 32))\n\n        # Integer path rounds each scale once to Q16 then multiplies.\n        # Bound error on resulting Q32 by small deterministic tolerance.\n        assert abs(got_q32 - expected_float_q32) <= 35_000_000\n\n\ndef test_error_on_bad_input_length() -> None:\n    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 15, half_bits(1.0), b\"\\x00\" * 16)\n    assert err == Q4_0_ERR_BAD_DST_LEN\n\n\ndef test_row_blocks_q16_matches_per_block_rounding() -> None:\n    rng = random.Random(9001)\n\n    lhs_blocks = []\n    rhs_blocks = []\n    for _ in range(9):\n        lhs_scale_fp16 = half_bits(rng.uniform(-3.5, 3.5))\n        rhs_scale_fp16 = half_bits(rng.uniform(-3.5, 3.5))\n        lhs_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n        rhs_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n        lhs_blocks.append((lhs_scale_fp16, lhs_qs))\n        rhs_blocks.append((rhs_scale_fp16, rhs_qs))\n\n    err, got_row_q16 = dot_row_blocks_q16(lhs_blocks, rhs_blocks)\n    assert err == Q4_0_OK\n\n    expected = 0\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        _, block_q32 = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        expected += dot_q32_to_q16(block_q32)\n\n    assert got_row_q16 == expected\n\n\ndef test_row_blocks_q16_distinct_from_round_at_end() -> None:\n    lhs_scale = half_bits(129.0 / 65536.0)\n    rhs_scale = half_bits(129.0 / 65536.0)\n\n    # Build two identical blocks with q_dot_q0 = 1.\n    # Here scale_q16=129 so each block contributes 129*129/2^16 = 0.2539 Q16 units.\n    # Per-block rounding gives 0 + 0, while round-at-end gives 1.\n    lhs_qs = bytes([0x89] + [0x88] * 15)\n    rhs_qs = bytes([0x89] + [0x88] * 15)\n\n    lhs_blocks = [(lhs_scale, lhs_qs), (lhs_scale, lhs_qs)]\n    rhs_blocks = [(rhs_scale, rhs_qs), (rhs_scale, rhs_qs)]\n\n    err, got_row_q16 = dot_row_blocks_q16(lhs_blocks, rhs_blocks)\n    assert err == Q4_0_OK\n\n    _, total_q32 = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n    total_q32 *= 2\n\n    round_at_end_q16 = dot_q32_to_q16(total_q32)\n    assert got_row_q16 != round_at_end_q16\n    assert got_row_q16 == 0\n    assert round_at_end_q16 == 1\n\n\ndef run() -> None:\n    test_identity_block()\n    test_opposite_sign_scales()\n    test_random_blocks_match_float_reference_bounds()\n    test_error_on_bad_input_length()\n    test_row_blocks_q16_matches_per_block_rounding()\n    test_row_blocks_q16_distinct_from_round_at_end()\n    print(\"q4_0_dot_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n---\n// q4_0_q8_0_dot.HC\n// Naive integer-only mixed Q4_0 x Q8_0 dot kernels for TempleOS.\n//\n// Math:\n//   Q4_0 decode: x_i = d4 * (q4_i - 8)\n//   Q8_0 decode: y_i = d8 * q8_i\n//\n// Integer HolyC form:\n//   d4_q16   = Round(d4 * 2^16)\n//   d8_q16   = Round(d8 * 2^16)\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (d4_q16 * d8_q16) * Sum(q4_signed_i * q8_signed_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q4_0_Q8_0_OK               0\n#define Q4_0_Q8_0_ERR_NULL_PTR     1\n#define Q4_0_Q8_0_ERR_BAD_DST_LEN  2\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q4_0_Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0_Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0_Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0_Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0_Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0_Q8_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nI32 Q4_0_Q8_0DotProductBlockQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n    U8 packed_q4;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0_Q8_0F16ToQ16(lhs_q4->d_fp16);\n    rhs_scale_q16 = Q4_0_Q8_0F16ToQ16(rhs_q8->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // q_dot_q0 = Sum(q4_signed_i * q8_signed_i).\n    // Q4 stores two values per byte, so map each nibble to one Q8 lane.\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        packed_q4 = lhs_q4->qs[byte_index];\n\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, FALSE) * rhs_q8->qs[(byte_index << 1)];\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, TRUE) * rhs_q8->qs[(byte_index << 1) + 1];\n    }\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ16Accumulate(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !io_accum_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n\n    // Matmul callers accumulate rows in Q16 lanes.\n    // Keep each block explicit and auditable:\n    //   block_q32 -> rounded block_q16 -> add to running accumulator.\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        total_q16 += Q4_0_Q8_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *io_accum_q16 = total_q16;\n    return Q4_0_Q8_0_OK;\n}\n\nI64 Q4_0_Q8_0DotQ32ToQ16(I64 dot_q32)\n{\n    return Q4_0_Q8_0RoundShiftRightSigned(dot_q32, 16);\n}\n---\n// q8_0_dot.HC\n// Naive integer-only Q8_0 dot product kernels for TempleOS.\n//\n// Math:\n//   GGML Q8_0 stores 32 signed 8-bit values and one fp16 scale d per block.\n//   Decode uses: x_i = d * q_i\n//\n// Integer HolyC form:\n//   d_q16    = Round(d * 2^16)\n//   x_q16    = d_q16 * q_i\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (dA_q16 * dB_q16) * Sum(qA_i * qB_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q8_0_OK               0\n#define Q8_0_ERR_NULL_PTR     1\n#define Q8_0_ERR_BAD_DST_LEN  2\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0DotProductBlockQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q8_0F16ToQ16(lhs->d_fp16);\n    rhs_scale_q16 = Q8_0F16ToQ16(rhs->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // Keep the integer dot explicit and auditable:\n    // q_dot_q0 = Sum(qA_i * qB_i), with q in signed byte domain [-128, 127].\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q8_0_PACKED_BYTES; ++byte_index)\n        q_dot_q0 += lhs->qs[byte_index] * rhs->qs[byte_index];\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q8_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ32ToQ16(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    // WS4 callers can keep the full multi-block dot in widened I64 Q32,\n    // then round once to Q16 for deterministic lane hand-off.\n    status = Q8_0DotProductBlocksQ32(lhs, rhs, block_count, &total_dot_q32);\n    if (status != Q8_0_OK)\n        return status;\n\n    *out_dot_q16 = Q8_0DotQ32ToQ16(total_dot_q32);\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ16Accumulate(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs || !rhs || !io_accum_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n\n    // Matmul callers usually hold accumulators in Q16 lanes.\n    // Keep per-block rounding explicit: Q32 block dot -> rounded Q16 -> add.\n    // This avoids hidden scale changes and makes every block contribution auditable.\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q8_0_OK)\n            return status;\n\n        total_q16 += Q8_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *io_accum_q16 = total_q16;\n    return Q8_0_OK;\n}\n\nI64 Q8_0DotQ32ToQ16(I64 dot_q32)\n{\n    return Q8_0RoundShiftRightSigned(dot_q32, 16);\n}\n","exit_code":0,"status":"completed"}}
