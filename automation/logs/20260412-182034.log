()\n    test_tensor_info_build_offset_index_random_non_overlapping()\n    print(\"gguf_tensor_data_base_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
