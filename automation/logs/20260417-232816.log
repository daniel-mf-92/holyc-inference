{"type":"item.started","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport re, pathlib\ns=pathlib.Path('MASTER_TASKS.md').read_text()\n# queue lines with checkboxes and iq ids\nlines=s.splitlines()\niq_entries=[]\nfor i,l in enumerate(lines,1):\n    m=re.match(r'- \\\\[( |x|X)\\\\] (IQ-(\\\\d+))\\\\s+(.*)\"'$'\"', l)\n    if m:\n        iq_entries.append((i,m.group(1)==' ',m.group(2),int(m.group(3)),m.group(4)))\nunchecked=[e for e in iq_entries if e[1]]\nprint('iq_total',len(iq_entries),'unchecked',len(unchecked),'checked',len(iq_entries)-len(unchecked))\nprint('first_unchecked',unchecked[0][:4],unchecked[0][4][:120] if unchecked else None)\nprint('max_id',max(e[3] for e in iq_entries))\nprint('last_5_iq')\nfor e in iq_entries[-5:]:\n    print(e[2], 'unchecked' if e[1] else 'checked', e[4][:80])\n# ws unchecked real tasks (WSx-yy)\nws=[]\nfor i,l in enumerate(lines,1):\n    m=re.match(r'- \\\\[ \\\\] (WS\\\\d+-\\\\d+)\\\\s+(.*)\"'$'\"', l)\n    if m: ws.append((i,m.group(1),m.group(2)))\nprint('unchecked_ws_task_count',len(ws))\nprint('first_ws',ws[:8])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
