{"type":"item.completed","item":{"id":"item_25","type":"command_execution","command":"/bin/zsh -lc \"cd /Users/danielmatthews-ferrero/Documents/local-codebases/holyc-inference && sed -n '1480,1665p' src/gguf/metadata.HC\"","aggregated_output":"    if (!buf || !cursor || !out_first || !out_second || !out_third)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage all scalar reads through the canonical signed-I32 helper so\n    // triple reads preserve identical bounds/overflow/no-partial-write\n    // semantics while keeping tuple decode paths straightforward to audit.\n    err = GGUFMetadataReadI32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &third);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I64 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadI64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I64 *out_value)\n{\n    // Keep legacy symbol as the canonical parser entrypoint while routing\n    // decode through the explicit no-partial-write helper.\n    return GGUFMetadataReadI64LECheckedNoPartial(buf,\n                                                 buf_nbytes,\n                                                 cursor,\n                                                 table_end,\n                                                 out_value);\n}\n\n// Checked little-endian I64 metadata reader with explicit all-or-nothing\n// staging contract. Cursor/output are committed only after full U64 decode\n// succeeds through the shared checked U64 reader.\nI32 GGUFMetadataReadI64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          I64 *out_value)\n{\n    U64 cur;\n    U64 raw_u64;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Keep no-partial-write semantics by decoding through a staged cursor and\n    // only committing cursor/output after the shared U64 checked reader passes.\n    err = GGUFMetadataReadU64LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &raw_u64);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_value = (I64)raw_u64;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I64 tuple reader with explicit all-or-nothing\n// staging contract. Both lane decodes route through the shared no-partial\n// signed-I64 helper and outputs/cursor are committed only when both succeed.\nI32 GGUFMetadataReadI64PairCheckedNoPartial(U8 *buf,\n                                            U64 buf_nbytes,\n                                            U64 *cursor,\n                                            U64 table_end,\n                                            I64 *out_first,\n                                            I64 *out_second)\n{\n    U64 cur;\n    I64 first;\n    I64 second;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage both lane reads through the canonical no-partial I64 helper so\n    // tuple decoding preserves identical bounds/overflow semantics and never\n    // commits a partially-decoded pair.\n    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n                                                buf_nbytes,\n                                                &cur,\n                                                table_end,\n                                                &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n                                                buf_nbytes,\n                                                &cur,\n                                                table_end,\n                                                &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian FLOAT32 bit-pattern metadata reader.\n// Runtime remains integer-only: the 32-bit payload is returned as raw bits\n// so callers can audit exact IEEE754 encodings without float math.\n// Contract: writes `*out_bits` and advances `*cursor` only on success.\nI32 GGUFMetadataReadF32BitsLEChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U32 *out_bits)\n{\n    // Keep legacy symbol as the canonical parser entrypoint while routing\n    // decode through the explicit no-partial-write helper.\n    return GGUFMetadataReadF32BitsLECheckedNoPartial(buf,\n                                                     buf_nbytes,\n                                                     cursor,\n                                                     table_end,\n                                                     out_bits);\n}\n\n// Checked little-endian FLOAT32 bit-pattern metadata reader with explicit\n// all-or-nothing staging contract. Cursor/output are committed only after\n// full U32 decode succeeds through the shared checked U32 reader.\nI32 GGUFMetadataReadF32BitsLECheckedNoPartial(U8 *buf,\n                                              U64 buf_nbytes,\n                                              U64 *cursor,\n                                              U64 table_end,\n                                              U32 *out_bits)\n{\n    U64 cur;\n    U32 raw_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared U32 checked reader so float32 payload bit\n    // extraction inherits identical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &raw_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_bits = raw_bits;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n","exit_code":0,"status":"completed"}}
