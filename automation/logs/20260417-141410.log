145\t    return ROPE_Q16_OK;\n   146\t}\n   147\t\n   148\tI32 RoPETrySubI64Checked(I64 lhs, I64 rhs, I64 *out_diff)\n   149\t{\n   150\t    I64 neg_rhs;\n   151\t    I32 status;\n   152\t\n   153\t    if (!out_diff)\n   154\t        return ROPE_Q16_ERR_NULL_PTR;\n   155\t\n   156\t    status = RoPETryNegateI64Checked(rhs,\n   157\t                                     &neg_rhs);\n   158\t    if (status != ROPE_Q16_OK)\n   159\t        return status;\n   160\t\n   161\t    return RoPETryAddI64Checked(lhs,\n   162\t                                neg_rhs,\n   163\t                                out_diff);\n   164\t}\n   165\t\n   166\tI32 RoPETryMulI64Checked(I64 lhs, I64 rhs, I64 *out_prod)\n   167\t{\n   168\t    U64 abs_lhs;\n   169\t    U64 abs_rhs;\n   170\t    U64 abs_prod;\n   171\t    Bool is_negative;\n   172\t\n   173\t    if (!out_prod)\n   174\t        return ROPE_Q16_ERR_NULL_PTR;\n   175\t\n   176\t    abs_lhs = RoPEAbsToU64(lhs);\n   177\t    abs_rhs = RoPEAbsToU64(rhs);\n   178\t    is_negative = ((lhs < 0) ^ (rhs < 0));\n   179\t\n   180\t    if (abs_lhs && abs_rhs && abs_lhs > (ROPE_U64_MAX_VALUE / abs_rhs))\n   181\t        return ROPE_Q16_ERR_OVERFLOW;\n   182\t\n   183\t    abs_prod = abs_lhs * abs_rhs;\n   184\t    return RoPEApplySignFromMagnitudeChecked(abs_prod,\n   185\t                                             is_negative,\n   186\t                                             out_prod);\n   187\t}\n   188\t\n   189\tI32 RoPEQ16FromIntChecked(I64 x, I64 *out_q16)\n   190\t{\n   191\t    if (!out_q16)\n   192\t        return ROPE_Q16_ERR_NULL_PTR;\n   193\t\n   194\t    if (x > (ROPE_I64_MAX_VALUE >> FP_Q16_SHIFT) || x < (ROPE_I64_MIN_VALUE >> FP_Q16_SHIFT))\n   195\t        return ROPE_Q16_ERR_OVERFLOW;\n   196\t\n   197\t    *out_q16 = x << FP_Q16_SHIFT;\n   198\t    return ROPE_Q16_OK;\n   199\t}\n   200\t\n   201\tI32 RoPEQ16MulChecked(I64 lhs_q16, I64 rhs_q16, I64 *out_q16)\n   202\t{\n   203\t    U64 abs_lhs;\n   204\t    U64 abs_rhs;\n   205\t    U64 abs_prod;\n   206\t    U64 round_bias;\n   207\t    U64 rounded;\n   208\t    Bool is_negative;\n   209\t\n   210\t    if (!out_q16)\n   211\t        return ROPE_Q16_ERR_NULL_PTR;\n   212\t\n   213\t    abs_lhs = RoPEAbsToU64(lhs_q16);\n   214\t    abs_rhs = RoPEAbsToU64(rhs_q16);\n   215\t    is_negative = ((lhs_q16 < 0) ^ (rhs_q16 < 0));\n   216\t\n   217\t    if (abs_lhs && abs_rhs && abs_lhs > (ROPE_U64_MAX_VALUE / abs_rhs))\n   218\t        return ROPE_Q16_ERR_OVERFLOW;\n   219\t\n   220\t    abs_prod = abs_lhs * abs_rhs;\n   221\t    round_bias = (U64)1 << (FP_Q16_SHIFT - 1);\n   222\t\n   223\t    if (abs_prod > ROPE_U64_MAX_VALUE - round_bias)\n   224\t        rounded = ROPE_U64_MAX_VALUE >> FP_Q16_SHIFT;\n   225\t    else\n   226\t        rounded = (abs_prod + round_bias) >> FP_Q16_SHIFT;\n   227\t\n   228\t    return RoPEApplySignFromMagnitudeChecked(rounded, is_negative, out_q16);\n   229\t}\n   230\t\n   231\tI32 RoPEQ16DivChecked(I64 num_q16, I64 den_q16, I64 *out_q16)\n   232\t{\n   233\t    U64 abs_num;\n   234\t    U64 abs_den;\n   235\t    U64 limit;\n   236\t    U64 int_part;\n   237\t    U64 rem;\n   238\t    U64 result_mag;\n   239\t    Bool is_negative;\n   240\t    I64 bit;\n   241\t\n   242\t    if (!out_q16)\n   243\t        return ROPE_Q16_ERR_NULL_PTR;\n   244\t    if (!den_q16)\n   245\t        return ROPE_Q16_ERR_DOMAIN;\n   246\t\n   247\t    abs_num = RoPEAbsToU64(num_q16);\n   248\t    abs_den = RoPEAbsToU64(den_q16);\n   249\t    is_negative = ((num_q16 < 0) ^ (den_q16 < 0));\n   250\t\n   251\t    limit = (U64)ROPE_I64_MAX_VALUE;\n   252\t    if (is_negative)\n   253\t        limit = 0x8000000000000000;\n   254\t\n   255\t    int_part = abs_num / abs_den;\n   256\t    if (int_part > (limit >> FP_Q16_SHIFT))\n   257\t        return ROPE_Q16_ERR_OVERFLOW;\n   258\t\n   259\t    result_mag = int_part << FP_Q16_SHIFT;\n   260\t    rem = abs_num % abs_den;\n   261\t\n   262\t    // Emit 16 fractional bits by long division.\n   263\t    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n   264\t    {\n   265\t        rem <<= 1;\n   266\t        if (rem >= abs_den)\n   267\t        {\n   268\t            rem -= abs_den;\n   269\t            if (result_mag > limit - (((U64)1) << bit))\n   270\t                return ROPE_Q16_ERR_OVERFLOW;\n   271\t            result_mag |= ((U64)1) << bit;\n   272\t        }\n   273\t    }\n   274\t\n   275\t    // Half-up rounding when residual remainder is >= 0.5.\n   276\t    if (rem >= ((abs_den + 1) >> 1))\n   277\t    {\n   278\t        if (result_mag == limit)\n   279\t            return ROPE_Q16_ERR_OVERFLOW;\n   280\t        result_mag++;\n   281\t    }\n   282\t\n   283\t    return RoPEApplySignFromMagnitudeChecked(result_mag, is_negative, out_q16);\n   284\t}\n   285\t\n   286\tI32 RoPEQ16DivByPositiveIntRoundedChecked(I64 num_q16, I64 den, I64 *out_q16)\n   287\t{\n   288\t    U64 abs_num;\n   289\t    U64 den_u64;\n   290\t    U64 q;\n   291\t    U64 r;\n   292\t    U64 limit;\n   293\t    Bool is_negative;\n   294\t\n   295\t    if (!out_q16)\n   296\t        return ROPE_Q16_ERR_NULL_PTR;\n   297\t    if (den <= 0)\n   298\t        return ROPE_Q16_ERR_BAD_PARAM;\n   299\t\n   300\t    abs_num = RoPEAbsToU64(num_q16);\n   301\t    den_u64 = (U64)den;\n   302\t    is_negative = (num_q16 < 0);\n   303\t\n   304\t    q = abs_num / den_u64;\n   305\t    r = abs_num % den_u64;\n   306\t\n   307\t    limit = (U64)ROPE_I64_MAX_VALUE;\n   308\t    if (is_negative)\n   309\t        limit = 0x8000000000000000;\n   310\t\n   311\t    if (q > limit)\n   312\t        return ROPE_Q16_ERR_OVERFLOW;\n   313\t\n   314\t    if (r >= ((den_u64 + 1) >> 1))\n   315\t    {\n   316\t        if (q == limit)\n   317\t            return ROPE_Q16_ERR_OVERFLOW;\n   318\t        q++;\n   319\t    }\n   320\t\n   321\t    return RoPEApplySignFromMagnitudeChecked(q,\n   322\t                                             is_negative,\n   323\t                                             out_q16);\n   324\t}\n   325\t\n   326\tI32 RoPEQ16NormalizeAnglePiChecked(I64 angle_q16,\n   327\t                                   I64 *out_norm_q16)\n   328\t{\n   329\t    I64 reduced;\n   330\t    I32 status;\n   331\t\n   332\t    if (!out_norm_q16)\n   333\t        return ROPE_Q16_ERR_NULL_PTR;\n   334\t\n   335\t    reduced = angle_q16 % ROPE_Q16_TWO_PI;\n   336\t\n   337\t    if (reduced > ROPE_Q16_PI)\n   338\t    {\n   339\t        status = RoPETrySubI64Checked(reduced,\n   340\t                                      ROPE_Q16_TWO_PI,\n   341\t                                      &reduced);\n   342\t        if (status != ROPE_Q16_OK)\n   343\t            return status;\n   344\t    }\n   345\t    else if (reduced < -ROPE_Q16_PI)\n   346\t    {\n   347\t        status = RoPETryAddI64Checked(reduced,\n   348\t                                      ROPE_Q16_TWO_PI,\n   349\t                                      &reduced);\n   350\t        if (status != ROPE_Q16_OK)\n   351\t            return status;\n   352\t    }\n   353\t\n   354\t    *out_norm_q16 = reduced;\n   355\t    return ROPE_Q16_OK;\n   356\t}\n   357\t\n   358\t// Integer-only sine approximation in Q16:\n   359\t//   sin(x) ~= x - x^3/6 + x^5/120 - x^7/5040\n   360\t// after reducing x to [-pi, pi] and reflecting into [-pi/2, pi/2].\n---related tests---\ntests/test_rope_q16_rotate_head_range_token_window_strided.py\ntests/test_rope_q16_rotate_head_range_preflighted_position.py\ntests/__pycache__/test_rope_q16_rotate_head_range_preflighted_position.cpython-314.pyc\ntests/__pycache__/test_rope_q16_rotate_head_range_token_window_preflighted_head_bases.cpython-314.pyc\ntests/test_rope_q16_rotate_head_range_token_window_preflighted_head_bases.py\ntests/test_rope_q16_rotate_head_range_token_window_strided_preflight_only.py\n---existing preflight test file---\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for RoPEQ16RotateHeadRangeByTokenWindowCheckedStridedPreflightOnly.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\timport sys\n     8\tfrom pathlib import Path\n     9\t\n    10\tsys.path.append(str(Path(__file__).resolve().parent))\n    11\t\n    12\timport test_rope_q16_angle_step as ref\n    13\timport test_rope_q16_rotate_head_range_preflighted_position as preflight_ref\n    14\t\n    15\t\n    16\tdef rope_try_add_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    17\t    if rhs > 0 and lhs > ref.I64_MAX - rhs:\n    18\t        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    19\t    if rhs < 0 and lhs < ref.I64_MIN - rhs:\n    20\t        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    21\t    return ref.ROPE_Q16_OK, lhs + rhs\n    22\t\n    23\t\n    24\tdef rope_try_mul_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    25\t    prod = lhs * rhs\n    26\t    if prod > ref.I64_MAX or prod < ref.I64_MIN:\n    27\t        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    28\t    return ref.ROPE_Q16_OK, prod\n    29\t\n    30\t\n    31\tdef rope_q16_rotate_head_range_by_token_window_checked_strided_preflight_only(\n    32\t    head_cell_capacity: int,\n    33\t    token_base_index: int,\n    34\t    token_stride_q16: int,\n    35\t    range_base_index: int,\n    36\t    head_count: int,\n    37\t    head_stride_cells: int,\n    38\t    head_dim: int,\n    39\t    pair_stride_cells: int,\n    40\t    position_start: int,\n    41\t    token_count: int,\n    42\t    position_step: int,\n    43\t) -> tuple[int, tuple[int, int, int, int]]:\n    44\t    if head_cell_capacity < 0:\n    45\t        return ref.ROPE_Q16_ERR_BAD_PARAM, (0, 0, 0, 0)\n    46\t    if token_stride_q16 < 0:\n    47\t        return ref.ROPE_Q16_ERR_BAD_PARAM, (0, 0, 0, 0)\n    48\t    if token_count < 0:\n    49\t        return ref.ROPE_Q16_ERR_BAD_PARAM, (0, 0, 0, 0)\n    50\t\n    51\t    if token_count == 0 or head_count == 0:\n    52\t        return (\n    53\t            ref.ROPE_Q16_OK,\n    54\t            (range_base_index, range_base_index, range_base_index, position_start),\n    55\t        )\n    56\t\n    57\t    last_abs_range_base = 0\n    58\t    last_head_base = 0\n    59\t    last_last_pair_y = 0\n    60\t    last_token_position = 0\n    61\t\n    62\t    for token_index in range(token_count):\n    63\t        err, token_base_offset = rope_try_mul_i64_checked(token_index, token_stride_q16)\n    64\t        if err != ref.ROPE_Q16_OK:\n    65\t            return err, (0, 0, 0, 0)\n    66\t\n    67\t        err, token_base = rope_try_add_i64_checked(token_base_index, token_base_offset)\n    68\t        if err != ref.ROPE_Q16_OK:\n    69\t            return err, (0, 0, 0, 0)\n    70\t\n    71\t        err, abs_range_base = rope_try_add_i64_checked(token_base, range_base_index)\n    72\t        if err != ref.ROPE_Q16_OK:\n    73\t            return err, (0, 0, 0, 0)\n    74\t\n    75\t        err, token_position_offset = rope_try_mul_i64_checked(token_index, position_step)\n    76\t        if err != ref.ROPE_Q16_OK:\n    77\t            return err, (0, 0, 0, 0)\n    78\t\n    79\t        err, token_position = rope_try_add_i64_checked(position_start, token_position_offset)\n    80\t        if err != ref.ROPE_Q16_OK:\n    81\t            return err, (0, 0, 0, 0)\n    82\t        if token_position < 0:\n    83\t            return ref.ROPE_Q16_ERR_BAD_PARAM, (0, 0, 0, 0)\n    84\t\n    85\t        err, last_head_base = preflight_ref.cap_ref.rope_q16_validate_head_range_capacity_checked(\n    86\t            head_cell_capacity,\n    87\t            abs_range_base,\n    88\t            head_count,\n    89\t            head_stride_cells,\n    90\t        )\n    91\t        if err != ref.ROPE_Q16_OK:\n    92\t            return err, (0, 0, 0, 0)\n    93\t\n    94\t        err, last_last_pair_y = preflight_ref.rope_q16_validate_head_range_span_for_dim_checked(\n    95\t            head_cell_capacity,\n    96\t            abs_range_base,\n    97\t            head_count,\n    98\t