{"type":"item.started","item":{"id":"item_30","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport random\n\nFP_Q16_SHIFT=16\nFP_Q16_ONE=1<<FP_Q16_SHIFT\nEXP_Q16_LN2=45426\nEXP_Q16_MAX_INPUT=655360\nEXP_Q16_MIN_INPUT=-655360\nI64_MAX_VALUE=(1<<63)-1\nU64_MAX_VALUE=(1<<64)-1\nFP_Q16_OK=0\nFP_Q16_ERR_NULL_PTR=1\nFP_Q16_ERR_BAD_PARAM=2\nFP_Q16_ERR_OVERFLOW=4\n\n\ndef fpq16_mul(a,b):\n    p=a*b\n    if p>=0:\n        return (p + (1<<(FP_Q16_SHIFT-1)))>>FP_Q16_SHIFT\n    return -(((-p)+(1<<(FP_Q16_SHIFT-1)))>>FP_Q16_SHIFT)\n\ndef clamp_checked(x,out_present=True):\n    if not out_present:\n        return FP_Q16_ERR_NULL_PTR,0\n    if EXP_Q16_MIN_INPUT>EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM,0\n    if x<EXP_Q16_MIN_INPUT:return FP_Q16_OK,EXP_Q16_MIN_INPUT\n    if x>EXP_Q16_MAX_INPUT:return FP_Q16_OK,EXP_Q16_MAX_INPUT\n    return FP_Q16_OK,x\n\ndef exp_from_clamped_checked(x,out_present=True):\n    if not out_present:return FP_Q16_ERR_NULL_PTR,0\n    if x<EXP_Q16_MIN_INPUT or x>EXP_Q16_MAX_INPUT:return FP_Q16_ERR_BAD_PARAM,0\n    if x>=EXP_Q16_MAX_INPUT:return FP_Q16_OK,I64_MAX_VALUE\n    if x<=EXP_Q16_MIN_INPUT:return FP_Q16_OK,0\n    k=x//EXP_Q16_LN2\n    if x<0 and (x%EXP_Q16_LN2):k-=1\n    r=x-k*EXP_Q16_LN2\n    r2=fpq16_mul(r,r)\n    r3=fpq16_mul(r2,r)\n    r4=fpq16_mul(r3,r)\n    poly=FP_Q16_ONE+r+(r2//2)+(r3//6)+(r4//24)\n    if k>=0:\n        if k>=30:return FP_Q16_OK,I64_MAX_VALUE\n        if poly>(I64_MAX_VALUE>>k):return FP_Q16_OK,I64_MAX_VALUE\n        return FP_Q16_OK, poly<<k\n    if k<=-63:return FP_Q16_OK,0\n    return FP_Q16_OK,poly>>(-k)\n\ndef exp_array_checked(inp,out,count,s_in=0x1000,s_out=0x2000):\n    if inp is None or out is None:return FP_Q16_ERR_NULL_PTR,out\n    if count<0:return FP_Q16_ERR_BAD_PARAM,out\n    if count==0:return FP_Q16_OK,out\n    last_index=count-1\n    if last_index>((1<<63)-1>>3):return FP_Q16_ERR_OVERFLOW,out\n    off=last_index<<3\n    if s_in>(U64_MAX_VALUE-off):return FP_Q16_ERR_OVERFLOW,out\n    if s_out>(U64_MAX_VALUE-off):return FP_Q16_ERR_OVERFLOW,out\n    for i in range(count):\n        e,c=clamp_checked(inp[i])\n        if e:return e,out\n        e,v=exp_from_clamped_checked(c)\n        if e:return e,out\n        out[i]=v\n    return FP_Q16_OK,out\n\n# edge/error checks\nassert exp_array_checked(None,[0],1)[0]==FP_Q16_ERR_NULL_PTR\nassert exp_array_checked([0],None,1)[0]==FP_Q16_ERR_NULL_PTR\nassert exp_array_checked([0],[0],-1)[0]==FP_Q16_ERR_BAD_PARAM\nassert exp_array_checked([1,2,3],[9,9,9],0)==(FP_Q16_OK,[9,9,9])\nassert exp_array_checked([0],[0],((1<<63)-1>>3)+2)[0]==FP_Q16_ERR_OVERFLOW\n\ncount=4\nnear=U64_MAX_VALUE-((count-1)<<3)+1\nassert exp_array_checked([0]*count,[0]*count,count,s_in=near)[0]==FP_Q16_ERR_OVERFLOW\nassert exp_array_checked([0]*count,[0]*count,count,s_out=near)[0]==FP_Q16_ERR_OVERFLOW\n\n# deterministic vectors\nv=[EXP_Q16_MIN_INPUT-111,EXP_Q16_MIN_INPUT,-123456,-1,0,1,123456,EXP_Q16_MAX_INPUT,EXP_Q16_MAX_INPUT+111]\nout=[0]*len(v)\nerr,got=exp_array_checked(v,out,len(v))\nassert err==FP_Q16_OK\nfor i,x in enumerate(v):\n    ce,cl=clamp_checked(x)\n    assert ce==0\n    ee,ev=exp_from_clamped_checked(cl)\n    assert ee==0\n    assert got[i]==ev\n\n# randomized + in-place parity\nrng=random.Random(20260417_165)\nfor _ in range(2000):\n    n=rng.randint(1,128)\n    data=[rng.randint(-(1<<62),(1<<62)) for _ in range(n)]\n    out=[0]*n\n    err,got=exp_array_checked(data,out,n)\n    assert err==0\n    for i,x in enumerate(data):\n        _,cl=clamp_checked(x)\n        _,ev=exp_from_clamped_checked(cl)\n        assert got[i]==ev\n    data2=data.copy()\n    err2,got2=exp_array_checked(data2,data2,n)\n    assert err2==0\n    assert got2==got\n\nprint('intexp_exp_array_checked_reference_checks=ok')\nPY\npython3 tests/test_intexp_exp_from_clamped_input_checked.py\npython3 tests/test_intexp_clamp_array_to_input_domain_checked.py\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
