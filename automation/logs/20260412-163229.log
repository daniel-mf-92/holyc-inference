{"type":"item.completed","item":{"id":"item_39","type":"command_execution","command":"/bin/zsh -lc \"cd /Users/danielmatthews-ferrero/Documents/local-codebases/holyc-inference\nnl -ba src/gguf/tensor_data_base.HC | sed -n '1,220p'\nnl -ba tests/test_gguf_tensor_data_base.py | sed -n '1,240p'\nrg -n \\\"IQ-028|IQ-036|IQ-037|loop-022\\\" MASTER_TASKS.md\"","aggregated_output":"     1\t// tensor_data_base.HC\n     2\t// GGUF tensor-data base alignment helpers for HolyC inference runtime.\n     3\t\n     4\t#define GGUF_TDBASE_OK 0\n     5\t#define GGUF_TDBASE_ERR_NULL_PTR 1\n     6\t#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n     7\t#define GGUF_TDBASE_ERR_OVERFLOW 3\n     8\t\n     9\t// GGUF default tensor alignment when metadata key `general.alignment`\n    10\t// is absent.\n    11\t#define GGUF_DEFAULT_ALIGNMENT 32\n    12\t\n    13\tBool GGUFIsPow2U32(U32 value)\n    14\t{\n    15\t    if (!value)\n    16\t        return FALSE;\n    17\t    return (value & (value - 1)) == 0;\n    18\t}\n    19\t\n    20\tI64 GGUFValidateAlignment(U32 alignment)\n    21\t{\n    22\t    if (!GGUFIsPow2U32(alignment))\n    23\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    24\t    return GGUF_TDBASE_OK;\n    25\t}\n    26\t\n    27\tI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n    28\t{\n    29\t    U64 mask;\n    30\t\n    31\t    if (!out)\n    32\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    33\t\n    34\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n    35\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    36\t\n    37\t    // For power-of-two alignments, align-up is:\n    38\t    //   (value + (alignment - 1)) & ~(alignment - 1)\n    39\t    // Keep overflow checks explicit so giant malformed offsets are rejected.\n    40\t    mask = (U64)alignment - 1;\n    41\t    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n    42\t        return GGUF_TDBASE_ERR_OVERFLOW;\n    43\t\n    44\t    *out = (value + mask) & ~mask;\n    45\t    return GGUF_TDBASE_OK;\n    46\t}\n    47\t\n    48\tI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n    49\t                            U32 alignment,\n    50\t                            U64 *out_tensor_data_base)\n    51\t{\n    52\t    return GGUFAlignUpU64(cursor_after_tensor_info,\n    53\t                          alignment,\n    54\t                          out_tensor_data_base);\n    55\t}\n    56\t\n    57\tI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n    58\t                                   U64 *out_tensor_data_base)\n    59\t{\n    60\t    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n    61\t                                   GGUF_DEFAULT_ALIGNMENT,\n    62\t                                   out_tensor_data_base);\n    63\t}\n    64\t\n    65\tBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n    66\t{\n    67\t    U64 mask;\n    68\t\n    69\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n    70\t        return FALSE;\n    71\t\n    72\t    mask = (U64)alignment - 1;\n    73\t    return (offset & mask) == 0;\n    74\t}\n    75\t\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for GGUF tensor-data base alignment semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\t\n     8\tGGUF_TDBASE_OK = 0\n     9\tGGUF_TDBASE_ERR_NULL_PTR = 1\n    10\tGGUF_TDBASE_ERR_BAD_ALIGNMENT = 2\n    11\tGGUF_TDBASE_ERR_OVERFLOW = 3\n    12\t\n    13\tGGUF_DEFAULT_ALIGNMENT = 32\n    14\tU64_MAX = (1 << 64) - 1\n    15\t\n    16\t\n    17\tdef is_pow2_u32(value: int) -> bool:\n    18\t    return value > 0 and (value & (value - 1)) == 0\n    19\t\n    20\t\n    21\tdef validate_alignment(alignment: int) -> int:\n    22\t    if not is_pow2_u32(alignment):\n    23\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    24\t    return GGUF_TDBASE_OK\n    25\t\n    26\t\n    27\tdef align_up_u64(value: int, alignment: int):\n    28\t    err = validate_alignment(alignment)\n    29\t    if err != GGUF_TDBASE_OK:\n    30\t        return err, 0\n    31\t\n    32\t    mask = alignment - 1\n    33\t    if value > U64_MAX - mask:\n    34\t        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    35\t\n    36\t    out = (value + mask) & ~mask\n    37\t    return GGUF_TDBASE_OK, out\n    38\t\n    39\t\n    40\tdef tensor_data_base_align(cursor_after_tensor_info: int, alignment: int):\n    41\t    return align_up_u64(cursor_after_tensor_info, alignment)\n    42\t\n    43\t\n    44\tdef tensor_data_base_align_default(cursor_after_tensor_info: int):\n    45\t    return tensor_data_base_align(cursor_after_tensor_info, GGUF_DEFAULT_ALIGNMENT)\n    46\t\n    47\t\n    48\tdef tensor_data_base_is_aligned(offset: int, alignment: int) -> bool:\n    49\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n    50\t        return False\n    51\t    return (offset & (alignment - 1)) == 0\n    52\t\n    53\t\n    54\tdef test_default_alignment_examples() -> None:\n    55\t    assert tensor_data_base_align_default(0) == (GGUF_TDBASE_OK, 0)\n    56\t    assert tensor_data_base_align_default(1) == (GGUF_TDBASE_OK, 32)\n    57\t    assert tensor_data_base_align_default(31) == (GGUF_TDBASE_OK, 32)\n    58\t    assert tensor_data_base_align_default(32) == (GGUF_TDBASE_OK, 32)\n    59\t    assert tensor_data_base_align_default(33) == (GGUF_TDBASE_OK, 64)\n    60\t\n    61\t\n    62\tdef test_custom_power_of_two_alignment() -> None:\n    63\t    err, base = tensor_data_base_align(0x1234, 64)\n    64\t    assert err == GGUF_TDBASE_OK\n    65\t    assert base == 0x1240\n    66\t    assert tensor_data_base_is_aligned(base, 64)\n    67\t\n    68\t\n    69\tdef test_reject_non_power_of_two_alignment() -> None:\n    70\t    assert tensor_data_base_align(100, 0)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    71\t    assert tensor_data_base_align(100, 3)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    72\t    assert tensor_data_base_align(100, 24)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    73\t    assert tensor_data_base_is_aligned(128, 24) is False\n    74\t\n    75\t\n    76\tdef test_overflow_guard_near_u64_max() -> None:\n    77\t    err, _ = tensor_data_base_align(U64_MAX - 7, 16)\n    78\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n    79\t\n    80\t    err, base = tensor_data_base_align(U64_MAX - 15, 16)\n    81\t    assert err == GGUF_TDBASE_OK\n    82\t    assert base == U64_MAX - 15\n    83\t\n    84\t\n    85\tdef test_random_alignment_matches_reference_formula() -> None:\n    86\t    rng = random.Random(760031)\n    87\t\n    88\t    for _ in range(1000):\n    89\t        alignment = 1 << rng.randint(0, 20)\n    90\t        cursor = rng.randrange(0, 1 << 56)\n    91\t\n    92\t        err, got = tensor_data_base_align(cursor, alignment)\n    93\t        assert err == GGUF_TDBASE_OK\n    94\t\n    95\t        reference = ((cursor + (alignment - 1)) // alignment) * alignment\n    96\t        assert got == reference\n    97\t        assert got >= cursor\n    98\t        assert tensor_data_base_is_aligned(got, alignment)\n    99\t\n   100\t\n   101\tdef run() -> None:\n   102\t    test_default_alignment_examples()\n   103\t    test_custom_power_of_two_alignment()\n   104\t    test_reject_non_power_of_two_alignment()\n   105\t    test_overflow_guard_near_u64_max()\n   106\t    test_random_alignment_matches_reference_formula()\n   107\t    print(\"gguf_tensor_data_base_reference_checks=ok\")\n   108\t\n   109\t\n   110\tif __name__ == \"__main__\":\n   111\t    run()\n   112\t\n216:- [x] IQ-028 Implement GGUF tensor data base alignment helper in `src/gguf/tensor_data_base.HC` (WS2-04)\n224:- [ ] IQ-036 Implement GGUF tensor data offset resolver (`GGUFTensorDataBaseOffset`) in `src/gguf/tensor_data_base.HC` with alignment validation (WS2-04)\n225:- [ ] IQ-037 Implement GGML tensor block-size/byte-size helpers in `src/gguf/tensor_data_base.HC` for F32/F16/Q4_0/Q8_0 sizing math (WS2-04)\n253:| 2026-04-12 | loop-022 | IQ-028 tensor data base alignment helper | done | Added `src/gguf/tensor_data_base.HC` alignment/overflow checks + `tests/test_gguf_tensor_data_base.py`; `python3 tests/test_gguf_tensor_data_base.py && python3 tests/test_gguf_metadata_parse.py && python3 tests/test_gguf_tensorinfo_parse.py` passed |\n","exit_code":0,"status":"completed"}}
