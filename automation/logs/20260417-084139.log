{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/gguf/metadata.HC; echo '---'; sed -n '260,560p' src/gguf/metadata.HC; echo '---'; ls -1 tests | rg 'gguf_metadata' ; sed -n '1,260p' tests/test_gguf_metadata_parse.py\"","aggregated_output":"// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n#define GGUF_META_PARSE_ERR_NOT_FOUND 9\n#define GGUF_META_PARSE_ERR_TYPE_MISMATCH 10\n\n#define GGUF_META_TABLE_OK 0\n#define GGUF_META_TABLE_ERR_NULL_PTR 1\n#define GGUF_META_TABLE_ERR_BAD_PARAM 2\n#define GGUF_META_TABLE_ERR_OVERFLOW 3\n#define GGUF_META_TABLE_ERR_OUT_OF_BOUNDS 4\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\n// Validate metadata table byte-window math before any parser cursor movement.\n// Contract: `out_table_end` is written only on success.\nI32 GGUFMetadataTableSpanValidateChecked(U64 table_start,\n                                         U64 table_nbytes,\n                                         U64 file_nbytes,\n                                         U64 *out_table_end)\n{\n    U64 table_end;\n\n    if (!out_table_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Parser cursors are signed in multiple call sites; reject spans that do\n    // not fit cleanly in positive I64 address space.\n    if (table_start > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (table_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (file_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (table_start > file_nbytes)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    if (table_nbytes > (0xFFFFFFFFFFFFFFFF - table_start))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    table_end = table_start + table_nbytes;\n    if (table_end > file_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_table_end = table_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate metadata table bounds, then derive a checked cursor position at\n// `table_start + cursor_advance`. This helper keeps parser entrypoints on one\n// auditable range-math path before any field reads happen.\n// Contract: out pointers are written only on success.\nI32 GGUFMetadataTableCursorAdvanceChecked(U64 table_start,\n                                          U64 table_nbytes,\n                                          U64 file_nbytes,\n                                          U64 cursor_advance,\n                                          U64 *out_cursor,\n                                          U64 *out_table_end)\n{\n    U64 table_end;\n    U64 cursor;\n    I32 err;\n\n    if (!out_cursor || !out_table_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    err = GGUFMetadataTableSpanValidateChecked(table_start,\n                                               table_nbytes,\n                                               file_nbytes,\n                                               &table_end);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Advance is relative to table_start. Reject requests that would place\n    // cursor beyond [table_start, table_end]. Equal-to-end is legal and\n    // matches cursor semantics used by metadata table loops.\n    if (cursor_advance > table_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    // Keep add-overflow guard explicit even though span validation already\n    // bounds table_start + table_nbytes.\n    if (table_start > (0xFFFFFFFFFFFFFFFF - cursor_advance))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    cursor = table_start + cursor_advance;\n    if (cursor > table_end)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_cursor = cursor;\n    *out_table_end = table_end;\n    return GGUF_META_TABLE_OK;\n}\n\nBool GGUFMetaCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n{\n    if (!buf)\n        return FALSE;\n    if (size < 0 || cursor < 0 || need < 0)\n        return FALSE;\n    if (cursor > size)\n        return FALSE;\n    if (need > size - cursor)\n        return FALSE;\n    return TRUE;\n}\n\nBool GGUFMetaReadU8(U8 *buf, I64 size, I64 *cursor, U8 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 1))\n        return FALSE;\n\n    *out = buf[c];\n    *cursor = c + 1;\n    return TRUE;\n}\n\nBool GGUFMetaReadU16LE(U8 *buf, I64 size, I64 *cursor, U16 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 2))\n        return FALSE;\n\n    *out = (U16)buf[c]\n         | ((U16)buf[c + 1] << 8);\n\n    *cursor = c + 2;\n    return TRUE;\n}\n\nBool GGUFMetaReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFMetaReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nBool GGUFMetaTypeSupported(U32 type)\n{\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n        case GGUF_TYPE_BOOL:\n        case GGUF_TYPE_STRING:\n---\n        case GGUF_TYPE_STRING:\n        case GGUF_TYPE_ARRAY:\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            return TRUE;\n    }\n\n    return FALSE;\n}\n\nU0 GGUFMetaZeroString(GGUFString *s)\n{\n    if (!s)\n        return;\n    s->len = 0;\n    s->data = NULL;\n}\n\nU0 GGUFMetaZeroValue(GGUFMetaValue *v)\n{\n    if (!v)\n        return;\n\n    v->type = 0;\n    v->u64 = 0;\n    v->i64 = 0;\n    v->b = FALSE;\n    GGUFMetaZeroString(&v->str);\n    v->array_elem_type = 0;\n    v->array_len = 0;\n    v->array_payload_off = 0;\n    v->array_payload_bytes = 0;\n}\n\nU0 GGUFMetaZeroKV(GGUFMetadataKV *kv)\n{\n    if (!kv)\n        return;\n    GGUFMetaZeroString(&kv->key);\n    GGUFMetaZeroValue(&kv->value);\n}\n\nU0 GGUFMetaFreeString(GGUFString *s)\n{\n    if (!s)\n        return;\n\n    if (s->data)\n        Free(s->data);\n\n    s->data = NULL;\n    s->len = 0;\n}\n\nI64 GGUFMetaReadString(U8 *buf, I64 size, I64 *cursor, GGUFString *out)\n{\n    U64 len;\n    I64 c;\n    U8 *dst;\n    I64 i;\n\n    if (!cursor || !out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    GGUFMetaZeroString(out);\n\n    if (!GGUFMetaReadU64LE(buf, size, cursor, &len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (len > GGUF_MAX_STRING_BYTES)\n        return GGUF_META_PARSE_ERR_BAD_STRING_LEN;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n\n    dst = MAlloc(len + 1);\n    if (!dst)\n        return GGUF_META_PARSE_ERR_ALLOC;\n\n    for (i = 0; i < len; ++i)\n        dst[i] = buf[c + i];\n    dst[len] = 0;\n\n    *cursor = c + len;\n\n    out->len = len;\n    out->data = dst;\n    return GGUF_META_PARSE_OK;\n}\n\nI64 GGUFMetaSkipValueByType(U8 *buf, I64 size, I64 *cursor, U32 type)\n{\n    U8 u8v;\n    U16 u16v;\n    U32 u32v;\n    U64 u64v;\n    U32 elem_type;\n    U64 elem_count;\n    U64 i;\n    I64 err;\n\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_BOOL:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_STRING:\n            {\n                GGUFString tmp;\n\n                err = GGUFMetaReadString(buf, size, cursor, &tmp);\n                if (err != GGUF_META_PARSE_OK)\n                    return err;\n                GGUFMetaFreeString(&tmp);\n                return GGUF_META_PARSE_OK;\n            }\n\n        case GGUF_TYPE_ARRAY:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            if (elem_type == GGUF_TYPE_ARRAY)\n                return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n            if (!GGUFMetaTypeSupported(elem_type))\n                return GGUF_META_PARSE_ERR_BAD_TYPE;\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n                return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n\n            for (i = 0; i < elem_count; ++i)\n            {\n                err = GGUFMetaSkipValueByType(buf, size, cursor, elem_type);\n                if (err != GGUF_META_PARSE_OK)\n                    return err;\n            }\n\n            return GGUF_META_PARSE_OK;\n    }\n\n    return GGUF_META_PARSE_ERR_BAD_TYPE;\n}\n\nI64 GGUFMetaParseScalar(U8 *buf, I64 size, I64 *cursor, U32 type, GGUFMetaValue *out)\n{\n    U8 u8v;\n    U16 u16v;\n    U32 u32v;\n    U64 u64v;\n    I64 err;\n\n    if (!out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    out->type = type;\n\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u8v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT8:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I8)u8v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u16v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I16)u16v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u32v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I32)u32v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u64v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I64)u64v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_FLOAT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u32v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_FLOAT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u64v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_BOOL:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->b = (u8v != 0);\n            out->u64 = out->b;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_STRING:\n            err = GGUFMetaReadString(buf, size, cursor, &out->str);\n            if (err != GGUF_META_PARSE_OK)\n                return err;\n            return GGUF_META_PARSE_OK;\n    }\n\n    return GGUF_META_PARSE_ERR_BAD_TYPE;\n}\n\nI64 GGUFMetaParseValue(U8 *buf, I64 size, I64 *cursor, GGUFMetaValue *out)\n{\n    U32 type;\n    U32 elem_type;\n    U64 elem_count;\n    I64 payload_begin;\n    I64 err;\n    U64 i;\n\n    if (!cursor || !out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    if (!GGUFMetaReadU32LE(buf, size, cursor, &type))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    GGUFMetaZeroValue(out);\n    out->type = type;\n\n    if (type != GGUF_TYPE_ARRAY)\n        return GGUFMetaParseScalar(buf, size, cursor, type, out);\n\n    if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (elem_type == GGUF_TYPE_ARRAY)\n        return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n    if (!GGUFMetaTypeSupported(elem_type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n        return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n\n    payload_begin = *cursor;\n---\ntest_gguf_metadata_parse.py\n#!/usr/bin/env python3\n\"\"\"Focused GGUF metadata parser parity fixtures.\n\nThis is host-side validation only. It mirrors GGUF metadata binary layout and\nchecks that expected decode/validation behavior matches HolyC parser intent.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport struct\n\nGGUF_TYPE_UINT8 = 0\nGGUF_TYPE_INT8 = 1\nGGUF_TYPE_UINT16 = 2\nGGUF_TYPE_INT16 = 3\nGGUF_TYPE_UINT32 = 4\nGGUF_TYPE_INT32 = 5\nGGUF_TYPE_FLOAT32 = 6\nGGUF_TYPE_BOOL = 7\nGGUF_TYPE_STRING = 8\nGGUF_TYPE_ARRAY = 9\nGGUF_TYPE_UINT64 = 10\nGGUF_TYPE_INT64 = 11\nGGUF_TYPE_FLOAT64 = 12\n\nGGUF_META_PARSE_OK = 0\nGGUF_META_PARSE_ERR_TRUNCATED = 2\nGGUF_META_PARSE_ERR_BAD_TYPE = 3\nGGUF_META_PARSE_ERR_NESTED_ARRAY = 7\nGGUF_META_PARSE_ERR_NOT_FOUND = 9\nGGUF_META_PARSE_ERR_TYPE_MISMATCH = 10\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU64_MAX = (1 << 64) - 1\n\n\ndef u8(v: int) -> bytes:\n    return struct.pack(\"<B\", v)\n\n\ndef u16(v: int) -> bytes:\n    return struct.pack(\"<H\", v)\n\n\ndef u32(v: int) -> bytes:\n    return struct.pack(\"<I\", v)\n\n\ndef u64(v: int) -> bytes:\n    return struct.pack(\"<Q\", v)\n\n\ndef i32(v: int) -> bytes:\n    return struct.pack(\"<i\", v)\n\n\ndef i64(v: int) -> bytes:\n    return struct.pack(\"<q\", v)\n\n\ndef f32(v: float) -> bytes:\n    return struct.pack(\"<f\", v)\n\n\ndef gguf_string(s: str) -> bytes:\n    raw = s.encode(\"utf-8\")\n    return u64(len(raw)) + raw\n\n\ndef meta_entry(key: str, value_type: int, payload: bytes) -> bytes:\n    return gguf_string(key) + u32(value_type) + payload\n\n\ndef scalar_payload(t: int, v):\n    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_BOOL):\n        return u8(int(v))\n    if t == GGUF_TYPE_INT8:\n        return struct.pack(\"<b\", int(v))\n    if t == GGUF_TYPE_UINT16:\n        return u16(int(v))\n    if t == GGUF_TYPE_INT16:\n        return struct.pack(\"<h\", int(v))\n    if t == GGUF_TYPE_UINT32:\n        return u32(int(v))\n    if t == GGUF_TYPE_INT32:\n        return i32(int(v))\n    if t == GGUF_TYPE_UINT64:\n        return u64(int(v))\n    if t == GGUF_TYPE_INT64:\n        return i64(int(v))\n    if t == GGUF_TYPE_FLOAT32:\n        return f32(float(v))\n    if t == GGUF_TYPE_FLOAT64:\n        return struct.pack(\"<d\", float(v))\n    if t == GGUF_TYPE_STRING:\n        return gguf_string(str(v))\n    raise ValueError(t)\n\n\ndef array_payload(elem_type: int, values: list) -> bytes:\n    payload = b\"\".join(\n        scalar_payload(elem_type, value) if elem_type != GGUF_TYPE_STRING else gguf_string(value)\n        for value in values\n    )\n    return u32(elem_type) + u64(len(values)) + payload\n\n\ndef decode_scalar_by_type(raw: bytes, t: int):\n    if t == GGUF_TYPE_UINT8:\n        return raw[0]\n    if t == GGUF_TYPE_INT8:\n        return int.from_bytes(raw[:1], \"little\", signed=True)\n    if t == GGUF_TYPE_UINT16:\n        return int.from_bytes(raw[:2], \"little\", signed=False)\n    if t == GGUF_TYPE_INT16:\n        return int.from_bytes(raw[:2], \"little\", signed=True)\n    if t == GGUF_TYPE_UINT32:\n        return int.from_bytes(raw[:4], \"little\", signed=False)\n    if t == GGUF_TYPE_INT32:\n        return int.from_bytes(raw[:4], \"little\", signed=True)\n    if t == GGUF_TYPE_UINT64:\n        return int.from_bytes(raw[:8], \"little\", signed=False)\n    if t == GGUF_TYPE_INT64:\n        return int.from_bytes(raw[:8], \"little\", signed=True)\n    if t == GGUF_TYPE_BOOL:\n        return raw[0] != 0\n    if t == GGUF_TYPE_FLOAT32:\n        return int.from_bytes(raw[:4], \"little\", signed=False)\n    if t == GGUF_TYPE_FLOAT64:\n        return int.from_bytes(raw[:8], \"little\", signed=False)\n    raise ValueError(t)\n\n\ndef decode_array_payload(buf: bytes, parsed_value: dict):\n    elem_type = parsed_value[\"array_elem_type\"]\n    cursor = parsed_value[\"array_payload_off\"]\n    end = cursor + parsed_value[\"array_payload_bytes\"]\n\n    values = []\n    while cursor < end:\n        if elem_type == GGUF_TYPE_STRING:\n            err, cursor2, value = parse_gguf_string(buf, cursor)\n            assert err == GGUF_META_PARSE_OK\n            cursor = cursor2\n            values.append(value)\n            continue\n\n        width = {\n            GGUF_TYPE_UINT8: 1,\n            GGUF_TYPE_INT8: 1,\n            GGUF_TYPE_BOOL: 1,\n            GGUF_TYPE_UINT16: 2,\n            GGUF_TYPE_INT16: 2,\n            GGUF_TYPE_UINT32: 4,\n            GGUF_TYPE_INT32: 4,\n            GGUF_TYPE_FLOAT32: 4,\n            GGUF_TYPE_UINT64: 8,\n            GGUF_TYPE_INT64: 8,\n            GGUF_TYPE_FLOAT64: 8,\n        }[elem_type]\n        raw = buf[cursor : cursor + width]\n        assert len(raw) == width\n        values.append(decode_scalar_by_type(raw, elem_type))\n        cursor += width\n\n    assert cursor == end\n    assert len(values) == parsed_value[\"array_len\"]\n    return values\n\n\ndef parse_gguf_string(buf: bytes, cursor: int):\n    if cursor + 8 > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    (n,) = struct.unpack_from(\"<Q\", buf, cursor)\n    cursor += 8\n    if cursor + n > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    s = buf[cursor : cursor + n].decode(\"utf-8\")\n    cursor += n\n    return GGUF_META_PARSE_OK, cursor, s\n\n\ndef skip_value_by_type(buf: bytes, cursor: int, t: int):\n    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_INT8, GGUF_TYPE_BOOL):\n        return (GGUF_META_PARSE_OK, cursor + 1) if cursor + 1 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT16, GGUF_TYPE_INT16):\n        return (GGUF_META_PARSE_OK, cursor + 2) if cursor + 2 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT32, GGUF_TYPE_INT32, GGUF_TYPE_FLOAT32):\n        return (GGUF_META_PARSE_OK, cursor + 4) if cursor + 4 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT64, GGUF_TYPE_INT64, GGUF_TYPE_FLOAT64):\n        return (GGUF_META_PARSE_OK, cursor + 8) if cursor + 8 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t == GGUF_TYPE_STRING:\n        err, cursor2, _ = parse_gguf_string(buf, cursor)\n        return err, cursor2\n    if t == GGUF_TYPE_ARRAY:\n        return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor\n    return GGUF_META_PARSE_ERR_BAD_TYPE, cursor\n\n\ndef parse_value(buf: bytes, cursor: int):\n    if cursor + 4 > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    (t,) = struct.unpack_from(\"<I\", buf, cursor)\n    cursor += 4\n\n    if t == GGUF_TYPE_ARRAY:\n        if cursor + 12 > len(buf):\n            return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n        elem_type, n = struct.unpack_from(\"<IQ\", buf, cursor)\n        cursor += 12\n        if elem_type == GGUF_TYPE_ARRAY:\n            return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor, None\n        if elem_type > GGUF_TYPE_FLOAT64:\n            return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n\n        payload_start = cursor\n        for _ in range(n):\n            err, cursor = skip_value_by_type(buf, cursor, elem_type)\n            if err != GGUF_META_PARSE_OK:\n                return err, cursor, None\n\n        return GGUF_META_PARSE_OK, cursor, {\n            \"type\": t,\n            \"array_elem_type\": elem_type,\n            \"array_len\": n,\n            \"array_payload_off\": payload_start,\n            \"array_payload_bytes\": cursor - payload_start,\n        }\n\n    if t > GGUF_TYPE_FLOAT64:\n        return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n\n    if t == GGUF_TYPE_STRING:\n        err, cursor, value = parse_gguf_string(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, None\n        return GGUF_META_PARSE_OK, cursor, {\"type\": t, \"value\": value}\n\n    err, cursor2 = skip_value_by_type(buf, cursor, t)\n    if err != GGUF_META_PARSE_OK:\n        return err, cursor2, None\n\n    raw = buf[cursor:cursor2]\n    return GGUF_META_PARSE_OK, cursor2, {\"type\": t, \"raw\": raw}\n\n\ndef parse_metadata_table(buf: bytes, count: int):\n    items = []\n    cursor = 0\n    for _ in range(count):\n        err, cursor, key = parse_gguf_string(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, items\n\n","exit_code":0,"status":"completed"}}
