{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' src/gguf/metadata.HC; echo '---'; sed -n '280,620p' src/gguf/metadata.HC; echo '---TESTS---'; ls tests | rg 'gguf_metadata_read_.*checked|gguf_metadata_parse'; sed -n '1,220p' tests/test_gguf_metadata_read_u64le_checked.py; echo '---'; sed -n '1,240p' tests/test_gguf_metadata_read_i8_checked.py; echo '---'; sed -n '1,280p' tests/test_gguf_metadata_parse.py\"","aggregated_output":"// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n#define GGUF_META_PARSE_ERR_NOT_FOUND 9\n#define GGUF_META_PARSE_ERR_TYPE_MISMATCH 10\n\n#define GGUF_META_TABLE_OK 0\n#define GGUF_META_TABLE_ERR_NULL_PTR 1\n#define GGUF_META_TABLE_ERR_BAD_PARAM 2\n#define GGUF_META_TABLE_ERR_OVERFLOW 3\n#define GGUF_META_TABLE_ERR_OUT_OF_BOUNDS 4\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor);\n\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value);\n\nI32 GGUFMetadataReadI8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              I8 *out_value);\n\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second);\n\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U16 *out_value);\n\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value);\n\nI32 GGUFMetadataReadU32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U32 *out_value);\n\nI32 GGUFMetadataReadU64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U64 *out_value);\n\nI32 GGUFMetadataReadU64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          U64 *out_value);\n\nI32 GGUFMetadataReadI32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I32 *out_value);\n\nI32 GGUFMetadataReadI64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I64 *out_value);\n\nI32 GGUFMetadataReadI64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          I64 *out_value);\n\nI32 GGUFMetadataReadF64BitsLEChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U64 *out_bits);\n\nI32 GGUFMetadataReadBoolChecked(U8 *buf,\n                                U64 buf_nbytes,\n                                U64 *cursor,\n                                U64 table_end,\n                                Bool *out_value);\n\nI32 GGUFMetadataReadStringLenU64Checked(U8 *buf,\n                                        U64 buf_nbytes,\n                                        U64 *cursor,\n                                        U64 table_end,\n                                        U64 *out_len);\n\nI32 GGUFMetadataReadStringU64HeaderAndBoundsChecked(U8 *buf,\n                                                    U64 buf_nbytes,\n                                                    U64 *cursor,\n                                                    U64 table_end,\n                                                    U64 *out_len,\n                                                    U64 *out_payload_end);\n\nI32 GGUFMetadataReadStringBytesChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U64 str_len,\n                                       U8 *out_bytes,\n                                       U64 out_nbytes);\n\nI32 GGUFMetadataReadStringChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_bytes,\n                                  U64 out_nbytes,\n                                  U64 *out_len);\n\nI32 GGUFMetadataReadArrayHeaderChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U32 *out_elem_type,\n                                       U64 *out_elem_count);\n\n// Validate metadata table byte-window math before any parser cursor movement.\n// Contract: `out_table_end` is written only on success.\nI32 GGUFMetadataTableSpanValidateChecked(U64 table_start,\n                                         U64 table_nbytes,\n                                         U64 file_nbytes,\n                                         U64 *out_table_end)\n{\n    U64 table_end;\n\n    if (!out_table_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Parser cursors are signed in multiple call sites; reject spans that do\n    // not fit cleanly in positive I64 address space.\n    if (table_start > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (table_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (file_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (table_start > file_nbytes)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    if (table_nbytes > (0xFFFFFFFFFFFFFFFF - table_start))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    table_end = table_start + table_nbytes;\n    if (table_end > file_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_table_end = table_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate metadata table bounds, then derive a checked cursor position at\n// `table_start + cursor_advance`. This helper keeps parser entrypoints on one\n// auditable range-math path before any field reads happen.\n// Contract: out pointers are written only on success.\nI32 GGUFMetadataTableCursorAdvanceChecked(U64 table_start,\n                                          U64 table_nbytes,\n                                          U64 file_nbytes,\n                                          U64 cursor_advance,\n                                          U64 *out_cursor,\n                                          U64 *out_table_end)\n{\n    U64 table_end;\n    I32 err;\n\n    if (!out_cursor || !out_table_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    err = GGUFMetadataTableSpanValidateChecked(table_start,\n                                               table_nbytes,\n                                               file_nbytes,\n                                               &table_end);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Advance is relative to table_start. Equal-to-end is legal and matches\n    // cursor semantics used by metadata table loops.\n    err = GGUFMetadataCursorCanAdvanceChecked(table_start,\n                                              cursor_advance,\n                                              table_end,\n                                              out_cursor);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_table_end = table_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate `cursor + need <= table_end` with explicit signed/unsigned overflow\n// guards. On success, `out_next_cursor` is the advanced cursor position.\n// Contract: out pointer is written only on success.\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor)\n{\n    U64 next_cursor;\n\n    if (!out_next_cursor)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n---\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep cursor math in positive I64 space because parser entrypoints route\n    // through signed cursors.\n    if (cursor > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (need > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (table_end > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (cursor > table_end)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    if (cursor > (0xFFFFFFFFFFFFFFFF - need))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    next_cursor = cursor + need;\n    if (next_cursor > table_end)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_next_cursor = next_cursor;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked 1-byte metadata reader used by table-backed decoders.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value)\n{\n    U64 cur;\n    U64 next_cursor;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep data-plane indexing in positive I64 space to match parser cursor\n    // contracts used across GGUF metadata entrypoints.\n    if (buf_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    cur = *cursor;\n    err = GGUFMetadataCursorCanAdvanceChecked(cur, 1, table_end, &next_cursor);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // The metadata span must live inside the provided byte buffer.\n    if (next_cursor > buf_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_value = buf[cur];\n    *cursor = next_cursor;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked signed-I8 metadata reader.\n// Contract: decodes through GGUFMetadataReadU8Checked and commits `*out_value`\n// plus `*cursor` only on success (strict no-partial-write semantics).\nI32 GGUFMetadataReadI8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              I8 *out_value)\n{\n    U64 cur;\n    U8 raw_u8;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage decode through the canonical checked U8 reader so signed-I8 keeps\n    // identical bounds/overflow and no-partial-write contracts.\n    err = GGUFMetadataReadU8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &raw_u8);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Two's-complement reinterpretation is a plain cast in HolyC.\n    *out_value = (I8)raw_u8;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked two-byte tuple reader for compact metadata fields.\n// Contract: decodes sequential bytes through GGUFMetadataReadU8Checked and\n// commits both outputs + cursor only after both reads succeed.\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second)\n{\n    U64 cur;\n    U8 first;\n    U8 second;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage both reads through the canonical checked U8 reader so bounds and\n    // no-partial-write behavior exactly matches scalar decoders.\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U16 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U16 *out_value)\n{\n    U64 cur;\n    U8 b0;\n    U8 b1;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Reuse the canonical checked 1-byte reader so 16-bit scalar decode keeps\n    // identical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b0);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b1);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_value = ((U16)b0)\n               | (((U16)b1) << 8);\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I16 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value)\n{\n    U64 cur;\n    U16 raw_u16;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared U16 checked reader so signed-I16 decode keeps\n    // identical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &raw_u16);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Two's-complement reinterpretation is a plain cast in HolyC.\n    *out_value = (I16)raw_u16;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U32 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U32 *out_value)\n{\n    U64 cur;\n    U8 b0;\n    U8 b1;\n    U8 b2;\n    U8 b3;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Reuse the canonical checked 1-byte reader so cursor/bounds semantics are\n    // identical across scalar-width metadata decoders.\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b0);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b1);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b2);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b3);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_value = ((U32)b0)\n               | (((U32)b1) << 8)\n               | (((U32)b2) << 16)\n               | (((U32)b3) << 24);\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U64 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U64 *out_value)\n{\n    // Keep legacy symbol as the canonical parser entrypoint while routing\n    // decode through the explicit no-partial-write helper.\n    return GGUFMetadataReadU64LECheckedNoPartial(buf,\n                                                 buf_nbytes,\n                                                 cursor,\n                                                 table_end,\n                                                 out_value);\n}\n\n// Checked little-endian U64 metadata reader with explicit all-or-nothing\n// staging contract. Cursor/output are committed only after all 8 byte reads\n// succeed through the shared checked U8 reader.\nI32 GGUFMetadataReadU64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          U64 *out_value)\n{\n    U64 cur;\n    U8 b0;\n    U8 b1;\n    U8 b2;\n    U8 b3;\n    U8 b4;\n    U8 b5;\n    U8 b6;\n    U8 b7;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Reuse the canonical checked 1-byte reader so all scalar-width readers\n    // inherit identical cursor/bounds behavior and overflow surfaces.\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b0);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b1);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b2);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b3);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b4);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b5);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b6);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b7);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_value = ((U64)b0)\n               | (((U64)b1) << 8)\n               | (((U64)b2) << 16)\n               | (((U64)b3) << 24)\n               | (((U64)b4) << 32)\n               | (((U64)b5) << 40)\n               | (((U64)b6) << 48)\n               | (((U64)b7) << 56);\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I32 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadI32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I32 *out_value)\n{\n    U64 cur;\n    U32 raw_u32;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared U32 checked reader so signed-I32 decode keeps\n    // identical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n---TESTS---\ntest_gguf_metadata_parse.py\ntest_gguf_metadata_read_array_header_checked.py\ntest_gguf_metadata_read_bool_checked.py\ntest_gguf_metadata_read_f64bitsle_checked.py\ntest_gguf_metadata_read_i16le_checked.py\ntest_gguf_metadata_read_i32le_checked.py\ntest_gguf_metadata_read_i64le_checked.py\ntest_gguf_metadata_read_i64le_checked_no_partial.py\ntest_gguf_metadata_read_i8_checked.py\ntest_gguf_metadata_read_string_bytes_checked.py\ntest_gguf_metadata_read_string_checked.py\ntest_gguf_metadata_read_string_len_u64_checked.py\ntest_gguf_metadata_read_string_u64_header_bounds_checked.py\ntest_gguf_metadata_read_u16le_checked.py\ntest_gguf_metadata_read_u32le_checked.py\ntest_gguf_metadata_read_u64le_checked.py\ntest_gguf_metadata_read_u64le_checked_no_partial.py\ntest_gguf_metadata_read_u8_checked.py\ntest_gguf_metadata_read_u8_pair_checked.py\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadU64LEChecked cursor/bounds semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n    if cursor + need > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n    return GGUF_META_TABLE_OK, cursor + need\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u64le_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    b = [0]\n    out = 0\n\n    for i in range(8):\n        err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, b)\n        if err != GGUF_META_TABLE_OK:\n            return err\n        out |= b[0] << (8 * i)\n\n    out_value_ref[0] = out\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [3]\n    out = [0xA5A5A5A5A5A5A5A5]\n\n    assert (\n        gguf_metadata_read_u64le_checked(None, 16, cursor, 16, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor[0] == 3\n    assert out[0] == 0xA5A5A5A5A5A5A5A5\n\n    assert (\n        gguf_metadata_read_u64le_checked([0] * 16, 16, None, 16, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out[0] == 0xA5A5A5A5A5A5A5A5\n\n    assert (\n        gguf_metadata_read_u64le_checked([0] * 16, 16, cursor, 16, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor[0] == 3\n\n\ndef test_short_reads_do_not_advance_cursor_or_write_output() -> None:\n    buf = [0xFF] * 16\n    out = [0x1122334455667788]\n\n    for table_end in range(0, 8):\n        cursor = [0]\n        err = gguf_metadata_read_u64le_checked(buf, len(buf), cursor, table_end, out)\n        assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n        assert cursor[0] == 0\n        assert out[0] == 0x1122334455667788\n\n\ndef test_success_decodes_little_endian_and_advances() -> None:\n    buf = [\n        0xAA,\n        0xBB,\n        0x01,\n        0x23,\n        0x45,\n        0x67,\n        0x89,\n        0xAB,\n        0xCD,\n        0xEF,\n        0x11,\n        0x22,\n    ]\n\n    cursor = [2]\n    out = [0]\n    err = gguf_metadata_read_u64le_checked(buf, len(buf), cursor, len(buf), out)\n\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == 0xEFCDAB8967452301\n    assert cursor[0] == 10\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_195)\n\n    for _ in range(4000):\n        n = rng.randint(1, 256)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        table_end = rng.randint(0, n)\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out = [0xDEADBEEFDEADBEEF]\n        err = gguf_metadata_read_u64le_checked(buf, n, cursor, table_end, out)\n\n        if cursor0 + 8 <= table_end and cursor0 + 8 <= n:\n            expect = 0\n            for i in range(8):\n                expect |= buf[cursor0 + i] << (8 * i)\n            assert err == GGUF_META_TABLE_OK\n            assert out[0] == expect\n            assert cursor[0] == cursor0 + 8\n        else:\n            assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n            assert out[0] == 0xDEADBEEFDEADBEEF\n            assert cursor[0] == cursor0\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_short_reads_do_not_advance_cursor_or_write_output()\n    test_success_decodes_little_endian_and_advances()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_u64le_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadI8Checked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU8_MASK = (1 << 8) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef reinterpret_u8_as_i8(value: int) -> int:\n    value &= U8_MASK\n    if value >= (1 << 7):\n        return value - (1 << 8)\n    return value\n\n\ndef gguf_metadata_read_i8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    raw = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, raw)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = reinterpret_u8_as_i8(raw[0])\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [3]\n    out = [88]\n\n    assert (\n        gguf_metadata_read_i8_checked(None, 8, cursor, 7, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [3]\n    assert out == [88]\n\n    assert (\n        gguf_metadata_read_i8_checked([1, 2, 3], 3, None, 3, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out == [88]\n\n    assert (\n        gguf_metadata_read_i8_checked([1, 2, 3], 3, cursor, 3, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [3]\n\n\ndef test_short_read_does_not_advance_or_write() -> None:\n    buf = [0x7F, 0x80, 0xFF]\n\n    cursor = [3]\n    out = [44]\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [3]\n    assert out == [44]\n\n    cursor = [1]\n    out = [55]\n    err = gguf_metadata_read_i8_checked(buf, 1, cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [1]\n    assert out == [55]\n\n\ndef test_success_signed_decode_and_cursor_advance() -> None:\n    buf = [0x7F, 0x80, 0xFF, 0x00]\n\n    cursor = [0]\n    out = [0]\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == 127\n    assert cursor[0] == 1\n\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == -128\n    assert cursor[0] == 2\n\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == -1\n    assert cursor[0] == 3\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_211)\n\n    for _ in range(5000):\n        n = rng.randint(1, 256)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        table_end = rng.randint(0, n)\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out = [999]\n        err = gguf_metadata_read_i8_checked(buf, n, cursor, table_end, out)\n\n        if cursor0 + 1 <= table_end and cursor0 + 1 <= n:\n            assert err == GGUF_META_TABLE_OK\n            assert out[0] == reinterpret_u8_as_i8(buf[cursor0])\n            assert cursor[0] == cursor0 + 1\n        else:\n            assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n            assert out[0] == 999\n            assert cursor[0] == cursor0\n\n\ndef test_table_end_overflow_surface() -> None:\n    buf = [0xAA]\n    cursor = [0]\n    out = [5]\n\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, I64_MAX + 1, out)\n    assert err == GGUF_META_TABLE_ERR_OVERFLOW\n    assert cursor == [0]\n    assert out == [5]\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_short_read_does_not_advance_or_write()\n    test_success_signed_decode_and_cursor_advance()\n    test_randomized_parity()\n    test_table_end_overflow_surface()\n    print(\"gguf_metadata_read_i8_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n---\n#!/usr/bin/env python3\n\"\"\"Focused GGUF metadata parser parity fixtures.\n\nThis is host-side validation only. It mirrors GGUF metadata binary layout and\nchecks that expected decode/validation behavior matches HolyC parser intent.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport struct\n\nGGUF_TYPE_UINT8 = 0\nGGUF_TYPE_INT8 = 1\nGGUF_TYPE_UINT16 = 2\nGGUF_TYPE_INT16 = 3\nGGUF_TYPE_UINT32 = 4\nGGUF_TYPE_INT32 = 5\nGGUF_TYPE_FLOAT32 = 6\nGGUF_TYPE_BOOL = 7\nGGUF_TYPE_STRING = 8\nGGUF_TYPE_ARRAY = 9\nGGUF_TYPE_UINT64 = 10\nGGUF_TYPE_INT64 = 11\nGGUF_TYPE_FLOAT64 = 12\n\nGGUF_META_PARSE_OK = 0\nGGUF_META_PARSE_ERR_TRUNCATED = 2\nGGUF_META_PARSE_ERR_BAD_TYPE = 3\nGGUF_META_PARSE_ERR_NESTED_ARRAY = 7\nGGUF_META_PARSE_ERR_NOT_FOUND = 9\nGGUF_META_PARSE_ERR_TYPE_MISMATCH = 10\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU64_MAX = (1 << 64) - 1\n\n\ndef u8(v: int) -> bytes:\n    return struct.pack(\"<B\", v)\n\n\ndef u16(v: int) -> bytes:\n    return struct.pack(\"<H\", v)\n\n\ndef u32(v: int) -> bytes:\n    return struct.pack(\"<I\", v)\n\n\ndef u64(v: int) -> bytes:\n    return struct.pack(\"<Q\", v)\n\n\ndef i32(v: int) -> bytes:\n    return struct.pack(\"<i\", v)\n\n\ndef i64(v: int) -> bytes:\n    return struct.pack(\"<q\", v)\n\n\ndef f32(v: float) -> bytes:\n    return struct.pack(\"<f\", v)\n\n\ndef gguf_string(s: str) -> bytes:\n    raw = s.encode(\"utf-8\")\n    return u64(len(raw)) + raw\n\n\ndef meta_entry(key: str, value_type: int, payload: bytes) -> bytes:\n    return gguf_string(key) + u32(value_type) + payload\n\n\ndef scalar_payload(t: int, v):\n    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_BOOL):\n        return u8(int(v))\n    if t == GGUF_TYPE_INT8:\n        return struct.pack(\"<b\", int(v))\n    if t == GGUF_TYPE_UINT16:\n        return u16(int(v))\n    if t == GGUF_TYPE_INT16:\n        return struct.pack(\"<h\", int(v))\n    if t == GGUF_TYPE_UINT32:\n        return u32(int(v))\n    if t == GGUF_TYPE_INT32:\n        return i32(int(v))\n    if t == GGUF_TYPE_UINT64:\n        return u64(int(v))\n    if t == GGUF_TYPE_INT64:\n        return i64(int(v))\n    if t == GGUF_TYPE_FLOAT32:\n        return f32(float(v))\n    if t == GGUF_TYPE_FLOAT64:\n        return struct.pack(\"<d\", float(v))\n    if t == GGUF_TYPE_STRING:\n        return gguf_string(str(v))\n    raise ValueError(t)\n\n\ndef array_payload(elem_type: int, values: list) -> bytes:\n    payload = b\"\".join(\n        scalar_payload(elem_type, value) if elem_type != GGUF_TYPE_STRING else gguf_string(value)\n        for value in values\n    )\n    return u32(elem_type) + u64(len(values)) + payload\n\n\ndef decode_scalar_by_type(raw: bytes, t: int):\n    if t == GGUF_TYPE_UINT8:\n        return raw[0]\n    if t == GGUF_TYPE_INT8:\n        return int.from_bytes(raw[:1], \"little\", signed=True)\n    if t == GGUF_TYPE_UINT16:\n        return int.from_bytes(raw[:2], \"little\", signed=False)\n    if t == GGUF_TYPE_INT16:\n        return int.from_bytes(raw[:2], \"little\", signed=True)\n    if t == GGUF_TYPE_UINT32:\n        return int.from_bytes(raw[:4], \"little\", signed=False)\n    if t == GGUF_TYPE_INT32:\n        return int.from_bytes(raw[:4], \"little\", signed=True)\n    if t == GGUF_TYPE_UINT64:\n        return int.from_bytes(raw[:8], \"little\", signed=False)\n    if t == GGUF_TYPE_INT64:\n        return int.from_bytes(raw[:8], \"little\", signed=True)\n    if t == GGUF_TYPE_BOOL:\n        return raw[0] != 0\n    if t == GGUF_TYPE_FLOAT32:\n        return int.from_bytes(raw[:4], \"little\", signed=False)\n    if t == GGUF_TYPE_FLOAT64:\n        return int.from_bytes(raw[:8], \"little\", signed=False)\n    raise ValueError(t)\n\n\ndef decode_array_payload(buf: bytes, parsed_value: dict):\n    elem_type = parsed_value[\"array_elem_type\"]\n    cursor = parsed_value[\"array_payload_off\"]\n    end = cursor + parsed_value[\"array_payload_bytes\"]\n\n    values = []\n    while cursor < end:\n        if elem_type == GGUF_TYPE_STRING:\n            err, cursor2, value = parse_gguf_string(buf, cursor)\n            assert err == GGUF_META_PARSE_OK\n            cursor = cursor2\n            values.append(value)\n            continue\n\n        width = {\n            GGUF_TYPE_UINT8: 1,\n            GGUF_TYPE_INT8: 1,\n            GGUF_TYPE_BOOL: 1,\n            GGUF_TYPE_UINT16: 2,\n            GGUF_TYPE_INT16: 2,\n            GGUF_TYPE_UINT32: 4,\n            GGUF_TYPE_INT32: 4,\n            GGUF_TYPE_FLOAT32: 4,\n            GGUF_TYPE_UINT64: 8,\n            GGUF_TYPE_INT64: 8,\n            GGUF_TYPE_FLOAT64: 8,\n        }[elem_type]\n        raw = buf[cursor : cursor + width]\n        assert len(raw) == width\n        values.append(decode_scalar_by_type(raw, elem_type))\n        cursor += width\n\n    assert cursor == end\n    assert len(values) == parsed_value[\"array_len\"]\n    return values\n\n\ndef parse_gguf_string(buf: bytes, cursor: int):\n    if cursor + 8 > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    (n,) = struct.unpack_from(\"<Q\", buf, cursor)\n    cursor += 8\n    if cursor + n > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    s = buf[cursor : cursor + n].decode(\"utf-8\")\n    cursor += n\n    return GGUF_META_PARSE_OK, cursor, s\n\n\ndef skip_value_by_type(buf: bytes, cursor: int, t: int):\n    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_INT8, GGUF_TYPE_BOOL):\n        return (GGUF_META_PARSE_OK, cursor + 1) if cursor + 1 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT16, GGUF_TYPE_INT16):\n        return (GGUF_META_PARSE_OK, cursor + 2) if cursor + 2 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT32, GGUF_TYPE_INT32, GGUF_TYPE_FLOAT32):\n        return (GGUF_META_PARSE_OK, cursor + 4) if cursor + 4 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT64, GGUF_TYPE_INT64, GGUF_TYPE_FLOAT64):\n        return (GGUF_META_PARSE_OK, cursor + 8) if cursor + 8 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t == GGUF_TYPE_STRING:\n        err, cursor2, _ = parse_gguf_string(buf, cursor)\n        return err, cursor2\n    if t == GGUF_TYPE_ARRAY:\n        return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor\n    return GGUF_META_PARSE_ERR_BAD_TYPE, cursor\n\n\ndef parse_value(buf: bytes, cursor: int):\n    if cursor + 4 > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    (t,) = struct.unpack_from(\"<I\", buf, cursor)\n    cursor += 4\n\n    if t == GGUF_TYPE_ARRAY:\n        if cursor + 12 > len(buf):\n            return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n        elem_type, n = struct.unpack_from(\"<IQ\", buf, cursor)\n        cursor += 12\n        if elem_type == GGUF_TYPE_ARRAY:\n            return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor, None\n        if elem_type > GGUF_TYPE_FLOAT64:\n            return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n\n        payload_start = cursor\n        for _ in range(n):\n            err, cursor = skip_value_by_type(buf, cursor, elem_type)\n            if err != GGUF_META_PARSE_OK:\n                return err, cursor, None\n\n        return GGUF_META_PARSE_OK, cursor, {\n            \"type\": t,\n            \"array_elem_type\": elem_type,\n            \"array_len\": n,\n            \"array_payload_off\": payload_start,\n            \"array_payload_bytes\": cursor - payload_start,\n        }\n\n    if t > GGUF_TYPE_FLOAT64:\n        return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n\n    if t == GGUF_TYPE_STRING:\n        err, cursor, value = parse_gguf_string(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, None\n        return GGUF_META_PARSE_OK, cursor, {\"type\": t, \"value\": value}\n\n    err, cursor2 = skip_value_by_type(buf, cursor, t)\n    if err != GGUF_META_PARSE_OK:\n        return err, cursor2, None\n\n    raw = buf[cursor:cursor2]\n    return GGUF_META_PARSE_OK, cursor2, {\"type\": t, \"raw\": raw}\n\n\ndef parse_metadata_table(buf: bytes, count: int):\n    items = []\n    cursor = 0\n    for _ in range(count):\n        err, cursor, key = parse_gguf_string(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, items\n\n        err, cursor, value = parse_value(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, items\n\n        items.append((key, value))\n\n    return GGUF_META_PARSE_OK, cursor, items\n\n\ndef metadata_table_span_validate_checked(\n    table_start: int,\n    table_nbytes: int,\n    file_nbytes: int,\n):\n    if table_start > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, 0\n    if table_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, 0\n    if file_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, 0\n","exit_code":0,"status":"completed"}}
