urn err;\n   582\t    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b7);\n   583\t    if (err != GGUF_META_TABLE_OK)\n   584\t        return err;\n   585\t\n   586\t    *out_value = ((U64)b0)\n   587\t               | (((U64)b1) << 8)\n   588\t               | (((U64)b2) << 16)\n   589\t               | (((U64)b3) << 24)\n   590\t               | (((U64)b4) << 32)\n   591\t               | (((U64)b5) << 40)\n   592\t               | (((U64)b6) << 48)\n   593\t               | (((U64)b7) << 56);\n   594\t    *cursor = cur;\n   595\t    return GGUF_META_TABLE_OK;\n   596\t}\n   597\t\n   598\t// Checked little-endian I32 metadata reader.\n   599\t// Contract: writes `*out_value` and advances `*cursor` only on success.\n   600\tI32 GGUFMetadataReadI32LEChecked(U8 *buf,\n   601\t                                 U64 buf_nbytes,\n   602\t                                 U64 *cursor,\n   603\t                                 U64 table_end,\n   604\t                                 I32 *out_value)\n   605\t{\n   606\t    U64 cur;\n   607\t    U32 raw_u32;\n   608\t    I32 err;\n   609\t\n   610\t    if (!buf || !cursor || !out_value)\n   611\t        return GGUF_META_TABLE_ERR_NULL_PTR;\n   612\t\n   613\t    cur = *cursor;\n   614\t\n   615\t    // Decode through the shared U32 checked reader so signed-I32 decode keeps\n   616\t    // identical cursor/bounds/no-partial-write behavior.\n   617\t    err = GGUFMetadataReadU32LEChecked(buf,\n   618\t                                       buf_nbytes,\n   619\t                                       &cur,\n   620\t                                       table_end,\n   621\t                                       &raw_u32);\n   622\t    if (err != GGUF_META_TABLE_OK)\n   623\t        return err;\n   624\t\n   625\t    // Two's-complement reinterpretation is a plain cast in HolyC.\n   626\t    *out_value = (I32)raw_u32;\n   627\t    *cursor = cur;\n   628\t    return GGUF_META_TABLE_OK;\n   629\t}\n   630\t\n   631\t// Checked little-endian I64 metadata reader.\n   632\t// Contract: writes `*out_value` and advances `*cursor` only on success.\n   633\tI32 GGUFMetadataReadI64LEChecked(U8 *buf,\n   634\t                                 U64 buf_nbytes,\n   635\t                                 U64 *cursor,\n   636\t                                 U64 table_end,\n   637\t                                 I64 *out_value)\n   638\t{\n   639\t    // Keep legacy symbol as the canonical parser entrypoint while routing\n   640\t    // decode through the explicit no-partial-write helper.\n   641\t    return GGUFMetadataReadI64LECheckedNoPartial(buf,\n   642\t                                                 buf_nbytes,\n   643\t                                                 cursor,\n   644\t                                                 table_end,\n   645\t                                                 out_value);\n   646\t}\n   647\t\n   648\t// Checked little-endian I64 metadata reader with explicit all-or-nothing\n   649\t// staging contract. Cursor/output are committed only after full U64 decode\n   650\t// succeeds through the shared checked U64 reader.\n   651\tI32 GGUFMetadataReadI64LECheckedNoPartial(U8 *buf,\n   652\t                                          U64 buf_nbytes,\n   653\t                                          U64 *cursor,\n   654\t                                          U64 table_end,\n   655\t                                          I64 *out_value)\n   656\t{\n   657\t    U64 cur;\n   658\t    U64 raw_u64;\n   659\t    I32 err;\n   660\t\n   661\t    if (!buf || !cursor || !out_value)\n   662\t        return GGUF_META_TABLE_ERR_NULL_PTR;\n   663\t\n   664\t    cur = *cursor;\n   665\t\n   666\t    // Keep no-partial-write semantics by decoding through a staged cursor and\n   667\t    // only committing cursor/output after the shared U64 checked reader passes.\n   668\t    err = GGUFMetadataReadU64LEChecked(buf,\n   669\t                                       buf_nbytes,\n   670\t                                       &cur,\n   671\t                                       table_end,\n   672\t                                       &raw_u64);\n   673\t    if (err != GGUF_META_TABLE_OK)\n   674\t        return err;\n   675\t\n   676\t    *out_value = (I64)raw_u64;\n   677\t    *cursor = cur;\n   678\t    return GGUF_META_TABLE_OK;\n   679\t}\n   680\t\n   681\t// Checked little-endian FLOAT64 bit-pattern metadata reader.\n   682\t// Runtime remains integer-only: the 64-bit payload is returned as raw bits\n   683\t// so callers can audit exact IEEE754 encodings without float math.\n   684\t// Contract: writes `*out_bits` and advances `*cursor` only on success.\n   685\tI32 GGUFMetadataReadF64BitsLEChecked(U8 *buf,\n   686\t                                     U64 buf_nbytes,\n   687\t                                     U64 *cursor,\n   688\t                                     U64 table_end,\n   689\t                                     U64 *out_bits)\n   690\t{\n   691\t    U64 cur;\n   692\t    U64 raw_bits;\n   693\t    I32 err;\n   694\t\n   695\t    if (!buf || !cursor || !out_bits)\n   696\t        return GGUF_META_TABLE_ERR_NULL_PTR;\n   697\t\n   698\t    cur = *cursor;\n   699\t\n   700\t    // Decode through the shared U64 checked reader so float64 payload bit\n   701\t    // extraction inherits identical cursor/bounds/no-partial-write behavior.\n   702\t    err = GGUFMetadataReadU64LEChecked(buf,\n   703\t                                       buf_nbytes,\n   704\t                                       &cur,\n   705\t                                       table_end,\n   706\t                                       &raw_bits);\n   707\t    if (err != GGUF_META_TABLE_OK)\n   708\t        return err;\n   709\t\n   710\t    *out_bits = raw_bits;\n   711\t    *cursor = cur;\n   712\t    return GGUF_META_TABLE_OK;\n   713\t}\n   714\t\n   715\t// Checked metadata BOOL reader (`U8 in {0,1}`).\n   716\t// Contract: writes `*out_value` and advances `*cursor` only on success.\n   717\tI32 GGUFMetadataReadBoolChecked(U8 *buf,\n   718\t                                U64 buf_nbytes,\n   719\t                                U64 *cursor,\n   720\t                                U64 table_end,\n   721\t                                Bool *out_value)\n   722\t{\n   723\t    U64 cur;\n   724\t    U8 raw_u8;\n   725\t    I32 err;\n   726\t\n   727\t    if (!buf || !cursor || !out_value)\n   728\t        return GGUF_META_TABLE_ERR_NULL_PTR;\n   729\t\n   730\t    cur = *cursor;\n   731\t\n   732\t    // Decode through the shared checked byte reader so bool decode inherits\n   733\t    // canonical cursor/bounds/no-partial-write behavior.\n   734\t    err = GGUFMetadataReadU8Checked(buf,\n   735\t                                    buf_nbytes,\n   736\t                                    &cur,\n   737\t                                    table_end,\n   738\t                                    &raw_u8);\n   739\t    if (err != GGUF_META_TABLE_OK)\n   740\t        return err;\n   741\t\n   742\t    // GGUF bool payloads are strict 0/1 in one byte.\n   743\t    if (raw_u8 > 1)\n   744\t        return GGUF_META_TABLE_ERR_BAD_PARAM;\n   745\t\n   746\t    *out_value = (raw_u8 != 0);\n   747\t    *cursor = cur;\n   748\t    return GGUF_META_TABLE_OK;\n   749\t}\n   750\t\n   751\t// Checked GGUF string header reader (`U64 len`) plus payload-window bounds\n   752\t// validation. This helper stages cursor advancement to payload start so string\n   753\t// payload readers can compose strict no-partial-write decode flows.\n   754\t// Contract: writes `*out_len`, `*out_payload_end`, and advances `*cursor`\n   755\t// to payload start only on success.\n   756\tI32 GGUFMetadataReadStringU64HeaderAndBoundsChecked(U8 *buf,\n   757\t                                                    U64 buf_nbytes,\n   758\t                                                    U64 *cursor,\n   759\t                                                    U64 table_end,\n   760\t                                                    U64 *out_len,\n","exit_code":0,"status":"completed"}}
