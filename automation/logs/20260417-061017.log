{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' src/gguf/header.HC\"","aggregated_output":"// header.HC\n// GGUF header parser for HolyC inference runtime.\n\n#define GGUF_MAGIC_U32 0x46554747\n#define GGUF_VERSION_V2 2\n#define GGUF_VERSION_V3 3\n\n// GGUF v2/v3 fixed header layout (little-endian):\n//   byte  0..3   : magic \"GGUF\" (U32)\n//   byte  4..7   : version (U32)\n//   byte  8..15  : tensor_count (U64)\n//   byte 16..23  : metadata_kv_count (U64)\n// Keep offsets centralized so all parser entrypoints share one canonical layout.\n#define GGUF_HEADER_MAGIC_OFFSET             0\n#define GGUF_HEADER_VERSION_OFFSET           4\n#define GGUF_HEADER_TENSOR_COUNT_OFFSET      8\n#define GGUF_HEADER_METADATA_COUNT_OFFSET   16\n\n#define GGUF_HEADER_MAGIC_BYTES              4\n#define GGUF_HEADER_VERSION_BYTES            4\n#define GGUF_HEADER_TENSOR_COUNT_BYTES       8\n#define GGUF_HEADER_METADATA_COUNT_BYTES     8\n\n#define GGUF_PARSE_OK 0\n#define GGUF_PARSE_ERR_NULL_PTR 1\n#define GGUF_PARSE_ERR_TRUNCATED 2\n#define GGUF_PARSE_ERR_BAD_MAGIC 3\n#define GGUF_PARSE_ERR_BAD_VERSION 4\n#define GGUF_PARSE_ERR_BAD_COUNT 5\n\nclass GGUFHeader\n{\n    U32 magic;\n    U32 version;\n    U64 tensor_count;\n    U64 metadata_kv_count;\n};\n\n#define GGUF_HEADER_OK              0\n#define GGUF_HEADER_ERR_NULL_PTR    1\n#define GGUF_HEADER_ERR_BAD_PARAM   2\n#define GGUF_HEADER_ERR_OVERFLOW    3\n#define GGUF_HEADER_ERR_TRUNCATED   4\n#define GGUF_HEADER_ERR_BAD_MAGIC   5\n#define GGUF_HEADER_ERR_BAD_VERSION 6\n\n#define GGUF_HEADER_BYTES (GGUF_HEADER_MAGIC_BYTES         \\\n                         + GGUF_HEADER_VERSION_BYTES       \\\n                         + GGUF_HEADER_TENSOR_COUNT_BYTES  \\\n                         + GGUF_HEADER_METADATA_COUNT_BYTES)\n\nBool GGUFHeaderVersionSupported(U32 version)\n{\n    return (version == GGUF_VERSION_V2 || version == GGUF_VERSION_V3);\n}\n\nBool GGUFHeaderCanReadSpan(U64 total_bytes, U64 offset, U64 need_bytes)\n{\n    U64 end_offset;\n\n    if (offset > total_bytes)\n        return FALSE;\n    if (need_bytes > (0xFFFFFFFFFFFFFFFF - offset))\n        return FALSE;\n\n    end_offset = offset + need_bytes;\n    if (end_offset > total_bytes)\n        return FALSE;\n\n    return TRUE;\n}\n\nI32 GGUFReadU32LEChecked(U8 *buf, U64 buf_nbytes, U64 offset, U32 *out_value)\n{\n    if (!buf || !out_value)\n        return GGUF_HEADER_ERR_NULL_PTR;\n    if (!GGUFHeaderCanReadSpan(buf_nbytes, offset, 4))\n        return GGUF_HEADER_ERR_TRUNCATED;\n\n    *out_value = (U32)buf[offset]\n               | ((U32)buf[offset + 1] << 8)\n               | ((U32)buf[offset + 2] << 16)\n               | ((U32)buf[offset + 3] << 24);\n\n    return GGUF_HEADER_OK;\n}\n\nI32 GGUFReadU64LEChecked(U8 *buf, U64 buf_nbytes, U64 offset, U64 *out_value)\n{\n    if (!buf || !out_value)\n        return GGUF_HEADER_ERR_NULL_PTR;\n    if (!GGUFHeaderCanReadSpan(buf_nbytes, offset, 8))\n        return GGUF_HEADER_ERR_TRUNCATED;\n\n    *out_value = (U64)buf[offset]\n               | ((U64)buf[offset + 1] << 8)\n               | ((U64)buf[offset + 2] << 16)\n               | ((U64)buf[offset + 3] << 24)\n               | ((U64)buf[offset + 4] << 32)\n               | ((U64)buf[offset + 5] << 40)\n               | ((U64)buf[offset + 6] << 48)\n               | ((U64)buf[offset + 7] << 56);\n\n    return GGUF_HEADER_OK;\n}\n\n// Validate parsed header fields and return the canonical byte width consumed by\n// the fixed GGUF v2/v3 header prefix. Downstream metadata/tensor parsers should\n// use this helper as the single source of truth for header-size math.\nI32 GGUFHeaderValidateAndSizeChecked(GGUFHeader *header, U64 *out_header_bytes)\n{\n    if (!header || !out_header_bytes)\n        return GGUF_HEADER_ERR_NULL_PTR;\n\n    if (header->magic != GGUF_MAGIC_U32)\n        return GGUF_HEADER_ERR_BAD_MAGIC;\n\n    if (!GGUFHeaderVersionSupported(header->version))\n        return GGUF_HEADER_ERR_BAD_VERSION;\n\n    // HolyC parser loops index with signed offsets in multiple call sites.\n    // Reject count fields that cannot be represented in positive I64 space.\n    if (header->tensor_count > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_HEADER_ERR_OVERFLOW;\n    if (header->metadata_kv_count > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_HEADER_ERR_OVERFLOW;\n\n    // Guard future header-layout edits that could accidentally exceed the\n    // signed index domain expected by downstream offset arithmetic.\n    if ((U64)GGUF_HEADER_BYTES > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_HEADER_ERR_OVERFLOW;\n\n    *out_header_bytes = GGUF_HEADER_BYTES;\n    return GGUF_HEADER_OK;\n}\n\n// Checked GGUF header decoder for parser front-ends that consume a fixed\n// byte span and need explicit status codes (NULL_PTR/BAD_PARAM/OVERFLOW).\n// Decodes fields exactly as little-endian U32/U64 values from bytes[0..23].\nI32 GGUFHeaderParseChecked(U8 *header_bytes,\n                           U64 header_nbytes,\n                           GGUFHeader *out_header,\n                           U64 *out_header_bytes)\n{\n    U32 magic_u32;\n    U32 version_u32;\n    U64 tensor_count;\n    U64 metadata_kv_count;\n    I32 status;\n\n    if (!header_bytes || !out_header || !out_header_bytes)\n        return GGUF_HEADER_ERR_NULL_PTR;\n\n    // HolyC indexed addressing uses signed offsets; reject spans that cannot\n    // be represented in positive I64 index space to avoid signed-wrap hazards.\n    if (header_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_HEADER_ERR_OVERFLOW;\n\n    if (header_nbytes < GGUF_HEADER_BYTES)\n        return GGUF_HEADER_ERR_TRUNCATED;\n\n    status = GGUFReadU32LEChecked(header_bytes,\n                                  header_nbytes,\n                                  GGUF_HEADER_MAGIC_OFFSET,\n                                  &magic_u32);\n    if (status)\n        return status;\n    if (magic_u32 != GGUF_MAGIC_U32)\n        return GGUF_HEADER_ERR_BAD_MAGIC;\n\n    status = GGUFReadU32LEChecked(header_bytes,\n                                  header_nbytes,\n                                  GGUF_HEADER_VERSION_OFFSET,\n                                  &version_u32);\n    if (status)\n        return status;\n    if (!GGUFHeaderVersionSupported(version_u32))\n        return GGUF_HEADER_ERR_BAD_VERSION;\n\n    status = GGUFReadU64LEChecked(header_bytes,\n                                  header_nbytes,\n                                  GGUF_HEADER_TENSOR_COUNT_OFFSET,\n                                  &tensor_count);\n    if (status)\n        return status;\n\n    status = GGUFReadU64LEChecked(header_bytes,\n                                  header_nbytes,\n                                  GGUF_HEADER_METADATA_COUNT_OFFSET,\n                                  &metadata_kv_count);\n    if (status)\n        return status;\n\n    out_header->magic = magic_u32;\n    out_header->version = version_u32;\n    out_header->tensor_count = tensor_count;\n    out_header->metadata_kv_count = metadata_kv_count;\n\n    return GGUFHeaderValidateAndSizeChecked(out_header, out_header_bytes);\n}\n\nBool GGUFCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n{\n    if (!buf)\n        return FALSE;\n    if (size < 0 || cursor < 0 || need < 0)\n        return FALSE;\n    if (cursor > size)\n        return FALSE;\n    if (need > size - cursor)\n        return FALSE;\n    return TRUE;\n}\n\nBool GGUFReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nI64 GGUFParseHeader(U8 *buf, I64 size, GGUFHeader *out, I64 *cursor)\n{\n    I64 c;\n    U32 magic;\n    U32 version;\n    U64 tensor_count;\n    U64 metadata_kv_count;\n\n    if (!buf || !out || !cursor)\n        return GGUF_PARSE_ERR_NULL_PTR;\n\n    c = *cursor;\n\n    if (!GGUFCanRead(buf, size, c, GGUF_HEADER_BYTES))\n        return GGUF_PARSE_ERR_TRUNCATED;\n\n    if (!GGUFReadU32LE(buf, size, &c, &magic))\n        return GGUF_PARSE_ERR_TRUNCATED;\n    if (magic != GGUF_MAGIC_U32)\n        return GGUF_PARSE_ERR_BAD_MAGIC;\n\n    if (!GGUFReadU32LE(buf, size, &c, &version))\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' tests/test_rope_q16_validate_head_span_for_dim.py\nsed -n '1,260p' tests/test_gguf_tensor_data_base.py\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' tests/test_rope_q16_validate_head_span_for_dim.py\nsed -n '1,260p' tests/test_gguf_tensor_data_base.py\"","aggregated_output":"#!/usr/bin/env python3\n\"\"\"Reference checks for RoPEQ16ValidateHeadSpanForDimChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.append(str(Path(__file__).resolve().parent))\n\nimport test_rope_q16_angle_step as ref\n\n\ndef rope_try_add_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    if rhs > 0 and lhs > ref.I64_MAX - rhs:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    if rhs < 0 and lhs < ref.I64_MIN - rhs:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return ref.ROPE_Q16_OK, lhs + rhs\n\n\ndef rope_try_sub_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    if rhs == ref.I64_MIN:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return rope_try_add_i64_checked(lhs, -rhs)\n\n\ndef rope_try_mul_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    prod = lhs * rhs\n    if prod > ref.I64_MAX or prod < ref.I64_MIN:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return ref.ROPE_Q16_OK, prod\n\n\ndef rope_q16_validate_head_span_for_dim_checked(\n    head_cell_capacity: int,\n    head_base_index: int,\n    head_dim: int,\n    pair_stride_cells: int,\n) -> tuple[int, int]:\n    if head_cell_capacity < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n    if head_base_index < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n    if head_dim <= 0 or (head_dim & 1):\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n    if pair_stride_cells < 2:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n\n    if head_base_index >= head_cell_capacity:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n\n    pair_count = head_dim >> 1\n\n    err, last_pair_index = rope_try_sub_i64_checked(pair_count, 1)\n    if err != ref.ROPE_Q16_OK:\n        return err, 0\n\n    err, last_pair_offset = rope_try_mul_i64_checked(last_pair_index, pair_stride_cells)\n    if err != ref.ROPE_Q16_OK:\n        return err, 0\n\n    err, last_pair_x = rope_try_add_i64_checked(head_base_index, last_pair_offset)\n    if err != ref.ROPE_Q16_OK:\n        return err, 0\n\n    err, last_pair_y = rope_try_add_i64_checked(last_pair_x, 1)\n    if err != ref.ROPE_Q16_OK:\n        return err, 0\n\n    if last_pair_x < 0 or last_pair_y < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n    if last_pair_y >= head_cell_capacity:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, 0\n\n    return ref.ROPE_Q16_OK, last_pair_y\n\n\ndef test_bad_param_contracts() -> None:\n    assert rope_q16_validate_head_span_for_dim_checked(-1, 0, 16, 2)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_validate_head_span_for_dim_checked(128, -1, 16, 2)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_validate_head_span_for_dim_checked(128, 0, 0, 2)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_validate_head_span_for_dim_checked(128, 0, 15, 2)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_validate_head_span_for_dim_checked(128, 0, 16, 1)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n\n\ndef test_known_value_case() -> None:\n    err, last_y = rope_q16_validate_head_span_for_dim_checked(128, 7, 16, 2)\n    assert err == ref.ROPE_Q16_OK\n    assert last_y == 22\n\n\ndef test_capacity_guard() -> None:\n    err, _ = rope_q16_validate_head_span_for_dim_checked(22, 7, 16, 2)\n    assert err == ref.ROPE_Q16_ERR_BAD_PARAM\n\n\ndef test_overflow_contract() -> None:\n    err, _ = rope_q16_validate_head_span_for_dim_checked(ref.I64_MAX, 0, ref.I64_MAX - 1, ref.I64_MAX)\n    assert err == ref.ROPE_Q16_ERR_OVERFLOW\n\n\ndef test_randomized_reference_parity() -> None:\n    rng = random.Random(2026041701)\n\n    for _ in range(5000):\n        head_cell_capacity = rng.randint(0, 400_000)\n        head_base_index = rng.randint(0, 420_000)\n        head_dim = rng.choice([2, 4, 8, 16, 32, 64])\n        pair_stride_cells = rng.randint(2, 64)\n\n        err, last_y = rope_q16_validate_head_span_for_dim_checked(\n            head_cell_capacity,\n            head_base_index,\n            head_dim,\n            pair_stride_cells,\n        )\n\n        if head_base_index >= head_cell_capacity:\n            assert err == ref.ROPE_Q16_ERR_BAD_PARAM\n            continue\n\n        pair_count = head_dim >> 1\n        expected_last_y = head_base_index + ((pair_count - 1) * pair_stride_cells) + 1\n\n        if expected_last_y > ref.I64_MAX:\n            assert err == ref.ROPE_Q16_ERR_OVERFLOW\n            continue\n\n        if expected_last_y >= head_cell_capacity:\n            assert err == ref.ROPE_Q16_ERR_BAD_PARAM\n            continue\n\n        assert err == ref.ROPE_Q16_OK\n        assert last_y == expected_last_y\n\n\ndef run() -> None:\n    test_bad_param_contracts()\n    test_known_value_case()\n    test_capacity_guard()\n    test_overflow_contract()\n    test_randomized_reference_parity()\n    print(\"rope_q16_validate_head_span_for_dim_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUF tensor-data base alignment and offset semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_TDBASE_OK = 0\nGGUF_TDBASE_ERR_NULL_PTR = 1\nGGUF_TDBASE_ERR_BAD_ALIGNMENT = 2\nGGUF_TDBASE_ERR_OVERFLOW = 3\nGGUF_TDBASE_ERR_MISALIGNED_BASE = 4\nGGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET = 5\nGGUF_TDBASE_ERR_BAD_TYPE = 6\nGGUF_TDBASE_ERR_OUT_OF_BOUNDS = 7\nGGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE = 8\nGGUF_TDBASE_ERR_OVERLAP = 9\n\nGGUF_DEFAULT_ALIGNMENT = 32\nU64_MAX = (1 << 64) - 1\n\nGGML_TYPE_F32 = 0\nGGML_TYPE_F16 = 1\nGGML_TYPE_Q4_0 = 2\nGGML_TYPE_Q8_0 = 8\n\n\ndef tensor_type_block_size(ggml_type: int):\n    if ggml_type == GGML_TYPE_F32:\n        return GGUF_TDBASE_OK, 1\n    if ggml_type == GGML_TYPE_F16:\n        return GGUF_TDBASE_OK, 1\n    if ggml_type == GGML_TYPE_Q4_0:\n        return GGUF_TDBASE_OK, 32\n    if ggml_type == GGML_TYPE_Q8_0:\n        return GGUF_TDBASE_OK, 32\n    return GGUF_TDBASE_ERR_BAD_TYPE, 0\n\n\ndef tensor_type_block_bytes(ggml_type: int):\n    if ggml_type == GGML_TYPE_F32:\n        return GGUF_TDBASE_OK, 4\n    if ggml_type == GGML_TYPE_F16:\n        return GGUF_TDBASE_OK, 2\n    if ggml_type == GGML_TYPE_Q4_0:\n        return GGUF_TDBASE_OK, 18\n    if ggml_type == GGML_TYPE_Q8_0:\n        return GGUF_TDBASE_OK, 34\n    return GGUF_TDBASE_ERR_BAD_TYPE, 0\n\n\ndef is_pow2_u32(value: int) -> bool:\n    return value > 0 and (value & (value - 1)) == 0\n\n\ndef tensor_bytes_for_type(ggml_type: int, element_count: int):\n    err, block_size = tensor_type_block_size(ggml_type)\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    err, block_bytes = tensor_type_block_bytes(ggml_type)\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    if element_count % block_size != 0:\n        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0\n\n    block_count = element_count // block_size\n    if block_count > U64_MAX // block_bytes:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0\n\n    return GGUF_TDBASE_OK, block_count * block_bytes\n\n\ndef validate_alignment(alignment: int) -> int:\n    if not is_pow2_u32(alignment):\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    return GGUF_TDBASE_OK\n\n\ndef align_up_u64(value: int, alignment: int):\n    err = validate_alignment(alignment)\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    mask = alignment - 1\n    if value > U64_MAX - mask:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0\n\n    out = (value + mask) & ~mask\n    return GGUF_TDBASE_OK, out\n\n\ndef tensor_data_base_align(cursor_after_tensor_info: int, alignment: int):\n    return align_up_u64(cursor_after_tensor_info, alignment)\n\n\ndef tensor_data_base_align_default(cursor_after_tensor_info: int):\n    return tensor_data_base_align(cursor_after_tensor_info, GGUF_DEFAULT_ALIGNMENT)\n\n\ndef tensor_data_base_is_aligned(offset: int, alignment: int) -> bool:\n    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n        return False\n    return (offset & (alignment - 1)) == 0\n\n\ndef tensor_data_base_offset(tensor_data_base: int, tensor_rel_offset: int, alignment: int):\n    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT, 0\n    if not tensor_data_base_is_aligned(tensor_data_base, alignment):\n        return GGUF_TDBASE_ERR_MISALIGNED_BASE, 0\n    if not tensor_data_base_is_aligned(tensor_rel_offset, alignment):\n        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET, 0\n    if tensor_data_base > U64_MAX - tensor_rel_offset:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    return GGUF_TDBASE_OK, tensor_data_base + tensor_rel_offset\n\n\ndef tensor_data_base_offset_default(tensor_data_base: int, tensor_rel_offset: int):\n    return tensor_data_base_offset(tensor_data_base, tensor_rel_offset, GGUF_DEFAULT_ALIGNMENT)\n\n\ndef tensor_resolve_range(\n    tensor_data_base: int,\n    tensor_rel_offset: int,\n    tensor_nbytes: int,\n    gguf_file_nbytes: int,\n    alignment: int,\n):\n    err, abs_start = tensor_data_base_offset(tensor_data_base, tensor_rel_offset, alignment)\n    if err != GGUF_TDBASE_OK:\n        return err, 0, 0\n\n    if abs_start > U64_MAX - tensor_nbytes:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0, 0\n\n    abs_end = abs_start + tensor_nbytes\n    if abs_end > gguf_file_nbytes:\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0\n\n    return GGUF_TDBASE_OK, abs_start, abs_end\n\n\ndef tensor_resolve_range_default(\n    tensor_data_base: int,\n    tensor_rel_offset: int,\n    tensor_nbytes: int,\n    gguf_file_nbytes: int,\n):\n    return tensor_resolve_range(\n        tensor_data_base,\n        tensor_rel_offset,\n        tensor_nbytes,\n        gguf_file_nbytes,\n        GGUF_DEFAULT_ALIGNMENT,\n    )\n\n\ndef validate_tensor_ranges(\n    tensor_data_base: int,\n    alignment: int,\n    gguf_file_nbytes: int,\n    tensor_rel_offsets: list[int],\n    tensor_nbytes: list[int],\n):\n    if len(tensor_rel_offsets) != len(tensor_nbytes):\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    count = len(tensor_rel_offsets)\n\n    for i in range(count):\n        err, _, _ = tensor_resolve_range(\n            tensor_data_base,\n            tensor_rel_offsets[i],\n            tensor_nbytes[i],\n            gguf_file_nbytes,\n            alignment,\n        )\n        if err != GGUF_TDBASE_OK:\n            return err, i\n\n    for i in range(count):\n        err, start_i, end_i = tensor_resolve_range(\n            tensor_data_base,\n            tensor_rel_offsets[i],\n            tensor_nbytes[i],\n            gguf_file_nbytes,\n            alignment,\n        )\n        assert err == GGUF_TDBASE_OK\n\n        for j in range(i + 1, count):\n            err, start_j, end_j = tensor_resolve_range(\n                tensor_data_base,\n                tensor_rel_offsets[j],\n                tensor_nbytes[j],\n                gguf_file_nbytes,\n                alignment,\n            )\n            assert err == GGUF_TDBASE_OK\n\n            if (start_i < end_j) and (start_j < end_i):\n                return GGUF_TDBASE_ERR_OVERLAP, j\n\n    return GGUF_TDBASE_OK, 0\n\n\ndef _sift_down(rel_offsets: list[int], nbytes: list[int], root: int, end: int) -> None:\n    def greater(i: int, j: int) -> bool:\n        if rel_offsets[i] > rel_offsets[j]:\n            return True\n        if rel_offsets[i] < rel_offsets[j]:\n            return False\n        return nbytes[i] > nbytes[j]\n\n    while True:\n        child = root * 2 + 1\n        if child > end:\n            return\n\n        swap_idx = root\n        if greater(child, swap_idx):\n            swap_idx = child\n        if child + 1 <= end and greater(child + 1, swap_idx):\n            swap_idx = child + 1\n\n        if swap_idx == root:\n            return\n\n        rel_offsets[root], rel_offsets[swap_idx] = rel_offsets[swap_idx], rel_offsets[root]\n        nbytes[root], nbytes[swap_idx] = nbytes[swap_idx], nbytes[root]\n        root = swap_idx\n\n\ndef _heapsort_ranges_in_place(rel_offsets: list[int], nbytes: list[int]) -> None:\n    count = len(rel_offsets)\n    if count < 2:\n        return\n\n    start = ((count - 2) // 2) + 1\n    while start > 0:\n        start -= 1\n        _sift_down(rel_offsets, nbytes, start, count - 1)\n\n    end = count - 1\n    while end > 0:\n        rel_offsets[0], rel_offsets[end] = rel_offsets[end], rel_offsets[0]\n        nbytes[0], nbytes[end] = nbytes[end], nbytes[0]\n        end -= 1\n        _sift_down(rel_offsets, nbytes, 0, end)\n\n\ndef validate_tensor_ranges_sorted(\n    tensor_data_base: int,\n    alignment: int,\n    gguf_file_nbytes: int,\n    tensor_rel_offsets: list[int],\n    tensor_nbytes: list[int],\n):\n","exit_code":0,"status":"completed"}}
