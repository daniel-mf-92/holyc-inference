{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/gguf/metadata.HC\nsed -n '261,560p' src/gguf/metadata.HC\nls tests | rg 'gguf|metadata' | sort\nsed -n '1,260p' tests/test_gguf_metadata_parse.py\"","aggregated_output":"// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n#define GGUF_META_PARSE_ERR_NOT_FOUND 9\n#define GGUF_META_PARSE_ERR_TYPE_MISMATCH 10\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nBool GGUFMetaCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n{\n    if (!buf)\n        return FALSE;\n    if (size < 0 || cursor < 0 || need < 0)\n        return FALSE;\n    if (cursor > size)\n        return FALSE;\n    if (need > size - cursor)\n        return FALSE;\n    return TRUE;\n}\n\nBool GGUFMetaReadU8(U8 *buf, I64 size, I64 *cursor, U8 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 1))\n        return FALSE;\n\n    *out = buf[c];\n    *cursor = c + 1;\n    return TRUE;\n}\n\nBool GGUFMetaReadU16LE(U8 *buf, I64 size, I64 *cursor, U16 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 2))\n        return FALSE;\n\n    *out = (U16)buf[c]\n         | ((U16)buf[c + 1] << 8);\n\n    *cursor = c + 2;\n    return TRUE;\n}\n\nBool GGUFMetaReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFMetaReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nBool GGUFMetaTypeSupported(U32 type)\n{\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n        case GGUF_TYPE_BOOL:\n        case GGUF_TYPE_STRING:\n        case GGUF_TYPE_ARRAY:\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            return TRUE;\n    }\n\n    return FALSE;\n}\n\nU0 GGUFMetaZeroString(GGUFString *s)\n{\n    if (!s)\n        return;\n    s->len = 0;\n    s->data = NULL;\n}\n\nU0 GGUFMetaZeroValue(GGUFMetaValue *v)\n{\n    if (!v)\n        return;\n\n    v->type = 0;\n    v->u64 = 0;\n    v->i64 = 0;\n    v->b = FALSE;\n    GGUFMetaZeroString(&v->str);\n    v->array_elem_type = 0;\n    v->array_len = 0;\n    v->array_payload_off = 0;\n    v->array_payload_bytes = 0;\n}\n\nU0 GGUFMetaZeroKV(GGUFMetadataKV *kv)\n{\n    if (!kv)\n        return;\n    GGUFMetaZeroString(&kv->key);\n    GGUFMetaZeroValue(&kv->value);\n}\n\nU0 GGUFMetaFreeString(GGUFString *s)\n{\n    if (!s)\n        return;\n\n    if (s->data)\n        Free(s->data);\n\n    s->data = NULL;\n    s->len = 0;\n}\n\nI64 GGUFMetaReadString(U8 *buf, I64 size, I64 *cursor, GGUFString *out)\n{\n    U64 len;\n    I64 c;\n    U8 *dst;\n    I64 i;\n\n    if (!cursor || !out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    GGUFMetaZeroString(out);\n\n    if (!GGUFMetaReadU64LE(buf, size, cursor, &len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (len > GGUF_MAX_STRING_BYTES)\n        return GGUF_META_PARSE_ERR_BAD_STRING_LEN;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n\n    dst = MAlloc(len + 1);\n    if (!dst)\n        return GGUF_META_PARSE_ERR_ALLOC;\n\n    for (i = 0; i < len; ++i)\n        dst[i] = buf[c + i];\n    dst[len] = 0;\n\n    *cursor = c + len;\n\n    out->len = len;\n    out->data = dst;\n    return GGUF_META_PARSE_OK;\n}\n\nI64 GGUFMetaSkipValueByType(U8 *buf, I64 size, I64 *cursor, U32 type)\n{\n    U8 u8v;\n    U16 u16v;\n    U32 u32v;\n    U64 u64v;\n    U32 elem_type;\n    U64 elem_count;\n    U64 i;\n    I64 err;\n\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_BOOL:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_STRING:\n            {\n                GGUFString tmp;\n\n                err = GGUFMetaReadString(buf, size, cursor, &tmp);\n                if (err != GGUF_META_PARSE_OK)\n                    return err;\n                GGUFMetaFreeString(&tmp);\n                return GGUF_META_PARSE_OK;\n            }\n\n        case GGUF_TYPE_ARRAY:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            if (elem_type == GGUF_TYPE_ARRAY)\n                return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n            if (!GGUFMetaTypeSupported(elem_type))\n                return GGUF_META_PARSE_ERR_BAD_TYPE;\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n                return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n\n            for (i = 0; i < elem_count; ++i)\n            {\n                err = GGUFMetaSkipValueByType(buf, size, cursor, elem_type);\n                if (err != GGUF_META_PARSE_OK)\n                    return err;\n            }\n\n            return GGUF_META_PARSE_OK;\n    }\n\n    return GGUF_META_PARSE_ERR_BAD_TYPE;\n}\n\nI64 GGUFMetaParseScalar(U8 *buf, I64 size, I64 *cursor, U32 type, GGUFMetaValue *out)\n{\n    U8 u8v;\n    U16 u16v;\n    U32 u32v;\n    U64 u64v;\n    I64 err;\n\n    if (!out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    out->type = type;\n\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u8v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT8:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I8)u8v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u16v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT16:\n            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I16)u16v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u32v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I32)u32v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_UINT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u64v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_INT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->i64 = (I64)u64v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_FLOAT32:\n            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u32v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_FLOAT64:\n            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->u64 = u64v;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_BOOL:\n            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n                return GGUF_META_PARSE_ERR_TRUNCATED;\n            out->b = (u8v != 0);\n            out->u64 = out->b;\n            return GGUF_META_PARSE_OK;\n\n        case GGUF_TYPE_STRING:\n            err = GGUFMetaReadString(buf, size, cursor, &out->str);\n            if (err != GGUF_META_PARSE_OK)\n                return err;\n            return GGUF_META_PARSE_OK;\n    }\n\n    return GGUF_META_PARSE_ERR_BAD_TYPE;\n}\n\nI64 GGUFMetaParseValue(U8 *buf, I64 size, I64 *cursor, GGUFMetaValue *out)\n{\n    U32 type;\n    U32 elem_type;\n    U64 elem_count;\n    I64 payload_begin;\n    I64 err;\n    U64 i;\n\n    if (!cursor || !out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    if (!GGUFMetaReadU32LE(buf, size, cursor, &type))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (!GGUFMetaTypeSupported(type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    GGUFMetaZeroValue(out);\n    out->type = type;\n\n    if (type != GGUF_TYPE_ARRAY)\n        return GGUFMetaParseScalar(buf, size, cursor, type, out);\n\n    if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (elem_type == GGUF_TYPE_ARRAY)\n        return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n    if (!GGUFMetaTypeSupported(elem_type))\n        return GGUF_META_PARSE_ERR_BAD_TYPE;\n\n    if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n        return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n\n    payload_begin = *cursor;\n    for (i = 0; i < elem_count; ++i)\n    {\n        err = GGUFMetaSkipValueByType(buf, size, cursor, elem_type);\n        if (err != GGUF_META_PARSE_OK)\n            return err;\n    }\n\n    out->array_elem_type = elem_type;\n    out->array_len = elem_count;\n    out->array_payload_off = payload_begin;\n    out->array_payload_bytes = *cursor - payload_begin;\n    return GGUF_META_PARSE_OK;\n}\n\nU0 GGUFFreeMetadataTable(GGUFMetadataTable *table)\n{\n    U64 i;\n\n    if (!table)\n        return;\n\n    if (!table->items)\n    {\n        table->count = 0;\n        return;\n    }\n\n    for (i = 0; i < table->count; ++i)\n    {\n        GGUFMetaFreeString(&table->items[i].key);\n        if (table->items[i].value.type == GGUF_TYPE_STRING)\n            GGUFMetaFreeString(&table->items[i].value.str);\n    }\n\n    Free(table->items);\n    table->items = NULL;\n    table->count = 0;\n}\n\nI64 GGUFParseMetadata(U8 *buf,\n                      I64 size,\n                      U64 metadata_kv_count,\n                      GGUFMetadataTable *out,\n                      I64 *cursor)\n{\n    GGUFMetadataKV *items;\n    U64 i;\n    I64 err;\n\n    if (!buf || !out || !cursor)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n    if (metadata_kv_count > GGUF_MAX_METADATA_COUNT)\n        return GGUF_META_PARSE_ERR_BAD_COUNT;\n\n    out->count = 0;\n    out->items = NULL;\n\n    if (!metadata_kv_count)\n        return GGUF_META_PARSE_OK;\n\n    items = MAlloc(sizeof(GGUFMetadataKV) * metadata_kv_count);\n    if (!items)\n        return GGUF_META_PARSE_ERR_ALLOC;\n\n    for (i = 0; i < metadata_kv_count; ++i)\n        GGUFMetaZeroKV(&items[i]);\n\n    out->items = items;\n\n    for (i = 0; i < metadata_kv_count; ++i)\n    {\n        err = GGUFMetaReadString(buf, size, cursor, &items[i].key);\n        if (err != GGUF_META_PARSE_OK)\n        {\n            out->count = metadata_kv_count;\n            GGUFFreeMetadataTable(out);\n            return err;\n        }\n\n        err = GGUFMetaParseValue(buf, size, cursor, &items[i].value);\n        if (err != GGUF_META_PARSE_OK)\n        {\n            out->count = metadata_kv_count;\n            GGUFFreeMetadataTable(out);\n            return err;\n        }\ntest_gguf_header_parse_checked.py\ntest_gguf_header_validate_and_size_checked.py\ntest_gguf_metadata_parse.py\ntest_gguf_tensor_data_base.py\ntest_gguf_tensorinfo_parse.py\n#!/usr/bin/env python3\n\"\"\"Focused GGUF metadata parser parity fixtures.\n\nThis is host-side validation only. It mirrors GGUF metadata binary layout and\nchecks that expected decode/validation behavior matches HolyC parser intent.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport struct\n\nGGUF_TYPE_UINT8 = 0\nGGUF_TYPE_INT8 = 1\nGGUF_TYPE_UINT16 = 2\nGGUF_TYPE_INT16 = 3\nGGUF_TYPE_UINT32 = 4\nGGUF_TYPE_INT32 = 5\nGGUF_TYPE_FLOAT32 = 6\nGGUF_TYPE_BOOL = 7\nGGUF_TYPE_STRING = 8\nGGUF_TYPE_ARRAY = 9\nGGUF_TYPE_UINT64 = 10\nGGUF_TYPE_INT64 = 11\nGGUF_TYPE_FLOAT64 = 12\n\nGGUF_META_PARSE_OK = 0\nGGUF_META_PARSE_ERR_TRUNCATED = 2\nGGUF_META_PARSE_ERR_BAD_TYPE = 3\nGGUF_META_PARSE_ERR_NESTED_ARRAY = 7\nGGUF_META_PARSE_ERR_NOT_FOUND = 9\nGGUF_META_PARSE_ERR_TYPE_MISMATCH = 10\n\n\ndef u8(v: int) -> bytes:\n    return struct.pack(\"<B\", v)\n\n\ndef u16(v: int) -> bytes:\n    return struct.pack(\"<H\", v)\n\n\ndef u32(v: int) -> bytes:\n    return struct.pack(\"<I\", v)\n\n\ndef u64(v: int) -> bytes:\n    return struct.pack(\"<Q\", v)\n\n\ndef i32(v: int) -> bytes:\n    return struct.pack(\"<i\", v)\n\n\ndef i64(v: int) -> bytes:\n    return struct.pack(\"<q\", v)\n\n\ndef f32(v: float) -> bytes:\n    return struct.pack(\"<f\", v)\n\n\ndef gguf_string(s: str) -> bytes:\n    raw = s.encode(\"utf-8\")\n    return u64(len(raw)) + raw\n\n\ndef meta_entry(key: str, value_type: int, payload: bytes) -> bytes:\n    return gguf_string(key) + u32(value_type) + payload\n\n\ndef scalar_payload(t: int, v):\n    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_BOOL):\n        return u8(int(v))\n    if t == GGUF_TYPE_INT8:\n        return struct.pack(\"<b\", int(v))\n    if t == GGUF_TYPE_UINT16:\n        return u16(int(v))\n    if t == GGUF_TYPE_INT16:\n        return struct.pack(\"<h\", int(v))\n    if t == GGUF_TYPE_UINT32:\n        return u32(int(v))\n    if t == GGUF_TYPE_INT32:\n        return i32(int(v))\n    if t == GGUF_TYPE_UINT64:\n        return u64(int(v))\n    if t == GGUF_TYPE_INT64:\n        return i64(int(v))\n    if t == GGUF_TYPE_FLOAT32:\n        return f32(float(v))\n    if t == GGUF_TYPE_FLOAT64:\n        return struct.pack(\"<d\", float(v))\n    if t == GGUF_TYPE_STRING:\n        return gguf_string(str(v))\n    raise ValueError(t)\n\n\ndef array_payload(elem_type: int, values: list) -> bytes:\n    payload = b\"\".join(\n        scalar_payload(elem_type, value) if elem_type != GGUF_TYPE_STRING else gguf_string(value)\n        for value in values\n    )\n    return u32(elem_type) + u64(len(values)) + payload\n\n\ndef parse_gguf_string(buf: bytes, cursor: int):\n    if cursor + 8 > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    (n,) = struct.unpack_from(\"<Q\", buf, cursor)\n    cursor += 8\n    if cursor + n > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    s = buf[cursor : cursor + n].decode(\"utf-8\")\n    cursor += n\n    return GGUF_META_PARSE_OK, cursor, s\n\n\ndef skip_value_by_type(buf: bytes, cursor: int, t: int):\n    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_INT8, GGUF_TYPE_BOOL):\n        return (GGUF_META_PARSE_OK, cursor + 1) if cursor + 1 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT16, GGUF_TYPE_INT16):\n        return (GGUF_META_PARSE_OK, cursor + 2) if cursor + 2 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT32, GGUF_TYPE_INT32, GGUF_TYPE_FLOAT32):\n        return (GGUF_META_PARSE_OK, cursor + 4) if cursor + 4 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t in (GGUF_TYPE_UINT64, GGUF_TYPE_INT64, GGUF_TYPE_FLOAT64):\n        return (GGUF_META_PARSE_OK, cursor + 8) if cursor + 8 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n    if t == GGUF_TYPE_STRING:\n        err, cursor2, _ = parse_gguf_string(buf, cursor)\n        return err, cursor2\n    if t == GGUF_TYPE_ARRAY:\n        return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor\n    return GGUF_META_PARSE_ERR_BAD_TYPE, cursor\n\n\ndef parse_value(buf: bytes, cursor: int):\n    if cursor + 4 > len(buf):\n        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n    (t,) = struct.unpack_from(\"<I\", buf, cursor)\n    cursor += 4\n\n    if t == GGUF_TYPE_ARRAY:\n        if cursor + 12 > len(buf):\n            return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n        elem_type, n = struct.unpack_from(\"<IQ\", buf, cursor)\n        cursor += 12\n        if elem_type == GGUF_TYPE_ARRAY:\n            return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor, None\n        if elem_type > GGUF_TYPE_FLOAT64:\n            return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n\n        payload_start = cursor\n        for _ in range(n):\n            err, cursor = skip_value_by_type(buf, cursor, elem_type)\n            if err != GGUF_META_PARSE_OK:\n                return err, cursor, None\n\n        return GGUF_META_PARSE_OK, cursor, {\n            \"type\": t,\n            \"array_elem_type\": elem_type,\n            \"array_len\": n,\n            \"array_payload_off\": payload_start,\n            \"array_payload_bytes\": cursor - payload_start,\n        }\n\n    if t > GGUF_TYPE_FLOAT64:\n        return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n\n    if t == GGUF_TYPE_STRING:\n        err, cursor, value = parse_gguf_string(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, None\n        return GGUF_META_PARSE_OK, cursor, {\"type\": t, \"value\": value}\n\n    err, cursor2 = skip_value_by_type(buf, cursor, t)\n    if err != GGUF_META_PARSE_OK:\n        return err, cursor2, None\n\n    raw = buf[cursor:cursor2]\n    return GGUF_META_PARSE_OK, cursor2, {\"type\": t, \"raw\": raw}\n\n\ndef parse_metadata_table(buf: bytes, count: int):\n    items = []\n    cursor = 0\n    for _ in range(count):\n        err, cursor, key = parse_gguf_string(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, items\n\n        err, cursor, value = parse_value(buf, cursor)\n        if err != GGUF_META_PARSE_OK:\n            return err, cursor, items\n\n        items.append((key, value))\n\n    return GGUF_META_PARSE_OK, cursor, items\n\n\ndef meta_find_by_key(items, key: str):\n    for k, v in items:\n        if k == key:\n            return v\n    return None\n\n\ndef meta_get_u64(items, key: str):\n    v = meta_find_by_key(items, key)\n    if v is None:\n        return GGUF_META_PARSE_ERR_NOT_FOUND, None\n    if v[\"type\"] not in (GGUF_TYPE_UINT8, GGUF_TYPE_UINT16, GGUF_TYPE_UINT32, GGUF_TYPE_UINT64):\n        return GGUF_META_PARSE_ERR_TYPE_MISMATCH, None\n    return GGUF_META_PARSE_OK, int.from_bytes(v[\"raw\"], \"little\", signed=False)\n\n\ndef meta_get_i64(items, key: str):\n    v = meta_find_by_key(items, key)\n    if v is None:\n        return GGUF_META_PARSE_ERR_NOT_FOUND, None\n    ty = v[\"type\"]\n    if ty not in (GGUF_TYPE_INT8, GGUF_TYPE_INT16, GGUF_TYPE_INT32, GGUF_TYPE_INT64):\n        return GGUF_META_PARSE_ERR_TYPE_MISMATCH, None\n    size = {GGUF_TYPE_INT8: 1, GGUF_TYPE_INT16: 2, GGUF_TYPE_INT32: 4, GGUF_TYPE_INT64: 8}[ty]\n    return GGUF_META_PARSE_OK, int.from_bytes(v[\"raw\"][:size], \"little\", signed=True)\n\n\ndef meta_get_bool(items, key: str):\n    v = meta_find_by_key(items, key)\n    if v is None:\n        return GGUF_META_PARSE_ERR_NOT_FOUND, None\n    if v[\"type\"] != GGUF_TYPE_BOOL:\n        return GGUF_META_PARSE_ERR_TYPE_MISMATCH, None\n    return GGUF_META_PARSE_OK, v[\"raw\"][0] != 0\n\n\ndef meta_get_string(items, key: str):\n    v = meta_find_by_key(items, key)\n    if v is None:\n        return GGUF_META_PARSE_ERR_NOT_FOUND, None\n    if v[\"type\"] != GGUF_TYPE_STRING:\n        return GGUF_META_PARSE_ERR_TYPE_MISMATCH, None\n    return GGUF_META_PARSE_OK, v[\"value\"]\n\n\ndef meta_get_f32_bits(items, key: str):\n    v = meta_find_by_key(items, key)\n    if v is None:\n        return GGUF_META_PARSE_ERR_NOT_FOUND, None\n    if v[\"type\"] != GGUF_TYPE_FLOAT32:\n        return GGUF_META_PARSE_ERR_TYPE_MISMATCH, None\n    return GGUF_META_PARSE_OK, int.from_bytes(v[\"raw\"], \"little\", signed=False)\n\n\ndef meta_get_f64_bits(items, key: str):\n    v = meta_find_by_key(items, key)\n    if v is None:\n        return GGUF_META_PARSE_ERR_NOT_FOUND, None\n    if v[\"type\"] != GGUF_TYPE_FLOAT64:\n        return GGUF_META_PARSE_ERR_TYPE_MISMATCH, None\n    return GGUF_META_PARSE_OK, int.from_bytes(v[\"raw\"], \"little\", signed=False)\n\n\n","exit_code":0,"status":"completed"}}
