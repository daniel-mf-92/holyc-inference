uf,\nsrc/gguf/metadata.HC:1347:I32 GGUFMetadataReadBoolPairChecked(U8 *buf,\ntests/test_gguf_metadata_read_i32_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadI32PairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_i64_pair_checked_no_partial.py:2:\"\"\"Reference checks for GGUFMetadataReadI64PairCheckedNoPartial semantics.\"\"\"\ntests/test_gguf_metadata_read_i16_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadI16PairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_bool_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadBoolPairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_f32bitsle_checked_no_partial.py:2:\"\"\"Reference checks for GGUFMetadataReadF32BitsLECheckedNoPartial semantics.\"\"\"\ntests/test_gguf_metadata_read_u8_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadU8PairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_f32bitsle_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadF32BitsLEChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_i8_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadI8PairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_u16_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadU16PairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_u32_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadU32PairChecked semantics.\"\"\"\ntests/test_gguf_metadata_read_f64bits_pair_checked.py:2:\"\"\"Reference checks for GGUFMetadataReadF64BitsPairChecked semantics.\"\"\"\n--- snippet metadata.HC ---\n    if (!out_payload_bytes)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Compose through shared checked multiply guards so all fixed-width array\n    // payload math follows one overflow/sign-domain contract.\n    err = GGUFMetadataMulU64Checked(elem_count,\n                                    elem_width_bytes,\n                                    &payload_bytes);\n    if (err != GGUF_META_TABLE_OK)\n        return err;