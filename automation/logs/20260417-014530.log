{"type":"item.completed","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' src/math/rmsnorm.HC; echo '---'; sed -n '320,680p' src/math/rmsnorm.HC; echo '---'; rg -n \\\"FPQ16RMSNormApplyInvDenom\\\" src/math/rmsnorm.HC tests -S; echo '---'; ls tests | rg rmsnorm -n || true; rg -n \\\"rmsnorm|inv denom|FPQ16\\\" tests -S\"","aggregated_output":"// rmsnorm.HC\n// Integer-only Q16.16 RMSNorm for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_DOMAIN    3\n#define FP_Q16_ERR_OVERFLOW  4\n\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Sqrt(I64 x);\nI32 FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(I64 a_q16,\n                                                     I64 b_q16,\n                                                     I64 d_q16,\n                                                     I64 *out_q16);\n\n// Apply precomputed RMSNorm inverse denominator to a Q16 vector with explicit\n// checked error surfaces. This uses one-rounding math:\n//   out[i] = round_half_up((input[i] * inv_denom_q16) / den_q16)\n// where den_q16 is a positive Q16 whole integer (d_int << 16).\nI32 FPQ16RMSNormApplyInvDenomChecked(I64 *input_q16,\n                                     I64 *output_q16,\n                                     I64 count,\n                                     I64 inv_denom_q16,\n                                     I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    // Delegate denominator contract + checked one-rounding to fixedpoint core.\n    // That keeps RMSNorm scaling error behavior identical to shared math helpers.\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        output_q16[i] = scaled_q16;\n    }\n\n    return 0;\n}\n\nU0 FPQ16RMSNorm(I64 *input, I64 *weight, I64 *output, I64 count, I64 eps_q16)\n{\n    I64 i;\n    I64 sq;\n    I64 sum_sq;\n    I64 mean_sq;\n    I64 denom;\n    I64 inv_denom;\n    I64 norm;\n\n    if (!input || !weight || !output || count <= 0)\n        return;\n\n    if (eps_q16 < 0)\n        eps_q16 = 0;\n\n    sum_sq = 0;\n    for (i = 0; i < count; i++)\n    {\n        sq = FPQ16Mul(input[i], input[i]);\n        if (sum_sq > I64_MAX_VALUE - sq)\n            sum_sq = I64_MAX_VALUE;\n        else\n            sum_sq += sq;\n    }\n\n    mean_sq = FPQ16Div(sum_sq, FPQ16FromInt(count));\n\n    if (mean_sq > I64_MAX_VALUE - eps_q16)\n        mean_sq = I64_MAX_VALUE;\n    else\n        mean_sq += eps_q16;\n\n    denom = FPQ16Sqrt(mean_sq);\n    if (denom <= 0)\n    {\n        for (i = 0; i < count; i++)\n            output[i] = 0;\n        return;\n    }\n\n    inv_denom = FPQ16Div(FP_Q16_ONE, denom);\n\n    for (i = 0; i < count; i++)\n    {\n        norm = FPQ16Mul(input[i], inv_denom);\n        output[i] = FPQ16Mul(norm, weight[i]);\n    }\n}\n---\n---\nsrc/math/rmsnorm.HC:25:I32 FPQ16RMSNormApplyInvDenomChecked(I64 *input_q16,\ntests/test_rmsnorm_apply_inv_denom_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormApplyInvDenomChecked semantics.\"\"\"\n---\n41:test_rmsnorm_apply_inv_denom_checked.py\ntests/test_softmax_entropy_q16.py:2:\"\"\"Host-side parity checks for FPQ16EntropyFromProbs behavior.\"\"\"\ntests/test_intlog_ratio_q16.py:2:\"\"\"Reference checks for FPQ16Log2 and FPQ16LnRatio HolyC semantics.\"\"\"\ntests/test_rmsnorm_apply_inv_denom_checked.py:2:\"\"\"Reference checks for FPQ16RMSNormApplyInvDenomChecked semantics.\"\"\"\ntests/test_rmsnorm_apply_inv_denom_checked.py:96:def fpq16_rmsnorm_apply_inv_denom_checked(\ntests/test_rmsnorm_apply_inv_denom_checked.py:130:    assert fpq16_rmsnorm_apply_inv_denom_checked(None, 3, FP_Q16_ONE, FP_Q16_ONE)[0] == FP_Q16_ERR_NULL_PTR\ntests/test_rmsnorm_apply_inv_denom_checked.py:131:    assert fpq16_rmsnorm_apply_inv_denom_checked(vec, -1, FP_Q16_ONE, FP_Q16_ONE)[0] == FP_Q16_ERR_BAD_PARAM\ntests/test_rmsnorm_apply_inv_denom_checked.py:132:    assert fpq16_rmsnorm_apply_inv_denom_checked(vec, 3, 0, FP_Q16_ONE)[0] == FP_Q16_ERR_DOMAIN\ntests/test_rmsnorm_apply_inv_denom_checked.py:133:    assert fpq16_rmsnorm_apply_inv_denom_checked(vec, 3, -FP_Q16_ONE, FP_Q16_ONE)[0] == FP_Q16_ERR_DOMAIN\ntests/test_rmsnorm_apply_inv_denom_checked.py:135:    assert fpq16_rmsnorm_apply_inv_denom_checked(vec, 3, FP_Q16_ONE, 0)[0] == FP_Q16_ERR_DOMAIN\ntests/test_rmsnorm_apply_inv_denom_checked.py:136:    assert fpq16_rmsnorm_apply_inv_denom_checked(vec, 3, FP_Q16_ONE, -FP_Q16_ONE)[0] == FP_Q16_ERR_DOMAIN\ntests/test_rmsnorm_apply_inv_denom_checked.py:137:    assert fpq16_rmsnorm_apply_inv_denom_checked(vec, 3, FP_Q16_ONE, FP_Q16_ONE + 1)[0] == FP_Q16_ERR_BAD_PARAM\ntests/test_rmsnorm_apply_inv_denom_checked.py:141:    err, out = fpq16_rmsnorm_apply_inv_denom_checked([11, 22, 33], 0, FP_Q16_ONE, FP_Q16_ONE)\ntests/test_rmsnorm_apply_inv_denom_checked.py:156:        err_vec, out_vec = fpq16_rmsnorm_apply_inv_denom_checked(vec, count, inv, den_q16)\ntests/test_rmsnorm_apply_inv_denom_checked.py:181:        err, out = fpq16_rmsnorm_apply_inv_denom_checked(vec, count, inv, den_q16)\ntests/test_rmsnorm_apply_inv_denom_checked.py:194:    err, out = fpq16_rmsnorm_apply_inv_denom_checked([huge], 1, huge, FP_Q16_ONE)\ntests/test_rmsnorm_apply_inv_denom_checked.py:205:    print(\"rmsnorm_apply_inv_denom_c