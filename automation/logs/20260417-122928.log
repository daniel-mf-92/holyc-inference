     return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 2))\n        return FALSE;\n\n    *out = (U16)buf[c]\n         | ((U16)buf[c + 1] << 8);\n\n    *cursor = c + 2;\n    return TRUE;\n}\n\nBool GGUFMetaReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFMetaReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nBool GGUFMetaTypeSupported(U32 type)\n{\n    switch (type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n        case GGUF_TYPE_BOOL:\n        case GGUF_TYPE_STRING:\n        case GGUF_TYPE_ARRAY:\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            return TRUE;\n    }\n\n    return FALSE;\n}\n\nU0 GGUFMetaZeroString(GGUFString *s)\n{\n    if (!s)\n        return;\n    s->len = 0;\n    s->data = NULL;\n}\n\nU0 GGUFMetaZeroValue(GGUFMetaValue *v)\n{\n    if (!v)\n        return;\n\n    v->type = 0;\n    v->u64 = 0;\n    v->i64 = 0;\n    v->b = FALSE;\n    GGUFMetaZeroString(&v->str);\n    v->array_elem_type = 0;\n    v->array_len = 0;\n    v->array_payload_off = 0;\n    v->array_payload_bytes = 0;\n}\n\nU0 GGUFMetaZeroKV(GGUFMetadataKV *kv)\n{\n    if (!kv)\n        return;\n    GGUFMetaZeroString(&kv->key);\n    GGUFMetaZeroValue(&kv->value);\n}\n\nU0 GGUFMetaFreeString(GGUFString *s)\n{\n    if (!s)\n        return;\n\n    if (s->data)\n        Free(s->data);\n\n    s->data = NULL;\n    s->len = 0;\n}\n\nI64 GGUFMetaReadString(U8 *buf, I64 size, I64 *cursor, GGUFString *out)\n{\n    U64 len;\n    I64 c;\n    U8 *dst;\n    I64 i;\n\n    if (!cursor || !out)\n        return GGUF_META_PARSE_ERR_NULL_PTR;\n\n    GGUFMetaZeroString(out);\n\n    if (!GGUFMetaReadU64LE(buf, size, cursor, &len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n    if (len > GGUF_MAX_STRING_BYTES)\n        return GGUF_META_PARSE_ERR_BAD_STRING_LEN;\n\n    c = *cursor;\n    if (!GGUFMetaCanRead(buf, size, c, len))\n        return GGUF_META_PARSE_ERR_TRUNCATED;\n\n    dst = MAlloc(len + 1);\n    if (!dst)\n        return GGUF_META_PARSE_ERR_ALLOC;\n\n    for (i = 0; i < len; ++i)\n        dst[i] = buf[c + i];\ntest_gguf_header_parse.py\ntest_gguf_header_parse_checked.py\ntest_gguf_header_read_endian_checked.py\ntest_gguf_header_validate_and_size_checked.py\ntest_gguf_metadata_parse.py\ntest_gguf_metadata_read_array_header_checked.py\ntest_gguf_metadata_read_bool_checked.py\ntest_gguf_metadata_read_f64bitsle_checked.py\ntest_gguf_metadata_read_i16le_checked.py\ntest_gguf_metadata_read_i32le_checked.py\ntest_gguf_metadata_read_i64le_checked.py\ntest_gguf_metadata_read_i64le_checked_no_partial.py\ntest_gguf_metadata_read_i8_checked.py\ntest_gguf_metadata_read_string_bytes_checked.py\ntest_gguf_metadata_read_string_len_u64_checked.py\ntest_gguf_metadata_read_string_u64_header_bounds_checked.py\ntest_gguf_metadata_read_u16le_checked.py\ntest_gguf_metadata_read_u32le_checked.py\ntest_gguf_metadata_read_u64le_checked.py\ntest_gguf_metadata_read_u64le_checked_no_partial.py\ntest_gguf_metadat