gned(I64 value, I64 shift)\n    58\t{\n    59\t    if (shift <= 0)\n    60\t        return value;\n    61\t\n    62\t    if (value >= 0)\n    63\t        return Q8_0RoundShiftRightUnsigned(value, shift);\n    64\t\n    65\t    return -Q8_0RoundShiftRightUnsigned(-value, shift);\n    66\t}\n    67\t\n    68\tI64 Q8_0F16ToQ16(U16 fp16_bits)\n    69\t{\n    70\t    I64 sign_bit;\n    71\t    I64 exponent_bits;\n    72\t    I64 fraction_bits;\n    73\t    I64 mantissa;\n    74\t    I64 shift_amount;\n    75\t    I64 magnitude_q16;\n    76\t\n    77\t    sign_bit = (fp16_bits >> 15) & 1;\n    78\t    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    79\t    fraction_bits = fp16_bits & 0x03FF;\n    80\t\n    81\t    if (!exponent_bits)\n    82\t    {\n    83\t        if (!fraction_bits)\n    84\t            return 0;\n    85\t\n    86\t        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n    87\t        if (sign_bit)\n    88\t            return -magnitude_q16;\n    89\t        return magnitude_q16;\n    90\t    }\n    91\t\n    92\t    if (exponent_bits == 0x1F)\n    93\t    {\n    94\t        if (sign_bit)\n    95\t            return -0x3FFFFFFFFFFFFFFF;\n    96\t        return 0x3FFFFFFFFFFFFFFF;\n    97\t    }\n    98\t\n    99\t    mantissa = 1024 + fraction_bits;\n   100\t    shift_amount = exponent_bits - 9;\n   101\t\n   102\t    if (shift_amount >= 0)\n   103\t        magnitude_q16 = mantissa << shift_amount;\n   104\t    else\n   105\t        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n   106\t\n   107\t    if (sign_bit)\n   108\t        return -magnitude_q16;\n   109\t    return magnitude_q16;\n   110\t}\n   111\t\n   112\tI32 Q8_0DotProductBlockQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 *out_dot_q32)\n   113\t{\n   114\t    I64 lhs_scale_q16;\n   115\t    I64 rhs_scale_q16;\n   116\t    I64 scale_prod_q32;\n   117\t    I64 byte_index;\n   118\t    I64 q_dot_q0;\n   119\t\n   120\t    if (!lhs || !rhs || !out_dot_q32)\n   121\t        return Q8_0_ERR_NULL_PTR;\n   122\t\n   123\t    lhs_scale_q16 = Q8_0F16ToQ16(lhs->d_fp16);\n   124\t    rhs_scale_q16 = Q8_0F16ToQ16(rhs->d_fp16);\n   125\t    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n   126\t\n   127\t    // Keep the integer dot explicit and auditable:\n   128\t    // q_dot_q0 = Sum(qA_i * qB_i), with q in signed byte domain [-128, 127].\n   129\t    q_dot_q0 = 0;\n   130\t    for (byte_index = 0; byte_index < Q8_0_PACKED_BYTES; ++byte_index)\n   131\t        q_dot_q0 += lhs->qs[byte_index] * rhs->qs[byte_index];\n   132\t\n   133\t    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n   134\t    return Q8_0_OK;\n   135\t}\n   136\t\n   137\tI32 Q8_0DotProductBlocksQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n   138\t{\n   139\t    I64 block_index;\n   140\t    I64 block_dot_q32;\n   141\t    I64 total_dot_q32;\n   142\t    I32 status;\n   143\t\n   144\t    if (!lhs || !rhs || !out_dot_q32)\n   145\t        return Q8_0_ERR_NULL_PTR;\n   146\t    if (block_count < 0)\n   147\t        return Q8_0_ERR_BAD_DST_LEN;\n   148\t\n   149\t    total_dot_q32 = 0;\n   150\t    for (block_index = 0; block_index < block_count; ++block_index)\n   151\t    {\n   152\t        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n   153\t        if (status != Q8_0_OK)\n   154\t            return status;\n   155\t\n   156\t        total_dot_q32 += block_dot_q32;\n   157\t    }\n   158\t\n   159\t    *out_dot_q32 = total_dot_q32;\n   160\t    return Q8_0_OK;\n   161\t}\n   162\t\n   163\tI32 Q8_0DotProductBlocksQ32Checked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n   164\t{\n   165\t    I64 block_index;\n   166\t    I64 block_dot_q32;\n   167\t    I64 total_dot_q32;\n   168\t    I32 status;\n   169\t\n   170\t    if (!lhs || !rhs || !out_dot_q32)\n   171\t        return Q8_0_ERR_NULL_PTR;\n   172\t    if (block_count < 0)\n   173\t        return Q8_0_ERR_BAD_DST_LEN;\n   174\t\n   175\t    total_dot_q32 = 0;\n   176\t    for (block_index = 0; block_index < block_count; ++block_index)\n   177\t    {\n   178\t        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n   179\t        if (status != Q8_0_OK)\n   180\t            return status;\n   181\t\n   182\t        // Keep hostile stream handling explicit.\n   183\t        // A malicious block sequence can drive total_dot_q32 beyond I64; reject early.\n   184\t        if (!Q8_0TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n   185\t            return Q8_0_ERR_OVERFLOW;\n   186\t    }\n   187\t\n   188\t    *out_dot_q32 = total_dot_q32;\n   189\t    return Q8_0_OK;\n   190\t}\n   191\t\n   192\tI32 Q8_0DotProductBlocksQ32ToQ16(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q16)\n   193\t{\n   194\t    I64 total_dot_q32;\n   195\t    I32 status;\n   196\t\n   197\t    if (!lhs || !rhs || !out_dot_q16)\n   198\t        return Q8_0_ERR_NULL_PTR;\n   199\t    if (block_count < 0)\n   200\t        return Q8_0_ERR_BAD_DST_LEN;\n   201\t\n   202\t    // WS4 callers can keep the full multi-block dot in widened I64 Q32,\n   203\t    // then round once to Q16 for deterministic lane hand-off.\n   204\t    status = Q8_0DotProductBlocksQ32(lhs, rhs, block_count, &total_dot_q32);\n   205\t    if (status != Q8_0_OK)\n   206\t        return status;\n   207\t\n   208\t    *out_dot_q16 = Q8_0DotQ32ToQ16(total_dot_q32);\n   209\t    return Q8_0_OK;\n   210\t}\n   211\t\n   212\tI32 Q8_0DotProductBlocksQ16Accumulate(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16)\n   213\t{\n   214\t    I64 block_index;\n   215\t    I64 block_dot_q32;\n   216\t    I64 total_q16;\n   217\t    I32 status;\n   218\t\n   219\t    if (!lhs || !rhs || !io_accum_q16)\n   220\t        return Q8_0_ERR_NULL_PTR;\n   221\t    if (block_count < 0)\n   222\t        return Q8_0_ERR_BAD_DST_LEN;\n   223\t\n   224\t    total_q16 = *io_accum_q16;\n   225\t\n   226\t    // Matmul callers usually hold accumulators in Q16 lanes.\n   227\t    // Keep per-block rounding explicit: Q32 block dot -> rounded Q16 -> add.\n   228\t    // This avoids hidden scale changes and makes every block contribution auditable.\n   229\t    for (block_index = 0; block_index < block_count; ++block_index)\n   230\t    {\n   231\t        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n   232\t        if (status != Q8_0_OK)\n   233\t            return status;\n   234\t\n   235\t        total_q16 += Q8_0DotQ32ToQ16(block_dot_q32);\n   236\t    }\n   237\t\n   238\t    *io_accum_q16 = total_q16;\n   239\t    return Q8_0_OK;\n   240\t}\n   241\t\n   242\tI32 Q8_0DotRowBlocksQ16(Q8_0Block *row_blocks, Q8_0Block *vec_blocks, I64 block_count, I64 *out_dot_q16)\n   243\t{\n   244\t    I64 block_index;\n   245\t    I64 block_dot_q32;\n   246\t    I64 total_dot_q16;\n   247\t    I32 status;\n   248\t\n   249\t    if (!row_blocks || !vec_blocks || !out_dot_q16)\n   250\t        return Q8_0_ERR_NULL_PTR;\n   251\t    if (block_count < 0)\n   252\t        return Q8_0_ERR_BAD_DST_LEN;\n   253\t\n   254\t    // WS4 row kernels consume Q16 lanes.\n   255\t    // Keep block contributions visible and deterministic:\n   256\t    //   each block dot in Q32 -> rounded Q16 -> accumulated row total.\n   257\t    // This intentionally preserves per-block rounding semantics.\n   258\t    total_dot_q16 = 0;\n   259\t    for (block_index = 0; block_index < block_count; ++block_index)\n   260\t    {\n   261\t        status = Q8_0DotProductBlockQ32(&row_blocks[block_index], &vec_blocks[block_index], &block_dot_q32);\n   262\t        if (status != Q8_0_OK)\n   263\t            return status;\n   264\t\n   265\t        total_dot_q16 += Q8_0DotQ32ToQ16(block_dot_q32);\n   266\t    }\n   267\t\n   268\t    *out_dot_q16 = total_dot_q16;\n   269\t    return Q8_0_OK;\n   270\t}\n   271\t\n   272\tI32 Q8_0DotRowsQ16MatrixVector(Q8_0Block *matrix_blocks, I64 row_count, I64 row_stride_blocks, Q8_0Block *vec_blocks, I64 vec_block_count, I64 *out_rows_q16)\n   273\t{\n   274\t    I64 row_index;\n   275\t    I64 row_dot_q16;\n   276\t    Q8_0Block *row_ptr;\n   277\t    I32 status;\n   278\t\n   279\t    if (!matrix_blocks || !vec_blocks || !out_rows_q16)\n   280\t        return Q8_0_ERR_NULL_PTR;\n   281\t    if (row_count < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n   282\t        return Q8_0_ERR_BAD_DST_LEN;\n   283\t\n   284\t    // Each row begins at:\n   285\t    //   matrix_blocks + row_index * row_stride_blocks\n   286\t    // and consumes vec_block_count contiguous blocks.\n   287\t    // Require stride >= active vector span so row windows are valid and auditable.\n   288\t    if (row_count > 0 && row_stride_blocks < vec_block_count)\n   289\t        return Q8_0_ERR_BAD_DST_LEN;\n   290\t\n   291\t    for (row_index = 0; row_index < row_count; ++row_index)\n   292\t    {\n   293\t        row_ptr = &matrix_blocks[row_index * row_stride_blocks];\n   294\t        status = Q8_0DotRowBlocksQ16(row_ptr, vec_blocks, vec_block_count, &row_dot_q16);\n   295\t        if (status != Q8_0_OK)\n   296\t            return status;\n   297\t\n   298\t        out_rows_q16[row_index] = row_dot_q16;\n   299\t    }\n   300\t\n   301\t    return Q8_0_OK;\n   302\t}\n   303\t\n   304\tI64 Q8_0DotQ32ToQ16(I64 dot_q32)\n   305\t{\n   306\t    return Q8_0RoundShiftRightSigned(dot_q32, 16);\n   307\t}\n","exit_code":0,"status":"completed"}}
