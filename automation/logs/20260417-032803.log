{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' src/math/intexp.HC; sed -n '1,260p' tests/test_intexp_exp_array_checked.py\"","aggregated_output":"// intexp.HC\n// Integer-only Q16.16 exponential approximation for TempleOS HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define EXP_Q16_LN2       45426   // round(ln(2) * 65536)\n#define EXP_Q16_MAX_INPUT 655360  // +10.0 in Q16\n#define EXP_Q16_MIN_INPUT -655360 // -10.0 in Q16\n\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n#define U64_MAX_VALUE 0xFFFFFFFFFFFFFFFF\n\nI64 FPQ16Mul(I64 a, I64 b);\n\n// Checked clamp helper used by scalar exp and vector exp callers.\n// Clamps to the saturating exp input domain [-10.0, +10.0] in Q16.\nI32 FPQ16ExpClampToInputDomainChecked(I64 input_q16,\n                                      I64 *out_clamped_q16)\n{\n    if (!out_clamped_q16)\n        return FP_Q16_ERR_NULL_PTR;\n\n    // Protect against accidental constant inversion during refactors.\n    if (EXP_Q16_MIN_INPUT > EXP_Q16_MAX_INPUT)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (input_q16 < EXP_Q16_MIN_INPUT)\n    {\n        *out_clamped_q16 = EXP_Q16_MIN_INPUT;\n        return FP_Q16_OK;\n    }\n\n    if (input_q16 > EXP_Q16_MAX_INPUT)\n    {\n        *out_clamped_q16 = EXP_Q16_MAX_INPUT;\n        return FP_Q16_OK;\n    }\n\n    *out_clamped_q16 = input_q16;\n    return FP_Q16_OK;\n}\n\n// Vector checked clamp helper for Q16 exp input-domain saturation.\n// Applies the same scalar clamp contract lane-by-lane:\n//   out[i] = clamp(in[i], EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT)\n// This keeps scalar and vector behavior identical by delegating each lane to\n// FPQ16ExpClampToInputDomainChecked instead of duplicating clamp logic.\nI32 FPQ16ExpClampArrayToInputDomainChecked(I64 *input_q16,\n                                           I64 *output_q16,\n                                           I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic used by indexed array access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16ExpClampToInputDomainChecked(input_q16[i],\n                                                   &output_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked Q16 exp evaluation for callers that already performed input-domain\n// clamping. This helper refuses out-of-domain inputs instead of clamping:\n//   requires EXP_Q16_MIN_INPUT <= clamped_input_q16 <= EXP_Q16_MAX_INPUT\n//   returns BAD_PARAM on domain violations\n// This keeps split-phase clamp+eval vector paths explicit and auditable.\nI32 FPQ16ExpFromClampedInputChecked(I64 clamped_input_q16,\n                                    I64 *out_exp_q16)\n{\n    I64 k;\n    I64 r;\n    I64 r2;\n    I64 r3;\n    I64 r4;\n    I64 t1;\n    I64 t2;\n    I64 t3;\n    I64 t4;\n    I64 poly;\n\n    if (!out_exp_q16)\n        return FP_Q16_ERR_NULL_PTR;\n\n    if (clamped_input_q16 < EXP_Q16_MIN_INPUT ||\n        clamped_input_q16 > EXP_Q16_MAX_INPUT)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Preserve scalar saturation contract exactly on domain boundaries.\n    if (clamped_input_q16 >= EXP_Q16_MAX_INPUT)\n    {\n        *out_exp_q16 = I64_MAX_VALUE;\n        return FP_Q16_OK;\n    }\n    if (clamped_input_q16 <= EXP_Q16_MIN_INPUT)\n    {\n        *out_exp_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Range reduction: x = k*ln(2) + r, where r in [0, ln(2)).\n    k = clamped_input_q16 / EXP_Q16_LN2;\n    if (clamped_input_q16 < 0 && (clamped_input_q16 % EXP_Q16_LN2))\n        k--;\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2);\n\n    // exp(r) ~= 1 + r + r^2/2 + r^3/6 + r^4/24\n    r2 = FPQ16Mul(r, r);\n    r3 = FPQ16Mul(r2, r);\n    r4 = FPQ16Mul(r3, r);\n\n    t1 = r;\n    t2 = r2 / 2;\n    t3 = r3 / 6;\n    t4 = r4 / 24;\n\n    poly = FP_Q16_ONE + t1 + t2 + t3 + t4;\n\n    if (k >= 0)\n    {\n        if (k >= 30)\n        {\n            *out_exp_q16 = I64_MAX_VALUE;\n            return FP_Q16_OK;\n        }\n\n        if (poly > (I64_MAX_VALUE >> k))\n        {\n            *out_exp_q16 = I64_MAX_VALUE;\n            return FP_Q16_OK;\n        }\n\n        *out_exp_q16 = poly << k;\n        return FP_Q16_OK;\n    }\n\n    if (k <= -63)\n    {\n        *out_exp_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    *out_exp_q16 = poly >> (-k);\n    return FP_Q16_OK;\n}\n\n// Checked vector exp helper for softmax precompute lanes.\n// For each lane i, this composes the scalar checked path directly:\n//   clamped = clamp(input_q16[i], EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT)\n//   output_q16[i] = exp(clamped)\n// This preserves scalar saturation/domain semantics exactly while keeping all\n// pointer/count arithmetic guarded for deterministic TempleOS-safe behavior.\nI32 FPQ16ExpArrayChecked(I64 *input_q16,\n                         I64 *output_q16,\n                         I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 clamped_lane;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic used by indexed lane access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16ExpClampToInputDomainChecked(input_q16[i],\n                                                   &clamped_lane);\n        if (status)\n            return status;\n\n        status = FPQ16ExpFromClampedInputChecked(clamped_lane,\n                                                 &output_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked vector exp helper for callers that already pre-clamped lanes into\n// the scalar-domain contract:\n//   EXP_Q16_MIN_INPUT <= input_q16[i] <= EXP_Q16_MAX_INPUT\n// On any out-of-domain lane this returns BAD_PARAM and performs zero writes,\n// so split-phase clamp/eval callers never observe partially-updated output.\nI32 FPQ16ExpArrayFromClampedInputChecked(I64 *input_q16,\n                                         I64 *output_q16,\n                                         I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic used by indexed lane access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Fail fast before any writes so output remains untouched on BAD_PARAM.\n    for (i = 0; i < count; i++)\n    {\n        if (input_q16[i] < EXP_Q16_MIN_INPUT ||\n            input_q16[i] > EXP_Q16_MAX_INPUT)\n            return FP_Q16_ERR_BAD_PARAM;\n    }\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16ExpFromClampedInputChecked(input_q16[i],\n                                                 &output_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\nI64 FPQ16Exp(I64 x)\n{\n    I32 clamp_status;\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16ExpArrayChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nEXP_Q16_LN2 = 45426\nEXP_Q16_MAX_INPUT = 655360\nEXP_Q16_MIN_INPUT = -655360\n\nI64_MAX_VALUE = (1 << 63) - 1\nU64_MAX_VALUE = (1 << 64) - 1\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_OVERFLOW = 4\n\n\ndef fpq16_mul(a: int, b: int) -> int:\n    prod = a * b\n    if prod >= 0:\n        return (prod + (1 << (FP_Q16_SHIFT - 1))) >> FP_Q16_SHIFT\n    return -(((-prod) + (1 << (FP_Q16_SHIFT - 1))) >> FP_Q16_SHIFT)\n\n\ndef fpq16_exp_clamp_to_input_domain_checked(input_q16: int, out_present: bool = True) -> tuple[int, int]:\n    if not out_present:\n        return FP_Q16_ERR_NULL_PTR, 0\n\n    if EXP_Q16_MIN_INPUT > EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM, 0\n\n    if input_q16 < EXP_Q16_MIN_INPUT:\n        return FP_Q16_OK, EXP_Q16_MIN_INPUT\n\n    if input_q16 > EXP_Q16_MAX_INPUT:\n        return FP_Q16_OK, EXP_Q16_MAX_INPUT\n\n    return FP_Q16_OK, input_q16\n\n\ndef fpq16_exp_from_clamped_input_checked(clamped_input_q16: int, out_present: bool = True) -> tuple[int, int]:\n    if not out_present:\n        return FP_Q16_ERR_NULL_PTR, 0\n\n    if clamped_input_q16 < EXP_Q16_MIN_INPUT or clamped_input_q16 > EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM, 0\n\n    if clamped_input_q16 >= EXP_Q16_MAX_INPUT:\n        return FP_Q16_OK, I64_MAX_VALUE\n    if clamped_input_q16 <= EXP_Q16_MIN_INPUT:\n        return FP_Q16_OK, 0\n\n    k = clamped_input_q16 // EXP_Q16_LN2\n    if clamped_input_q16 < 0 and (clamped_input_q16 % EXP_Q16_LN2):\n        k -= 1\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2)\n\n    r2 = fpq16_mul(r, r)\n    r3 = fpq16_mul(r2, r)\n    r4 = fpq16_mul(r3, r)\n\n    poly = FP_Q16_ONE + r + (r2 // 2) + (r3 // 6) + (r4 // 24)\n\n    if k >= 0:\n        if k >= 30:\n            return FP_Q16_OK, I64_MAX_VALUE\n        if poly > (I64_MAX_VALUE >> k):\n            return FP_Q16_OK, I64_MAX_VALUE\n        return FP_Q16_OK, poly << k\n\n    if k <= -63:\n        return FP_Q16_OK, 0\n\n    return FP_Q16_OK, poly >> (-k)\n\n\ndef fpq16_exp_array_checked(\n    input_q16: list[int] | None,\n    output_q16: list[int] | None,\n    count: int,\n    *,\n    synthetic_input_addr: int = 0x1100,\n    synthetic_output_addr: int = 0x2200,\n) -> tuple[int, list[int] | None]:\n    if input_q16 is None or output_q16 is None:\n        return FP_Q16_ERR_NULL_PTR, output_q16\n    if count < 0:\n        return FP_Q16_ERR_BAD_PARAM, output_q16\n    if count == 0:\n        return FP_Q16_OK, output_q16\n\n    last_index = count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, output_q16\n\n    last_byte_offset = last_index << 3\n    if synthetic_input_addr > (U64_MAX_VALUE - last_byte_offset):\n        return FP_Q16_ERR_OVERFLOW, output_q16\n    if synthetic_output_addr > (U64_MAX_VALUE - last_byte_offset):\n        return FP_Q16_ERR_OVERFLOW, output_q16\n\n    if len(input_q16) < count or len(output_q16) < count:\n        raise ValueError(\"test harness requires count <= provided buffer lengths\")\n\n    for i in range(count):\n        err, clamped = fpq16_exp_clamp_to_input_domain_checked(input_q16[i])\n        if err != FP_Q16_OK:\n            return err, output_q16\n\n        err, lane = fpq16_exp_from_clamped_input_checked(clamped)\n        if err != FP_Q16_OK:\n            return err, output_q16\n\n        output_q16[i] = lane\n\n    return FP_Q16_OK, output_q16\n\n\ndef test_null_pointer_surfaces() -> None:\n    err, _ = fpq16_exp_array_checked(None, [0], 1)\n    assert err == FP_Q16_ERR_NULL_PTR\n\n    err, _ = fpq16_exp_array_checked([0], None, 1)\n    assert err == FP_Q16_ERR_NULL_PTR\n\n\ndef test_bad_param_negative_count() -> None:\n    out = [111, 222]\n    err, got = fpq16_exp_array_checked([1, 2], out, -1)\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert got == [111, 222]\n\n\ndef test_zero_count_no_write() -> None:\n    out = [111, 222, 333]\n    err, got = fpq16_exp_array_checked([1, 2, 3], out, 0)\n    assert err == FP_Q16_OK\n    assert got == [111, 222, 333]\n\n\ndef test_overflow_pointer_span_guards() -> None:\n    huge_count = (I64_MAX_VALUE >> 3) + 2\n    err, _ = fpq16_exp_array_checked([0], [0], huge_count)\n    assert err == FP_Q16_ERR_OVERFLOW\n\n    count = 4\n    near_end = U64_MAX_VALUE - ((count - 1) << 3) + 1\n    err, _ = fpq16_exp_array_checked(\n        [0] * count,\n        [0] * count,\n        count,\n        synthetic_input_addr=near_end,\n    )\n    assert err == FP_Q16_ERR_OVERFLOW\n\n    err, _ = fpq16_exp_array_checked(\n        [0] * count,\n        [0] * count,\n        count,\n        synthetic_output_addr=near_end,\n    )\n    assert err == FP_Q16_ERR_OVERFLOW\n\n\ndef test_boundary_saturation_edges() -> None:\n    inputs = [\n        EXP_Q16_MIN_INPUT - 99,\n        EXP_Q16_MIN_INPUT,\n        EXP_Q16_MIN_INPUT + 1,\n        0,\n        EXP_Q16_MAX_INPUT - 1,\n        EXP_Q16_MAX_INPUT,\n        EXP_Q16_MAX_INPUT + 99,\n    ]\n\n    out = [0] * len(inputs)\n    err, got = fpq16_exp_array_checked(inputs, out, len(inputs))\n    assert err == FP_Q16_OK\n    assert got is not None\n\n    assert got[0] == 0\n    assert got[1] == 0\n    assert got[5] == I64_MAX_VALUE\n    assert got[6] == I64_MAX_VALUE\n\n\ndef test_scalar_composition_parity_with_unclamped_inputs() -> None:\n    inputs = [\n        EXP_Q16_MIN_INPUT - 777,\n        -500000,\n        -12345,\n        -1,\n        0,\n        1,\n        12345,\n        500000,\n        EXP_Q16_MAX_INPUT + 777,\n    ]\n\n    out = [0] * len(inputs)\n    err, got = fpq16_exp_array_checked(inputs, out, len(inputs))\n    assert err == FP_Q16_OK\n    assert got is not None\n\n    for i, value in enumerate(inputs):\n        clamp_err, clamped = fpq16_exp_clamp_to_input_domain_checked(value)\n        assert clamp_err == FP_Q16_OK\n\n        eval_err, scalar = fpq16_exp_from_clamped_input_checked(clamped)\n        assert eval_err == FP_Q16_OK\n        assert got[i] == scalar\n\n\ndef test_randomized_clamp_eval_parity() -> None:\n    rng = random.Random(20260417_166)\n\n    for _ in range(1500):\n        count = rng.randint(1, 96)\n        inputs = [rng.randint(-(1 << 62), (1 << 62)) for _ in range(count)]\n        out = [0] * count\n\n        err, got = fpq16_exp_array_checked(inputs, out, count)\n        assert err == FP_Q16_OK\n        assert got is not None\n\n        for i in range(count):\n            clamp_err, clamped = fpq16_exp_clamp_to_input_domain_checked(inputs[i])\n            assert clamp_err == FP_Q16_OK\n            eval_err, scalar = fpq16_exp_from_clamped_input_checked(clamped)\n            assert eval_err == FP_Q16_OK\n            assert got[i] == scalar\n\n\ndef test_inplace_alias_path_matches_out_of_place() -> None:\n    values = [\n        EXP_Q16_MIN_INPUT - 1,\n        -42,\n        0,\n        42,\n        EXP_Q16_MAX_INPUT + 1,\n    ]\n\n    out_of_place = [0] * len(values)\n    err, expected = fpq16_exp_array_checked(values.copy(), out_of_place, len(values))\n    assert err == FP_Q16_OK\n    assert expected is not None\n\n    aliased = values.copy()\n    err, got = fpq16_exp_array_checked(aliased, aliased, len(aliased))\n    assert err == FP_Q16_OK\n    assert