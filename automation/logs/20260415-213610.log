{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/math/softmax.HC && python3 - <<'PY'\nimport math, random\nFP_Q16_SHIFT=16\nFP_Q16_ONE=1<<FP_Q16_SHIFT\nI64_MIN=-(1<<63)\nI64_MAX=(1<<63)-1\n\ndef rsu(v,s):\n    if s<=0:return v\n    return (v + (1<<(s-1)))>>s\n\ndef rss(v,s):\n    if s<=0:return v\n    return rsu(v,s) if v>=0 else -rsu(-v,s)\n\ndef mul(a,b):\n    return rss(a*b, FP_Q16_SHIFT)\nLOG_Q16_LN2=45426\nLOG_Q16_SPLIT=(FP_Q16_ONE*3)//2\n\ndef ln1p_poly(y):\n    y2=mul(y,y); y3=mul(y2,y); y4=mul(y3,y); y5=mul(y4,y)\n    return y-(y2//2)+(y3//3)-(y4//4)+(y5//5)\ndef ln_reduce(x):\n    if x<=0:return 0,0\n    m=x; k=0\n    while m>=(FP_Q16_ONE<<1): m>>=1; k+=1\n    while m<FP_Q16_ONE: m<<=1; k-=1\n    return m,k\ndef lnq(x):\n    if x<=0:return I64_MIN\n    m,k=ln_reduce(x)\n    if m>=LOG_Q16_SPLIT:\n        m=(m+1)>>1; k+=1\n    return k*LOG_Q16_LN2 + ln1p_poly(m-FP_Q16_ONE)\ndef entropy_from_probs(probs):\n    s=0\n    for p in probs:\n        if p<=0: continue\n        if p>FP_Q16_ONE: p=FP_Q16_ONE\n        ln=lnq(p)\n        if ln==I64_MIN: continue\n        plnp=mul(p,ln)\n        if plnp>0: plnp=0\n        s = max(I64_MIN, s+plnp)\n    if s==I64_MIN:return I64_MAX\n    return -s\n\nrng=random.Random(20260415)\nfor n in [2,3,4,8,16,32]:\n    for _ in range(300):\n        xs=[rng.uniform(-5,5) for _ in range(n)]\n        mx=max(xs)\n        ex=[math.exp(x-mx) for x in xs]\n        den=sum(ex)\n        ps=[e/den for e in ex]\n        q=[round(p*FP_Q16_ONE) for p in ps]\n        diff=FP_Q16_ONE-sum(q)\n        q[ps.index(max(ps))]+=diff\n        got=entropy_from_probs(q)/FP_Q16_ONE\n        want=-sum((qq/FP_Q16_ONE)*math.log(max(qq/FP_Q16_ONE,1e-18)) for qq in q if qq>0)\n        if abs(got-want)>0.02:\n            raise SystemExit(f\\\"entropy mismatch n={n}: got={got} want={want}\\\")\nprint('softmax_entropy_q16_reference_checks=ok')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
