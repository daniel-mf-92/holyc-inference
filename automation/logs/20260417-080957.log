{"type":"item.started","item":{"id":"item_30","type":"command_execution","command":"/bin/zsh -lc \"python3 tests/test_fixedpoint_q16_muldiv_positive_int_checked.py && python3 tests/test_fixedpoint_q16_muldiv_array_checked.py && python3 - <<'PY'\nimport random\nFP_Q16_SHIFT=16\nFP_Q16_ONE=1<<FP_Q16_SHIFT\nI64_MAX=(1<<63)-1\nU64_MAX=(1<<64)-1\nOK,DOMAIN,OVER=0,3,4\n\ndef absu(x):\n    return x if x>=0 else (-(x+1))+1\n\ndef lane(a,b,d):\n    if d<=0:return DOMAIN,None\n    if d > (U64_MAX>>FP_Q16_SHIFT): return OVER,None\n    aa,bb=absu(a),absu(b)\n    neg=(a<0)\"'^(b<0)\n    if aa and bb and aa > (U64_MAX//bb): return OVER,None\n    num=aa*bb\n    den=d<<FP_Q16_SHIFT\n    q,r=divmod(num,den)\n    lim=(1<<63) if neg else I64_MAX\n    if q>lim:return OVER,None\n    if r>=((den+1)>>1):\n        if q==lim:return OVER,None\n        q+=1\n    if neg:\n        return OK, (-(1<<63) if q==(1<<63) else -q)\n    return OK,q\n\ndef arr(a,b,d,out):\n    for i in range(len(a)):\n        e,_=lane(a[i],b[i],d[i])\n        if e:return e\n    for i in range(len(a)):\n        e,v=lane(a[i],b[i],d[i]); out[i]=v\n    return OK\n\nrng=random.Random(20260417_188)\nfor _ in range(3000):\n    n=rng.randint(1,32)\n    a=[rng.randint(-(1<<30),1<<30) for _ in range(n)]\n    b=[rng.randint(-(1<<30),1<<30) for _ in range(n)]\n    d=[rng.randint(1,1<<20) for _ in range(n)]\n    out=[0x7F7F7F7F]*n\n    e=arr(a,b,d,out)\n    if e!=OK:\n        raise SystemExit('\"'unexpected error in valid-domain run')\n    for i in range(n):\n        ee,v=lane(a[i],b[i],d[i])\n        if ee\"'!=OK or out[i]!=v:\n            raise SystemExit('\"'lane mismatch')\n\n# no-partial-write adversarial sample\nout=[111,222,333,444]\na=[1,2,3,4]\nb=[1,1,1,1]\nd=[1,0,1,1]\ne=arr(a,b,d,out)\nassert e==DOMAIN and out==[111,222,333,444]\nprint('fixedpoint_q16_muldiv_array_positive_int_checked_reference_checks=ok')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
