\n\ndef gguf_metadata_read_u8_pair_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_first_ref: list[int] | None,\n    out_second_ref: list[int] | None,\n) -> int:\n    if (\n        buf is None\n        or cursor_ref is None\n        or out_first_ref is None\n        or out_second_ref is None\n    ):\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    first = [0]\n    second = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, first)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, second)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_first_ref[0] = first[0]\n    out_second_ref[0] = second[0]\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [1]\n    out_first = [77]\n    out_second = [88]\n\n    assert (\n        gguf_metadata_read_u8_pair_checked(None, 4, cursor, 4, out_first, out_second)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_first == [77]\n    assert out_second == [88]\n\n    assert (\n        gguf_metadata_read_u8_pair_checked([1, 2, 3], 3, None, 3, out_first, out_second)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out_first == [77]\n    assert out_second == [88]\n\n    assert (\n        gguf_metadata_read_u8_pair_checked([1, 2, 3], 3, cursor, 3, None, out_second)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_second == [88]\n\n    assert (\n        gguf_metadata_read_u8_pair_checked([1, 2, 3], 3, cursor, 3, out_first, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_first == [77]\n\n\ndef test_short_read_does_not_commit_first_or_cursor() -> None:\n    buf = [0xAA, 0xBB, 0xCC]\n    cursor = [2]\n    out_first = [0x11]\n    out_second = [0x22]\n\n    err = gguf_metadata_read_u8_pair_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [2]\n    assert out_first == [0x11]\n    assert out_second == [0x22]\n\n\ndef test_success_reads_two_bytes_and_advances() -> None:\n    buf = [10, 20, 30, 40]\n    cursor = [1]\n    out_first = [0]\n    out_second = [0]\n\n    err = gguf_metadata_read_u8_pair_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n    )\n    assert err == GGUF_META_TABLE_OK\n    assert out_first[0] == 20\n    assert out_second[0] == 30\n    assert cursor[0] == 3\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_208)\n\n    for _ in range(4000):\n        n = rng.randint(1, 256)\n        table_end = rng.randint(0, n)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out_first = [123]\n        out_second = [231]\n\n        err = gguf_metadata_read_u8_pair_checked(\n            buf,\n            n,\n            cursor,\n            table_end,\n            out_first,\n            out_second,\n        )\n\n        if cursor0 + 2 <= table_end and cursor0 + 2 <= n:\n            assert err == GGUF_META_TABLE_OK\n            assert out_first[0] == buf[cursor0]\n            assert out_second[0] == buf[cursor0 + 1]\n            assert cursor[0] == cursor0 + 2\n        else:\n            assert err in (\n                GGUF_META_TABLE_ERR_OUT_OF_BOUNDS,\n                GGUF_META_TABLE_ERR_BAD_PARAM,\n                GGUF_META_TABLE_ERR_OVERFLOW,\n            )\n            assert out_first[0] == 123\n            assert out_second[0] == 231\n            assert cursor[0] == cursor0\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_short_read_does_not_commit_first_or_cursor()\n    test_success_reads_two_bytes_and_advances()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_u8_pair_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadI8Checked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU8_MASK = (1 << 8) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef reinterpret_u8_as_i8(value: int) -> int:\n    value &= U8_MASK\n    if value >= (1 << 7):\n        return value - (1 << 8)\n    return value\n\n\ndef gguf_metadata_read_i8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    raw = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, raw)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = reinterpret_u8_as_i8(raw[0])\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [3]\n    out = [88]\n\n    assert (\n        gguf_metadata_read_i8_checked(None, 8, cursor, 7, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [3]\n    assert out == [88]\n\n    assert (\n        gguf_metadata_read_i8_checked([1, 2, 3], 3, None, 3, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out == [88]\n\n    assert (\n        gguf_metadata_read_i8_checked([1, 2, 3], 3, cursor, 3, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [3]\n\n\ndef test_short_read_does_not_advance_or_write() -> None:\n    buf = [0x7F, 0x80, 0xFF]\n\n    cursor = [3]\n    out = [44]\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [3]\n    assert out == [44]\n\n    cursor = [1]\n    out = [55]\n    err = gguf_metadata_read_i8_checked(buf, 1, cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [1]\n    assert out == [55]\n\n\ndef test_success_signed_decode_and_cursor_advance() -> None:\n    buf = [0x7F, 0x80, 0xFF, 0x00]\n\n    cursor = [0]\n    out = [0]\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == 127\n    assert cursor[0] == 1\n\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == -128\n    assert cursor[0] == 2\n\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == -1\n    assert cursor[0] == 3\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_211)\n\n    for _ in range(5000):\n        n = rng.randint(1, 256)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        table_end = rng.randint(0, n)\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out = [999]\n        err = gguf_metadata_read_i8_checked(buf, n, cursor, table_end, out)\n\n        if cursor0 + 1 <= table_end and cursor0 + 1 <= n:\n            assert err == GGUF_META_TABLE_OK\n            assert out[0] == reinterpret_u8_as_i8(buf[cursor0])\n            assert cursor[0] == cursor0 + 1\n        else:\n            assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n            assert out[0] == 999\n            assert cursor[0] == cursor0\n\n\ndef test_table_end_overflow_surface() -> None:\n    buf = [0xAA]\n    cursor = [0]\n    out = [5]\n\n    err = gguf_metadata_read_i8_checked(buf, len(buf), cursor, I64_MAX + 1, out)\n    assert err == GGUF_META_TABLE_ERR_OVERFLOW\n    assert cursor == [0]\n    assert out == [5]\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_short_read_does_not_advance_or_write()\n    test_success_signed_decode_and_cursor_advance()\n    test_randomized_parity()\n    test_table_end_overflow_surface()\n    print(\"gguf_metadata_read_i8_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
