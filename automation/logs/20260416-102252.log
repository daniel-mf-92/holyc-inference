  51\t    if shift_amount >= 0:\n    52\t        magnitude_q16 = mantissa << shift_amount\n    53\t    else:\n    54\t        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n    55\t\n    56\t    return -magnitude_q16 if sign_bit else magnitude_q16\n    57\t\n    58\t\n    59\tdef half_bits(value: float) -> int:\n    60\t    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n    61\t\n    62\t\n    63\tdef pack_signed(values: list[int]) -> bytes:\n    64\t    assert len(values) == Q8_0_PACKED_BYTES\n    65\t    return bytes((v + 256) % 256 for v in values)\n    66\t\n    67\t\n    68\tdef unpack_signed(qs: bytes) -> list[int]:\n    69\t    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n    70\t\n    71\t\n    72\tdef dot_product_block_q32(\n    73\t    lhs_scale_fp16: int,\n    74\t    lhs_qs: bytes,\n    75\t    rhs_scale_fp16: int,\n    76\t    rhs_qs: bytes,\n    77\t) -> tuple[int, int]:\n    78\t    if len(lhs_qs) != Q8_0_PACKED_BYTES or len(rhs_qs) != Q8_0_PACKED_BYTES:\n    79\t        return Q8_0_ERR_BAD_DST_LEN, 0\n    80\t\n    81\t    lhs_signed = unpack_signed(lhs_qs)\n    82\t    rhs_signed = unpack_signed(rhs_qs)\n    83\t\n    84\t    q_dot_q0 = 0\n    85\t    for lhs_q, rhs_q in zip(lhs_signed, rhs_signed):\n    86\t        q_dot_q0 += lhs_q * rhs_q\n    87\t\n    88\t    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n    89\t    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n    90\t    dot_q32 = lhs_scale_q16 * rhs_scale_q16 * q_dot_q0\n    91\t    return Q8_0_OK, dot_q32\n    92\t\n    93\t\n    94\tdef dot_product_blocks_q32(\n    95\t    lhs_blocks: list[tuple[int, bytes]],\n    96\t    rhs_blocks: list[tuple[int, bytes]],\n    97\t) -> tuple[int, int]:\n    98\t    if len(lhs_blocks) != len(rhs_blocks):\n    99\t        return Q8_0_ERR_BAD_DST_LEN, 0\n   100\t\n   101\t    total = 0\n   102\t    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n   103\t        err, block_dot = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n   104\t        if err != Q8_0_OK:\n   105\t            return err, 0\n   106\t        total += block_dot\n   107\t\n   108\t    return Q8_0_OK, total\n   109\t\n   110\t\n   111\tdef try_add_i64(lhs: int, rhs: int) -> tuple[bool, int]:\n   112\t    if rhs > 0 and lhs > Q8_0_I64_MAX - rhs:\n   113\t        return False, 0\n   114\t    if rhs < 0 and lhs < Q8_0_I64_MIN - rhs:\n   115\t        return False, 0\n   116\t    return True, lhs + rhs\n   117\t\n   118\t\n   119\tdef dot_product_blocks_q32_checked(\n   120\t    lhs_blocks: list[tuple[int, bytes]],\n   121\t    rhs_blocks: list[tuple[int, bytes]],\n   122\t) -> tuple[int, int]:\n   123\t    if len(lhs_blocks) != len(rhs_blocks):\n   124\t        return Q8_0_ERR_BAD_DST_LEN, 0\n   125\t\n   126\t    total = 0\n   127\t    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n   128\t        err, block_dot = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n   129\t        if err != Q8_0_OK:\n   130\t            return err, 0\n   131\t\n   132\t        ok, checked_sum = try_add_i64(total, block_dot)\n   133\t        if not ok:\n   134\t            return Q8_0_ERR_OVERFLOW, 0\n   135\t        total = checked_sum\n   136\t\n   137\t    return Q8_0_OK, total\n   138\t\n   139\t\n   140\tdef dot_q32_to_q16(dot_q32: int) -> int:\n   141\t    return round_shift_right_signed(dot_q32, 16)\n   142\t\n   143\t\n   144\tdef dot_product_blocks_q16_accumulate(\n   145\t    lhs_blocks: list[tuple[int, bytes]],\n   146\t    rhs_blocks: list[tuple[int, bytes]],\n   147\t    initial_accum_q16: int,\n   148\t) -> tuple[int, int]:\n   149\t    if len(lhs_blocks) != len(rhs_blocks):\n   150\t        return Q8_0_ERR_BAD_DST_LEN, 0\n   151\t\n   152\t    total_q16 = initial_accum_q16\n   153\t    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n   154\t        err, block_dot_q32 = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n   155\t        if err != Q8_0_OK:\n   156\t            return err, 0\n   157\t        total_q16 += dot_q32_to_q16(block_dot_q32)\n   158\t\n   159\t    return Q8_0_OK, total_q16\n   160\t\n   161\t\n   162\tdef dot_row_blocks_q16(\n   163\t    lhs_blocks: list[tuple[int, bytes]],\n   164\t    rhs_blocks: list[tuple[int, bytes]],\n   165\t) -> tuple[int, int]:\n   166\t    return dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n   167\t\n   168\t\n   169\tdef dot_rows_q16_matrix_vector(\n   170\t    matrix_blocks: list[tuple[int, bytes]],\n   171\t    row_count: int,\n   172\t    row_stride_blocks: int,\n   173\t    vec_blocks: list[tuple[int, bytes]],\n   174\t    vec_block_count: int,\n   175\t) -> tuple[int, list[int]]:\n   176\t    if row_count < 0 or row_stride_blocks < 0 or vec_block_count < 0:\n   177\t        return Q8_0_ERR_BAD_DST_LEN, []\n   178\t    if row_count > 0 and row_stride_blocks < vec_block_count:\n   179\t        return Q8_0_ERR_BAD_DST_LEN, []\n   180\t\n   181\t    out_rows_q16 = [0] * row_count\n   182\t    for row_index in range(row_count):\n   183\t        row_base = row_index * row_stride_blocks\n   184\t        row_slice = matrix_blocks[row_base : row_base + vec_block_count]\n   185\t        if len(row_slice) != vec_block_count:\n   186\t            return Q8_0_ERR_BAD_DST_LEN, []\n   187\t\n   188\t        err, row_dot_q16 = dot_row_blocks_q16(row_slice, vec_blocks[:vec_block_count])\n   189\t        if err != Q8_0_OK:\n   190\t            return err, []\n   191\t\n   192\t        out_rows_q16[row_index] = row_dot_q16\n   193\t\n   194\t    return Q8_0_OK, out_rows_q16\n   195\t\n   196\t\n   197\tdef dot_product_blocks_q32_to_q16(\n   198\t    lhs_blocks: list[tuple[int, bytes]],\n   199\t    rhs_blocks: list[tuple[int, bytes]],\n   200\t) -> tuple[int, int]:\n   201\t    err, total_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   202\t    if err != Q8_0_OK:\n   203\t        return err, 0\n   204\t    return Q8_0_OK, dot_q32_to_q16(total_q32)\n   205\t\n   206\t\n   207\tdef test_identity_block() -> None:\n   208\t    lhs_scale_fp16 = half_bits(1.0)\n   209\t    rhs_scale_fp16 = half_bits(1.0)\n   210\t    signed = list(range(-16, 16))\n   211\t    packed = pack_signed(signed)\n   212\t\n   213\t    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, packed, rhs_scale_fp16, packed)\n   214\t    assert err == Q8_0_OK\n   215\t\n   216\t    expected_q0 = sum(v * v for v in signed)\n   217\t    expected_q32 = expected_q0 * (1 << 32)\n   218\t    assert got_q32 == expected_q32\n   219\t    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n   220\t\n---\n   460\t    assert err == Q8_0_OK\n   461\t    assert got_rows == expected_rows\n   462\t\n   463\t\n   464\tdef test_matrix_vector_rejects_stride_smaller_than_vector_span() -> None:\n   465\t    matrix_blocks = [(half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK))]\n   466\t    vec_blocks = [(half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK))]\n   467\t\n   468\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, 1, 0, vec_blocks, 1)\n   469\t    assert err == Q8_0_ERR_BAD_DST_LEN\n   470\t\n   471\t\n   472\tdef test_checked_q32_matches_unchecked_on_normal_ranges() -> None:\n   473\t    rng = random.Random(2026041509)\n   474\t\n   475\t    for _ in range(250):\n   476\t        block_count = rng.randint(1, 8)\n   477\t        lhs_blocks: list[tuple[int, bytes]] = []\n   478\t        rhs_blocks: list[tuple[int, bytes]] = []\n   479\t\n   480\t        for _ in range(block_count):\n   481\t            lhs_scale = half_bits(rng.uniform(-2.0, 2.0))\n   482\t            rhs_scale = half_bits(rng.uniform(-2.0, 2.0))\n   483\t            lhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   484\t            rhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   485\t            lhs_blocks.append((lhs_scale, lhs_qs))\n   486\t            rhs_blocks.append((rhs_scale, rhs_qs))\n   487\t\n   488\t        err_unchecked, got_unchecked = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   489\t        err_checked, got_checked = dot_product_blocks_q32_checked(lhs_blocks, rhs_blocks)\n   490\t        assert err_unchecked == Q8_0_OK\n   491\t        assert err_checked == Q8_0_OK\n   492\t        assert got_checked == got_unchecked\n   493\t\n   494\t\n   495\tdef test_checked_q32_reports_positive_overflow() -> None:\n   496\t    scale_max = 0x7C00  # +inf in fp16 -> saturated large q16 in this kernel\n   497\t    plus_one = pack_signed([1] + [0] * (Q8_0_VALUES_PER_BLOCK - 1))\n   498\t\n   499\t    lhs_blocks = [(scale_max, plus_one), (scale_max, plus_one)]\n   500\t    rhs_blocks = [(scale_max, plus_one), (scale_max, plus_one)]\n   501\t\n   502\t    err_checked, _ = dot_product_blocks_q32_checked(lhs_blocks, rhs_blocks)\n   503\t    assert err_checked == Q8_0_ERR_OVERFLOW\n   504\t\n   505\t\n   506\tdef test_checked_q32_reports_negative_overflow() -> None:\n   507\t    scale_pos_max = 0x7C00  # +inf\n   508\t    scale_neg_max = 0xFC00  # -inf\n   509\t    plus_one = pack_signed([1] + [0] * (Q8_0_VALUES_PER_BLOCK - 1))\n   510\t\n   511\t    lhs_blocks = [(scale_pos_max, plus_one), (scale_pos_max, plus_one)]\n   512\t    rhs_blocks = [(scale_neg_max, plus_one), (scale_neg_max, plus_one)]\n   513\t\n   514\t    err_checked, _ = dot_product_blocks_q32_checked(lhs_blocks, rhs_blocks)\n   515\t    assert err_checked == Q8_0_ERR_OVERFLOW\n   516\t\n   517\t\n   518\tdef run() -> None:\n   519\t    test_identity_block()\n   520\t    test_negative_scale_sign()\n   521\t    test_random_blocks_match_float_reference_bounds()\n   522\t    test_multiblock_accumulation()\n   523\t    test_error_on_bad_input_length()\n   524\t    test_q16_accumulator_helper_matches_blockwise_rounding()\n   525\t    test_q16_accumulator_bad_length_error()\n   526\t    test_row_blocks_q16_matches_per_block_rounding()\n   527\t    test_row_blocks_q16_distinct_from_round_at_end()\n   528\t    test_row_blocks_q16_bad_length_error()\n   529\t    test_q32_to_q16_single_rounding_matches_total_q32_rounding()\n   530\t    test_q32_to_q16_length_mismatch_error()\n   531\t    test_matrix_vector_rows_stride_and_values()\n   532\t    test_matrix_vector_rejects_stride_smaller_than_vector_span()\n   533\t    test_checked_q32_matches_unchecked_on_normal_ranges()\n   534\t    test_checked_q32_reports_positive_overflow()\n   535\t    test_checked_q32_reports_negative_overflow()\n   536\t    print(\"q8_0_dot_reference_checks=ok\")\n   537\t\n   538\t\n   539\tif __name__ == \"__main__\":\n   540\t    run()\n","exit_code":0,"status":"completed"}}
