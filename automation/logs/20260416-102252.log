   else:\n    52\t        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n    53\t\n    54\t    return -magnitude_q16 if sign_bit else magnitude_q16\n    55\t\n    56\t\n    57\tdef half_bits(value: float) -> int:\n    58\t    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n    59\t\n    60\t\n    61\tdef nibble_to_signed(packed: int, upper_nibble: bool) -> int:\n    62\t    if upper_nibble:\n    63\t        q_unsigned = (packed >> 4) & 0x0F\n    64\t    else:\n    65\t        q_unsigned = packed & 0x0F\n    66\t    return q_unsigned - 8\n    67\t\n    68\t\n    69\tdef unpack_q4_signed(qs: bytes) -> list[int]:\n    70\t    out: list[int] = []\n    71\t    for packed in qs:\n    72\t        out.append(nibble_to_signed(packed, False))\n    73\t        out.append(nibble_to_signed(packed, True))\n    74\t    return out\n    75\t\n    76\t\n    77\tdef unpack_q8_signed(qs: bytes) -> list[int]:\n    78\t    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n    79\t\n    80\t\n    81\tdef pack_q4_from_signed(vals: list[int]) -> bytes:\n    82\t    assert len(vals) == 32\n    83\t    out = bytearray()\n    84\t    for idx in range(0, 32, 2):\n    85\t        lo = vals[idx] + 8\n    86\t        hi = vals[idx + 1] + 8\n    87\t        assert 0 <= lo <= 15 and 0 <= hi <= 15\n    88\t        out.append((lo & 0x0F) | ((hi & 0x0F) << 4))\n    89\t    return bytes(out)\n    90\t\n    91\t\n    92\tdef pack_q8_signed(vals: list[int]) -> bytes:\n    93\t    assert len(vals) == 32\n    94\t    return bytes((v + 256) % 256 for v in vals)\n    95\t\n    96\t\n    97\tdef dot_product_block_q32(lhs_scale_fp16: int, lhs_q4: bytes, rhs_scale_fp16: int, rhs_q8: bytes) -> tuple[int, int]:\n    98\t    if len(lhs_q4) != Q4_0_PACKED_BYTES or len(rhs_q8) != Q8_0_PACKED_BYTES:\n    99\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n   100\t\n   101\t    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   102\t    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n   103\t    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16\n   104\t\n   105\t    lhs_signed = unpack_q4_signed(lhs_q4)\n   106\t    rhs_signed = unpack_q8_signed(rhs_q8)\n   107\t    q_dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n   108\t    return Q4_0_Q8_0_OK, scale_prod_q32 * q_dot_q0\n   109\t\n   110\t\n   111\tdef dot_product_blocks_q32(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n   112\t    if len(lhs_blocks) != len(rhs_blocks):\n   113\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n   114\t\n   115\t    total = 0\n   116\t    for (l_scale, l_q4), (r_scale, r_q8) in zip(lhs_blocks, rhs_blocks):\n   117\t        err, block_dot = dot_product_block_q32(l_scale, l_q4, r_scale, r_q8)\n   118\t        if err != Q4_0_Q8_0_OK:\n   119\t            return err, 0\n   120\t        total += block_dot\n   121\t\n   122\t    return Q4_0_Q8_0_OK, total\n   123\t\n   124\t\n   125\tdef dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n   126\t    err, dot_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   127\t    if err != Q4_0_Q8_0_OK:\n   128\t        return err, 0\n   129\t    return Q4_0_Q8_0_OK, dot_q32_to_q16(dot_q32)\n   130\t\n   131\t\n   132\tdef dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, initial_accum_q16: int) -> tuple[int, int]:\n   133\t    if len(lhs_blocks) != len(rhs_blocks):\n   134\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n   135\t\n   136\t    total_q16 = initial_accum_q16\n   137\t    for (l_scale, l_q4), (r_scale, r_q8) in zip(lhs_blocks, rhs_blocks):\n   138\t        err, block_dot_q32 = dot_product_block_q32(l_scale, l_q4, r_scale, r_q8)\n   139\t        if err != Q4_0_Q8_0_OK:\n   140\t            return err, 0\n   141\t        total_q16 += dot_q32_to_q16(block_dot_q32)\n   142\t\n   143\t    return Q4_0_Q8_0_OK, total_q16\n   144\t\n   145\t\n   146\tdef dot_row_blocks_q16(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n   147\t    return dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n   148\t\n   149\t\n   150\tdef dot_rows_q16_matrix_vector(\n   151\t    matrix_blocks,\n   152\t    row_count: int,\n   153\t    row_stride_blocks: int,\n   154\t    vec_blocks,\n   155\t    vec_block_count: int,\n   156\t) -> tuple[int, list[int]]:\n   157\t    if row_count < 0 or row_stride_blocks < 0 or vec_block_count < 0:\n   158\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, []\n   159\t    if row_count > 0 and row_stride_blocks < vec_block_count:\n   160\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, []\n   161\t\n   162\t    required_matrix_blocks = row_count * row_stride_blocks\n   163\t    if required_matrix_blocks > len(matrix_blocks):\n   164\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, []\n   165\t    if vec_block_count > len(vec_blocks):\n   166\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, []\n   167\t\n   168\t    out_rows: list[int] = []\n   169\t    for row_index in range(row_count):\n   170\t        row_start = row_index * row_stride_blocks\n   171\t        row_slice = matrix_blocks[row_start : row_start + vec_block_count]\n   172\t        err, row_q16 = dot_row_blocks_q16(row_slice, vec_blocks[:vec_block_count])\n   173\t        if err != Q4_0_Q8_0_OK:\n   174\t            return err, []\n   175\t        out_rows.append(row_q16)\n   176\t\n   177\t    return Q4_0_Q8_0_OK, out_rows\n   178\t\n   179\t\n   180\tdef dot_q32_to_q16(dot_q32: int) -> int:\n   181\t    return round_shift_right_signed(dot_q32, 16)\n   182\t\n   183\t\n   184\tdef test_identity_mixed_block() -> None:\n   185\t    lhs_scale_fp16 = half_bits(1.0)\n   186\t    rhs_scale_fp16 = half_bits(1.0)\n   187\t\n   188\t    q4_signed = [((idx % 16) - 8) for idx in range(32)]\n   189\t    q8_signed = q4_signed[:]\n   190\t\n   191\t    lhs_q4 = pack_q4_from_signed(q4_signed)\n   192\t    rhs_q8 = pack_q8_signed(q8_signed)\n   193\t\n   194\t    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n   195\t    assert err == Q4_0_Q8_0_OK\n   196\t\n   197\t    expected_q0 = sum(v * v for v in q4_signed)\n   198\t    expected_q32 = (1 << 16) * (1 << 16) * expected_q0\n   199\t    assert got_q32 == expected_q32\n   200\t    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n   201\t\n   202\t\n   203\tdef test_random_blocks_match_integer_reference() -> None:\n   204\t    rng = random.Random(20260412)\n   205\t\n   206\t    for _ in range(500):\n   207\t        lhs_scale = rng.uniform(-4.0, 4.0)\n   208\t        rhs_scale = rng.uniform(-4.0, 4.0)\n   209\t\n   210\t        lhs_scale_fp16 = half_bits(lhs_scale)\n   211\t        rhs_scale_fp16 = half_bits(rhs_scale)\n   212\t\n   213\t        q4_signed = [rng.randrange(-8, 8) for _ in range(32)]\n   214\t        q8_signed = [rng.randrange(-128, 128) for _ in range(32)]\n   215\t\n   216\t        lhs_q4 = pack_q4_from_signed(q4_signed)\n   217\t        rhs_q8 = pack_q8_signed(q8_signed)\n   218\t\n   219\t        err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n   220\t        assert err == Q4_0_Q8_0_OK\n   221\t\n   222\t        expected_q0 = sum(a * b for a, b in zip(q4_signed, q8_signed))\n   223\t        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   224\t        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n   225\t        expected_q32 = lhs_scale_q16 * rhs_scale_q16 * expected_q0\n   226\t        assert got_q32 == expected_q32\n   227\t\n   228\t        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n   229\t        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n   230\t        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * expected_q0 * (1 << 32))\n   231\t\n   232\t        # Integer path rounds scales once to Q16 then multiplies.\n   233\t        assert abs(got_q32 - expected_float_q32) <= 70_000_000\n   234\t\n   235\t\n   236\tdef test_multiblock_accumulation() -> None:\n   237\t    b0 = (half_bits(0.75), pack_q4_from_signed([((i % 8) - 4) for i in range(32)]))\n   238\t    b1 = (half_bits(-0.5), pack_q4_from_signed([4 - (i % 8) for i in range(32)]))\n   239\t\n   240\t    r0 = (half_bits(1.25), pack_q8_signed([((i % 11) - 5) * 3 for i in range(32)]))\n   241\t    r1 = (half_bits(-1.5), pack_q8_signed([7 - (i % 13) for i in range(32)]))\n   242\t\n   243\t    err, total = dot_product_blocks_q32([b0, b1], [r0, r1])\n   244\t    assert err == Q4_0_Q8_0_OK\n   245\t\n   246\t    _, part0 = dot_product_block_q32(*b0, *r0)\n   247\t    _, part1 = dot_product_block_q32(*b1, *r1)\n   248\t    assert total == part0 + part1\n   249\t\n   250\t\n   251\tdef test_error_on_bad_lengths() -> None:\n   252\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 15, half_bits(1.0), b\"\\x00\" * 32)\n   253\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   254\t\n   255\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 16, half_bits(1.0), b\"\\x00\" * 31)\n   256\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   257\t\n   258\t\n   259\tdef test_q16_accumulator_helper_matches_blockwise_rounding() -> None:\n   260\t    rng = random.Random(2026041217)\n   261\t\n   262\t    for _ in range(250):\n   263\t        block_count = rng.randint(1, 6)\n   264\t        lhs_blocks = []\n   265\t        rhs_blocks = []\n   266\t\n   267\t        for _ in range(block_count):\n   268\t            l_scale = half_bits(rng.uniform(-3.0, 3.0))\n   269\t            r_scale = half_bits(rng.uniform(-3.0, 3.0))\n   270\t            l_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n   271\t            r_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n   272\t            lhs_blocks.append((l_scale, l_q4))\n   273\t            rhs_blocks.append((r_scale, r_q8))\n   274\t\n   275\t        initial_accum = rng.randint(-(1 << 30), (1 << 30))\n   276\t        err, got_q16 = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, initial_accum)\n   277\t        assert err == Q4_0_Q8_0_OK\n   278\t\n   279\t        expected_q16 = initial_accum\n   280\t        for lhs_block, rhs_block in zip(lhs_blocks, rhs_blocks):\n   281\t            err, block_dot_q32 = dot_product_block_q32(*lhs_block, *rhs_block)\n   282\t            assert err == Q4_0_Q8_0_OK\n   283\t            expected_q16 += dot_q32_to_q16(block_dot_q32)\n   284\t\n   285\t        assert got_q16 == expected_q16\n   286\t\n   287\t\n   288\tdef test_q32_to_q16_helper_rounds_once_after_full_accumulation() -> None:\n   289\t    b0 = (half_bits(0.125), pack_q4_from_signed([7] * 32))\n   290\t    b1 = (half_bits(0.125), pack_q4_from_signed([-8] * 32))\n   291\t    r0 = (half_bits(0.125), pack_q8_signed([127] * 32))\n   292\t    r1 = (half_bits(0.125), pack_q8_signed([127] * 32))\n   293\t\n   294\t    err, dot_q16_single_round = dot_product_blocks_q32_to_q16([b0, b1], [r0, r1])\n   295\t    assert err == Q4_0_Q8_0_OK\n   296\t\n   297\t    err, dot_q16_blockwise = dot_product_blocks_q16_accumulate([b0, b1], [r0, r1], 0)\n   298\t    assert err == Q4_0_Q8_0_OK\n   299\t\n   300\t    # This vector pair intentionally exercises fractional cancellation.\n   301\t    # Full-dot single rounding (Q32->Q16 once) is the IQ-085 contract,\n   302\t    # while blockwise Q16 accumulation can differ by a few LSBs.\n   303\t    assert abs(dot_q16_single_round - dot_q16_blockwise) <= 2\n   304\t\n   305\t\n   306\tdef test_q32_to_q16_helper_matches_full_dot_reference() -> None:\n   307\t    rng = random.Random(202604151)\n   308\t\n   309\t    for _ in range(200):\n   310\t        block_count = rng.randint(1, 8)\n   311\t        lhs_blocks = []\n   312\t        rhs_blocks = []\n   313\t\n   314\t        for _ in range(block_count):\n   315\t            l_scale = half_bits(rng.uniform(-3.5, 3.5))\n   316\t            r_scale = half_bits(rng.uniform(-3.5, 3.5))\n   317\t            l_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n   318\t            r_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n   319\t            lhs_blocks.append((l_scale, l_q4))\n   320\t            rhs_blocks.append((r_scale, r_q8))\n   321\t\n   322\t        err, got_q16 = dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks)\n   323\t        assert err == Q4_0_Q8_0_OK\n   324\t\n   325\t        err, full_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   326\t        assert err == Q4_0_Q8_0_OK\n   327\t        assert got_q16 == dot_q32_to_q16(full_q32)\n   328\t\n   329\t\n   330\tdef test_q16_accumulator_bad_length_error() -> None:\n   331\t    lhs_blocks = [(half_bits(1.0), pack_q4_from_signed([0] * 32))]\n   332\t    rhs_blocks = []\n   333\t    err, _ = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n   334\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   335\t\n   336\t\n   337\tdef test_row_helper_matches_zero_init_accumulate() -> None:\n   338\t    rng = random.Random(2026041527)\n   339\t\n   340\t    for _ in range(220):\n   341\t        block_count = rng.randint(1, 8)\n   342\t        lhs_blocks = []\n   343\t        rhs_blocks = []\n   344\t\n   345\t        for _ in range(block_count):\n   346\t            l_scale = half_bits(rng.uniform(-3.25, 3.25))\n   347\t            r_scale = half_bits(rng.uniform(-3.25, 3.25))\n   348\t            l_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n   349\t            r_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n   350\t            lhs_blocks.append((l_scale, l_q4))\n   351\t            rhs_blocks.append((r_scale, r_q8))\n   352\t\n   353\t        err, got_row_q16 = dot_row_blocks_q16(lhs_blocks, rhs_blocks)\n   354\t        assert err == Q4_0_Q8_0_OK\n   355\t\n   356\t        err, expected_q16 = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n   357\t        assert err == Q4_0_Q8_0_OK\n   358\t        assert got_row_q16 == expected_q16\n   359\t\n   360\t\n   361\tdef test_row_helper_can_differ_from_full_dot_single_rounding() -> None:\n   362\t    b0 = (half_bits(0.125), pack_q4_from_signed([7] * 32))\n   363\t    b1 = (half_bits(0.125), pack_q4_from_signed([-8] * 32))\n   364\t    r0 = (half_bits(0.125), pack_q8_signed([127] * 32))\n   365\t    r1 = (half_bits(0.125), pack_q8_signed([127] * 32))\n   366\t\n   367\t    err, row_q16 = dot_row_blocks_q16([b0, b1], [r0, r1])\n   368\t    assert err == Q4_0_Q8_0_OK\n   369\t\n   370\t    err, single_round_q16 = dot_product_blocks_q32_to_q16([b0, b1], [r0, r1])\n   371\t    assert err == Q4_0_Q8_0_OK\n   372\t\n   373\t    # Row helper intentionally rounds each block contribution before summation.\n   374\t    # Keep tolerance tight so any hidden semantic drift is caught quickly.\n   375\t    assert abs(row_q16 - single_round_q16) <= 2\n   376\t\n   377\t\n   378\tdef test_matrix_vector_stride_padding_ignored_randomized() -> None:\n   379\t    rng = random.Random(2026041601)\n   380\t\n   381\t    for _ in range(220):\n   382\t        row_count = rng.randint(1, 8)\n   383\t        vec_block_count = rng.randint(1, 6)\n   384\t        row_stride_blocks = vec_block_count + rng.randint(0, 4)\n   385\t\n   386\t        vec_blocks = []\n   387\t        for _ in range(vec_block_count):\n   388\t            vec_scale = half_bits(rng.uniform(-2.25, 2.25))\n   389\t            vec_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n   390\t            vec_blocks.append((vec_scale, vec_q8))\n   391\t\n   392\t        matrix_blocks = []\n   393\t        expected_rows = []\n   394\t\n   395\t        for _ in range(row_count):\n   396\t            active_blocks = []\n   397\t            for _ in range(vec_block_count):\n   398\t                row_scale = half_bits(rng.uniform(-2.25, 2.25))\n   399\t                row_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n   400\t                block = (row_scale, row_q4)\n   401\t                matrix_blocks.append(block)\n   402\t                active_blocks.append(block)\n   403\t\n   404\t            pad_blocks = row_stride_blocks - vec_block_count\n   405\t            for _ in range(pad_blocks):\n   406\t                pad_scale = half_bits(rng.uniform(-2.25, 2.25))\n   407\t                pad_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n   408\t                matrix_blocks.append((pad_scale, pad_q4))\n   409\t\n   410\t            err, expected_q16 = dot_row_blocks_q16(active_blocks, vec_blocks)\n   411\t            assert err == Q4_0_Q8_0_OK\n   412\t            expected_rows.append(expected_q16)\n   413\t\n   414\t        err, got_rows = dot_rows_q16_matrix_vector(\n   415\t            matrix_blocks,\n   416\t            row_count,\n   417\t            row_stride_blocks,\n   418\t            vec_blocks,\n   419\t            vec_block_count,\n   420\t        )\n   421\t        assert err == Q4_0_Q8_0_OK\n   422\t        assert got_rows == expected_rows\n   423\t\n   424\t\n   425\tdef test_matrix_vector_sign_semantics_reference_rowwise() -> None:\n   426\t    row_count = 4\n   427\t    vec_block_count = 1\n   428\t    row_stride_blocks = 1\n   429\t\n   430\t    vec_blocks = [(half_bits(1.0), pack_q8_signed([3] * 32))]\n   431\t    matrix_rows = [\n   432\t        [(half_bits(1.0), pack_q4_from_signed([2] * 32))],\n   433\t        [(half_bits(-1.0), pack_q4_from_signed([2] * 32))],\n   434\t        [(half_bits(1.0), pack_q4_from_signed([-2] * 32))],\n   435\t        [(half_bits(-1.0), pack_q4_from_signed([-2] * 32))],\n   436\t    ]\n   437\t\n   438\t    matrix_blocks = [block for row in matrix_rows for block in row]\n   439\t    err, got_rows = dot_rows_q16_matrix_vector(\n   440\t        matrix_blocks,\n   441\t        row_count,\n   442\t        row_stride_blocks,\n   443\t        vec_blocks,\n   444\t        vec_block_count,\n   445\t    )\n   446\t    assert err == Q4_0_Q8_0_OK\n   447\t\n   448\t    expected_rows = []\n   449\t    for row in matrix_rows:\n   450\t        err, row_q16 = dot_row_blocks_q16(row, vec_blocks)\n   451\t        assert err == Q4_0_Q8_0_OK\n   452\t        expected_rows.append(row_q16)\n   453\t\n   454\t    assert got_rows == expected_rows\n   455\t    assert got_rows[0] > 0\n   456\t    assert got_rows[1] < 0\n   457\t    assert got_rows[2] < 0\n   458\t    assert got_rows[3] > 0\n   459\t\n   460\t\n   461\tdef test_matrix_vector_argument_and_extent_errors() -> None:\n   462\t    vec_blocks = [(half_bits(1.0), pack_q8_signed([1] * 32))]\n   463\t    matrix_blocks = [(half_bits(1.0), pack_q4_from_signed([1] * 32))]\n   464\t\n   465\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, -1, 1, vec_blocks, 1)\n   466\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   467\t\n   468\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, 1, -1, vec_blocks, 1)\n   469\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   470\t\n   471\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, 1, 1, vec_blocks, -1)\n   472\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   473\t\n   474\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, 1, 0, vec_blocks, 1)\n   475\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   476\t\n   477\t    # Truncated matrix extent for two rows with stride=1.\n   478\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, 2, 1, vec_blocks, 1)\n   479\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   480\t\n   481\t    # Truncated vector extent when vec_block_count exceeds provided vector blocks.\n   482\t    err, _ = dot_rows_q16_matrix_vector(matrix_blocks, 1, 1, [], 1)\n   483\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   484\t\n   485\t\n   486\tdef run() -> None:\n   487\t    test_identity_mixed_block()\n   488\t    test_random_blocks_match_integer_reference()\n   489\t    test_multiblock_accumulation()\n   490\t    test_error_on_bad_lengths()\n   491\t    test_q16_accumulator_helper_matches_blockwise_rounding()\n   492\t    test_q32_to_q16_helper_rounds_once_after_full_accumulation()\n   493\t    test_q32_to_q16_helper_matches_full_dot_reference()\n   494\t    test_q16_accumulator_bad_length_error()\n   495\t    test_row_helper_matches_zero_init_accumulate()\n   496\t    test_row_helper_can_differ_from_full_dot_single_rounding()\n   497\t    test_matrix_vector_stride_padding_ignored_randomized()\n   498\t    test_matrix_vector_sign_semantics_reference_rowwise()\n   499\t    test_matrix_vector_argument_and_extent_errors()\n   500\t    print(\"q4_0_q8_0_dot_kernel_reference_checks=ok\")\n   501\t\n   502\t\n   503\tif __name__ == \"__main__\":\n   504\t    run()\n","exit_code":0,"status":"completed"}}
