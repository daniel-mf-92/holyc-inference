{"type":"item.started","item":{"id":"item_19","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport struct\n\nGGUF_MAGIC_U32 = 0x46554747\nGGUF_PARSE_OK = 0\nGGUF_PARSE_ERR_TRUNCATED = 2\nGGUF_PARSE_ERR_BAD_MAGIC = 3\nGGUF_PARSE_ERR_BAD_VERSION = 4\nGGUF_PARSE_ERR_BAD_COUNT = 5\n\ndef parse_header(buf, cursor=0):\n    if cursor + 24 > len(buf):\n        return GGUF_PARSE_ERR_TRUNCATED, None, cursor\n    magic, version = struct.unpack_from('<II', buf, cursor)\n    cursor += 8\n    if magic \"'!= GGUF_MAGIC_U32:\n        return GGUF_PARSE_ERR_BAD_MAGIC, None, cursor\n    if version not in (2, 3):\n        return GGUF_PARSE_ERR_BAD_VERSION, None, cursor\n    tensor_count, metadata_kv_count = struct.unpack_from('\"'<QQ', buf, cursor)\n    cursor += 16\n    if tensor_count == 0:\n        return GGUF_PARSE_ERR_BAD_COUNT, None, cursor\n    return GGUF_PARSE_OK, (magic, version, tensor_count, metadata_kv_count), cursor\n\nok_buf = struct.pack('<IIQQ', GGUF_MAGIC_U32, 3, 123, 456)\nbad_magic = struct.pack('<IIQQ', 0xDEADBEEF, 3, 1, 0)\nbad_ver = struct.pack('<IIQQ', GGUF_MAGIC_U32, 99, 1, 0)\nzero_tensor = struct.pack('<IIQQ', GGUF_MAGIC_U32, 3, 0, 7)\ntrunc = ok_buf[:10]\n\nassert parse_header(ok_buf)[0] == GGUF_PARSE_OK\nassert parse_header(ok_buf)[2] == 24\nassert parse_header(bad_magic)[0] == GGUF_PARSE_ERR_BAD_MAGIC\nassert parse_header(bad_ver)[0] == GGUF_PARSE_ERR_BAD_VERSION\nassert parse_header(zero_tensor)[0] == GGUF_PARSE_ERR_BAD_COUNT\nassert parse_header(trunc)[0] == GGUF_PARSE_ERR_TRUNCATED\nprint('gguf_header_reference_checks=ok')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
