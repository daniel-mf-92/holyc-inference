{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/zsh -lc \"find src -maxdepth 3 -type f | sort; sed -n '1,220p' src/math/fixedpoint.HC; sed -n '1,220p' src/math/intexp.HC; sed -n '1,220p' src/math/intsqrt.HC; sed -n '1,260p' src/math/softmax.HC; sed -n '1,260p' src/math/rmsnorm.HC\"","aggregated_output":"src/math/fixedpoint.HC\nsrc/math/intexp.HC\nsrc/math/intsqrt.HC\nsrc/math/rmsnorm.HC\nsrc/math/softmax.HC\n// fixedpoint.HC\n// Q16.16 fixed-point helpers for integer-only inference math.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define FP_Q16_HALF  (1 << (FP_Q16_SHIFT - 1))\n\nI64 FPQ16Abs(I64 x)\n{\n    if (x < 0)\n        return -x;\n    return x;\n}\n\nI64 FPQ16FromInt(I64 x)\n{\n    return x << FP_Q16_SHIFT;\n}\n\nI64 FPQ16ToInt(I64 x)\n{\n    if (x >= 0)\n        return (x + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-x) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Mul(I64 a, I64 b)\n{\n    I64 prod;\n\n    prod = a * b;\n    if (prod >= 0)\n        return (prod + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-prod) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Div(I64 num, I64 den)\n{\n    I64 sign;\n    I64 abs_num;\n    I64 abs_den;\n    I64 scaled;\n    I64 q;\n\n    if (!den)\n        return 0;\n\n    sign = 1;\n    if (num < 0)\n    {\n        sign = -sign;\n        num = -num;\n    }\n    if (den < 0)\n    {\n        sign = -sign;\n        den = -den;\n    }\n\n    abs_num = num;\n    abs_den = den;\n\n    scaled = abs_num << FP_Q16_SHIFT;\n    q = (scaled + (abs_den >> 1)) / abs_den;\n\n    if (sign < 0)\n        return -q;\n    return q;\n}\n// intexp.HC\n// Integer-only Q16.16 exponential approximation for TempleOS HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define EXP_Q16_LN2       45426   // round(ln(2) * 65536)\n#define EXP_Q16_MAX_INPUT 655360  // +10.0 in Q16\n#define EXP_Q16_MIN_INPUT -655360 // -10.0 in Q16\n\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n\nI64 FPQ16Mul(I64 a, I64 b);\n\nI64 FPQ16Exp(I64 x)\n{\n    I64 k;\n    I64 r;\n    I64 r2;\n    I64 r3;\n    I64 r4;\n    I64 t1;\n    I64 t2;\n    I64 t3;\n    I64 t4;\n    I64 poly;\n\n    if (x >= EXP_Q16_MAX_INPUT)\n        return I64_MAX_VALUE;\n    if (x <= EXP_Q16_MIN_INPUT)\n        return 0;\n\n    // Range reduction: x = k*ln(2) + r, where r in [0, ln(2))\n    k = x / EXP_Q16_LN2;\n    if (x < 0 && (x % EXP_Q16_LN2))\n        k--;\n\n    r = x - (k * EXP_Q16_LN2);\n\n    // exp(r) ~= 1 + r + r^2/2 + r^3/6 + r^4/24\n    r2 = FPQ16Mul(r, r);\n    r3 = FPQ16Mul(r2, r);\n    r4 = FPQ16Mul(r3, r);\n\n    t1 = r;\n    t2 = r2 / 2;\n    t3 = r3 / 6;\n    t4 = r4 / 24;\n\n    poly = FP_Q16_ONE + t1 + t2 + t3 + t4;\n\n    if (k >= 0)\n    {\n        if (k >= 30)\n            return I64_MAX_VALUE;\n\n        if (poly > (I64_MAX_VALUE >> k))\n            return I64_MAX_VALUE;\n\n        return poly << k;\n    }\n\n    if (k <= -63)\n        return 0;\n\n    return poly >> (-k);\n}\n// intsqrt.HC\n// Integer square-root helpers for Q16.16 fixed-point inference math.\n\n#define FP_Q16_SHIFT 16\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n\nU64 IntSqrtU64(U64 x)\n{\n    U64 res;\n    U64 bit;\n\n    res = 0;\n    bit = 1 << 62;\n\n    while (bit > x)\n        bit >>= 2;\n\n    while (bit)\n    {\n        if (x >= res + bit)\n        {\n            x -= res + bit;\n            res = (res >> 1) + bit;\n        }\n        else\n            res >>= 1;\n\n        bit >>= 2;\n    }\n\n    return res;\n}\n\nI64 FPQ16Sqrt(I64 x)\n{\n    U64 shifted;\n\n    if (x <= 0)\n        return 0;\n\n    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n        shifted = I64_MAX_VALUE;\n    else\n        shifted = ((U64)x) << FP_Q16_SHIFT;\n\n    return IntSqrtU64(shifted);\n}\n// softmax.HC\n// Integer-only Q16.16 softmax for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\nI64 FPQ16Exp(I64 x);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\n\nU0 FPQ16Softmax(I64 *logits, I64 *probs, I64 count)\n{\n    I64 i;\n    I64 max_logit;\n    I64 shifted;\n    I64 exp_val;\n    I64 exp_sum;\n    I64 prob_sum;\n    I64 diff;\n    I64 max_idx;\n\n    if (!logits || !probs || count <= 0)\n        return;\n\n    max_logit = logits[0];\n    max_idx = 0;\n    for (i = 1; i < count; i++)\n    {\n        if (logits[i] > max_logit)\n        {\n            max_logit = logits[i];\n            max_idx = i;\n        }\n    }\n\n    exp_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        shifted = logits[i] - max_logit;\n        exp_val = FPQ16Exp(shifted);\n        probs[i] = exp_val;\n\n        if (exp_sum > 0x7FFFFFFFFFFFFFFF - exp_val)\n            exp_sum = 0x7FFFFFFFFFFFFFFF;\n        else\n            exp_sum += exp_val;\n    }\n\n    if (exp_sum <= 0)\n    {\n        exp_val = FPQ16Div(FP_Q16_ONE, FPQ16FromInt(count));\n        for (i = 0; i < count; i++)\n            probs[i] = exp_val;\n        return;\n    }\n\n    prob_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        probs[i] = FPQ16Div(probs[i], exp_sum);\n        prob_sum += probs[i];\n    }\n\n    diff = FP_Q16_ONE - prob_sum;\n    probs[max_idx] += diff;\n}\n// rmsnorm.HC\n// Integer-only Q16.16 RMSNorm for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Sqrt(I64 x);\n\nU0 FPQ16RMSNorm(I64 *input, I64 *weight, I64 *output, I64 count, I64 eps_q16)\n{\n    I64 i;\n    I64 sq;\n    I64 sum_sq;\n    I64 mean_sq;\n    I64 denom;\n    I64 inv_denom;\n    I64 norm;\n\n    if (!input || !weight || !output || count <= 0)\n        return;\n\n    if (eps_q16 < 0)\n        eps_q16 = 0;\n\n    sum_sq = 0;\n    for (i = 0; i < count; i++)\n    {\n        sq = FPQ16Mul(input[i], input[i]);\n        if (sum_sq > I64_MAX_VALUE - sq)\n            sum_sq = I64_MAX_VALUE;\n        else\n            sum_sq += sq;\n    }\n\n    mean_sq = FPQ16Div(sum_sq, FPQ16FromInt(count));\n\n    if (mean_sq > I64_MAX_VALUE - eps_q16)\n        mean_sq = I64_MAX_VALUE;\n    else\n        mean_sq += eps_q16;\n\n    denom = FPQ16Sqrt(mean_sq);\n    if (denom <= 0)\n    {\n        for (i = 0; i < count; i++)\n            output[i] = 0;\n        return;\n    }\n\n    inv_denom = FPQ16Div(FP_Q16_ONE, denom);\n\n    for (i = 0; i < count; i++)\n    {\n        norm = FPQ16Mul(input[i], inv_denom);\n        output[i] = FPQ16Mul(norm, weight[i]);\n    }\n}\n","exit_code":0,"status":"completed"}}
