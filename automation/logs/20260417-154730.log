\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor);\n\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value);\n\nI32 GGUFMetadataReadI8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              I8 *out_value);\n\nI32 GGUFMetadataReadI8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second);\n\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second);\n\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U16 *out_value);\n\nI32 GGUFMetadataReadU16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out