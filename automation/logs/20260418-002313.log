       status = Q4_0Q8_0PackQ4BlockToI16LanesAVX2(&lhs_q4[block_index],\n   348\t                                                   lhs_q4_lanes_i16,\n   349\t                                                   Q4_0_Q8_0_AVX2_LANES);\n   350\t        if (status != Q4_0_Q8_0_OK)\n   351\t            return status;\n   352\t\n   353\t        status = Q4_0Q8_0PackQ8BlockToI16LanesAVX2(&rhs_q8[block_index],\n   354\t                                                   rhs_q8_lanes_i16,\n   355\t                                                   Q4_0_Q8_0_AVX2_LANES);\n   356\t        if (status != Q4_0_Q8_0_OK)\n   357\t            return status;\n   358\t\n   359\t        status = Q4_0Q8_0DotI16LanesAVX2(lhs_q4_lanes_i16,\n   360\t                                         Q4_0_Q8_0_AVX2_LANES,\n   361\t                                         rhs_q8_lanes_i16,\n   362\t                                         Q4_0_Q8_0_AVX2_LANES,\n   363\t                                         &q_dot_q0);\n   364\t        if (status != Q4_0_Q8_0_OK)\n   365\t            return status;\n   366\t\n   367\t        lhs_scale_q16 = Q4_0_Q8_0F16ToQ16(lhs_q4[block_index].d_fp16);\n   368\t        rhs_scale_q16 = Q4_0_Q8_0F16ToQ16(rhs_q8[block_index].d_fp16);\n   369\t\n   370\t        if (!Q4_0Q8_0TryMulI64(lhs_scale_q16, rhs_scale_q16, &scale_prod_q32))\n   371\t            return Q4_0_Q8_0_ERR_OVERFLOW;\n   372\t        if (!Q4_0Q8_0TryMulI64(scale_prod_q32, q_dot_q0, &block_dot_q32))\n   373\t            return Q4_0_Q8_0_ERR_OVERFLOW;\n   374\t        if (!Q4_0Q8_0TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n   375\t            return Q4_0_Q8_0_ERR_OVERFLOW;\n   376\t    }\n   377\t\n   378\t    *out_dot_q32 = total_dot_q32;\n   379\t    return Q4_0_Q8_0_OK;\n   380\t}\n   381\t\n   382\tI32 Q4_0_Q8_0DotBlocksAVX2Q32Checked(Q4_0Block *lhs_q4,\n   383\t                                     Q8_0Block *rhs_q8,\n   384\t                                     I64 block_count,\n   385\t