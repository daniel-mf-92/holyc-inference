  return GGUF_TDBASE_ERR_NULL_PTR, 0, 0\n   702\t\n   703\t    if tensor_index >= count:\n   704\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0\n   705\t\n   706\t    sorted_pos = sorted_position_by_tensor[tensor_index]\n   707\t    if sorted_pos >= count:\n   708\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0\n   709\t\n   710\t    abs_start = tensor_abs_starts[sorted_pos]\n   711\t    abs_end = tensor_abs_ends[sorted_pos]\n   712\t\n   713\t    if abs_end < abs_start:\n   714\t        return GGUF_TDBASE_ERR_OVERFLOW, 0, 0\n   715\t\n   716\t    return GGUF_TDBASE_OK, abs_start, abs_end\n   717\t\n   718\t\n   719\tdef tensor_range_find_by_index(\n   720\t    tensor_index: int,\n   721\t    tensor_abs_starts: list[int],\n   722\t    tensor_abs_ends: list[int],\n   723\t    sorted_position_by_tensor: list[int],\n   724\t):\n   725\t    return tensor_index_to_abs_range(\n   726\t        tensor_index=tensor_index,\n   727\t        tensor_abs_starts=tensor_abs_starts,\n   728\t        tensor_abs_ends=tensor_abs_ends,\n   729\t        sorted_position_by_tensor=sorted_position_by_tensor,\n   730\t    )\n   731\t\n   732\t\n   733\tdef tensor_lookup_by_rel_offset(\n   734\t    tensor_rel_offset: int,\n   735\t    tensor_data_base: int,\n   736\t    alignment: int,\n   737\t    tensor_abs_starts: list[int],\n   738\t    tensor_abs_ends: list[int],\n   739\t    sorted_tensor_indices: list[int],\n   740\t):\n   741\t    count = len(tensor_abs_starts)\n   742\t    if len(tensor_abs_ends) != count:\n   743\t        return GGUF_TDBASE_ERR_NULL_PTR, 0, 0, 0\n   744\t    if len(sorted_tensor_indices) != count:\n   745\t        return GGUF_TDBASE_ERR_NULL_PTR, 0, 0, 0\n   746\t\n   747\t    err, sorted_pos = tensor_range_find_by_rel_offset(\n   748\t        tensor_rel_offset=tensor_rel_offset,\n   749\t        tensor_data_base=tensor_data_base,\n   750\t        alignment=alignment,\n   751\t        tensor_abs_starts=tensor_abs_starts,\n   752\t        tensor_abs_ends=tensor_abs_ends,\n   753\t    )\n   754\t    if err != GGUF_TDBASE_OK:\n   755\t        return err, 0, 0, 0\n   756\t\n   757\t    if sorted_pos >= count:\n   758\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0, 0\n   759\t\n   760\t    tensor_index = sorted_tensor_indices[sorted_pos]\n","exit_code":0,"status":"completed"}}
