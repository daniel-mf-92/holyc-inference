f cursor > I64_MAX:\n    23\t        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    24\t    if need > I64_MAX:\n    25\t        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    26\t    if table_end > I64_MAX:\n    27\t        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    28\t    if cursor > table_end:\n    29\t        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n    30\t\n    31\t    next_cursor = cursor + need\n    32\t    if next_cursor > table_end:\n    33\t        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n    34\t\n    35\t    return GGUF_META_TABLE_OK, next_cursor\n    36\t\n    37\t\n    38\tdef gguf_metadata_read_u8_checked(\n    39\t    buf: list[int] | None,\n    40\t    buf_nbytes: int,\n    41\t    cursor_ref: list[int] | None,\n    42\t    table_end: int,\n    43\t    out_value_ref: list[int] | None,\n    44\t) -> int:\n    45\t    if buf is None or cursor_ref is None or out_value_ref is None:\n    46\t        return GGUF_META_TABLE_ERR_NULL_PTR\n    47\t    if buf_nbytes > I64_MAX:\n    48\t        return GGUF_META_TABLE_ERR_OVERFLOW\n    49\t\n    50\t    cur = cursor_ref[0]\n    51\t    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    52\t    if err != GGUF_META_TABLE_OK:\n    53\t        return err\n    54\t\n    55\t    assert next_cursor is not None\n    56\t    if next_cursor > buf_nbytes:\n    57\t        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    58\t\n    59\t    out_value_ref[0] = buf[cur]\n    60\t    cursor_ref[0] = next_cursor\n    61\t    return GGUF_META_TABLE_OK\n    62\t\n    63\t\n    64\tdef gguf_metadata_read_u64le_checked_no_partial(\n    65\t    buf: list[int] | None,\n    66\t    buf_nbytes: int,\n    67\t    cursor_ref: list[int] | None,\n    68\t    table_end: int,\n    69\t    out_value_ref: list[int] | None,\n    70\t) -> int:\n    71\t    if buf is None or cursor_ref is None or out_value_ref is None:\n    72\t        return GGUF_META_TABLE_ERR_NULL_PTR\n    73\t\n    74\t    cur = [cu