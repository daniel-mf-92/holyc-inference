time remains integer-only: the 32-bit payload is returned as raw bits\n// so callers can audit exact IEEE754 encodings without float math.\n// Contract: writes `*out_bits` and advances `*cursor` only on success.\nI32 GGUFMetadataReadF32BitsLEChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U32 *out_bits)\n{\n    // Keep legacy symbol as the canonical parser entrypoint while routing\n    // decode through the explicit no-partial-write helper.\n    return GGUFMetadataReadF32BitsLECheckedNoPartial(buf,\n                                                     buf_nbytes,\n                                                     cursor,\n                                                     table_end,\n                                                     out_bits);\n}\n\n// Checked little-endian FLOAT32 bit-pattern metadata reader with explicit\n// all-or-nothing staging contract. Cursor/output are committed only after\n// full U32 decode succeeds through the shared checked U32 reader.\nI32 GGUFMetadataReadF32BitsLECheckedNoPartial(U8 *buf,\n                                              U64 buf_nbytes,\n                                              U64 *cursor,\n                                              U64 table_end,\n                                              U32 *out_bits)\n{\n    U64 cur;\n    U32 raw_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared U32 checked reader so float32 payload bit\n    // extraction inherits identical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                  