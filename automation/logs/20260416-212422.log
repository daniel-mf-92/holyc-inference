t_out_row_base)\n   186\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n   187\t\n   188\t    if (row_index < 0 || lhs_row_stride_blocks < 0 || out_row_stride_cells < 0)\n   189\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   190\t\n   191\t    if (!Q8_0MatMulTryMulI64NonNeg(row_index,\n   192\t                                   lhs_row_stride_blocks,\n   193\t                                   out_lhs_row_base))\n   194\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   195\t\n   196\t    if (!Q8_0MatMulTryMulI64NonNeg(row_index,\n   197\t                                   out_row_stride_cells,\n   198\t                                   out_out_row_base))\n   199\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   200\t\n   201\t    return Q8_0_MATMUL_OK;\n   202\t}\n   203\t\n   204\t// Shared checked output-index math for tiled Q8_0 matmul inner loops:\n   205\t//   out_index = out_row_base + col_index\n   206\t// Centralizing this keeps overflow/BAD_LEN behavior identical across\n   207\t// scalar Q16, AVX2 Q32, and AVX2 Q16 tiled entrypoints.\n   208\tI32 Q8_0MatMulTiledComputeOutIndexChecked(\n   209\t    I64 out_row_base,\n   210\t    I64 col_index,\n   211\t    I64 *out_out_index)\n   212\t{\n   213\t    if (!out_out_index)\n   214\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n   215\t\n   216\t    if (out_row_base < 0 || col_index < 0)\n   217\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   218\t\n   219\t    if (!Q8_0MatMulTryAddI64NonNeg(out_row_base,\n   220\t                                   col_index,\n   221\t                                   out_out_index))\n   222\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   223\t\n   224\t    return Q8_0_MATMUL_OK;\n   225\t}\n   226\t\n   227\t// Shared checked RHS-column base math for tiled Q8_0 matmul inner loops:\n   228\t//   rhs_col_base = col_index * rhs_col_stride_blocks\n   229\t// Centralizing this keeps overflow/BAD_LEN behavior identical across\n   230\t// scalar Q16, AVX2 Q32, and AVX2 Q16 tiled entrypoints.\n","ex