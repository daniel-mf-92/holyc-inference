                U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U16 *out_first,\n                                     U16 *out_second,\n                                     U16 *out_third);\n\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value);\n\nI32 GGUFMetadataReadI16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second);\n\nI32 GGUFMetadataReadI16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     I16 *out_first,\n                                     I16 *out_second,\n                                     I16 *out_third);\n\nI32 GGUFMetadataReadU32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U32 *out_value);\n\nI32 GGUFMetadataReadU32PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U32 *out_first,\n                                   U32 *out_second);\n\nI32 GGUFMetadataReadU32TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                           