{"type":"item.started","item":{"id":"item_39","type":"command_execution","command":"/bin/zsh -lc \"python3 - <<'PY'\nimport random,struct,sys\nfrom pathlib import Path\nsys.path.append(str(Path('tests').resolve()))\nimport test_q4_0_q8_0_dot_kernel as ref\n\ndef half_to_float(h):\n    return float(struct.unpack('<e', struct.pack('<H', h))[0])\n\ndef q4_block_qdot_q0(lhs_q4,rhs_q8):\n    return sum(a*b for a,b in zip(ref.unpack_q4_signed(lhs_q4), ref.unpack_q8_signed(rhs_q8)))\n\ndef ggml_q32(lh,lq,rh,rq):\n    qdot=q4_block_qdot_q0(lq,rq)\n    return int(round(half_to_float(lh)*half_to_float(rh)*qdot*(1<<32)))\n\ndef q32toq16(v):\n    return ref.round_shift_right_signed(v,16)\n\nrng=random.Random(517733)\nworst=(0,0,0)\nfor bc in (1,5,9):\n  for _ in range(2000):\n    lhs=[];rhs=[]\n    for i in range(bc):\n      lhs_scale=ref.half_bits(rng.uniform(-3.0,3.0))\n      rhs_scale=ref.half_bits(rng.uniform(-3.0,3.0))\n      lhs_q4=ref.pack_q4_from_signed([rng.randrange(-8,8) for _ in range(32)])\n      rhs_q8=ref.pack_q8_signed([rng.randrange(-128,128) for _ in range(32)])\n      lhs.append((lhs_scale,lhs_q4)); rhs.append((rhs_scale,rhs_q8))\n    seed=rng.randrange(-(1<<27),1<<27)\n    err,got=ref.dot_product_blocks_q16_accumulate_checked(lhs,rhs,seed)\n    ex=seed\n    for (ls,lq),(rs,rq) in zip(lhs,rhs):\n      ex+=q32toq16(ggml_q32(ls,lq,rs,rq))\n    d=abs(got-ex)\n    if d>worst[0]:\n      worst=(d,bc,seed)\nprint('worst',worst)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
