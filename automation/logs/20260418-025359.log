                       U64 buf_nbytes,\n                                           U64 *cursor,\n                                           I8 *out_first,\n                                           I8 *out_second,\n                                           I8 *out_third);\n\nI32 GGUFMetadataReadI8QuadChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second,\n                                  I8 *out_third,\n                                  I8 *out_fourth);\n\nI32 GGUFMetadataReadI8QuadCheckedNoPartial(U8 *buf,\n                                           U64 buf_nbytes,\n                                           U64 *cursor,\n                                           U64 table_end,\n                                           I8 *out_first,\n                                           I8 *out_second,\n                                           I8 *out_third,\n                                           I8 *out_fourth);\n\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second);\n\nI32 GGUFMetadataReadU8TripleChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    U8 *out_first,\n                                    U8 *out_second,\n                                    U8 *out_third);\n\nI32 GGUFMetadataReadU8QuadChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n   