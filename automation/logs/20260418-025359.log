 U16 *out_third,\n                                          U16 *out_fourth);\n\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value);\n\nI32 GGUFMetadataReadI16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second);\n\nI32 GGUFMetadataReadI16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n---\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    I8 *out_first,\n                                    I8 *out_second,\n                                    I8 *out_third)\n{\n    U64 cur;\n    I8 first;\n    I8 second;\n    I8 third;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second || !out_third)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage all scalar reads through the canonical signed-I8 helper so triple\n    // reads preserve identical bounds/overflow and no-partial-write behavior.\n    err = GGUFMetadataReadI8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &third);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked metadata signed-I8 triple reader with explicit no-partial wrapper\n// semantics.\n// Contract: this entrypoint enforces strict all-or-nothing cursor/output\n// commit by delegating to the canonical staged triple decoder.\nI32 GGUFMetadataReadI8TripleCheckedNoPartial(U8 *buf,\n                                             U64 buf_nbytes,\n                                             U64 *cursor,\n                                             U64 table_end,\n                                             I8 *out_first,\n                                             I8 *out_second,\n                                             I8 *out_third)\n{\n    return GGUFMetadataReadI8TripleChecked(buf,\n                                           buf_nbytes,\n                                           cursor,\n                                           table_end,\n                                           out_first,\n                                           out_second,\n                                           out_third);\n}\n\n// Canonical default-end wrapper for fixed-layout signed-I8 triple metadata\n// records.\n// Contract: preserves exact checked triple semantics by pinning table_end to\n// buf_nbytes and delegating to GGUFMetadataReadI8TripleChecked.\nI32 GGUFMetadataReadI8TripleCheckedDefault(U8 *buf,\n                                           U64 buf_nbytes,\n                                           U64 *cursor,\n                                           I8 *out_first,\n                                           I8 *out_second,\n                                           I8 *out_third)\n{\n    return GGUFMetadataReadI8TripleChecked(buf,\n                                           buf_nbytes,\n                                           cursor,\n                                           buf_nbytes,\n                                           out_first,\n                                           out_second,\n                                           out_third);\n}\n\n// Checked signed-I8 tuple reader for compact metadata quad fields.\n// Contract: stages three signed-I8 decodes through the shared triple helper,\n// decodes lane four through the canonical scalar helper, and commits all\n// outputs + cursor only when all four lanes succeed.\nI32 GGUFMetadataReadI8QuadChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second,\n                                  I8 *out_third,\n                                  I8 *out_fourth)\n{\n    U64 cur;\n    I8 first;\n    I8 second;\n    I8 third;\n    I8 fourth;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second || !out_third || !out_fourth)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage lanes 1..3 through the canonical triple helper so cursor math,\n    // bounds checking, and no-partial-write semantics stay shared.\n    err = GGUFMetadataReadI8TripleChecked(buf,\n                                          buf_nbytes,\n                                          &cur,\n                                          table_end,\n                                          &first,\n                                          &second,\n                                          &third);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Stage lane 4 through the canonical scalar helper and commit only after\n    // all lanes decode successfully.\n    err = GGUFMetadataReadI8Checked(buf,\n                                    buf_nbytes,\n                                    &cur,\n                                    table_end,\n                                    &fourth);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *out_fourth = fourth;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked metadata signed-I8 quad reader with explicit no-partial wrapper\n// semantics.\n// Contract: this entrypoint enforces strict all-or-nothing cursor/output\n// commit by delegating to the canonical staged quad decoder.\nI32 GGUFMetadataReadI8QuadCheckedNoPartial(U8 *buf,\n                                           U64 buf_nbytes,\n                                           U64 *cursor,\n                                           U64 table_end,\n                                           I8 *out_first,\n                                           I8 *out_second,\n                                           I8 *out_third,\n                                           I8 *out_fourth)\n{\n    return GGUFMetadataReadI8QuadChecked(buf,\n                                         buf_nbytes,\n                                         cursor,\n                                         table_end,\n                                         out_first,\n                                         out_second,\n                                         out_third,\n                                         out_fourth);\n}\n\n// Checked little-endian U16 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                             