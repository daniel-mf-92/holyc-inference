{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/bin/zsh -lc \"ls tests | rg 'gguf|metadata|i64|u16|reader|checked' | sort | head -n 80\nsed -n '1,260p' tests/test_gguf_metadata_read_i64le_checked.py\nsed -n '1,260p' tests/test_gguf_metadata_read_u16le_checked.py\"","aggregated_output":"test_fixedpoint_q16_checked.py\ntest_fixedpoint_q16_muldiv_array_checked.py\ntest_fixedpoint_q16_muldiv_array_positive_int_checked.py\ntest_fixedpoint_q16_muldiv_array_positive_int_from_q16den_checked.py\ntest_fixedpoint_q16_muldiv_array_positive_int_from_q16den_no_alias_checked.py\ntest_fixedpoint_q16_muldiv_checked.py\ntest_fixedpoint_q16_muldiv_positive_int_checked.py\ntest_fixedpoint_q16_muldiv_positive_int_from_q16den_checked.py\ntest_gguf_header_parse.py\ntest_gguf_header_parse_checked.py\ntest_gguf_header_read_endian_checked.py\ntest_gguf_header_validate_and_size_checked.py\ntest_gguf_metadata_parse.py\ntest_gguf_metadata_read_array_header_checked.py\ntest_gguf_metadata_read_bool_checked.py\ntest_gguf_metadata_read_f64bitsle_checked.py\ntest_gguf_metadata_read_i32le_checked.py\ntest_gguf_metadata_read_i64le_checked.py\ntest_gguf_metadata_read_string_bytes_checked.py\ntest_gguf_metadata_read_string_len_u64_checked.py\ntest_gguf_metadata_read_string_u64_header_bounds_checked.py\ntest_gguf_metadata_read_u16le_checked.py\ntest_gguf_metadata_read_u32le_checked.py\ntest_gguf_metadata_read_u64le_checked.py\ntest_gguf_metadata_read_u8_checked.py\ntest_gguf_tensor_bytes_for_type.py\ntest_gguf_tensor_data_base.py\ntest_gguf_tensorinfo_parse.py\ntest_intexp_clamp_array_to_input_domain_checked.py\ntest_intexp_clamp_to_input_domain_checked.py\ntest_intexp_exp_array_checked.py\ntest_intexp_exp_array_from_clamped_input_checked.py\ntest_intexp_exp_array_no_alias_checked.py\ntest_intexp_exp_from_clamped_input_checked.py\ntest_intexp_split_base2_from_clamped_input_checked.py\ntest_q4_0_q8_0_matmul_tiled_checked.py\ntest_q8_0_dot_matrix_vector_checked.py\ntest_q8_0_matmul_tiled_checked.py\ntest_rmsnorm_apply_inv_denom_checked.py\ntest_rmsnorm_apply_inv_denom_weighted_auto_checked.py\ntest_rmsnorm_apply_inv_denom_weighted_checked.py\ntest_rmsnorm_apply_inv_denom_weighted_inplace_checked.py\ntest_rmsnorm_q16_checked.py\ntest_rmsnorm_q16_checked_inplace.py\ntest_softmax_exp_phase_from_preclamped_checked.py\ntest_softmax_exp_phase_from_preclamped_no_alias_checked.py\ntest_softmax_from_preclamped_checked.py\ntest_softmax_from_preclamped_checked_with_sum_out.py\ntest_softmax_from_preclamped_no_alias_checked.py\ntest_softmax_from_preclamped_no_alias_checked_with_sum_out.py\ntest_softmax_normalize_phase_checked.py\ntest_softmax_normalize_phase_no_alias_checked.py\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadI64LEChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU64_MASK = (1 << 64) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u64le_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    b = [0]\n    out = 0\n\n    for i in range(8):\n        err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, b)\n        if err != GGUF_META_TABLE_OK:\n            return err\n        out |= b[0] << (8 * i)\n\n    out_value_ref[0] = out\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef reinterpret_u64_as_i64(value: int) -> int:\n    value &= U64_MASK\n    if value >= (1 << 63):\n        return value - (1 << 64)\n    return value\n\n\ndef gguf_metadata_read_i64le_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    raw = [0]\n\n    err = gguf_metadata_read_u64le_checked(buf, buf_nbytes, cur, table_end, raw)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = reinterpret_u64_as_i64(raw[0])\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [3]\n    out = [123456789]\n\n    assert (\n        gguf_metadata_read_i64le_checked(None, 32, cursor, 16, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor[0] == 3\n    assert out[0] == 123456789\n\n    assert (\n        gguf_metadata_read_i64le_checked([0] * 32, 32, None, 16, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out[0] == 123456789\n\n    assert (\n        gguf_metadata_read_i64le_checked([0] * 32, 32, cursor, 16, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor[0] == 3\n\n\ndef test_short_reads_do_not_advance_or_write() -> None:\n    buf = [0xAA] * 32\n    out = [-987654321]\n\n    for table_end in range(0, 8):\n        cursor = [0]\n        err = gguf_metadata_read_i64le_checked(buf, len(buf), cursor, table_end, out)\n        assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n        assert cursor[0] == 0\n        assert out[0] == -987654321\n\n\ndef test_success_signed_interpretation_and_cursor_advance() -> None:\n    buf = [\n        0x00,\n        0x00,\n        0xFF,\n        0xFF,\n        0xFF,\n        0xFF,\n        0xFF,\n        0xFF,\n        0xFF,\n        0xFF,\n        0x7F,\n        0x00,\n        0x00,\n        0x00,\n    ]\n\n    cursor = [2]\n    out = [0]\n\n    err = gguf_metadata_read_i64le_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == -1\n    assert cursor[0] == 10\n\n\ndef test_min_i64_boundary() -> None:\n    # 0x8000000000000000 little-endian => -9223372036854775808\n    buf = [0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x80]\n    cursor = [0]\n    out = [1]\n\n    err = gguf_metadata_read_i64le_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == -(1 << 63)\n    assert cursor[0] == 8\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_197)\n\n    for _ in range(5000):\n        n = rng.randint(1, 256)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        table_end = rng.randint(0, n)\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out = [314159265]\n        err = gguf_metadata_read_i64le_checked(buf, n, cursor, table_end, out)\n\n        if cursor0 + 8 <= table_end and cursor0 + 8 <= n:\n            raw = 0\n            for i in range(8):\n                raw |= buf[cursor0 + i] << (8 * i)\n            expect = reinterpret_u64_as_i64(raw)\n            assert err == GGUF_META_TABLE_OK\n            assert out[0] == expect\n            assert cursor[0] == cursor0 + 8\n        else:\n            assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n            assert out[0] == 314159265\n            assert cursor[0] == cursor0\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_short_reads_do_not_advance_or_write()\n    test_success_signed_interpretation_and_cursor_advance()\n    test_min_i64_boundary()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_i64le_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadU16LEChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u16le_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    b0 = [0]\n    b1 = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, b0)\n    if err != GGUF_META_TABLE_OK:\n        return err\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, b1)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = b0[0] | (b1[0] << 8)\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [2]\n    out = [0xABCD]\n\n    assert (\n        gguf_metadata_read_u16le_checked(None, 5, cursor, 5, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [2]\n    assert out == [0xABCD]\n\n    assert (\n        gguf_metadata_read_u16le_checked([1, 2], 2, None, 2, out)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out == [0xABCD]\n\n    assert (\n        gguf_metadata_read_u16le_checked([1, 2], 2, cursor, 2, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [2]\n\n\ndef test_short_reads_do_not_advance_cursor() -> None:\n    buf = [0x11, 0x22, 0x33]\n\n    cursor = [2]\n    out = [0x7777]\n    assert (\n        gguf_metadata_read_u16le_checked(buf, len(buf), cursor, len(buf), out)\n        == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    )\n    assert cursor == [2]\n    assert out == [0x7777]\n\n    cursor = [1]\n    out = [0xAAAA]\n    assert (\n        gguf_metadata_read_u16le_checked(buf, 2, cursor, 3, out)\n        == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    )\n    assert cursor == [1]\n    assert out == [0xAAAA]\n\n\ndef test_success_decodes_little_endian_and_advances() -> None:\n    buf = [0x34, 0x12, 0x99]\n    cursor = [0]\n    out = [0]\n\n    err = gguf_metadata_read_u16le_checked(buf, len(buf), cursor, len(buf), out)\n    assert err == GGUF_META_TABLE_OK\n    assert out[0] == 0x1234\n    assert cursor[0] == 2\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_206)\n\n    for _ in range(4000):\n        n = rng.randint(1, 256)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        table_end = rng.randint(0, n)\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out = [0x1111]\n\n        err = gguf_metadata_read_u16le_checked(buf, n, cursor, table_end, out)\n\n        if cursor0 + 2 <= table_end and cursor0 + 2 <= n:\n            expect = buf[cursor0] | (buf[cursor0 + 1] << 8)\n            assert err == GGUF_META_TABLE_OK\n            assert out[0] == expect\n            assert cursor[0] == cursor0 + 2\n        else:\n            assert err in (GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, GGUF_META_TABLE_ERR_BAD_PARAM)\n            assert out[0] == 0x1111\n            assert cursor[0] == cursor0\n\n\ndef test_table_end_overflow_surface() -> None:\n    buf = [0xAA, 0xBB]\n    cursor = [0]\n    out = [123]\n\n    err = gguf_metadata_read_u16le_checked(buf, len(buf), cursor, I64_MAX + 1, out)\n    assert err == GGUF_META_TABLE_ERR_OVERFLOW\n    assert cursor == [0]\n    assert out == [123]\n\n\ndef run() -> None:\n    test_null_ptr_and_no_partial_write()\n    test_short_reads_do_not_advance_cursor()\n    test_success_decodes_little_endian_and_advances()\n    test_randomized_parity()\n    test_table_end_overflow_surface()\n    print(\"gguf_metadata_read_u16le_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
