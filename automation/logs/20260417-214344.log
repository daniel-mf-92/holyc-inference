                    U64 table_end,\n                                     U8 *out_key_bytes,\n                                     U64 out_key_nbytes,\n                                     U64 *out_key_len);\n\nI32 GGUFMetadataReadArrayHeaderChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U32 *out_elem_type,\n                                       U64 *out_elem_count);\n\nI32 GGUFMetadataArrayPayloadSpanValidateChecked(U64 payload_start,\n                                                U64 payload_bytes,\n                                                U64 table_end,\n                                                U64 buf_nbytes,\n                                                U64 *out_payload_end);\n\nI32 GGUFMetadataArrayPayloadSpanValidateFromCursorChecked(U64 *cursor,\n                                                          U64 payload_bytes,\n                                                          U64 table_end,\n                                                          U64 buf_nbytes,\n                                                          U64 *out_payload_end);\n\nI32 GGUFMetadataArrayFixedElemWidthBytesChecked(U32 elem_type,\n                                                U64 *out_elem_width_bytes);\n\nI32 GGUFMetadataArrayFixedPayloadBytesChecked(U64 elem_count,\n                                              U64 elem_width_bytes,\n                                              U64 *out_payload_bytes);\n\nI32 GGUFMetadataArrayPayloadSpanFromFixedTypeChecked(U32 elem_type,\n                                                     U64 elem_count,\n                                                     U64 payload_start,\n                                                     U64 table_end,\n                                                     U64 buf_nbytes,\n                               