 alignment\n  1212\t\n  1213\t        rel_offsets = []\n  1214\t        nbytes = []\n  1215\t        cursor = 0\n  1216\t\n  1217\t        force_overlap = rng.random() < 0.5 and count >= 2\n  1218\t        overlap_i = rng.randint(0, count - 2) if force_overlap else -1\n  1219\t\n  1220\t        for i in range(count):\n  1221\t            gap = rng.randint(0, 6) * alignment\n  1222\t            cursor += gap\n  1223\t            span = rng.randint(0, 6) * alignment\n  1224\t\n  1225\t            start = cursor\n  1226\t            if force_overlap and i == overlap_i + 1:\n  1227\t                prev_start = rel_offsets[-1]\n  1228\t                prev_span = nbytes[-1]\n  1229\t                if prev_span == 0:\n  1230\t                    start = prev_start\n  1231\t                else:\n  1232\t                    start = prev_start + rng.randint(0, max(0, (prev_span // alignment) - 1)) * alignment\n  1233\t\n  1234\t            rel_offsets.append(start)\n  1235\t            nbytes.append(span)\n  1236\t            cursor = max(cursor, start + span)\n  1237\t\n  1238\t        file_nbytes = base + cursor + rng.randint(0, 8) * alignment + alignment\n  1239\t\n  1240\t        rel_a = rel_offsets.copy()\n  1241\t        nbytes_a = nbytes.copy()\n  1242\t        err_quad, bad_quad = validate_tensor_ranges(\n  1243\t            tensor_data_base=base,\n  1244\t            alignment=alignment,\n  1245\t            gguf_file_nbytes=file_nbytes,\n  1246\t            tensor_rel_offsets=rel_a,\n  1247\t            tensor_nbytes=nbytes_a,\n  1248\t        )\n  1249\t\n  1250\t        rel_b = rel_offsets.copy()\n  1251\t        nbytes_b = nbytes.copy()\n  1252\t        err_sorted, bad_sorted = validate_tensor_ranges_sorted(\n  1253\t            tensor_data_base=base,\n  1254\t            alignment=alignment,\n  1255\t            gguf_file_nbytes=file_nbytes,\n  1256\t            tensor_rel_offsets=rel_b,\n  1257\t            tensor_nbytes=nbytes_b,\n  1258\t        )\n  1259