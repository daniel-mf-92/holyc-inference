 assert tensor_data_base_align(100, 24)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   865\t    assert tensor_data_base_is_aligned(128, 24) is False\n   866\t\n   867\t\n   868\tdef test_overflow_guard_near_u64_max() -> None:\n   869\t    err, _ = tensor_data_base_align(U64_MAX - 7, 16)\n   870\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   871\t\n   872\t    err, base = tensor_data_base_align(U64_MAX - 15, 16)\n   873\t    assert err == GGUF_TDBASE_OK\n   874\t    assert base == U64_MAX - 15\n   875\t\n   876\t\n   877\tdef test_random_alignment_matches_reference_formula() -> None:\n   878\t    rng = random.Random(760031)\n   879\t\n   880\t    for _ in range(1000):\n   881\t        alignment = 1 << rng.randint(0, 20)\n   882\t        cursor = rng.randrange(0, 1 << 56)\n   883\t\n   884\t        err, got = tensor_data_base_align(cursor, alignment)\n   885\t        assert err == GGUF_TDBASE_OK\n   886\t\n   887\t        reference = ((cursor + (alignment - 1)) // alignment) * alignment\n   888\t        assert got == reference\n   889\t        assert got >= cursor\n   890\t        assert tensor_data_base_is_aligned(got, alignment)\n   891\t\n   892\t\n   893\tdef test_tensor_data_base_offset_happy_path() -> None:\n   894\t    err, abs_off = tensor_data_base_offset(0x2000, 0x80, 32)\n   895\t    assert err == GGUF_TDBASE_OK\n   896\t    assert abs_off == 0x2080\n   897\t\n   898\t\n   899\t\n   900\tdef test_tensor_data_base_offset_default_alignment() -> None:\n   901\t    err, abs_off = tensor_data_base_offset_default(0x100, 0x40)\n   902\t    assert err == GGUF_TDBASE_OK\n   903\t    assert abs_off == 0x140\n   904\t\n   905\t\n   906\t\n   907\tdef test_tensor_data_base_offset_reject_bad_alignment() -> None:\n   908\t    err, _ = tensor_data_base_offset(0x1000, 0x40, 24)\n   909\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   910\t\n   911\t\n   912\t\n   913\tdef test_tensor_data_base_offset_reject_misaligned_base() -> None:\n   914\t    err, _ = tensor_data_base_offset(0x1010, 0x40, 32)\n   915\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   916\t\n   917\t\n   918\t\n   919\tdef test_tensor_data_base_offset_reject_misaligned_rel() -> None:\n   920\t    err, _ = tensor_data_base_offset(0x1000, 0x48, 32)\n   921\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n   922\t\n   923\t\n   924\t\n   925\tdef test_tensor_data_base_offset_overflow_guard() -> None:\n   926\t    err, _ = tensor_data_base_offset(U64_MAX - 31, 32, 32)\n   927\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   928\t\n   929\t\n   930\t\n   931\tdef test_tensor_data_base_offset_random_aligned_cases() -> None:\n   932\t    rng = random.Random(761113)\n   933\t\n   934\t    for _ in range(1000):\n   935\t        alignment = 1 << rng.randint(0, 15)\n   936\t        base_units = rng.randrange(0, 1 << 24)\n   937\t        rel_units = rng.randrange(0, 1 << 20)\n   938\t        base = base_units * alignment\n   939\t        rel = rel_units * alignment\n   940\t\n   941\t        err, got = tensor_data_base_offset(base, rel, alignment)\n   942\t        assert err == GGUF_TDBASE_OK\n   943\t        assert got == base + rel\n   944\t        assert tensor_data_base_is_aligned(got, alignment)\n   945\t\n   946\t\n   947\tdef test_tensor_resolve_range_happy_path() -> None:\n   948\t    err, abs_start, abs_end = tensor_resolve_range(0x2000, 0x80, 0x120, 0x3000, 32)\n   949\t    assert err == GGUF_TDBASE_OK\n   950\t    assert abs_start == 0x2080\n   951\t    assert abs_end == 0x21A0\n   952\t\n   953\t\n   954\tdef test_tensor_resolve_range_default_alignment() -> None:\n   955\t    err, abs_start, abs_end = tensor_resolve_range_default(0x100, 0x40, 0x10, 0x1000)\n   956\t    assert err == GGUF_TDBASE_OK\n   957\t    assert abs_start == 0x140\n   958\t    assert abs_end == 0x150\n   959\t\n   960\t\n   961\tdef test_tensor_resolve_range_reject_bad_alignment() -> None:\n   962\t    err, _, _ = tensor_resolve_range(0x100, 0x20, 0x10, 0x1000, 24)\n   963\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   964\t\n   965\t\n   966\tdef test_tensor_resolve_range_reject_misaligned_base() -> None:\n   967\t    err, _, _ = tensor_resolve_range(0x110, 0x20, 0x10, 0x1000, 32)\n   968\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   969\t\n   970\t\n   971\tdef test_tensor_resolve_range_reject_misaligned_offset() -> None:\n   972\t    err, _, _ = tensor_resolve_range(0x100, 0x18, 0x10, 0x1000, 32)\n   973\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n   974\t\n   975\t\n   976\tdef test_tensor_resolve_range_overflow_guard() -> None:\n   977\t    err, _, _ = tensor_resolve_range(U64_MAX - 0x1F, 0x20, 0x40, U64_MAX, 32)\n   978\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   979\t\n   980\t\n   981\tdef test_tensor_resolve_range_out_of_bounds() -> None:\n   982\t    err, _, _ = tensor_resolve_range(0x200, 0x40, 0xC0, 0x2F0, 32)\n   983\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n   984\t\n   985\t\n   986\tdef test_tensor_resolve_range_allows_exact_eof() -> None:\n   987\t    err, abs_start, abs_end = tensor_resolve_range(0x400, 0x80, 0x100, 0x580, 32)\n   988\t    assert err == GGUF_TDBASE_OK\n   989\t    assert abs_start == 0x480\n   990\t    assert abs_end == 0x580\n   991\t\n   992\t\n   993\tdef test_tensor_resolve_range_random_valid_cases() -> None:\n   994\t    rng = random.Random(761499)\n   995\t\n   996\t    for _ in range(1000):\n   997\t        alignment = 1 << rng.randint(0, 15)\n   998\t        base_units = rng.randrange(0, 1 << 20)\n   999\t        rel_units = rng.randrange(0, 1 << 20)\n  1000\t        tensor_nbytes = rng.randrange(0, 1 << 16)\n  1001\t\n  1002\t        base = base_units * alignment\n  1003\t        rel = rel_units * alignment\n  1004\t        start = base + rel\n  1005\t        if start > U64_MAX - tensor_nbytes:\n  1006\t            continue\n  1007\t        end = start + tensor_nbytes\n  1008\t\n  1009\t        file_pad = rng.randrange(0, 1 << 12)\n  1010\t        file_nbytes = end + file_pad\n  1011\t\n  1012\t        err, got_start, got_end = tensor_resolve_range(\n  1013\t            base,\n  1014\t            rel,\n  1015\t            tensor_nbytes,\n  1016\t            file_nbytes,\n  1017\t            alignment,\n  1018\t        )\n  1019\t        assert err == GGUF_TDBASE_OK\n  1020\t        assert got_start == start\n  1021\t        assert got_end == end\n  1022\t\n  1023\t\n  1024\tdef test_validate_tensor_ranges_non_overlapping_happy_path() -> None:\n  1025\t    err, bad = validate_tensor_ranges(\n  1026\t        tensor_data_base=0x1000,\n  1027\t        alignment=32,\n  1028\t        gguf_file_nbytes=0x5000,\n  1029\t        tensor_rel_offsets=[0x00, 0x80, 0x100, 0x200],\n  1030\t        tensor_nbytes=[0x40, 0x40, 0x80, 0x20],\n  1031\t    )\n  1032\t    assert err == GGUF_TDBASE_OK\n  1033\t    assert bad == 0\n  1034\t\n  1035\t\n  1036\tdef test_validate_tensor_ranges_detect_overlap() -> None:\n  1037\t    err, bad = validate_tensor_ranges(\n  1038\t        tensor_data_base=0x1000,\n  1039\t        alignment=32,\n  1040\t        gguf_file_nbytes=0x5000,\n  1041\t        tensor_rel_offsets=[0x00, 0x20, 0x200],\n  1042\t        tensor_nbytes=[0x40, 0x40, 0x20],\n  1043\t    )\n  1044\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1045\t    assert bad == 1\n  1046\t\n  1047\t\n  1048\tdef test_validate_tensor_ranges_propagates_bad_alignment() -> None:\n  1049\t    err, bad = validate_tensor_ranges(\n  1050\t        tensor_data_base=0x1000,\n  1051\t        alignment=24,\n  1052\t        gguf_file_nbytes=0x5000,\n  1053\t        tensor_rel_offsets=[0x00, 0x20],\n  1054\t        tensor_nbytes=[0x20, 0x20],\n  1055\t    )\n  1056\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n  1057\t    assert bad == 0\n  1058\t\n  1059\t\n  1060\tdef test_validate_tensor_ranges_propagates_out_of_bounds_with_index() -> None:\n  1061\t    err, bad = validate_tensor_ranges(\n  1062\t        tensor_data_base=0x1000,\n  1063\t        alignment=32,\n  1064\t        gguf_file_nbytes=0x1100,\n  1065\t        tensor_rel_offsets=[0x00, 0x80],\n  1066\t        tensor_nbytes=[0x20, 0x120],\n  1067\t    )\n  1068\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1069\t    assert bad == 1\n  1070\t\n  1071\t\n  1072\tdef test_validate_tensor_ranges_random_non_overlapping() -> None:\n  1073\t    rng = random.Random(761991)\n  1074\t\n  1075\t    for _ in range(300):\n  1076\t        alignment = 1 << rng.randint(0, 10)\n  1077\t        count = rng.randint(1, 12)\n  1078\t        cursor = 0\n  1079\t\n  1080\t        rel_offsets = []\n  1081\t        nbytes = []\n  1082\t        for _ in range(count):\n  1083\t            gap_units = rng.randint(0, 8)\n  1084\t            gap = gap_units * alignment\n  1085\t            cursor += gap\n  1086\t\n  1087\t            span_units = rng.randint(0, 6)\n  1088\t            span = span_units * alignment\n  1089\t\n  1090\t            rel_offsets.append(cursor)\n  1091\t            nbytes.append(span)\n  1092\t            cursor += span\n  1093\t\n  1094\t        base_units = rng.randint(0, 1024)\n  1095\t        base = base_units * alignment\n  1096\t        file_nbytes = base + cursor + (rng.randint(0, 16) * alignment)\n  1097\t\n  1098\t        err, bad = validate_tensor_ranges(\n  1099\t            tensor_data_base=base,\n  1100\t            alignment=alignment,\n  1101\t            gguf_file_nbytes=file_nbytes,\n  1102\t            tensor_rel_offsets=rel_offsets,\n  1103\t            tensor_nbytes=nbytes,\n  1104\t        )\n  1105\t        assert err == GGUF_TDBASE_OK\n  1106\t        assert bad == 0\n  1107\t\n  1108\t\n  1109\tdef test_validate_tensor_ranges_random_overlap_cases() -> None:\n  1110\t    rng = random.Random(762007)\n  1111\t\n  1112\t    for _ in range(200):\n  1113\t        alignment = 1 << rng.randint(0, 10)\n  1114\t        base = rng.randint(0, 1024) * alignment\n  1115\t\n  1116\t        a_start = rng.randint(0, 128) * alignment\n  1117\t        a_len = max(alignment, rng.randint(1, 8) * alignment)\n  1118\t        b_start = a_start + rng.randint(0, (a_len // alignment) - 1) * alignment\n  1119\t        b_len = max(alignment, rng.randint(1, 8) * alignment)\n  1120\t\n  1121\t        rel_offsets = [a_start, b_start]\n  1122\t        nbytes = [a_len, b_len]\n  1123\t        max_end = max(a_start + a_len, b_start + b_len)\n  1124\t        file_nbytes = base + max_end + alignment\n  1125\t\n  1126\t        err, bad = validate_tensor_ranges(\n  1127\t            tensor_data_base=base,\n  1128\t            alignment=alignment,\n  1129\t            gguf_file_nbytes=file_nbytes,\n  1130\t            tensor_rel_offsets=rel_offsets,\n  1131\t            tensor_nbytes=nbytes,\n  1132\t        )\n  1133\t        assert err == GGUF_TDBASE_ERR_OVERLAP\n  1134\t        assert bad == 1\n  1135\t\n  1136\t\n  1137\tdef test_validate_tensor_ranges_sorted_non_overlapping_happy_path() -> None:\n  1138\t    rel_offsets = [0x200, 0x00, 0x100, 0x80]\n  1139\t    nbytes = [0x20, 0x40, 0x40, 0x40]\n  1140\t\n  1141\t    err, bad = validate_tensor_ranges_sorted(\n  1142\t        tensor_data_base=0x1000,\n  1143\t        alignment=32,\n  1144\t        gguf_file_nbytes=0x5000,\n  1145\t        tensor_rel_offsets=rel_offsets,\n  1146\t        tensor_nbytes=nbytes,\n  1147\t    )\n  1148\t    assert err == GGUF_TDBASE_OK\n  1149\t    assert bad == 0\n  1150\t    assert rel_offsets == [0x00, 0x80, 0x100, 0x200]\n  1151\t    assert nbytes == [0x40, 0x40, 0x40, 0x20]\n  1152\t\n  1153\t\n  1154\tdef test_validate_tensor_ranges_sorted_tie_breaks_equal_offsets_by_size() -> None:\n  1155\t    rel_offsets = [0x80, 0x80, 0x80]\n  1156\t    nbytes = [0x20, 0x00, 0x08]\n  1157\t\n  1158\t    err, bad = validate_tensor_ranges_sorted(\n  1159\t        tensor_data_base=0x1000,\n  1160\t        alignment=32,\n  1161\t        gguf_file_nbytes=0x5000,\n  1162\t        tensor_rel_offsets=rel_offsets,\n  1163\t        tensor_nbytes=nbytes,\n  1164\t    )\n  1165\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1166\t    assert bad == 2\n  1167\t    assert rel_offsets == [0x80, 0x80, 0x80]\n  1168\t    assert nbytes == [0x00, 0x08, 0x20]\n  1169\t\n  1170\t\n  1171\tdef test_validate_tensor_ranges_sorted_detect_overlap() -> None:\n  1172\t    rel_offsets = [0x100, 0x00, 0x20]\n  1173\t    nbytes = [0x20, 0x40, 0x40]\n  1174\t\n  1175\t    err, bad = validate_tensor_ranges_sorted(\n  1176\t        tensor_data_base=0x1000,\n  1177\t        alignment=32,\n  1178\t        gguf_file_nbytes=0x5000,\n  1179\t        tensor_rel_offsets=rel_offsets,\n  1180\t        tensor_nbytes=nbytes,\n  1181\t    )\n  1182\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1183\t    assert bad == 1\n  1184\t    assert rel_offsets == [0x00, 0x20, 0x100]\n  1185\t    assert nbytes == [0x40, 0x40, 0x20]\n  1186\t\n  1187\t\n  1188\tdef test_validate_tensor_ranges_sorted_propagates_bad_alignment_without_sort() -> None:\n  1189\t    rel_offsets = [0x80, 0x00]\n  1190\t    nbytes = [0x20, 0x20]\n  1191\t\n  1192\t    err, bad = validate_tensor_ranges_sorted(\n  1193\t        tensor_data_base=0x1000,\n  1194\t        alignment=24,\n  1195\t        gguf_file_nbytes=0x5000,\n  1196\t        tensor_rel_offsets=rel_offsets,\n  1197\t        tensor_nbytes=nbytes,\n  1198\t    )\n  1199\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n  1200\t    assert bad == 0\n  1201\t    assert rel_offsets == [0x80, 0x00]\n  1202\t    assert nbytes == [0x20, 0x20]\n  1203\t\n  1204\t\n  1205\tdef test_validate_tensor_ranges_sorted_random_matches_quadratic_validator() -> None:\n  1206\t    rng = random.Random(762199)\n  1207\t\n  1208\t    for _ in range(500):\n  1209\t        alignment = 1 << rng.randint(0, 10)\n  1210\t        count = rng.randint(1, 24)\n  1211\t        base = rng.randint(0, 1024) * alignment\n  1212\t\n  1213\t        rel_offsets = []\n  1214\t        nbytes = []\n  1215\t        cursor = 0\n  1216\t\n  1217\t        force_overlap = rng.random() < 0.5 and count >= 2\n  1218\t        overlap_i = rng.randint(0, count - 2) if force_overlap else -1\n  1219\t\n  1220\t        for i in range(count):\n  1700\t        tensor_ggml_types=[GGML_TYPE_Q8_0, GGML_TYPE_Q8_0],\n  1701\t        out_abs_starts=starts,\n  1702\t        out_abs_ends=ends,\n  1703\t        out_sorted_tensor_indices=sorted_idx,\n  1704\t    )\n  1705\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1706\t    assert bad == 1\n  1707\t\n  1708\t\n  1709\tdef test_tensor_info_build_offset_index_random_non_overlapping() -> None:\n  1710\t    rng = random.Random(764021)\n  1711\t\n  1712\t    for _ in range(200):\n  1713\t        count = rng.randint(1, 12)\n  1714\t        rel_offsets: list[int] = []\n  1715\t        elem_counts: list[int] = []\n  1716\t        ggml_types: list[int] = []\n  1717\t\n  1718\t        cursor = 0\n  1719\t        for _ in range(count):\n  1720\t            gap_units = rng.randint(0, 4)\n  1721\t            cursor += gap_units * 32\n  1722\t\n  1723\t            ggml_type = rng.choice([GGML_TYPE_Q4_0, GGML_TYPE_Q8_0, GGML_TYPE_F16, GGML_TYPE_F32])\n  1724\t            if ggml_type in (GGML_TYPE_Q4_0, GGML_TYPE_Q8_0):\n  1725\t                blocks = rng.randint(1, 4)\n  1726\t                elem_count = blocks * 32\n  1727\t            else:\n  1728\t                elem_count = rng.randint(1, 128)\n  1729\t\n  1730\t            err, nbytes = tensor_bytes_for_type(ggml_type, elem_count)\n  1731\t            assert err == GGUF_TDBASE_OK\n  1732\t\n  1733\t            rel_offsets.append(cursor)\n  1734\t            elem_counts.append(elem_count)\n  1735\t            ggml_types.append(ggml_type)\n  1736\t\n  1737\t            span_units = (nbytes + 31) // 32\n  1738\t            cursor += span_units * 32\n  1739\t\n  1740\t        starts = [0] * count\n  1741\t        ends = [0] * count\n  1742\t        sorted_idx = [0] * count\n  1743\t        file_nbytes = 0x1000 + cursor + 0x100\n  1744\t\n  1745\t        err, bad = tensor_info_build_offset_index(\n  1746\t            tensor_data_base=0x1000,\n  1747\t            alignment=32,\n  1748\t            gguf_file_nbytes=file_nbytes,\n  1749\t            tensor_rel_offsets=rel_offsets,\n  1750\t            tensor_element_counts=elem_counts,\n  1751\t            tensor_ggml_types=ggml_types,\n  1752\t            out_abs_starts=starts,\n  1753\t            out_abs_ends=ends,\n  1754\t            out_sorted_tensor_indices=sorted_idx,\n  1755\t        )\n  1756\t        assert err == GGUF_TDBASE_OK\n  1757\t        assert bad == 0\n  1758\t        assert starts == sorted(starts)\n  1759\t        for i in range(1, count):\n  1760\t            assert starts[i] >= ends[i - 1]\n  1761\t        assert sorted(sorted_idx) == list(range(count))\n  1762\t\n  1763\t\n  1764\tdef test_validate_sorted_tensor_index_happy_path() -> None:\n  1765\t    starts = [0x1000, 0x1040, 0x1080]\n  1766\t    ends = [0x1020, 0x1062, 0x1092]\n  1767\t    sorted_idx = [2, 0, 1]\n  1768\t\n  1769\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1770\t    assert err == GGUF_TDBASE_OK\n  1771\t    assert bad == 0\n  1772\t\n  1773\t\n  1774\tdef test_validate_sorted_tensor_index_empty_ok() -> None:\n  1775\t    err, bad = validate_sorted_tensor_index([], [], [])\n  1776\t    assert err == GGUF_TDBASE_OK\n  1777\t    assert bad == 0\n  1778\t\n  1779\t\n  1780\tdef test_validate_sorted_tensor_index_detects_overflow_range() -> None:\n  1781\t    starts = [0x1000, 0x1080]\n  1782\t    ends = [0x1020, 0x107F]\n  1783\t    sorted_idx = [0, 1]\n  1784\t\n  1785\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1786\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n  1787\t    assert bad == 1\n  1788\t\n  1789\t\n  1790\tdef test_validate_sorted_tensor_index_detects_unsorted_starts() -> None:\n  1791\t    starts = [0x1000, 0x1100, 0x1080]\n  1792\t    ends = [0x1020, 0x1120, 0x10A0]\n  1793\t    sorted_idx = [0, 1, 2]\n  1794\t\n  1795\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1796\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1797\t    assert bad == 2\n  1798\t\n  1799\t\n  1800\tdef test_validate_sorted_tensor_index_detects_overlap() -> None:\n  1801\t    starts = [0x1000, 0x1040]\n  1802\t    ends = [0x1060, 0x1080]\n  1803\t    sorted_idx = [0, 1]\n  1804\t\n  1805\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1806\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1807\t    assert bad == 1\n  1808\t\n  1809\t\n  1810\tdef test_validate_sorted_tensor_index_rejects_bad_mapped_index() -> None:\n  1811\t    starts = [0x1000, 0x1040, 0x1080]\n  1812\t    ends = [0x1020, 0x1060, 0x10A0]\n  1813\t    sorted_idx = [1, 3, 0]\n  1814\t\n  1815\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1816\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1817\t    assert bad == 1\n  1818\t\n  1819\t\n  1820\tdef test_validate_sorted_tensor_index_rejects_duplicate_mapped_index() -> None:\n  1821\t    starts = [0x1000, 0x1040, 0x1080]\n  1822\t    ends = [0x1020, 0x1060, 0x10A0]\n  1823\t    sorted_idx = [1, 0, 1]\n  1824\t\n  1825\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1826\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1827\t    assert bad == 2\n  1828\t\n  1829\t\n  1830\tdef test_validate_sorted_tensor_index_with_built_index() -> None:\n  1831\t    rel_offsets = [0xC0, 0x00, 0x40]\n  1832\t    elem_counts = [32, 64, 32]\n  1833\t    ggml_types = [GGML_TYPE_Q8_0, GGML_TYPE_Q4_0, GGML_TYPE_F16]\n  1834\t    starts = [0, 0, 0]\n  1835\t    ends = [0, 0, 0]\n  1836\t    sorted_idx = [0, 0, 0]\n  1837\t\n  1838\t    err, bad = tensor_info_build_offset_index(\n  1839\t        tensor_data_base=0x1000,\n  1840\t        alignment=32,\n  1841\t        gguf_file_nbytes=0x2000,\n  1842\t        tensor_rel_offsets=rel_offsets,\n  1843\t        tensor_element_counts=elem_counts,\n  1844\t        tensor_ggml_types=ggml_types,\n  1845\t        out_abs_starts=starts,\n  1846\t        out_abs_ends=ends,\n  1847\t        out_sorted_tensor_indices=sorted_idx,\n  1848\t    )\n  1849\t    assert err == GGUF_TDBASE_OK\n  1850\t    assert bad == 0\n  1851\t\n  1852\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1853\t    assert err == GGUF_TDBASE_OK\n  1854\t    assert bad == 0\n  1855\t\n  1856\t\n  1857\tdef test_validate_sorted_tensor_index_random_valid_permutations() -> None:\n  1858\t    rng = random.Random(764069)\n  1859\t\n  1860\t    for _ in range(300):\n  1861\t        count = rng.randint(1, 20)\n  1862\t        starts: list[int] = []\n  1863\t        ends: list[int] = []\n  1864\t        cursor = rng.randint(0, 32) * 32\n  1865\t        for _ in range(count):\n  1866\t            cursor += rng.randint(0, 4) * 32\n  1867\t            span = rng.randint(0, 6) * 32\n  1868\t            starts.append(cursor)\n  1869\t            ends.append(cursor + span)\n  1870\t            cursor += span\n  1871\t\n  1872\t        perm = list(range(count))\n  1873\t        rng.shuffle(perm)\n  1874\t\n  1875\t        err, bad = validate_sorted_tensor_index(starts, ends, perm)\n  1876\t        assert err == GGUF_TDBASE_OK\n  1877\t        assert bad == 0\n  1878\t\n  1879\t\n  1880\tdef test_validate_sorted_tensor_index_random_adversarial_mutations() -> None:\n  1881\t    rng = random.Random(764077)\n  1882\t\n  1883\t    for _ in range(240):\n  1884\t        count = rng.randint(3, 18)\n  1885\t        starts: list[int] = []\n  1886\t        ends: list[int] = []\n  1887\t        cursor = rng.randint(0, 32) * 32\n  1888\t        for _ in range(count):\n  1889\t            cursor += rng.randint(0, 3) * 32\n  1890\t            span = max(32, rng.randint(1, 6) * 32)\n  1891\t            starts.append(cursor)\n  1892\t            ends.append(cursor + span)\n  1893\t            cursor += span\n  1894\t\n  1895\t        sorted_idx = list(range(count))\n  1896\t       