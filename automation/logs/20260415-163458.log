3\t    {\n  1154\t        tensor_index = sorted_tensor_indices[i];\n  1155\t\n  1156\t        if (tensor_index >= tensor_count)\n  1157\t        {\n  1158\t            if (out_bad_index)\n  1159\t                *out_bad_index = i;\n  1160\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1161\t        }\n  1162\t\n  1163\t        if (out_sorted_position_by_tensor[tensor_index] != tensor_count)\n  1164\t        {\n  1165\t            if (out_bad_index)\n  1166\t                *out_bad_index = i;\n  1167\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1168\t        }\n  1169\t\n  1170\t        out_sorted_position_by_tensor[tensor_index] = i;\n  1171\t    }\n  1172\t\n  1173\t    // Confirm every original tensor index appeared exactly once.\n  1174\t    for (i = 0; i < tensor_count; ++i)\n  1175\t    {\n  1176\t        if (out_sorted_position_by_tensor[i] == tensor_count)\n  1177\t        {\n  1178\t            if (out_bad_index)\n  1179\t                *out_bad_index = i;\n  1180\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1181\t        }\n  1182\t    }\n  1183\t\n  1184\t    return GGUF_TDBASE_OK;\n  1185\t}\n  1186\t\n  1187\tI64 GGUFValidateSortedPositionMap(U64 tensor_count,\n  1188\t                                  U64 *sorted_tensor_indices,\n  1189\t                                  U64 *sorted_position_by_tensor,\n  1190\t                                  U64 *out_bad_index)\n  1191\t{\n  1192\t    U64 i;\n  1193\t    U64 j;\n  1194\t    U64 sorted_pos;\n  1195\t    U64 orig_idx;\n  1196\t\n  1197\t    if (!sorted_tensor_indices || !sorted_position_by_tensor)\n  1198\t        return GGUF_TDBASE_ERR_NULL_PTR;\n  1199\t\n  1200\t    if (out_bad_index)\n  1201\t        *out_bad_index = 0;\n  1202\t\n  1203\t    // Pass 1: validate original->sorted map bounds, enforce uniqueness,\n  1204\t    // and check round-trip consistency through sorted_tensor_indices.\n  1205\t    for (i = 0; i < tensor_count; ++i)\n  1206\t    {\n  1207\t        sorted_pos = sorted_position_by_tensor[i];\n  1208\t\n  1209\t        if (sorted_pos >= tensor_count)\n  1210\t        {\n  1211\t            if (out_bad_index)\n  1212\t                *out_bad_index = i;\n  1213\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1214\t        }\n  1215\t\n  1216\t        for (j = 0; j < i; ++j)\n  1217\t        {\n  1218\t            if (sorted_position_by_tensor[j] == sorted_pos)\n  1219\t            {\n  1220\t                if (out_bad_index)\n  1221\t                    *out_bad_index = i;\n  1222\t                return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1223\t            }\n  1224\t        }\n  1225\t\n  1226\t        if (sorted_tensor_indices[sorted_pos] != i)\n  1227\t        {\n  1228\t            if (out_bad_index)\n  1229\t                *out_bad_index = i;\n  1230\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1231\t        }\n  1232\t    }\n  1233\t\n  1234\t    // Pass 2: validate sorted->original entries are in-range and that\n  1235\t    // each sorted position points back to itself via inverse map.\n  1236\t    for (i = 0; i < tensor_count; ++i)\n  1237\t    {\n  1238\t        orig_idx = sorted_tensor_indices[i];\n  1239\t\n  1240\t        if (orig_idx >= tensor_count)\n  1241\t        {\n  1242\t            if (out_bad_index)\n  1243\t                *out_bad_index = i;\n  1244\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1245\t        }\n  1246\t\n  1247\t        if (sorted_position_by_tensor[orig_idx] != i)\n  1248\t        {\n  1249\t            if (out_bad_index)\n  1250\t                *out_bad_index = i;\n  1251\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n  1252\t        }\n  1253\t    }\n  1254\t\n  1255\t    return GGUF_TDBASE_OK;\n  1256\t}\n  1257\t\n  1258\tI64 GGUFTensorIndexToAbsRange(U64 tensor_index,\n  1259\t                              U64 tensor_count,\n  1260\t                              U64 *tensor_abs_starts,\n  1261\t                              U64 *tensor_abs_