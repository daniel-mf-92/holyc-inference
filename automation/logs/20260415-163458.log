offset,\n  1016\t                                               tensor_count,\n  1017\t                                               tensor_abs_starts,\n  1018\t                                               tensor_abs_ends,\n  1019\t                                               sorted_tensor_indices,\n  1020\t                                               out_tensor_index);\n  1021\t}\n  1022\t\n  1023\tI64 GGUFTensorRangeFindIndexByRelOffsetDefault(U64 tensor_rel_offset,\n  1024\t                                               U64 tensor_data_base,\n  1025\t                                               U64 tensor_count,\n  1026\t                                               U64 *tensor_abs_starts,\n  1027\t                                               U64 *tensor_abs_ends,\n  1028\t                                               U64 *sorted_tensor_indices,\n  1029\t                                               U64 *out_tensor_index)\n  1030\t{\n  1031\t    // Default GGUF tensor payload alignment when `general.alignment`\n  1032\t    // metadata is absent.\n  1033\t    return GGUFTensorRangeFindIndexByRelOffset(tensor_rel_offset,\n  1034\t                                               tensor_data_base,\n  1035\t                                               GGUF_DEFAULT_ALIGNMENT,\n  1036\t                                               tensor_count,\n  1037\t                                               tensor_abs_starts,\n  1038\t                                               tensor_abs_ends,\n  1039\t                                               sorted_tensor_indices,\n  1040\t                                               out_tensor_index);\n  1041\t}\n  1042\t\n  1043\tI64 GGUFValidateSortedTensorIndex(U64 tensor_count,\n  1044\t                                  U64 *tensor_abs_starts,\n  1045\t                                  U64 *tensor_abs_ends,\n  1046\t                                  U64 *sorted_tensor_indices,\n  1047\t                                  U64 *out_bad_index)\n  1048\t{\n  1049\t    U64 i;\n  1050\t    U64 j;\n  1051\t    U64 start_i;\n  1052\t    U64 end_i;\n  1053\t    U64 prev_start;\n  1054\t    U64 prev_end;\n  1055\t    U64 sorted_idx_i;\n  1056\t\n  1057\t    if (!tensor_abs_starts || !tensor_abs_ends || !sorted_tensor_indices)\n  1058\t        return GGUF_TDBASE_ERR_NULL_PTR;\n  1059\t\n  1060\t    if (out_bad_index)\n  1061\t        *out_bad_index = 0;\n  1062\t\n  1063\t    if (!tensor_count)\n  1064\t        return GGUF_TDBASE_OK;\n  1065\t\n  1066\t    for (i = 0; i < tensor_count; ++i)\n  1067\t    {\n  1068\t        start_i = tensor_abs_starts[i];\n  1069\t        end_i = tensor_abs_ends[i];\n  1070\t        sorted_idx_i = sorted_tensor_indices[i];\n  1071\t\n  1072\t        // Ranges are half-open [start,end). End before start means\n  1073\t        // malformed table arithmetic or corrupted caller memory.\n  1074\t        if (end_i < start_i)\n  1075\t        {\n  1076\t            if (out_bad_index)\n  1077\t                *out_bad_index = i;\n  1078\t            return GGUF_TDBASE_ERR_OVERFLOW;\n  1079\t        }\n  1080\t\n  1081\t        // Binary search helpers require starts to be non-decreasing.\n  1082\t        // We also reject overlapping ranges up-front.\n  1083\t        if (i)\n  1084\t        {\n  1085\t            prev_start = tensor_abs_starts[i - 1];\n  1086\t            prev_end = tensor_abs_ends[i - 1];\n  1087\t\n  1088\t            if (start_i < prev_start)\n  1089\t            {\n  1090\t                if (out_bad_index)\n  1091\t                    *out_bad_index = i;\n  1092\t                return GGUF_TDBASE_ERR_OVERLAP;\n  1093\t            }\n  1094\t\n  1095\t            if (start_i == prev_start && end_i < prev_end)\n  1096\t            {\n  1097\t                if (out_bad_index)\n  1098\t                    *out_bad_index = i;\n  1099\t                return GGUF_TDBASE_ERR_OVERLAP;\n  1100\t            }\n  1101\t\n  1102\t            if (star