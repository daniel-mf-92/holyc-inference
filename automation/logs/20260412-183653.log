 520\t    sorted_tensor_indices: list[int],\n   521\t):\n   522\t    return tensor_range_find_index_by_rel_offset(\n   523\t        tensor_rel_offset=tensor_rel_offset,\n   524\t        tensor_data_base=tensor_data_base,\n   525\t        alignment=GGUF_DEFAULT_ALIGNMENT,\n   526\t        tensor_abs_starts=tensor_abs_starts,\n   527\t        tensor_abs_ends=tensor_abs_ends,\n   528\t        sorted_tensor_indices=sorted_tensor_indices,\n   529\t    )\n   530\t\n   531\t\n   532\tdef validate_sorted_tensor_index(\n   533\t    tensor_abs_starts: list[int],\n   534\t    tensor_abs_ends: list[int],\n   535\t    sorted_tensor_indices: list[int],\n   536\t):\n   537\t    count = len(tensor_abs_starts)\n   538\t    if len(tensor_abs_ends) != count:\n   539\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   540\t    if len(sorted_tensor_indices) != count:\n   541\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   542\t\n   543\t    for i in range(count):\n   544\t        start_i = tensor_abs_starts[i]\n   545\t        end_i = tensor_abs_ends[i]\n   546\t        idx_i = sorted_tensor_indices[i]\n   547\t\n   548\t        if end_i < start_i:\n   549\t            return GGUF_TDBASE_ERR_OVERFLOW, i\n   550\t\n   551\t        if i > 0:\n   552\t            prev_start = tensor_abs_starts[i - 1]\n   553\t            prev_end = tensor_abs_ends[i - 1]\n   554\t\n   555\t            if start_i < prev_start:\n   556\t                return GGUF_TDBASE_ERR_OVERLAP, i\n   557\t            if start_i == prev_start and end_i < prev_end:\n   558\t                return GGUF_TDBASE_ERR_OVERLAP, i\n   559\t            if start_i < prev_end:\n   560\t                return GGUF_TDBASE_ERR_OVERLAP, i\n   561\t\n   562\t        if idx_i >= count:\n   563\t            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, i\n   564\t\n   565\t        for j in range(i):\n   566\t            if sorted_tensor_indices[j] == idx_i:\n   567\t                return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, i\n   568\t\n   569\t    return GGUF_TDBASE_OK, 0\n   570\t\n   571\t\n   572\tdef _abs_range_greater(\n   573\t    starts: list[int],\n   574\t    ends: list[int],\n   575\t    indices: list[int],\n   576\t    i: int,\n   577\t    j: int,\n   578\t) -> bool:\n   579\t    if starts[i] > starts[j]:\n   580\t        return True\n   581\t    if starts[i] < starts[j]:\n   582\t        return False\n   583\t    if ends[i] > ends[j]:\n   584\t        return True\n   585\t    if ends[i] < ends[j]:\n   586\t        return False\n   587\t    return indices[i] > indices[j]\n   588\t\n   589\t\n   590\tdef _abs_range_sift_down(\n   591\t    starts: list[int],\n   592\t    ends: list[int],\n   593\t    indices: list[int],\n   594\t    root: int,\n   595\t    end: int,\n   596\t) -> None:\n   597\t    while True:\n   598\t        child = root * 2 + 1\n   599\t        if child > end:\n   600\t            return\n   601\t\n   602\t        swap_idx = root\n   603\t        if _abs_range_greater(starts, ends, indices, child, swap_idx):\n   604\t            swap_idx = child\n   605\t        if child + 1 <= end and _abs_range_greater(starts, ends, indices, child + 1, swap_idx):\n   606\t            swap_idx = child + 1\n   607\t\n   608\t        if swap_idx == root:\n   609\t            return\n   610\t\n   611\t        starts[root], starts[swap_idx] = starts[swap_idx], starts[root]\n   612\t        ends[root], ends[swap_idx] = ends[swap_idx], ends[root]\n   613\t        indices[root], indices[swap_idx] = indices[swap_idx], indices[root]\n   614\t        root = swap_idx\n   615\t\n   616\t\n   617\tdef _sort_abs_ranges_with_indices(\n   618\t    starts: list[int],\n   619\t    ends: list[int],\n   620\t    indices: list[int],\n   621\t) -> None:\n   622\t    count = len(starts)\n   623\t    if count < 2:\n   624\t        return\n   625\t\n   626\t    start = ((count - 2) // 2) + 1\n   627\t    while start > 0:\n   628\t        start -= 1\n   629\t        _abs_range_sift_down(starts, ends, indices, start, count - 1)\n   630\t\n   631\t    end = count - 1\n   632\t    while end > 0:\n   633\t        starts[0], starts[end] = starts[end], starts[0]\n   634\t        ends[0], ends[end] = ends[end], ends[0]\n   635\t        indices[0], indices[end] = indices[end], indices[0]\n   636\t        end -= 1\n   637\t        _abs_range_sift_down(starts, ends, indices, 0, end)\n   638\t\n   639\t\n   640\tdef tensor_info_build_offset_index(\n   641\t    tensor_data_base: int,\n   642\t    alignment: int,\n   643\t    gguf_file_nbytes: int,\n   644\t    tensor_rel_offsets: list[int],\n   645\t    tensor_element_counts: list[int],\n   646\t    tensor_ggml_types: list[int],\n   647\t    out_abs_starts: list[int],\n   648\t    out_abs_ends: list[int],\n   649\t    out_sorted_tensor_indices: list[int],\n   650\t):\n   651\t    count = len(tensor_rel_offsets)\n   652\t\n   653\t    if len(tensor_element_counts) != count:\n   654\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   655\t    if len(tensor_ggml_types) != count:\n   656\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   657\t    if len(out_abs_starts) != count:\n   658\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   659\t    if len(out_abs_ends) != count:\n   660\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   661\t    if len(out_sorted_tensor_indices) != count:\n   662\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   663\t\n   664\t    for i in range(count):\n   665\t        err, nbytes = tensor_bytes_for_type(tensor_ggml_types[i], tensor_element_counts[i])\n   666\t        if err != GGUF_TDBASE_OK:\n   667\t            return err, i\n   668\t\n   669\t        err, abs_start, abs_end = tensor_resolve_range(\n   670\t            tensor_data_base=tensor_data_base,\n   671\t            tensor_rel_offset=tensor_rel_offsets[i],\n   672\t            tensor_nbytes=nbytes,\n   673\t            gguf_file_nbytes=gguf_file_nbytes,\n   674\t            alignment=alignment,\n   675\t        )\n   676\t        if err != GGUF_TDBASE_OK:\n   677\t            return err, i\n   678\t\n   679\t        out_abs_starts[i] = abs_start\n   680\t        out_abs_ends[i] = abs_end\n   681\t        out_sorted_tensor_indices[i] = i\n   682\t\n   683\t    if count < 2:\n   684\t        return GGUF_TDBASE_OK, 0\n   685\t\n   686\t    _sort_abs_ranges_with_indices(out_abs_starts, out_abs_ends, out_sorted_tensor_indices)\n   687\t\n   688\t    max_end = out_abs_ends[0]\n   689\t    for i in range(1, count):\n   690\t        if out_abs_ends[i] < out_abs_starts[i]:\n   691\t            return GGUF_TDBASE_ERR_OVERFLOW, out_sorted_tensor_indices[i]\n   692\t        if out_abs_starts[i] < max_end:\n   693\t            return GGUF_TDBASE_ERR_OVERLAP, out_sorted_tensor_indices[i]\n   694\t        if out_abs_ends[i] > max_end:\n   695\t            max_end = out_abs_ends[i]\n   696\t\n   697\t    return GGUF_TDBASE_OK, 0\n   698\t\n   699\t\n   700\t\n   701\t\n   702\tdef test_tensor_bytes_for_type_scalars() -> None:\n   703\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 0) == (GGUF_TDBASE_OK, 0)\n   704\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 7) == (GGUF_TDBASE_OK, 28)\n   705\t    assert tensor_bytes_for_type(GGML_TYPE_F16, 7) == (GGUF_TDBASE_OK, 14)\n   706\t\n   707\t\n   708\tdef test_tensor_bytes_for_type_quantized_exact_blocks() -> None:\n   709\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 32) == (GGUF_TDBASE_OK, 18)\n   710\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 64) == (GGUF_TDBASE_OK, 36)\n   711\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 32) == (GGUF_TDBASE_OK, 34)\n   712\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 96) == (GGUF_TDBASE_OK, 102)\n   713\t\n   714\t\n   715\tdef test_tensor_bytes_for_type_reject_non_multiple_block() -> None:\n   716\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 31) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   717\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 33) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   718\t\n   719\t\n   720\tdef test_tensor_bytes_for_type_reject_unknown_type() -> None:\n   721\t    assert tensor_bytes_for_type(999, 32) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   722\t\n   723\t\n   724\tdef test_tensor_bytes_for_type_overflow_guard() -> None:\n   725\t    q8_block = 32\n   726\t    q8_bytes = 34\n   727\t    max_blocks = U64_MAX // q8_bytes\n   728\t    ok_elements = max_blocks * q8_block\n   729\t    err, nbytes = tensor_bytes_for_type(GGML_TYPE_Q8_0, ok_elements)\n   730\t    assert err == GGUF_TDBASE_OK\n   731\t    assert nbytes == max_blocks * q8_bytes\n   732\t\n   733\t    overflow_elements = (max_blocks + 1) * q8_block\n   734\t    err, _ = tensor_bytes_for_type(GGML_TYPE_Q8_0, overflow_elements)\n   735\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   736\t\n   737\tdef test_default_alignment_examples() -> None:\n   738\t    assert tensor_data_base_align_default(0) == (GGUF_TDBASE_OK, 0)\n   739\t    assert tensor_data_base_align_default(1) == (GGUF_TDBASE_OK, 32)\n   740\t    assert tensor_data_base_align_default(31) == (GGUF_TDBASE_OK, 32)\n   741\t    assert tensor_data_base_align_default(32) == (GGUF_TDBASE_OK, 32)\n   742\t    assert tensor_data_base_align_default(33) == (GGUF_TDBASE_OK, 64)\n   743\t\n   744\t\n   745\tdef test_tensor_type_block_size_known_types() -> None:\n   746\t    assert tensor_type_block_size(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 1)\n   747\t    assert tensor_type_block_size(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 1)\n   748\t    assert tensor_type_block_size(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 32)\n   749\t    assert tensor_type_block_size(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 32)\n   750\t\n   751\t\n   752\tdef test_tensor_type_block_bytes_known_types() -> None:\n   753\t    assert tensor_type_block_bytes(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 4)\n   754\t    assert tensor_type_block_bytes(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 2)\n   755\t    assert tensor_type_block_bytes(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 18)\n   756\t    assert tensor_type_block_bytes(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 34)\n   757\t\n   758\t\n   759\tdef test_tensor_type_helpers_reject_unknown_type() -> None:\n   760\t    assert tensor_type_block_size(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n---\n  1500\t        tensor_rel_offsets=rel_offsets,\n  1501\t        tensor_element_counts=elem_counts,\n  1502\t        tensor_ggml_types=ggml_types,\n  1503\t        out_abs_starts=starts,\n  1504\t        out_abs_ends=ends,\n  1505\t        out_sorted_tensor_indices=sorted_idx,\n  1506\t    )\n  1507\t    assert err == GGUF_TDBASE_OK\n  1508\t    assert bad == 0\n  1509\t\n  1510\t    assert tensor_range_find_index_by_rel_offset(0x00, 0x1000, 32, starts, ends, sorted_idx) == (\n  1511\t        GGUF_TDBASE_OK,\n  1512\t        1,\n  1513\t    )\n  1514\t    assert tensor_range_find_index_by_rel_offset(0x40, 0x1000, 32, starts, ends, sorted_idx) == (\n  1515\t        GGUF_TDBASE_OK,\n  1516\t        2,\n  1517\t    )\n  1518\t    assert tensor_range_find_index_by_rel_offset(0xC0, 0x1000, 32, starts, ends, sorted_idx) == (\n  1519\t        GGUF_TDBASE_OK,\n  1520\t        0,\n  1521\t    )\n  1522\t\n  1523\t\n  1524\tdef test_tensor_range_find_index_by_rel_offset_default_happy_path() -> None:\n  1525\t    starts = [0x1000, 0x1040, 0x1080]\n  1526\t    ends = [0x1020, 0x1062, 0x1092]\n  1527\t    sorted_idx = [2, 0, 1]\n  1528\t\n  1529\t    assert tensor_range_find_index_by_rel_offset_default(0x00, 0x1000, starts, ends, sorted_idx) == (\n  1530\t        GGUF_TDBASE_OK,\n  1531\t        2,\n  1532\t    )\n  1533\t    assert tensor_range_find_index_by_rel_offset_default(0x40, 0x1000, starts, ends, sorted_idx) == (\n  1534\t        GGUF_TDBASE_OK,\n  1535\t        0,\n  1536\t    )\n  1537\t    assert tensor_range_find_index_by_rel_offset_default(0x80, 0x1000, starts, ends, sorted_idx) == (\n  1538\t        GGUF_TDBASE_OK,\n  1539\t        1,\n  1540\t    )\n  1541\t\n  1542\t\n  1543\tdef test_tensor_range_find_index_by_rel_offset_default_propagates_error() -> None:\n  1544\t    starts = [0x1000, 0x1040]\n  1545\t    ends = [0x1020, 0x1060]\n  1546\t    sorted_idx = [0, 1]\n  1547\t\n  1548\t    err, idx = tensor_range_find_index_by_rel_offset_default(0x48, 0x1000, starts, ends, sorted_idx)\n  1549\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n  1550\t    assert idx == 0\n  1551\t\n  1552\t\n  1553\tdef test_tensor_info_build_offset_index_happy_path() -> None:\n  1554\t    rel_offsets = [0xC0, 0x00, 0x40]\n  1555\t    elem_counts = [32, 64, 32]\n  1556\t    ggml_types = [GGML_TYPE_Q8_0, GGML_TYPE_Q4_0, GGML_TYPE_F16]\n  1557\t    starts = [0, 0, 0]\n  1558\t    ends = [0, 0, 0]\n  1559\t    sorted_idx = [0, 0, 0]\n  1560\t\n  1561\t    err, bad = tensor_info_build_offset_index(\n  1562\t        tensor_data_base=0x1000,\n  1563\t        alignment=32,\n  1564\t        gguf_file_nbytes=0x2000,\n  1565\t        tensor_rel_offsets=rel_offsets,\n  1566\t        tensor_element_counts=elem_counts,\n  1567\t        tensor_ggml_types=ggml_types,\n  1568\t        out_abs_starts=starts,\n  1569\t        out_abs_ends=ends,\n  1570\t        out_sorted_tensor_indices=sorted_idx,\n  1571\t    )\n  1572\t    assert err == GGUF_TDBASE_OK\n  1573\t    assert bad == 0\n  1574\t    assert starts == [0x1000, 0x1040, 0x10C0]\n  1575\t    assert ends == [0x1024, 0x1080, 0x10E2]\n  1576\t    assert sorted_idx == [1, 2, 0]\n  1577\t\n  1578\t\n  1579\tdef test_tensor_info_build_offset_index_propagates_bad_block_multiple() -> None:\n  1580\t    starts = [0, 0]\n  1581\t    ends = [0, 0]\n  1582\t    sorted_idx = [0, 0]\n  1583\t\n  1584\t    err, bad = tensor_info_build_offset_index(\n  1585\t        tensor_data_base=0x1000,\n  1586\t        alignment=32,\n  1587\t        gguf_file_nbytes=0x3000,\n  1588\t        tensor_rel_offsets=[0x00, 0x40],\n  1589\t        tensor_element_counts=[31, 32],\n  1590\t        tensor_ggml_types=[GGML_TYPE_Q4_0, GGML_TYPE_Q8_0],\n  1591\t        out_abs_starts=starts,\n  1592\t        out_abs_ends=ends,\n  1593\t        out_sorted_tensor_indices=sorted_idx,\n  1594\t    )\n  1595\t    assert err == GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE\n  1596\t    assert bad == 0\n  1597\t\n  1598\t\n  1599\tdef test_tensor_info_build_offset_index_detects_overlap() -> None:\n  1600\t    starts = [0, 0]\n  1601\t    ends = [0, 0]\n  1602\t    sorted_idx = [0, 0]\n  1603\t\n  1604\t    err, bad = tensor_info_build_offset_index(\n  1605\t        tensor_data_base=0x1000,\n  1606\t        alignment=32,\n  1607\t        gguf_file_nbytes=0x3000,\n  1608\t        tensor_rel_offsets=[0x00, 0x20],\n  1609\t        tensor_element_counts=[32, 32],\n  1610\t        tensor_ggml_types=[GGML_TYPE_Q8_0, GGML_TYPE_Q8_0],\n  1611\t        out_abs_starts=starts,\n  1612\t        out_abs_ends=ends,\n  1613\t        out_sorted_tensor_indices=sorted_idx,\n  1614\t    )\n  1615\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1616\t    assert bad == 1\n  1617\t\n  1618\t\n  1619\tdef test_tensor_info_build_offset_index_random_non_overlapping() -> None:\n  1620\t    rng = random.Random(764021)\n  1621\t\n  1622\t    for _ in range(200):\n  1623\t        count = rng.randint(1, 12)\n  1624\t        rel_offsets: list[int] = []\n  1625\t        elem_counts: list[int] = []\n  1626\t        ggml_types: list[int] = []\n  1627\t\n  1628\t        cursor = 0\n  1629\t        for _ in range(count):\n  1630\t            gap_units = rng.randint(0, 4)\n  1631\t            cursor += gap_units * 32\n  1632\t\n  1633\t            ggml_type = rng.choice([GGML_TYPE_Q4_0, GGML_TYPE_Q8_0, GGML_TYPE_F16, GGML_TYPE_F32])\n  1634\t            if ggml_type in (GGML_TYPE_Q4_0, GGML_TYPE_Q8_0):\n  1635\t                blocks = rng.randint(1, 4)\n  1636\t                elem_count = blocks * 32\n  1637\t            else:\n  1638\t                elem_count = rng.randint(1, 128)\n  1639\t\n  1640\t            err, nbytes = tensor_bytes_for_type(ggml_type, elem_count)\n  1641\t            assert err == GGUF_TDBASE_OK\n  1642\t\n  1643\t            rel_offsets.append(cursor)\n  1644\t            elem_counts.append(elem_count)\n  1645\t            ggml_types.append(ggml_type)\n  1646\t\n  1647\t            span_units = (nbytes + 31) // 32\n  1648\t            cursor += span_units * 32\n  1649\t\n  1650\t        starts = [0] * count\n  1651\t        ends = [0] * count\n  1652\t        sorted_idx = [0] * count\n  1653\t        file_nbytes = 0x1000 + cursor + 0x100\n  1654\t\n  1655\t        err, bad = tensor_info_build_offset_index(\n  1656\t            tensor_data_base=0x1000,\n  1657\t            alignment=32,\n  1658\t            gguf_file_nbytes=file_nbytes,\n  1659\t            tensor_rel_offsets=rel_offsets,\n  1660\t            tensor_element_counts=elem_counts,\n  1661\t            tensor_ggml_types=ggml_types,\n  1662\t            out_abs_starts=starts,\n  1663\t            out_abs_ends=ends,\n  1664\t            out_sorted_tensor_indices=sorted_idx,\n  1665\t        )\n  1666\t        assert err == GGUF_TDBASE_OK\n  1667\t        assert bad == 0\n  1668\t        assert starts == sorted(starts)\n  1669\t        for i in range(1, count):\n  1670\t            assert starts[i] >= ends[i - 1]\n  1671\t        assert sorted(sorted_idx) == list(range(count))\n  1672\t\n  1673\t\n  1674\tdef test_validate_sorted_tensor_index_happy_path() -> None:\n  1675\t    starts = [0x1000, 0x1040, 0x1080]\n  1676\t    ends = [0x1020, 0x1062, 0x1092]\n  1677\t    sorted_idx = [2, 0, 1]\n  1678\t\n  1679\t    err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1680\t    assert err == GGUF_TDBASE_OK\n  1681\t    assert bad == 0\n  1682\t\n  1683\t\n  1684\tdef test_validate_sorted_tensor_index_empty_ok() -> None:\n  1685\t    err, bad = validate_sorted_tensor_index([], [], [])\n  1686\t    assert err == GGUF_TDBASE_OK\n  1687\t    assert bad == 0\n  1688\t\n  1689\t\n  1690\tdef test_validate_sorted_tensor_index_detects_overflow_range() -> None:\n  1691\t    starts = [0x1000, 0x1080]\n  1692\t    ends = [0x1020, 0x