2   4\n    39\t#define GGML_TYPE_SIZE_F16   2\n    40\t#define GGML_TYPE_SIZE_Q4_0  18\n    41\t#define GGML_TYPE_SIZE_Q8_0  34\n    42\t\n    43\tI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n    44\t{\n    45\t    if (!out_block_size)\n    46\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    47\t\n    48\t    switch (ggml_type)\n    49\t    {\n    50\t        case GGML_TYPE_F32:\n    51\t            *out_block_size = GGML_BLCK_SIZE_F32;\n    52\t            return GGUF_TDBASE_OK;\n    53\t        case GGML_TYPE_F16:\n    54\t            *out_block_size = GGML_BLCK_SIZE_F16;\n    55\t            return GGUF_TDBASE_OK;\n    56\t        case GGML_TYPE_Q4_0:\n    57\t            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n    58\t            return GGUF_TDBASE_OK;\n    59\t        case GGML_TYPE_Q8_0:\n    60\t            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n    61\t            return GGUF_TDBASE_OK;\n    62\t    }\n    63\t\n    64\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    65\t}\n    66\t\n    67\tI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n    68\t{\n    69\t    if (!out_block_bytes)\n    70\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    71\t\n    72\t    switch (ggml_type)\n    73\t    {\n    74\t        case GGML_TYPE_F32:\n    75\t            *out_block_bytes = GGML_TYPE_SIZE_F32;\n    76\t            return GGUF_TDBASE_OK;\n    77\t        case GGML_TYPE_F16:\n    78\t            *out_block_bytes = GGML_TYPE_SIZE_F16;\n    79\t            return GGUF_TDBASE_OK;\n    80\t        case GGML_TYPE_Q4_0:\n    81\t            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n    82\t            return GGUF_TDBASE_OK;\n    83\t        case GGML_TYPE_Q8_0:\n    84\t            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n    85\t            return GGUF_TDBASE_OK;\n    86\t    }\n    87\t\n    88\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    89\t}\n    90\t\n    91\tI64 GGUFTensorBytesForType(U32 ggml_type,\n    92\t                           U64 el