\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   200\t\n   201\t    // Both base and relative tensor offsets must preserve GGUF alignment.\n   202\t    // Enforcing this here keeps every downstream payload read auditable.\n   203\t    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n   204\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n   205\t    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n   206\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n   207\t\n   208\t    // Absolute payload pointer is base + relative offset.\n   209\t    // Keep overflow check explicit for malformed large files.\n   210\t    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n   211\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   212\t\n   213\t    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n   214\t    return GGUF_TDBASE_OK;\n   215\t}\n   216\t\n   217\tI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n   218\t                                    U64 tensor_rel_offset,\n   219\t                                    U64 *out_tensor_abs)\n   220\t{\n   221\t    return GGUFTensorDataBaseOffset(tensor_data_base,\n   222\t                                    tensor_rel_offset,\n   223\t                                    GGUF_DEFAULT_ALIGNMENT,\n   224\t                                    out_tensor_abs);\n   225\t}\n   226\t\n   227\tI64 GGUFTensorResolveRange(U64 tensor_data_base,\n   228\t                           U64 tensor_rel_offset,\n   229\t                           U64 tensor_nbytes,\n   230\t                           U64 gguf_file_nbytes,\n   231\t                           U32 alignment,\n   232\t                           U64 *out_tensor_abs_start,\n   233\t                           U64 *out_tensor_abs_end)\n   234\t{\n   235\t    U64 abs_start;\n   236\t    U64 abs_end;\n   237\t    I64 err;\n   238\t\n   239\t    if (!out_tensor_abs_start || !out_tensor_abs_end)\n   240\t        return GGUF_TD