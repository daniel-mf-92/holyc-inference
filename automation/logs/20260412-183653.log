   101\t\n   102\tdef tensor_data_base_is_aligned(offset: int, alignment: int) -> bool:\n   103\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n   104\t        return False\n   105\t    return (offset & (alignment - 1)) == 0\n   106\t\n   107\t\n   108\tdef tensor_data_base_offset(tensor_data_base: int, tensor_rel_offset: int, alignment: int):\n   109\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n   110\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT, 0\n   111\t    if not tensor_data_base_is_aligned(tensor_data_base, alignment):\n   112\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE, 0\n   113\t    if not tensor_data_base_is_aligned(tensor_rel_offset, alignment):\n   114\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET, 0\n   115\t    if tensor_data_base > U64_MAX - tensor_rel_offset:\n   116\t        return GGUF_TDBASE_ERR_OVERFLOW, 0\n   117\t    return GGUF_TDBASE_OK, tensor_data_base + tensor_rel_offset\n   118\t\n   119\t\n   120\tdef tensor_data_base_offset_default(tensor_data_base: int, tensor_rel_offset: int):\n   121\t    return tensor_data_base_offset(tensor_data_base, tensor_rel_offset, GGUF_DEFAULT_ALIGNMENT)\n   122\t\n   123\t\n   124\tdef tensor_resolve_range(\n   125\t    tensor_data_base: int,\n   126\t    tensor_rel_offset: int,\n   127\t    tensor_nbytes: int,\n   128\t    gguf_file_nbytes: int,\n   129\t    alignment: int,\n   130\t):\n   131\t    err, abs_start = tensor_data_base_offset(tensor_data_base, tensor_rel_offset, alignment)\n   132\t    if err != GGUF_TDBASE_OK:\n   133\t        return err, 0, 0\n   134\t\n   135\t    if abs_start > U64_MAX - tensor_nbytes:\n   136\t        return GGUF_TDBASE_ERR_OVERFLOW, 0, 0\n   137\t\n   138\t    abs_end = abs_start + tensor_nbytes\n   139\t    if abs_end > gguf_file_nbytes:\n   140\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0\n   141\t\n   142\t    return GGUF_TDBASE_OK, abs_start, abs_end\n   143\t\n   144\t\n   145\tdef tensor_resolve_range_default(\n   146\t