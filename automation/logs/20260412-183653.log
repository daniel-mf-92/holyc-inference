{"type":"item.completed","item":{"id":"item_43","type":"command_execution","command":"/bin/zsh -lc \"echo 'Reviewing current GGUF parser constants for doc parity.'; sed -n '1,260p' src/gguf/header.HC; echo '---'; sed -n '1,320p' src/gguf/metadata.HC; echo '---'; sed -n '1,320p' src/gguf/tensorinfo.HC; echo '---'; sed -n '1,360p' src/gguf/tensor_data_base.HC\"","aggregated_output":"// tensorinfo.HC\n// GGUF tensor info table parser for HolyC inference runtime.\n\n#define GGUF_TENSOR_PARSE_OK 0\n#define GGUF_TENSOR_PARSE_ERR_NULL_PTR 1\n#define GGUF_TENSOR_PARSE_ERR_TRUNCATED 2\n#define GGUF_TENSOR_PARSE_ERR_BAD_COUNT 3\n#define GGUF_TENSOR_PARSE_ERR_BAD_NAME_LEN 4\n#define GGUF_TENSOR_PARSE_ERR_BAD_DIMS 5\n#define GGUF_TENSOR_PARSE_ERR_BAD_DIM_SIZE 6\n#define GGUF_TENSOR_PARSE_ERR_DIM_OVERFLOW 7\n#define GGUF_TENSOR_PARSE_ERR_BAD_TYPE 8\n#define GGUF_TENSOR_PARSE_ERR_ALLOC 9\n\n#define GGUF_TENSOR_MAX_COUNT     (1 << 20)\n#define GGUF_TENSOR_MAX_NAME_BYTES (1 << 20)\n#define GGUF_TENSOR_MAX_DIMS      8\n\n// Common ggml tensor types used in GGUF today. Parser is strict so bad type tags\n// are rejected early and never reach tensor byte-loader math.\n#define GGML_TYPE_F32   0\n#define GGML_TYPE_F16   1\n#define GGML_TYPE_Q4_0  2\n#define GGML_TYPE_Q4_1  3\n#define GGML_TYPE_Q5_0  6\n#define GGML_TYPE_Q5_1  7\n#define GGML_TYPE_Q8_0  8\n#define GGML_TYPE_Q8_1  9\n#define GGML_TYPE_Q2_K  10\n#define GGML_TYPE_Q3_K  11\n#define GGML_TYPE_Q4_K  12\n#define GGML_TYPE_Q5_K  13\n#define GGML_TYPE_Q6_K  14\n#define GGML_TYPE_Q8_K  15\n#define GGML_TYPE_IQ2_XXS 16\n#define GGML_TYPE_IQ2_XS  17\n#define GGML_TYPE_IQ3_XXS 18\n#define GGML_TYPE_IQ1_S   19\n#define GGML_TYPE_IQ4_NL  20\n#define GGML_TYPE_IQ3_S   21\n#define GGML_TYPE_IQ2_S   22\n#define GGML_TYPE_IQ4_XS  23\n#define GGML_TYPE_I8    24\n#define GGML_TYPE_I16   25\n#define GGML_TYPE_I32   26\n#define GGML_TYPE_I64   27\n#define GGML_TYPE_F64   28\n#define GGML_TYPE_IQ1_M 29\n#define GGML_TYPE_BF16  30\n#define GGML_TYPE_Q4_0_4_4 31\n#define GGML_TYPE_Q4_0_4_8 32\n#define GGML_TYPE_Q4_0_8_8 33\n#define GGML_TYPE_TQ1_0 34\n#define GGML_TYPE_TQ2_0 35\n\nclass GGUFTensorString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFTensorInfo\n{\n    GGUFTensorString name;\n\n    U32 n_dims;\n    U64 dims[GGUF_TENSOR_MAX_DIMS];\n    U64 n_elements;\n\n    U32 ggml_type;\n    U64 offset;\n};\n\nclass GGUFTensorTable\n{\n    U64 count;\n    GGUFTensorInfo *items;\n};\n\nBool GGUFTensorCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n{\n    if (!buf)\n        return FALSE;\n    if (size < 0 || cursor < 0 || need < 0)\n        return FALSE;\n    if (cursor > size)\n        return FALSE;\n    if (need > size - cursor)\n        return FALSE;\n    return TRUE;\n}\n\nBool GGUFTensorReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFTensorCanRead(buf, size, c, 4))\n        return FALSE;\n\n    *out = (U32)buf[c]\n         | ((U32)buf[c + 1] << 8)\n         | ((U32)buf[c + 2] << 16)\n         | ((U32)buf[c + 3] << 24);\n\n    *cursor = c + 4;\n    return TRUE;\n}\n\nBool GGUFTensorReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n{\n    I64 c;\n\n    if (!cursor || !out)\n        return FALSE;\n\n    c = *cursor;\n    if (!GGUFTensorCanRead(buf, size, c, 8))\n        return FALSE;\n\n    *out = (U64)buf[c]\n         | ((U64)buf[c + 1] << 8)\n         | ((U64)buf[c + 2] << 16)\n         | ((U64)buf[c + 3] << 24)\n         | ((U64)buf[c + 4] << 32)\n         | ((U64)buf[c + 5] << 40)\n         | ((U64)buf[c + 6] << 48)\n         | ((U64)buf[c + 7] << 56);\n\n    *cursor = c + 8;\n    return TRUE;\n}\n\nBool GGUFTensorTypeKnown(U32 t)\n{\n    switch (t)\n    {\n        case GGML_TYPE_F32:\n        case GGML_TYPE_F16:\n        case GGML_TYPE_Q4_0:\n        case GGML_TYPE_Q4_1:\n        case GGML_TYPE_Q5_0:\n        case GGML_TYPE_Q5_1:\n        case GGML_TYPE_Q8_0:\n        case GGML_TYPE_Q8_1:\n        case GGML_TYPE_Q2_K:\n        case GGML_TYPE_Q3_K:\n        case GGML_TYPE_Q4_K:\n        case GGML_TYPE_Q5_K:\n        case GGML_TYPE_Q6_K:\n        case GGML_TYPE_Q8_K:\n        case GGML_TYPE_IQ2_XXS:\n        case GGML_TYPE_IQ2_XS:\n        case GGML_TYPE_IQ3_XXS:\n        case GGML_TYPE_IQ1_S:\n        case GGML_TYPE_IQ4_NL:\n        case GGML_TYPE_IQ3_S:\n        case GGML_TYPE_IQ2_S:\n        case GGML_TYPE_IQ4_XS:\n        case GGML_TYPE_I8:\n        case GGML_TYPE_I16:\n        case GGML_TYPE_I32:\n        case GGML_TYPE_I64:\n        case GGML_TYPE_F64:\n        case GGML_TYPE_IQ1_M:\n        case GGML_TYPE_BF16:\n        case GGML_TYPE_Q4_0_4_4:\n        case GGML_TYPE_Q4_0_4_8:\n        case GGML_TYPE_Q4_0_8_8:\n        case GGML_TYPE_TQ1_0:\n        case GGML_TYPE_TQ2_0:\n            return TRUE;\n    }\n\n    return FALSE;\n}\n\nU0 GGUFTensorZeroString(GGUFTensorString *s)\n{\n    if (!s)\n        return;\n    s->len = 0;\n    s->data = NULL;\n}\n\nU0 GGUFTensorZeroInfo(GGUFTensorInfo *ti)\n{\n    I64 i;\n\n    if (!ti)\n        return;\n\n    GGUFTensorZeroString(&ti->name);\n    ti->n_dims = 0;\n    for (i = 0; i < GGUF_TENSOR_MAX_DIMS; ++i)\n        ti->dims[i] = 0;\n    ti->n_elements = 0;\n    ti->ggml_type = 0;\n    ti->offset = 0;\n}\n\nU0 GGUFTensorFreeString(GGUFTensorString *s)\n{\n    if (!s)\n        return;\n\n    if (s->data)\n        Free(s->data);\n\n    s->data = NULL;\n    s->len = 0;\n}\n\nU0 GGUFFreeTensorTable(GGUFTensorTable *table)\n{\n    U64 i;\n\n    if (!table)\n        return;\n\n    if (!table->items)\n    {\n        table->count = 0;\n        return;\n    }\n\n    for (i = 0; i < table->count; ++i)\n        GGUFTensorFreeString(&table->items[i].name);\n\n    Free(table->items);\n    table->items = NULL;\n    table->count = 0;\n}\n\nI64 GGUFTensorReadString(U8 *buf, I64 size, I64 *cursor, GGUFTensorString *out)\n{\n    U64 len;\n    I64 c;\n    U8 *dst;\n    I64 i;\n\n    if (!cursor || !out)\n        return GGUF_TENSOR_PARSE_ERR_NULL_PTR;\n\n    GGUFTensorZeroString(out);\n\n    if (!GGUFTensorReadU64LE(buf, size, cursor, &len))\n        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n    if (len > GGUF_TENSOR_MAX_NAME_BYTES)\n        return GGUF_TENSOR_PARSE_ERR_BAD_NAME_LEN;\n\n    c = *cursor;\n    if (!GGUFTensorCanRead(buf, size, c, len))\n        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n\n    dst = MAlloc(len + 1);\n    if (!dst)\n        return GGUF_TENSOR_PARSE_ERR_ALLOC;\n\n    for (i = 0; i < len; ++i)\n        dst[i] = buf[c + i];\n    dst[len] = 0;\n\n    *cursor = c + len;\n\n    out->len = len;\n    out->data = dst;\n    return GGUF_TENSOR_PARSE_OK;\n}\n\nI64 GGUFTensorParseOne(U8 *buf, I64 size, I64 *cursor, GGUFTensorInfo *out)\n{\n    U32 n_dims;\n    U64 dim;\n    U64 prod;\n    U32 ggml_type;\n    U64 offset;\n    I64 err;\n    U32 i;\n\n    if (!cursor || !out)\n        return GGUF_TENSOR_PARSE_ERR_NULL_PTR;\n\n    GGUFTensorZeroInfo(out);\n\n    err = GGUFTensorReadString(buf, size, cursor, &out->name);\n    if (err != GGUF_TENSOR_PARSE_OK)\n        return err;\n\n    if (!GGUFTensorReadU32LE(buf, size, cursor, &n_dims))\n        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n    if (!n_dims || n_dims > GGUF_TENSOR_MAX_DIMS)\n        return GGUF_TENSOR_PARSE_ERR_BAD_DIMS;\n\n    // The tensor element count is the exact product of dims. Keep this explicit\n    // and overflow-checked so later offset math is auditable and safe.\n    prod = 1;\n    for (i = 0; i < n_dims; ++i)\n    {\n        if (!GGUFTensorReadU64LE(buf, size, cursor, &dim))\n            return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n        if (!dim)\n            return GGUF_TENSOR_PARSE_ERR_BAD_DIM_SIZE;\n        if (prod > 0xFFFFFFFFFFFFFFFF / dim)\n            return GGUF_TENSOR_PARSE_ERR_DIM_OVERFLOW;\n\n        out->dims[i] = dim;\n        prod *= dim;\n    }\n\n    if (!GGUFTensorReadU32LE(buf, size, cursor, &ggml_type))\n        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n    if (!GGUFTensorTypeKnown(ggml_type))\n        return GGUF_TENSOR_PARSE_ERR_BAD_TYPE;\n\n    if (!GGUFTensorReadU64LE(buf, size, cursor, &offset))\n        return GGUF_TENSOR_PARSE_ERR_TRUNCATED;\n---\n// tensor_data_base.HC\n// GGUF tensor-data base alignment helpers for HolyC inference runtime.\n\n#define GGUF_TDBASE_OK 0\n#define GGUF_TDBASE_ERR_NULL_PTR 1\n#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n#define GGUF_TDBASE_ERR_OVERFLOW 3\n#define GGUF_TDBASE_ERR_MISALIGNED_BASE 4\n#define GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET 5\n#define GGUF_TDBASE_ERR_BAD_TYPE 6\n#define GGUF_TDBASE_ERR_OUT_OF_BOUNDS 7\n#define GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE 8\n#define GGUF_TDBASE_ERR_OVERLAP 9\n\n// GGUF default tensor alignment when metadata key `general.alignment`\n// is absent.\n#define GGUF_DEFAULT_ALIGNMENT 32\n\n// Subset of ggml tensor types currently enabled in HolyC inference runtime.\n// Keep this list strict and explicit so sizing math never silently accepts\n// unknown quantization tags from malformed GGUF files.\n#define GGML_TYPE_F32   0\n#define GGML_TYPE_F16   1\n#define GGML_TYPE_Q4_0  2\n#define GGML_TYPE_Q8_0  8\n\n// GGML quantization blocks for runtime-critical formats:\n// - F32/F16 are scalar types (block size 1).\n// - Q4_0 and Q8_0 are packed in 32-element blocks.\n#define GGML_BLCK_SIZE_F32   1\n#define GGML_BLCK_SIZE_F16   1\n#define GGML_BLCK_SIZE_Q4_0  32\n#define GGML_BLCK_SIZE_Q8_0  32\n\n// Block payload byte widths from ggml struct layouts:\n// - Q4_0: fp16 scale (2 bytes) + 16 packed nibbles = 18 bytes.\n// - Q8_0: fp16 scale (2 bytes) + 32 signed bytes = 34 bytes.\n#define GGML_TYPE_SIZE_F32   4\n#define GGML_TYPE_SIZE_F16   2\n#define GGML_TYPE_SIZE_Q4_0  18\n#define GGML_TYPE_SIZE_Q8_0  34\n\nI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n{\n    if (!out_block_size)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    switch (ggml_type)\n    {\n        case GGML_TYPE_F32:\n            *out_block_size = GGML_BLCK_SIZE_F32;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_F16:\n            *out_block_size = GGML_BLCK_SIZE_F16;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q4_0:\n            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q8_0:\n            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n            return GGUF_TDBASE_OK;\n    }\n\n    return GGUF_TDBASE_ERR_BAD_TYPE;\n}\n\nI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n{\n    if (!out_block_bytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    switch (ggml_type)\n    {\n        case GGML_TYPE_F32:\n            *out_block_bytes = GGML_TYPE_SIZE_F32;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_F16:\n            *out_block_bytes = GGML_TYPE_SIZE_F16;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q4_0:\n            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q8_0:\n            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n            return GGUF_TDBASE_OK;\n    }\n\n    return GGUF_TDBASE_ERR_BAD_TYPE;\n}\n\nI64 GGUFTensorBytesForType(U32 ggml_type,\n                           U64 element_count,\n                           U64 *out_tensor_nbytes)\n{\n    U64 block_size;\n    U64 block_bytes;\n    U64 block_count;\n    I64 err;\n\n    if (!out_tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    err = GGUFTensorTypeBlockSize(ggml_type, &block_size);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    err = GGUFTensorTypeBlockBytes(ggml_type, &block_bytes);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // Quantized formats are stored in fixed-size element blocks.\n    // Reject non-multiples instead of silently rounding/truncating.\n    if (element_count % block_size)\n        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE;\n\n    block_count = element_count / block_size;\n\n    // Byte size = number of blocks * bytes per block.\n    // Guard overflow before multiplication for malformed giant tensors.\n    if (block_count > 0xFFFFFFFFFFFFFFFF / block_bytes)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out_tensor_nbytes = block_count * block_bytes;\n    return GGUF_TDBASE_OK;\n}\n\nBool GGUFIsPow2U32(U32 value)\n{\n    if (!value)\n        return FALSE;\n    return (value & (value - 1)) == 0;\n}\n\nI64 GGUFValidateAlignment(U32 alignment)\n{\n    if (!GGUFIsPow2U32(alignment))\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n{\n    U64 mask;\n\n    if (!out)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n\n    // For power-of-two alignments, align-up is:\n    //   (value + (alignment - 1)) & ~(alignment - 1)\n    // Keep overflow checks explicit so giant malformed offsets are rejected.\n    mask = (U64)alignment - 1;\n    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out = (value + mask) & ~mask;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n                            U32 alignment,\n                            U64 *out_tensor_data_base)\n{\n    return GGUFAlignUpU64(cursor_after_tensor_info,\n                          alignment,\n                          out_tensor_data_base);\n}\n\nI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n                                   U64 *out_tensor_data_base)\n{\n    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n                                   GGUF_DEFAULT_ALIGNMENT,\n                                   out_tensor_data_base);\n}\n\nBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n{\n    U64 mask;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return FALSE;\n\n    mask = (U64)alignment - 1;\n    return (offset & mask) == 0;\n}\n\nI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n                             U64 tensor_rel_offset,\n                             U32 alignment,\n                             U64 *out_tensor_abs)\n{\n    if (!out_tensor_abs)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n\n    // Both base and relative tensor offsets must preserve GGUF alignment.\n    // Enforcing this here keeps every downstream payload read auditable.\n    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n\n    // Absolute payload pointer is base + relative offset.\n    // Keep overflow check explicit for malformed large files.\n    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n                                    U64 tensor_rel_offset,\n                                    U64 *out_tensor_abs)\n{\n    return GGUFTensorDataBaseOffset(tensor_data_base,\n                                    tensor_rel_offset,\n                                    GGUF_DEFAULT_ALIGNMENT,\n                                    out_tensor_abs);\n}\n\nI64 GGUFTensorResolveRange(U64 tensor_data_base,\n                           U64 tensor_rel_offset,\n                           U64 tensor_nbytes,\n                           U64 gguf_file_nbytes,\n                           U32 alignment,\n                           U64 *out_tensor_abs_start,\n                           U64 *out_tensor_abs_end)\n{\n    U64 abs_start;\n    U64 abs_end;\n    I64 err;\n\n    if (!out_tensor_abs_start || !out_tensor_abs_end)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    // Resolve and validate the absolute tensor start offset first.\n    err = GGUFTensorDataBaseOffset(tensor_data_base,\n                                   tensor_rel_offset,\n                                   alignment,\n                                   &abs_start);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // Tensor byte-range is [abs_start, abs_start + tensor_nbytes).\n    // Guard add overflow before constructing the exclusive end.\n    if (abs_start > 0xFFFFFFFFFFFFFFFF - tensor_nbytes)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n    abs_end = abs_start + tensor_nbytes;\n\n    // Reject ranges that run past the file boundary.\n    // A tensor may legally end exactly at gguf_file_nbytes.\n    if (abs_end > gguf_file_nbytes)\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n\n    *out_tensor_abs_start = abs_start;\n    *out_tensor_abs_end   = abs_end;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorResolveRangeDefault(U64 tensor_data_base,\n                                  U64 tensor_rel_offset,\n                                  U64 tensor_nbytes,\n                                  U64 gguf_file_nbytes,\n                                  U64 *out_tensor_abs_start,\n                                  U64 *out_tensor_abs_end)\n{\n    return GGUFTensorResolveRange(tensor_data_base,\n                                  tensor_rel_offset,\n                                  tensor_nbytes,\n                                  gguf_file_nbytes,\n                                  GGUF_DEFAULT_ALIGNMENT,\n                                  out_tensor_abs_start,\n                                  out_tensor_abs_end);\n}\n\nI64 GGUFValidateTensorRanges(U64 tensor_data_base,\n                             U32 alignment,\n                             U64 gguf_file_nbytes,\n                             U64 tensor_count,\n                             U64 *tensor_rel_offsets,\n                             U64 *tensor_nbytes,\n                             U64 *out_bad_index)\n{\n    U64 i;\n    U64 j;\n    U64 start_i;\n    U64 end_i;\n    U64 start_j;\n    U64 end_j;\n    I64 err;\n\n    if (!tensor_rel_offsets || !tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (out_bad_index)\n        *out_bad_index = 0;\n\n    // Pass 1: each tensor range must be individually valid.\n    // This enforces aligned offsets, add-overflow safety, and EOF bounds.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorResolveRange(tensor_data_base,\n                                     tensor_rel_offsets[i],\n                                     tensor_nbytes[i],\n                                     gguf_file_nbytes,\n                                     alignment,\n                                     &start_i,\n                                     &end_i);\n        if (err != GGUF_TDBASE_OK)\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return err;\n        }\n    }\n\n    // Pass 2: pairwise overlap check.\n    // Explicit O(n^2) keeps logic simple and fully auditable in HolyC.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorResolveRange(tensor_data_base,\n                                     tensor_rel_offsets[i],\n                                     tensor_nbytes[i],\n                                     gguf_file_nbytes,\n                                     alignment,\n                                     &start_i,\n                                     &end_i);\n        if (err != GGUF_TDBASE_OK)\n            return err;\n\n        for (j = i + 1; j < tensor_count; ++j)\n        {\n            err = GGUFTensorResolveRange(tensor_data_base,\n                                         tensor_rel_offsets[j],\n                                         tensor_nbytes[j],\n                                         gguf_file_nbytes,\n                                         alignment,\n                                         &start_j,\n                                         &end_j);\n            if (err != GGUF_TDBASE_OK)\n                return err;\n\n            // Half-open intervals [start, end) overlap when each interval starts\n            // before the other ends. Exact touching boundaries are legal.\n            if ((start_i < end_j) && (start_j < end_i))\n            {\n                if (out_bad_index)\n                    *out_bad_index = j;\n                return GGUF_TDBASE_ERR_OVERLAP;\n            }\n        }\n    }\n\n    return GGUF_TDBASE_OK;\n","exit_code":0,"status":"completed"}}
