R, 0\n   661\t    if len(out_sorted_tensor_indices) != count:\n   662\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   663\t\n   664\t    for i in range(count):\n   665\t        err, nbytes = tensor_bytes_for_type(tensor_ggml_types[i], tensor_element_counts[i])\n   666\t        if err != GGUF_TDBASE_OK:\n   667\t            return err, i\n   668\t\n   669\t        err, abs_start, abs_end = tensor_resolve_range(\n   670\t            tensor_data_base=tensor_data_base,\n   671\t            tensor_rel_offset=tensor_rel_offsets[i],\n   672\t            tensor_nbytes=nbytes,\n   673\t            gguf_file_nbytes=gguf_file_nbytes,\n   674\t            alignment=alignment,\n   675\t        )\n   676\t        if err != GGUF_TDBASE_OK:\n   677\t            return err, i\n   678\t\n   679\t        out_abs_starts[i] = abs_start\n   680\t        out_abs_ends[i] = abs_end\n   681\t        out_sorted_tensor_indices[i] = i\n   682\t\n   683\t    if count < 2:\n   684\t        return GGUF_TDBASE_OK, 0\n   685\t\n   686\t    _sort_abs_ranges_with_indices(out_abs_starts, out_abs_ends, out_sorted_tensor_indices)\n   687\t\n   688\t    max_end = out_abs_ends[0]\n   689\t    for i in range(1, count):\n   690\t        if out_abs_ends[i] < out_abs_starts[i]:\n   691\t            return GGUF_TDBASE_ERR_OVERFLOW, out_sorted_tensor_indices[i]\n   692\t        if out_abs_starts[i] < max_end:\n   693\t            return GGUF_TDBASE_ERR_OVERLAP, out_sorted_tensor_indices[i]\n   694\t        if out_abs_ends[i] > max_end:\n   695\t            max_end = out_abs_ends[i]\n   696\t\n   697\t    return GGUF_TDBASE_OK, 0\n   698\t\n   699\t\n   700\t\n   701\t\n   702\tdef test_tensor_bytes_for_type_scalars() -> None:\n   703\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 0) == (GGUF_TDBASE_OK, 0)\n   704\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 7) == (GGUF_TDBASE_OK, 28)\n   705\t    assert tensor_bytes_for_type(GGML_TYPE_F16, 7) == (GGUF_TDBASE_OK, 14)\n   706\t\n   707\t\n   708\tdef test_tensor_bytes_for_type_quantized_exact_blocks() -> None:\n   709\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 32) == (GGUF_TDBASE_OK, 18)\n   710\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 64) == (GGUF_TDBASE_OK, 36)\n   711\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 32) == (GGUF_TDBASE_OK, 34)\n   712\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 96) == (GGUF_TDBASE_OK, 102)\n   713\t\n   714\t\n   715\tdef test_tensor_bytes_for_type_reject_non_multiple_block() -> None:\n   716\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 31) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   717\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 33) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   718\t\n   719\t\n   720\tdef test_tensor_bytes_for_type_reject_unknown_type() -> None:\n   721\t    assert tensor_bytes_for_type(999, 32) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   722\t\n   723\t\n   724\tdef test_tensor_bytes_for_type_overflow_guard() -> None:\n   725\t    q8_block = 32\n   726\t    q8_bytes = 34\n   727\t    max_blocks = U64_MAX // q8_bytes\n   728\t    ok_elements = max_blocks * q8_block\n   729\t    err, nbytes = tensor_bytes_for_type(GGML_TYPE_Q8_0, ok_elements)\n   730\t    assert err == GGUF_TDBASE_OK\n   731\t    assert nbytes == max_blocks * q8_bytes\n   732\t\n   733\t    overflow_elements = (max_blocks + 1) * q8_block\n   734\t    err, _ = tensor_bytes_for_type(GGML_TYPE_Q8_0, overflow_elements)\n   735\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   736\t\n   737\tdef test_default_alignment_examples() -> None:\n   738\t    assert tensor_data_base_align_default(0) == (GGUF_TDBASE_OK, 0)\n   739\t    assert tensor_data_base_align_default(1) == (GGUF_TDBASE_OK, 32)\n   740\t    assert tensor_data_base_align_default(31) == (GGUF_TDBASE_OK, 32)\n   741\t    assert tensor_data_base_align_default(32) == (GGUF_TDBASE_OK, 32)\n   742\t    assert tensor_data_base_align_default(33) == (GGUF_TDBASE_OK, 64)\n   743\t\n   744\t\n   745\tdef test_tensor_type_block_size_known_types() -> None:\n   746\t    assert tensor_type_block_size(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 1)\n   747\t    assert tensor_type_block_size(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 1)\n   748\t    assert tensor_type_block_size(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 32)\n   749\t    assert tensor_type_block_size(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 32)\n   750\t\n   751\t\n   752\tdef test_tensor_type_block_bytes_known_types() -> None:\n   753\t    assert tensor_type_block_bytes(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 4)\n   754\t    assert tensor_type_block_bytes(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 2)\n   755\t    assert tensor_type_block_bytes(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 18)\n   756\t    assert tensor_type_block_bytes(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 34)\n   757\t\n   758\t\n   759\tdef test_tensor_type_helpers_reject_unknown_type() -> None:\n   760\t    assert tensor_type_block_size(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   761\t    assert tensor_type_block_bytes(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   762\t\n   763\t\n   764\tdef test_custom_power_of_two_alignment() -> None:\n   765\t    err, base = tensor_data_base_align(0x1234, 64)\n   766\t    assert err == GGUF_TDBASE_OK\n   767\t    assert base == 0x1240\n   768\t    assert tensor_data_base_is_aligned(base, 64)\n   769\t\n   770\t\n   771\tdef test_reject_non_power_of_two_alignment() -> None:\n   772\t    assert tensor_data_base_align(100, 0)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   773\t    assert tensor_data_base_align(100, 3)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   774\t    assert tensor_data_base_align(100, 24)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   775\t    assert tensor_data_base_is_aligned(128, 24) is False\n   776\t\n   777\t\n   778\tdef test_overflow_guard_near_u64_max() -> None:\n   779\t    err, _ = tensor_data_base_align(U64_MAX - 7, 16)\n   780\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   781\t\n   782\t    err, base = tensor_data_base_align(U64_MAX - 15, 16)\n   783\t    assert err == GGUF_TDBASE_OK\n   784\t    assert base == U64_MAX - 15\n   785\t\n   786\t\n   787\tdef test_random_alignment_matches_reference_formula() -> None:\n   788\t    rng = random.Random(760031)\n   789\t\n   790\t    for _ in range(1000):\n   791\t        alignment = 1 << rng.randint(0, 20)\n   792\t        cursor = rng.randrange(0, 1 << 56)\n   793\t\n   794\t        err, got = tensor_data_base_align(cursor, alignment)\n   795\t        assert err == GGUF_TDBASE_OK\n   796\t\n   797\t        reference = ((cursor + (alignment - 1)) // alignment) * alignment\n   798\t        assert got == reference\n   799\t        assert got >= cursor\n   800\t        assert tensor_data_base_is_aligned(got, alignment)\n   801\t\n   802\t\n   803\tdef test_tensor_data_base_offset_happy_path() -> None:\n   804\t    err, abs_off = tensor_data_base_offset(0x2000, 0x80, 32)\n   805\t    assert err == GGUF_TDBASE_OK\n   806\t    assert abs_off == 0x2080\n   807\t\n   808\t\n   809\t\n   810\tdef test_tensor_data_base_offset_default_alignment() -> None:\n   811\t    err, abs_off = tensor_data_base_offset_default(0x100, 0x40)\n   812\t    assert err == GGUF_TDBASE_OK\n   813\t    assert abs_off == 0x140\n   814\t\n   815\t\n   816\t\n   817\tdef test_tensor_data_base_offset_reject_bad_alignment() -> None:\n   818\t    err, _ = tensor_data_base_offset(0x1000, 0x40, 24)\n   819\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   820\t\n   821\t\n   822\t\n   823\tdef test_tensor_data_base_offset_reject_misaligned_base() -> None:\n   824\t    err, _ = tensor_data_base_offset(0x1010, 0x40, 32)\n   825\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   826\t\n   827\t\n   828\t\n   829\tdef test_tensor_data_base_offset_reject_misaligned_rel() -> None:\n   830\t    err, _ = tensor_data_base_offset(0x1000, 0x48, 32)\n   831\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n   832\t\n   833\t\n   834\t\n   835\tdef test_tensor_data_base_offset_overflow_guard() -> None:\n   836\t    err, _ = tensor_data_base_offset(U64_MAX - 31, 32, 32)\n   837\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   838\t\n   839\t\n   840\t\n   841\tdef test_tensor_data_base_offset_random_aligned_cases() -> None:\n   842\t    rng = random.Random(761113)\n   843\t\n   844\t    for _ in range(1000):\n   845\t        alignment = 1 << rng.randint(0, 15)\n   846\t        base_units = rng.randrange(0, 1 << 24)\n   847\t        rel_units = rng.randrange(0, 1 << 20)\n   848\t        base = base_units * alignment\n   849\t        rel = rel_units * alignment\n   850\t\n   851\t        err, got = tensor_data_base_offset(base, rel, alignment)\n   852\t        assert err == GGUF_TDBASE_OK\n   853\t        assert got == base + rel\n   854\t        assert tensor_data_base_is_aligned(got, alignment)\n   855\t\n   856\t\n   857\tdef test_tensor_resolve_range_happy_path() -> None:\n   858\t    err, abs_start, abs_end = tensor_resolve_range(0x2000, 0x80, 0x120, 0x3000, 32)\n   859\t    assert err == GGUF_TDBASE_OK\n   860\t    assert abs_start == 0x2080\n   861\t    assert abs_end == 0x21A0\n   862\t\n   863\t\n   864\tdef test_tensor_resolve_range_default_alignment() -> None:\n   865\t    err, abs_start, abs_end = tensor_resolve_range_default(0x100, 0x40, 0x10, 0x1000)\n   866\t    assert err == GGUF_TDBASE_OK\n   867\t    assert abs_start == 0x140\n   868\t    assert abs_end == 0x150\n   869\t\n   870\t\n   871\tdef test_tensor_resolve_range_reject_bad_alignment() -> None:\n   872\t    err, _, _ = tensor_resolve_range(0x100, 0x20, 0x10, 0x1000, 24)\n   873\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   874\t\n   875\t\n   876\tdef test_tensor_resolve_range_reject_misaligned_base() -> None:\n   877\t    err, _, _ = tensor_resolve_range(0x110, 0x20, 0x10, 0x1000, 32)\n   878\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   879\t\n   880\t\n   881\tdef test_tensor_resolve_range_reject_misaligned_offset() -> None:\n   882\t    err, _, _ = tensor_resolve_range(0x100, 0x18, 0x10, 0x1000, 32)\n   883\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n   884\t\n   885\t\n   886\tdef test_tensor_resolve_range_overflow_guard() -> None:\n   887\t    err, _, _ = tensor_resolve_range(U64_MAX - 0x1F, 0x20, 0x40, U64_MAX, 32)\n   888\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   889\t\n   890\t\n   891\tdef test_tensor_resolve_range_out_of_bounds() -> None:\n   892\t    err, _, _ = tensor_resolve_range(0x200, 0x40, 0xC0, 0x2F0, 32)\n   893\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n   894\t\n   895\t\n   896\tdef test_tensor_resolve_range_allows_exact_eof() -> None:\n   897\t    err, abs_start, abs_end = tensor_resolve_range(0x400, 0x80, 0x100, 0x580, 32)\n   898\t    assert err == GGUF_TDBASE_OK\n   899\t    assert abs_start == 0x480\n   900\t    assert abs_end == 0x580\n   901\t\n   902\t\n   903\tdef test_tensor_resolve_range_random_valid_cases() -> None:\n   904\t    rng = random.Random(761499)\n   905\t\n   906\t    for _ in range(1000):\n   907\t        alignment = 1 << rng.randint(0, 15)\n   908\t        base_units = rng.randrange(0, 1 << 20)\n   909\t        rel_units = rng.randrange(0, 1 << 20)\n   910\t        tensor_nbytes = rng.randrange(0, 1 << 16)\n   911\t\n   912\t        base = base_units * alignment\n   913\t        rel = rel_units * alignment\n   914\t        start = base + rel\n   915\t        if start > U64_MAX - tensor_nbytes:\n   916\t            continue\n   917\t        end = start + tensor_nbytes\n   918\t\n   919\t        file_pad = rng.randrange(0, 1 << 12)\n   920\t        file_nbytes = end + file_pad\n   921\t\n   922\t        err, got_start, got_end = tensor_resolve_range(\n   923\t            base,\n   924\t            rel,\n   925\t            tensor_nbytes,\n   926\t            file_nbytes,\n   927\t            alignment,\n   928\t        )\n   929\t        assert err == GGUF_TDBASE_OK\n   930\t        assert got_start == start\n   931\t        assert got_end == end\n   932\t\n   933\t\n   934\tdef test_validate_tensor_ranges_non_overlapping_happy_path() -> None:\n   935\t    err, bad = validate_tensor_ranges(\n   936\t        tensor_data_base=0x1000,\n   937\t        alignment=32,\n   938\t        gguf_file_nbytes=0x5000,\n   939\t        tensor_rel_offsets=[0x00, 0x80, 0x100, 0x200],\n   940\t        tensor_nbytes=[0x40, 0x40, 0x80, 0x20],\n   941\t    )\n   942\t    assert err == GGUF_TDBASE_OK\n   943\t    assert bad == 0\n   944\t\n   945\t\n   946\tdef test_validate_tensor_ranges_detect_overlap() -> None:\n   947\t    err, bad = validate_tensor_ranges(\n   948\t        tensor_data_base=0x1000,\n   949\t        alignment=32,\n   950\t        gguf_file_nbytes=0x5000,\n   951\t        tensor_rel_offsets=[0x00, 0x20, 0x200],\n   952\t        tensor_nbytes=[0x40, 0x40, 0x20],\n   953\t    )\n   954\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n   955\t    assert bad == 1\n   956\t\n   957\t\n   958\tdef test_validate_tensor_ranges_propagates_bad_alignment() -> None:\n   959\t    err, bad = validate_tensor_ranges(\n   960\t        tensor_data_base=0x1000,\n   961\t        alignment=24,\n   962\t        gguf_file_nbytes=0x5000,\n   963\t        tensor_rel_offsets=[0x00, 0x20],\n   964\t        tensor_nbytes=[0x20, 0x20],\n   965\t    )\n   966\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   967\t    assert bad == 0\n   968\t\n   969\t\n   970\tdef test_validate_tensor_ranges_propagates_out_of_bounds_with_index() -> None:\n   971\t    err, bad = validate_tensor_ranges(\n   972\t        tensor_data_base=0x1000,\n   973\t        alignment=32,\n   974\t        gguf_file_nbytes=0x1100,\n   975\t        tensor_rel_offsets=[0x00, 0x80],\n   976\t        tensor_nbytes=[0x20, 0x120],\n   977\t    )\n   978\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n   979\t    assert bad == 1\n   980\t\n---\n   980\t\n   981\t\n   982\tdef test_validate_tensor_ranges_random_non_overlapping() -> None:\n   983\t    rng = random.Random(761991)\n   984\t\n   985\t    for _ in range(300):\n   986\t        alignment = 1 << rng.randint(0, 10)\n   987\t        count = rng.randint(1, 12)\n   988\t        cursor = 0\n   989\t\n   990\t        rel_offsets = []\n   991\t        nbytes = []\n   992\t        for _ in range(count):\n   993\t            gap_units = rng.randint(0, 8)\n   994\t            gap = gap_units * alignment\n   995\t            cursor += gap\n   996\t\n   997\t            span_units = rng.randint(0, 6)\n   998\t            span = span_units * alignment\n   999\t\n  1000\t            rel_offsets.append(cursor)\n  1001\t            nbytes.append(span)\n  1002\t            cursor += span\n  1003\t\n  1004\t        base_units = rng.randint(0, 1024)\n  1005\t        base = base_units * alignment\n  1006\t        file_nbytes = base + cursor + (rng.randint(0, 16) * alignment)\n  1007\t\n  1008\t        err, bad = validate_tensor_ranges(\n  1009\t            tensor_data_base=base,\n  1010\t            alignment=alignment,\n  1011\t            gguf_file_nbytes=file_nbytes,\n  1012\t            tensor_rel_offsets=rel_offsets,\n  1013\t            tensor_nbytes=nbytes,\n  1014\t        )\n  1015\t        assert err == GGUF_TDBASE_OK\n  1016\t        assert bad == 0\n  1017\t\n  1018\t\n  1019\tdef test_validate_tensor_ranges_random_overlap_cases() -> None:\n  1020\t    rng = random.Random(762007)\n  1021\t\n  1022\t    for _ in range(200):\n  1023\t        alignment = 1 << rng.randint(0, 10)\n  1024\t        base = rng.randint(0, 1024) * alignment\n  1025\t\n  1026\t        a_start = rng.randint(0, 128) * alignment\n  1027\t        a_len = max(alignment, rng.randint(1, 8) * alignment)\n  1028\t        b_start = a_start + rng.randint(0, (a_len // alignment) - 1) * alignment\n  1029\t        b_len = max(alignment, rng.randint(1, 8) * alignment)\n  1030\t\n  1031\t        rel_offsets = [a_start, b_start]\n  1032\t        nbytes = [a_len, b_len]\n  1033\t        max_end = max(a_start + a_len, b_start + b_len)\n  1034\t        file_nbytes = base + max_end + alignment\n  1035\t\n  1036\t        err, bad = validate_tensor_ranges(\n  1037\t            tensor_data_base=base,\n  1038\t            alignment=alignment,\n  1039\t            gguf_file_nbytes=file_nbytes,\n  1040\t            tensor_rel_offsets=rel_offsets,\n  1041\t            tensor_nbytes=nbytes,\n  1042\t        )\n  1043\t        assert err == GGUF_TDBASE_ERR_OVERLAP\n  1044\t        assert bad == 1\n  1045\t\n  1046\t\n  1047\tdef test_validate_tensor_ranges_sorted_non_overlapping_happy_path() -> None:\n  1048\t    rel_offsets = [0x200, 0x00, 0x100, 0x80]\n  1049\t    nbytes = [0x20, 0x40, 0x40, 0x40]\n  1050\t\n  1051\t    err, bad = validate_tensor_ranges_sorted(\n  1052\t        tensor_data_base=0x1000,\n  1053\t        alignment=32,\n  1054\t        gguf_file_nbytes=0x5000,\n  1055\t        tensor_rel_offsets=rel_offsets,\n  1056\t        tensor_nbytes=nbytes,\n  1057\t    )\n  1058\t    assert err == GGUF_TDBASE_OK\n  1059\t    assert bad == 0\n  1060\t    assert rel_offsets == [0x00, 0x80, 0x100, 0x200]\n  1061\t    assert nbytes == [0x40, 0x40, 0x40, 0x20]\n  1062\t\n  1063\t\n  1064\tdef test_validate_tensor_ranges_sorted_tie_breaks_equal_offsets_by_size() -> None:\n  1065\t    rel_offsets = [0x80, 0x80, 0x80]\n  1066\t    nbytes = [0x20, 0x00, 0x08]\n  1067\t\n  1068\t    err, bad = validate_tensor_ranges_sorted(\n  1069\t        tensor_data_base=0x1000,\n  1070\t        alignment=32,\n  1071\t        gguf_file_nbytes=0x5000,\n  1072\t        tensor_rel_offsets=rel_offsets,\n  1073\t        tensor_nbytes=nbytes,\n  1074\t    )\n  1075\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1076\t    assert bad == 2\n  1077\t    assert rel_offsets == [0x80, 0x80, 0x80]\n  1078\t    assert nbytes == [0x00, 0x08, 0x20]\n  1079\t\n  1080\t\n  1081\tdef test_validate_tensor_ranges_sorted_detect_overlap() -> None:\n  1082\t    rel_offsets = [0x100, 0x00, 0x20]\n  1083\t    nbytes = [0x20, 0x40, 0x40]\n  1084\t\n  1085\t    err, bad = validate_tensor_ranges_sorted(\n  1086\t        tensor_data_base=0x1000,\n  1087\t        alignment=32,\n  1088\t        gguf_file_nbytes=0x5000,\n  1089\t        tensor_rel_offsets=rel_offsets,\n  1090\t        tensor_nbytes=nbytes,\n  1091\t    )\n  1092\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1093\t    assert bad == 1\n  1094\t    assert rel_offsets == [0x00, 0x20, 0x100]\n  1095\t    assert nbytes == [0x40, 0x40, 0x20]\n  1096\t\n  1097\t\n  1098\tdef test_validate_tensor_ranges_sorted_propagates_bad_alignment_without_sort() -> None:\n  1099\t    rel_offsets = [0x80, 0x00]\n  1100\t    nbytes = [0x20, 0x20]\n  1101\t\n  1102\t    err, bad = validate_tensor_ranges_sorted(\n  1103\t        tensor_data_base=0x1000,\n  1104\t        alignment=24,\n  1105\t        gguf_file_nbytes=0x5000,\n  1106\t        tensor_rel_offsets=rel_offsets,\n  1107\t        tensor_nbytes=nbytes,\n  1108\t    )\n  1109\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n  1110\t    assert bad == 0\n  1111\t    assert rel_offsets == [0x80, 0x00]\n  1112\t    assert nbytes == [0x20, 0x20]\n  1113\t\n  1114\t\n  1115\tdef test_validate_tensor_ranges_sorted_random_matches_quadratic_validator() -> None:\n  1116\t    rng = random.Random(762199)\n  1117\t\n  1118\t    for _ in range(500):\n  1119\t        alignment = 1 << rng.randint(0, 10)\n  1120\t        count = rng.randint(1, 24)\n  1121\t        base = rng.randint(0, 1024) * alignment\n  1122\t\n  1123\t        rel_offsets = []\n  1124\t        nbytes = []\n  1125\t        cursor = 0\n  1126\t\n  1127\t        force_overlap = rng.random() < 0.5 and count >= 2\n  1128\t        overlap_i = rng.randint(0, count - 2) if force_overlap else -1\n  1129\t\n  1130\t        for i in range(count):\n  1131\t            gap = rng.randint(0, 6) * alignment\n  1132\t            cursor += gap\n  1133\t            span = rng.randint(0, 6) * alignment\n  1134\t\n  1135\t            start = cursor\n  1136\t            if force_overlap and i == overlap_i + 1:\n  1137\t                prev_start = rel_offsets[-1]\n  1138\t                prev_span = nbytes[-1]\n  1139\t                if prev_span == 0:\n  1140\t                    start = prev_start\n  1141\t                else:\n  1142\t                    start = prev_start + rng.randint(0, max(0, (prev_span // alignment) - 1)) * alignment\n  1143\t\n  1144\t            rel_offsets.append(start)\n  1145\t            nbytes.append(span)\n  1146\t            cursor = max(cursor, start + span)\n  1147\t\n  1148\t        file_nbytes = base + cursor + rng.randint(0, 8) * alignment + alignment\n  1149\t\n  1150\t        rel_a = rel_offsets.copy()\n  1151\t        nbytes_a = nbytes.copy()\n  1152\t        err_quad, bad_quad = validate_tensor_ranges(\n  1153\t            tensor_data_base=base,\n  1154\t            alignment=alignment,\n  1155\t            gguf_file_nbytes=file_nbytes,\n  1156\t            tensor_rel_offsets=rel_a,\n  1157\t            tensor_nbytes=nbytes_a,\n  1158\t        )\n  1159\t\n  1160\t        rel_b = rel_offsets.copy()\n  1161\t        nbytes_b = nbytes.copy()\n  1162\t        err_sorted, bad_sorted = validate_tensor_ranges_sorted(\n  1163\t            tensor_data_base=base,\n  1164\t            alignment=alignment,\n  1165\t            gguf_file_nbytes=file_nbytes,\n  1166\t            tensor_rel_offsets=rel_b,\n  1167\t            tensor_nbytes=nbytes_b,\n  1168\t        )\n  1169\t\n  1170\t        assert err_sorted == err_quad\n  1171\t        if err_sorted == GGUF_TDBASE_ERR_OVERLAP:\n  1172\t            assert bad_sorted >= 1\n  1173\t        elif err_sorted == GGUF_TDBASE_OK:\n  1174\t            assert bad_sorted == 0\n  1175\t            assert rel_b == sorted(rel_offsets)\n  1176\t\n  1177\t\n  1178\tdef test_tensor_info_resolve_byte_spans_happy_path() -> None:\n  1179\t    rel_offsets = [0x80, 0x00, 0x40]\n  1180\t    element_counts = [32, 8, 32]\n  1181\t    ggml_types = [GGML_TYPE_Q4_0, GGML_TYPE_F32, GGML_TYPE_Q8_0]\n  1182\t    out_nbytes = [0, 0, 0]\n  1183\t\n  1184\t    err, bad = tensor_info_resolve_byte_spans(\n  1185\t        tensor_data_base=0x1000,\n  1186\t        alignment=32,\n  1187\t        gguf_file_nbytes=0x4000,\n  1188\t        tensor_rel_offsets=rel_offsets,\n  1189\t        tensor_element_counts=element_counts,\n  1190\t        tensor_ggml_types=ggml_types,\n  1191\t        out_tensor_nbytes=out_nbytes,\n  1192\t    )\n  1193\t    assert err == GGUF_TDBASE_OK\n  1194\t    assert bad == 0\n  1195\t    assert rel_offsets == [0x00, 0x40, 0x80]\n  1196\t    assert out_nbytes == [32, 34, 18]\n  1197\t\n  1198\t\n  1199\tdef test_tensor_info_resolve_byte_spans_reject_bad_block_multiple() -> None:\n  1200\t    rel_offsets = [0x00, 0x20]\n  1201\t    element_counts = [32, 31]\n  1202\t    ggml_types = [GGML_TYPE_Q8_0, GGML_TYPE_Q4_0]\n  1203\t    out_nbytes = [0, 0]\n  1204\t\n  1205\t    err, bad = tensor_info_resolve_byte_spans(\n  1206\t        tensor_data_base=0x2000,\n  1207\t        alignment=32,\n  1208\t        gguf_file_nbytes=0x5000,\n  1209\t        tensor_rel_offsets=rel_offsets,\n  1210\t        tensor_element_counts=element_counts,\n  1211\t        tensor_ggml_types=ggml_types,\n  1212\t        out_tensor_nbytes=out_nbytes,\n  1213\t    )\n  1214\t    assert err == GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE\n  1215\t    assert bad == 1\n  1216\t\n  1217\t\n  1218\tdef test_tensor_info_resolve_byte_spans_reject_unknown_type() -> None:\n  1219\t    rel_offsets = [0x00]\n  1220\t    element_counts = [32]\n  1221\t    ggml_types = [999]\n  1222\t    out_nbytes = [0]\n  1223\t\n  1224\t    err, bad = tensor_info_resolve_byte_spans(\n  1225\t        tensor_data_base=0x1000,\n  1226\t        alignment=32,\n  1227\t        gguf_file_nbytes=0x2000,\n  1228\t        tensor_rel_offsets=rel_offsets,\n  1229\t        tensor_element_counts=element_counts,\n  1230\t        tensor_ggml_types=ggml_types,\n  1231\t        out_tensor_nbytes=out_nbytes,\n  1232\t    )\n  1233\t    assert err == GGUF_TDBASE_ERR_BAD_TYPE\n  1234\t    assert bad == 0\n  1235\t\n  1236\t\n  1237\tdef test_tensor_info_resolve_byte_spans_detect_overlap_after_sizing() -> None:\n  1238\t    rel_offsets = [0x00, 0x20]\n  1239\t    element_counts = [16, 8]\n  1240\t    ggml_types = [GGML_TYPE_F32, GGML_TYPE_F32]\n  1241\t    out_nbytes = [0, 0]\n  1242\t\n  1243\t    err, bad = tensor_info_resolve_byte_spans(\n  1244\t        tensor_data_base=0x1000,\n  1245\t        alignment=32,\n  1246\t        gguf_file_nbytes=0x5000,\n  1247\t        tensor_rel_offsets=rel_offsets,\n  1248\t        tensor_element_counts=element_counts,\n  1249\t        tensor_ggml_types=ggml_types,\n  1250\t        out_tensor_nbytes=out_nbytes,\n  1251\t    )\n  1252\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n  1253\t    assert bad == 1\n  1254\t\n  1255\t\n  1256\tdef test_tensor_info_resolve_abs_ranges_happy_path() -> None:\n  1257\t    rel_offsets = [0x80, 0x00, 0x40]\n  1258\t    element_counts = [32, 8, 32]\n  1259\t    ggml_types = [GGML_TYPE_Q4_0, GGML_TYPE_F32, GGML_TYPE_Q8_0]\n  1260\t    out_nbytes = [0, 0, 0]\n  1261\t    out_abs_starts = [0, 0, 0]\n  1262\t    out_abs_ends = [0, 0, 0]\n  1263\t\n  1264\t    err, bad = tensor_info_resolve_abs_ranges(\n  1265\t        tensor_data_base=0x1000,\n  1266\t        alignment=32,\n  1267\t        gguf_file_nbytes=0x4000,\n  1268\t        tensor_rel_offsets=rel_offsets,\n  1269\t        tensor_element_counts=element_counts,\n  1270\t        tensor_ggml_types=ggml_types,\n  1271\t        out_tensor_nbytes=out_nbytes,\n  1272\t        out_abs_starts=out_abs_starts,\n  1273\t        out_abs_ends=out_abs_ends,\n  1274\t    )\n  1275\t    assert err == GGUF_TDBASE_OK\n  1276\t    assert bad == 0\n  1277\t    assert rel_offsets == [0x00, 0x40, 0x80]\n  1278\t    assert out_nbytes == [32, 34, 18]\n  1279\t    assert out_abs_starts == [0x1000, 0x1040, 0x1080]\n  1280\t    assert out_abs_ends == [0x1020, 0x1062, 0x1092]\n  1281\t\n  1282\t\n  1283\tdef test_tensor_info_resolve_abs_ranges_propagates_bad_block_multiple() -> None:\n  1284\t    rel_offsets = [0x00, 0x20]\n  1285\t    element_counts = [32, 31]\n  1286\t    ggml_types = [GGML_TYPE_Q8_0, GGML_TYPE_Q4_0]\n  1287\t    out_nbytes = [0, 0]\n  1288\t    out_abs_starts = [0, 0]\n  1289\t    out_abs_ends = [0, 0]\n  1290\t\n  1291\t    err, bad = tensor_info_resolve_abs_ranges(\n  1292\t        tensor_data_base=0x1000,\n  1293\t        alignment=32,\n  1294\t        gguf_file_nbytes=0x5000,\n  1295\t        tensor_rel_offsets=rel_offsets,\n  1296\t        tensor_element_counts=element_counts,\n  1297\t        tensor_ggml_types=ggml_types,\n  1298\t        out_tensor_nbytes=out_nbytes,\n  1299\t        out_abs_starts=out_abs_starts,\n  1300\t        out_abs_ends=out_abs_ends,\n  1301\t    )\n  1302\t    assert err == GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE\n  1303\t    assert bad == 1\n  1304\t\n  1305\t\n  1306\tdef test_tensor_info_resolve_abs_ranges_reject_null_outputs() -> None:\n  1307\t    rel_offsets = [0x00]\n  1308\t    element_counts = [8]\n  1309\t    ggml_types = [GGML_TYPE_F32]\n  1310\t    out_nbytes = [0]\n  1311\t\n  1312\t    err, bad = tensor_info_resolve_abs_ranges(\n  1313\t        tensor_data_base=0x1000,\n  1314\t        alignment=32,\n  1315\t        gguf_file_nbytes=0x2000,\n  1316\t        tensor_rel_offsets=rel_offsets,\n  1317\t        tensor_element_counts=element_counts,\n  1318\t        tensor_ggml_types=ggml_types,\n  1319\t        out_tensor_nbytes=out_nbytes,\n  1320\t        out_abs_starts=[],\n  1321\t        out_abs_ends=[0],\n  1322\t    )\n  1323\t    assert err == GGUF_TDBASE_ERR_NULL_PTR\n  1324\t    assert bad == 0\n  1325\t\n  1326\t\n  1327\tdef test_tensor_range_find_by_abs_offset_happy_path() -> None:\n  1328\t    starts = [0x1000, 0x1040, 0x1080]\n  1329\t    ends = [0x1020, 0x1062, 0x1092]\n  1330\t\n  1331\t    assert tensor_range_find_by_abs_offset(0x1000, starts, ends) == (GGUF_TDBASE_OK, 0)\n  1332\t    assert tensor_range_find_by_abs_offset(0x101F, starts, ends) == (GGUF_TDBASE_OK, 0)\n  1333\t    assert tensor_range_find_by_abs_offset(0x1040, starts, ends) == (GGUF_TDBASE_OK, 1)\n  1334\t    assert tensor_range_find_by_abs_offset(0x1061, starts, ends) == (GGUF_TDBASE_OK, 1)\n  1335\t    assert tensor_range_find_by_abs_offset(0x1080, starts, ends) == (GGUF_TDBASE_OK, 2)\n  1336\t\n  1337\t\n  1338\tdef test_tensor_range_find_by_abs_offset_gap_and_end_exclusive() -> None:\n  1339\t    starts = [0x1000, 0x1040, 0x1080]\n  1340\t    ends = [0x1020, 0x1062, 0x1092]\n  1341\t\n  1342\t    assert tensor_range_find_by_abs_offset(0x1020, starts, ends)[0] == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1343\t    assert tensor_range_find_by_abs_offset(0x107F, starts, ends)[0] == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1344\t    assert tensor_range_find_by_abs_offset(0x1092, starts, ends)[0] == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1345\t\n  1346\t\n  1347\tdef test_tensor_range_find_by_abs_offset_rejects_malformed_range() -> None:\n  1348\t    starts = [0x1000, 0x1040]\n  1349\t    ends = [0x1020, 0x1030]\n  1350\t\n  1351\t    err, idx = tensor_range_find_by_abs_offset(0x1040, starts, ends)\n  1352\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n  1353\t    assert idx == 0\n  1354\t\n  1355\t\n  1356\tdef test_tensor_range_find_by_abs_offset_empty_table() -> None:\n  1357\t    err, idx = tensor_range_find_by_abs_offset(0x1000, [], [])\n  1358\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1359\t    assert idx == 0\n  1360\t\n---\n  1360\t\n  1361\t\n  1362\tdef test_tensor_range_find_by_rel_offset_happy_path() -> None:\n  1363\t    starts = [0x1000, 0x1040, 0x1080]\n  1364\t    ends = [0x1020, 0x1062, 0x1092]\n  1365\t\n  1366\t    assert tensor_range_find_by_rel_offset(0x00, 0x1000, 32, starts, ends) == (GGUF_TDBASE_OK, 0)\n  1367\t    assert tensor_range_find_by_rel_offset(0x40, 0x1000, 32, starts, ends) == (GGUF_TDBASE_OK, 1)\n  1368\t    assert tensor_range_find_by_rel_offset(0x80, 0x1000, 32, starts, ends) == (GGUF_TDBASE_OK, 2)\n  1369\t\n  1370\t\n  1371\tdef test_tensor_range_find_by_rel_offset_propagates_alignment_error() -> None:\n  1372\t    starts = [0x1000, 0x1040]\n  1373\t    ends = [0x1020, 0x1060]\n  1374\t\n  1375\t    err, idx = tensor_range_find_by_rel_offset(0x40, 0x1000, 24, starts, ends)\n  1376\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n  1377\t    assert idx == 0\n  1378\t\n  1379\t\n  1380\tdef test_tensor_range_find_by_rel_offset_propagates_misaligned_rel() -> None:\n  1381\t    starts = [0x1000, 0x1040]\n  1382\t    ends = [0x1020, 0x1060]\n  1383\t\n  1384\t    err, idx = tensor_range_find_by_rel_offset(0x48, 0x1000, 32, starts, ends)\n  1385\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n  1386\t    assert idx == 0\n  1387\t\n  1388\t\n  1389\tdef test_tensor_range_find_by_rel_offset_gap_and_out_of_bounds() -> None:\n  1390\t    starts = [0x1000, 0x1040, 0x1080]\n  1391\t    ends = [0x1020, 0x1062, 0x1092]\n  1392\t\n  1393\t    err, idx = tensor_range_find_by_rel_offset(0x20, 0x1000, 32, starts, ends)\n  1394\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1395\t    assert idx == 0\n  1396\t\n  1397\t    err, idx = tensor_range_find_by_rel_offset(0xA0, 0x1000, 32, starts, ends)\n  1398\t    assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1399\t    assert idx == 0\n  1400\t\n  1401\t\n  1402\tdef test_tensor_range_find_by_rel_offset_default_alignment_happy_path() -> None:\n  1403\t    starts = [0x1000, 0x1040, 0x1080]\n  1404\t    ends = [0x1020, 0x1062, 0x1092]\n  1405\t\n  1406\t    assert tensor_range_find_by_rel_offset_default(0x00, 0x1000, starts, ends) == (GGUF_TDBASE_OK, 0)\n  1407\t    assert tensor_range_find_by_rel_offset_default(0x40, 0x1000, starts, ends) == (GGUF_TDBASE_OK, 1)\n  1408\t    assert tensor_range_find_by_rel_offset_default(0x80, 0x1000, starts, ends) == (GGUF_TDBASE_OK, 2)\n  1409\t\n  1410\t\n  1411\tdef test_tensor_range_find_by_rel_offset_default_alignment_propagates_error() -> None:\n  1412\t    starts = [0x