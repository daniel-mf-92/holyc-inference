          ends[i], ends[i - 1] = ends[i - 1], ends[i]\n  1812\t            err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1813\t            assert err == GGUF_TDBASE_ERR_OVERLAP\n  1814\t            assert bad == i\n  1815\t        elif case == 1:\n  1816\t            i = rng.randint(1, count - 1)\n  1817\t            starts[i] = max(starts[i - 1], starts[i] - 32)\n  1818\t            ends[i - 1] = starts[i] + 32\n  1819\t            err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1820\t            assert err == GGUF_TDBASE_ERR_OVERLAP\n  1821\t            assert bad == i\n  1822\t        elif case == 2:\n  1823\t            i = rng.randint(0, count - 1)\n  1824\t            sorted_idx[i] = count + rng.randint(0, 10)\n  1825\t            err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1826\t            assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1827\t            assert bad == i\n  1828\t        else:\n  1829\t            i = rng.randint(1, count - 1)\n  1830\t            sorted_idx[i] = sorted_idx[rng.randint(0, i - 1)]\n  1831\t            err, bad = validate_sorted_tensor_index(starts, ends, sorted_idx)\n  1832\t            assert err == GGUF_TDBASE_ERR_OUT_OF_BOUNDS\n  1833\t            assert bad == i\n  1834\t\n  1835\t\n  1836\t\n  1837\t\n  1838\tdef run() -> None:\n  1839\t    test_default_alignment_examples()\n  1840\t    test_tensor_bytes_for_type_scalars()\n  1841\t    test_tensor_bytes_for_type_quantized_exact_blocks()\n  1842\t    test_tensor_bytes_for_type_reject_non_multiple_block()\n  1843\t    test_tensor_bytes_for_type_reject_unknown_type()\n  1844\t    test_tensor_bytes_for_type_overflow_guard()\n  1845\t    test_tensor_type_block_size_known_types()\n  1846\t    test_tensor_type_block_bytes_known_types()\n  1847\t    test_tensor_type_helpers_reject_unknown_type()\n  1848\t    test_custom_power_of_two_alignment()\n  1849\t    test_reject_non_power_of_two_alignment()\n  1850\t    te