{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,360p' src/gguf/tensor_data_base.HC; echo '---'; sed -n '360,760p' src/gguf/tensor_data_base.HC; echo '---'; sed -n '1,320p' tests/test_gguf_tensor_data_base.py; echo '---'; sed -n '320,760p' tests/test_gguf_tensor_data_base.py\"","aggregated_output":"// tensor_data_base.HC\n// GGUF tensor-data base alignment helpers for HolyC inference runtime.\n\n#define GGUF_TDBASE_OK 0\n#define GGUF_TDBASE_ERR_NULL_PTR 1\n#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n#define GGUF_TDBASE_ERR_OVERFLOW 3\n#define GGUF_TDBASE_ERR_MISALIGNED_BASE 4\n#define GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET 5\n#define GGUF_TDBASE_ERR_BAD_TYPE 6\n#define GGUF_TDBASE_ERR_OUT_OF_BOUNDS 7\n#define GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE 8\n#define GGUF_TDBASE_ERR_OVERLAP 9\n\n// GGUF default tensor alignment when metadata key `general.alignment`\n// is absent.\n#define GGUF_DEFAULT_ALIGNMENT 32\n\n// Subset of ggml tensor types currently enabled in HolyC inference runtime.\n// Keep this list strict and explicit so sizing math never silently accepts\n// unknown quantization tags from malformed GGUF files.\n#define GGML_TYPE_F32   0\n#define GGML_TYPE_F16   1\n#define GGML_TYPE_Q4_0  2\n#define GGML_TYPE_Q8_0  8\n\n// GGML quantization blocks for runtime-critical formats:\n// - F32/F16 are scalar types (block size 1).\n// - Q4_0 and Q8_0 are packed in 32-element blocks.\n#define GGML_BLCK_SIZE_F32   1\n#define GGML_BLCK_SIZE_F16   1\n#define GGML_BLCK_SIZE_Q4_0  32\n#define GGML_BLCK_SIZE_Q8_0  32\n\n// Block payload byte widths from ggml struct layouts:\n// - Q4_0: fp16 scale (2 bytes) + 16 packed nibbles = 18 bytes.\n// - Q8_0: fp16 scale (2 bytes) + 32 signed bytes = 34 bytes.\n#define GGML_TYPE_SIZE_F32   4\n#define GGML_TYPE_SIZE_F16   2\n#define GGML_TYPE_SIZE_Q4_0  18\n#define GGML_TYPE_SIZE_Q8_0  34\n\nI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n{\n    if (!out_block_size)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    switch (ggml_type)\n    {\n        case GGML_TYPE_F32:\n            *out_block_size = GGML_BLCK_SIZE_F32;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_F16:\n            *out_block_size = GGML_BLCK_SIZE_F16;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q4_0:\n            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q8_0:\n            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n            return GGUF_TDBASE_OK;\n    }\n\n    return GGUF_TDBASE_ERR_BAD_TYPE;\n}\n\nI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n{\n    if (!out_block_bytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    switch (ggml_type)\n    {\n        case GGML_TYPE_F32:\n            *out_block_bytes = GGML_TYPE_SIZE_F32;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_F16:\n            *out_block_bytes = GGML_TYPE_SIZE_F16;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q4_0:\n            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n            return GGUF_TDBASE_OK;\n        case GGML_TYPE_Q8_0:\n            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n            return GGUF_TDBASE_OK;\n    }\n\n    return GGUF_TDBASE_ERR_BAD_TYPE;\n}\n\nI64 GGUFTensorBytesForType(U32 ggml_type,\n                           U64 element_count,\n                           U64 *out_tensor_nbytes)\n{\n    U64 block_size;\n    U64 block_bytes;\n    U64 block_count;\n    I64 err;\n\n    if (!out_tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    err = GGUFTensorTypeBlockSize(ggml_type, &block_size);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    err = GGUFTensorTypeBlockBytes(ggml_type, &block_bytes);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // Quantized formats are stored in fixed-size element blocks.\n    // Reject non-multiples instead of silently rounding/truncating.\n    if (element_count % block_size)\n        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE;\n\n    block_count = element_count / block_size;\n\n    // Byte size = number of blocks * bytes per block.\n    // Guard overflow before multiplication for malformed giant tensors.\n    if (block_count > 0xFFFFFFFFFFFFFFFF / block_bytes)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out_tensor_nbytes = block_count * block_bytes;\n    return GGUF_TDBASE_OK;\n}\n\nBool GGUFIsPow2U32(U32 value)\n{\n    if (!value)\n        return FALSE;\n    return (value & (value - 1)) == 0;\n}\n\nI64 GGUFValidateAlignment(U32 alignment)\n{\n    if (!GGUFIsPow2U32(alignment))\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n{\n    U64 mask;\n\n    if (!out)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n\n    // For power-of-two alignments, align-up is:\n    //   (value + (alignment - 1)) & ~(alignment - 1)\n    // Keep overflow checks explicit so giant malformed offsets are rejected.\n    mask = (U64)alignment - 1;\n    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out = (value + mask) & ~mask;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n                            U32 alignment,\n                            U64 *out_tensor_data_base)\n{\n    return GGUFAlignUpU64(cursor_after_tensor_info,\n                          alignment,\n                          out_tensor_data_base);\n}\n\nI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n                                   U64 *out_tensor_data_base)\n{\n    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n                                   GGUF_DEFAULT_ALIGNMENT,\n                                   out_tensor_data_base);\n}\n\nBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n{\n    U64 mask;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return FALSE;\n\n    mask = (U64)alignment - 1;\n    return (offset & mask) == 0;\n}\n\nI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n                             U64 tensor_rel_offset,\n                             U32 alignment,\n                             U64 *out_tensor_abs)\n{\n    if (!out_tensor_abs)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n\n    // Both base and relative tensor offsets must preserve GGUF alignment.\n    // Enforcing this here keeps every downstream payload read auditable.\n    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n\n    // Absolute payload pointer is base + relative offset.\n    // Keep overflow check explicit for malformed large files.\n    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n\n    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n                                    U64 tensor_rel_offset,\n                                    U64 *out_tensor_abs)\n{\n    return GGUFTensorDataBaseOffset(tensor_data_base,\n                                    tensor_rel_offset,\n                                    GGUF_DEFAULT_ALIGNMENT,\n                                    out_tensor_abs);\n}\n\nI64 GGUFTensorResolveRange(U64 tensor_data_base,\n                           U64 tensor_rel_offset,\n                           U64 tensor_nbytes,\n                           U64 gguf_file_nbytes,\n                           U32 alignment,\n                           U64 *out_tensor_abs_start,\n                           U64 *out_tensor_abs_end)\n{\n    U64 abs_start;\n    U64 abs_end;\n    I64 err;\n\n    if (!out_tensor_abs_start || !out_tensor_abs_end)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    // Resolve and validate the absolute tensor start offset first.\n    err = GGUFTensorDataBaseOffset(tensor_data_base,\n                                   tensor_rel_offset,\n                                   alignment,\n                                   &abs_start);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // Tensor byte-range is [abs_start, abs_start + tensor_nbytes).\n    // Guard add overflow before constructing the exclusive end.\n    if (abs_start > 0xFFFFFFFFFFFFFFFF - tensor_nbytes)\n        return GGUF_TDBASE_ERR_OVERFLOW;\n    abs_end = abs_start + tensor_nbytes;\n\n    // Reject ranges that run past the file boundary.\n    // A tensor may legally end exactly at gguf_file_nbytes.\n    if (abs_end > gguf_file_nbytes)\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n\n    *out_tensor_abs_start = abs_start;\n    *out_tensor_abs_end   = abs_end;\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorResolveRangeDefault(U64 tensor_data_base,\n                                  U64 tensor_rel_offset,\n                                  U64 tensor_nbytes,\n                                  U64 gguf_file_nbytes,\n                                  U64 *out_tensor_abs_start,\n                                  U64 *out_tensor_abs_end)\n{\n    return GGUFTensorResolveRange(tensor_data_base,\n                                  tensor_rel_offset,\n                                  tensor_nbytes,\n                                  gguf_file_nbytes,\n                                  GGUF_DEFAULT_ALIGNMENT,\n                                  out_tensor_abs_start,\n                                  out_tensor_abs_end);\n}\n\nI64 GGUFValidateTensorRanges(U64 tensor_data_base,\n                             U32 alignment,\n                             U64 gguf_file_nbytes,\n                             U64 tensor_count,\n                             U64 *tensor_rel_offsets,\n                             U64 *tensor_nbytes,\n                             U64 *out_bad_index)\n{\n    U64 i;\n    U64 j;\n    U64 start_i;\n    U64 end_i;\n    U64 start_j;\n    U64 end_j;\n    I64 err;\n\n    if (!tensor_rel_offsets || !tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (out_bad_index)\n        *out_bad_index = 0;\n\n    // Pass 1: each tensor range must be individually valid.\n    // This enforces aligned offsets, add-overflow safety, and EOF bounds.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorResolveRange(tensor_data_base,\n                                     tensor_rel_offsets[i],\n                                     tensor_nbytes[i],\n                                     gguf_file_nbytes,\n                                     alignment,\n                                     &start_i,\n                                     &end_i);\n        if (err != GGUF_TDBASE_OK)\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return err;\n        }\n    }\n\n    // Pass 2: pairwise overlap check.\n    // Explicit O(n^2) keeps logic simple and fully auditable in HolyC.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorResolveRange(tensor_data_base,\n                                     tensor_rel_offsets[i],\n                                     tensor_nbytes[i],\n                                     gguf_file_nbytes,\n                                     alignment,\n                                     &start_i,\n                                     &end_i);\n        if (err != GGUF_TDBASE_OK)\n            return err;\n\n        for (j = i + 1; j < tensor_count; ++j)\n        {\n            err = GGUFTensorResolveRange(tensor_data_base,\n                                         tensor_rel_offsets[j],\n                                         tensor_nbytes[j],\n                                         gguf_file_nbytes,\n                                         alignment,\n                                         &start_j,\n                                         &end_j);\n            if (err != GGUF_TDBASE_OK)\n                return err;\n\n            // Half-open intervals [start, end) overlap when each interval starts\n            // before the other ends. Exact touching boundaries are legal.\n            if ((start_i < end_j) && (start_j < end_i))\n            {\n                if (out_bad_index)\n                    *out_bad_index = j;\n                return GGUF_TDBASE_ERR_OVERLAP;\n            }\n        }\n    }\n\n    return GGUF_TDBASE_OK;\n---\n    return GGUF_TDBASE_OK;\n}\n\nU0 GGUFSwapU64(U64 *a, U64 *b)\n{\n    U64 tmp;\n\n    tmp = *a;\n    *a = *b;\n    *b = tmp;\n}\n\nBool GGUFTensorRangeGreater(U64 a_off,\n                            U64 a_nbytes,\n                            U64 b_off,\n                            U64 b_nbytes)\n{\n    if (a_off > b_off)\n        return TRUE;\n    if (a_off < b_off)\n        return FALSE;\n\n    // Tie-break by nbytes so equal offsets are ordered shortest-first.\n    // This preserves GGUFValidateTensorRanges behavior for zero-byte ranges.\n    return a_nbytes > b_nbytes;\n}\n\nU0 GGUFTensorRangeSiftDown(U64 *tensor_rel_offsets,\n                           U64 *tensor_nbytes,\n                           U64 root,\n                           U64 end)\n{\n    U64 child;\n    U64 swap_idx;\n\n    while (TRUE)\n    {\n        child = root * 2 + 1;\n        if (child > end)\n            return;\n\n        swap_idx = root;\n\n        if (GGUFTensorRangeGreater(tensor_rel_offsets[child],\n                                   tensor_nbytes[child],\n                                   tensor_rel_offsets[swap_idx],\n                                   tensor_nbytes[swap_idx]))\n            swap_idx = child;\n\n        if (child + 1 <= end &&\n            GGUFTensorRangeGreater(tensor_rel_offsets[child + 1],\n                                   tensor_nbytes[child + 1],\n                                   tensor_rel_offsets[swap_idx],\n                                   tensor_nbytes[swap_idx]))\n            swap_idx = child + 1;\n\n        if (swap_idx == root)\n            return;\n\n        GGUFSwapU64(&tensor_rel_offsets[root], &tensor_rel_offsets[swap_idx]);\n        GGUFSwapU64(&tensor_nbytes[root], &tensor_nbytes[swap_idx]);\n        root = swap_idx;\n    }\n}\n\nU0 GGUFTensorSortRangesByOffset(U64 tensor_count,\n                                U64 *tensor_rel_offsets,\n                                U64 *tensor_nbytes)\n{\n    U64 start;\n    U64 end;\n\n    if (tensor_count < 2)\n        return;\n\n    // In-place heapsort by relative offset so overlap detection can scan once.\n    // We swap offset and nbytes together to preserve each tensor range pair.\n    start = (tensor_count - 2) / 2 + 1;\n    while (start > 0)\n    {\n        --start;\n        GGUFTensorRangeSiftDown(tensor_rel_offsets,\n                                tensor_nbytes,\n                                start,\n                                tensor_count - 1);\n    }\n\n    end = tensor_count - 1;\n    while (end > 0)\n    {\n        GGUFSwapU64(&tensor_rel_offsets[0], &tensor_rel_offsets[end]);\n        GGUFSwapU64(&tensor_nbytes[0], &tensor_nbytes[end]);\n\n        --end;\n        GGUFTensorRangeSiftDown(tensor_rel_offsets,\n                                tensor_nbytes,\n                                0,\n                                end);\n    }\n}\n\nBool GGUFTensorAbsRangeGreater(U64 a_start,\n                               U64 a_end,\n                               U64 a_index,\n                               U64 b_start,\n                               U64 b_end,\n                               U64 b_index)\n{\n    if (a_start > b_start)\n        return TRUE;\n    if (a_start < b_start)\n        return FALSE;\n\n    if (a_end > b_end)\n        return TRUE;\n    if (a_end < b_end)\n        return FALSE;\n\n    // Final tie-break on original tensor index keeps ordering deterministic\n    // for exact-equal ranges from degenerate zero-byte tensors.\n    return a_index > b_index;\n}\n\nU0 GGUFTensorAbsRangeSiftDown(U64 *tensor_abs_starts,\n                              U64 *tensor_abs_ends,\n                              U64 *tensor_indices,\n                              U64 root,\n                              U64 end)\n{\n    U64 child;\n    U64 swap_idx;\n\n    while (TRUE)\n    {\n        child = root * 2 + 1;\n        if (child > end)\n            return;\n\n        swap_idx = root;\n\n        if (GGUFTensorAbsRangeGreater(tensor_abs_starts[child],\n                                      tensor_abs_ends[child],\n                                      tensor_indices[child],\n                                      tensor_abs_starts[swap_idx],\n                                      tensor_abs_ends[swap_idx],\n                                      tensor_indices[swap_idx]))\n            swap_idx = child;\n\n        if (child + 1 <= end &&\n            GGUFTensorAbsRangeGreater(tensor_abs_starts[child + 1],\n                                      tensor_abs_ends[child + 1],\n                                      tensor_indices[child + 1],\n                                      tensor_abs_starts[swap_idx],\n                                      tensor_abs_ends[swap_idx],\n                                      tensor_indices[swap_idx]))\n            swap_idx = child + 1;\n\n        if (swap_idx == root)\n            return;\n\n        GGUFSwapU64(&tensor_abs_starts[root], &tensor_abs_starts[swap_idx]);\n        GGUFSwapU64(&tensor_abs_ends[root], &tensor_abs_ends[swap_idx]);\n        GGUFSwapU64(&tensor_indices[root], &tensor_indices[swap_idx]);\n        root = swap_idx;\n    }\n}\n\nU0 GGUFTensorSortAbsRangesWithIndices(U64 tensor_count,\n                                      U64 *tensor_abs_starts,\n                                      U64 *tensor_abs_ends,\n                                      U64 *tensor_indices)\n{\n    U64 start;\n    U64 end;\n\n    if (tensor_count < 2)\n        return;\n\n    // In-place heapsort over (abs_start, abs_end, original_index) tuples.\n    start = (tensor_count - 2) / 2 + 1;\n    while (start > 0)\n    {\n        --start;\n        GGUFTensorAbsRangeSiftDown(tensor_abs_starts,\n                                   tensor_abs_ends,\n                                   tensor_indices,\n                                   start,\n                                   tensor_count - 1);\n    }\n\n    end = tensor_count - 1;\n    while (end > 0)\n    {\n        GGUFSwapU64(&tensor_abs_starts[0], &tensor_abs_starts[end]);\n        GGUFSwapU64(&tensor_abs_ends[0], &tensor_abs_ends[end]);\n        GGUFSwapU64(&tensor_indices[0], &tensor_indices[end]);\n\n        --end;\n        GGUFTensorAbsRangeSiftDown(tensor_abs_starts,\n                                   tensor_abs_ends,\n                                   tensor_indices,\n                                   0,\n                                   end);\n    }\n}\n\nI64 GGUFValidateTensorRangesSorted(U64 tensor_data_base,\n                                   U32 alignment,\n                                   U64 gguf_file_nbytes,\n                                   U64 tensor_count,\n                                   U64 *tensor_rel_offsets,\n                                   U64 *tensor_nbytes,\n                                   U64 *out_bad_index)\n{\n    U64 i;\n    U64 start_i;\n    U64 end_i;\n    U64 max_end;\n    I64 err;\n\n    if (!tensor_rel_offsets || !tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (out_bad_index)\n        *out_bad_index = 0;\n\n    // Pass 1: preserve strict per-range validation behavior from\n    // GGUFValidateTensorRanges before any in-place reordering.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorResolveRange(tensor_data_base,\n                                     tensor_rel_offsets[i],\n                                     tensor_nbytes[i],\n                                     gguf_file_nbytes,\n                                     alignment,\n                                     &start_i,\n                                     &end_i);\n        if (err != GGUF_TDBASE_OK)\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return err;\n        }\n    }\n\n    if (tensor_count < 2)\n        return GGUF_TDBASE_OK;\n\n    // Sort in-place by tensor relative offsets.\n    GGUFTensorSortRangesByOffset(tensor_count,\n                                 tensor_rel_offsets,\n                                 tensor_nbytes);\n\n    // Single linear overlap scan over half-open ranges [start, end).\n    err = GGUFTensorResolveRange(tensor_data_base,\n                                 tensor_rel_offsets[0],\n                                 tensor_nbytes[0],\n                                 gguf_file_nbytes,\n                                 alignment,\n                                 &start_i,\n                                 &max_end);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    for (i = 1; i < tensor_count; ++i)\n    {\n        err = GGUFTensorResolveRange(tensor_data_base,\n                                     tensor_rel_offsets[i],\n                                     tensor_nbytes[i],\n                                     gguf_file_nbytes,\n                                     alignment,\n                                     &start_i,\n                                     &end_i);\n        if (err != GGUF_TDBASE_OK)\n            return err;\n\n        if (start_i < max_end)\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return GGUF_TDBASE_ERR_OVERLAP;\n        }\n\n        if (end_i > max_end)\n            max_end = end_i;\n    }\n\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorInfoResolveByteSpans(U64 tensor_data_base,\n                                   U32 alignment,\n                                   U64 gguf_file_nbytes,\n                                   U64 tensor_count,\n                                   U64 *tensor_rel_offsets,\n                                   U64 *tensor_element_counts,\n                                   U32 *tensor_ggml_types,\n                                   U64 *out_tensor_nbytes,\n                                   U64 *out_bad_index)\n{\n    U64 i;\n    I64 err;\n\n    if (!tensor_rel_offsets || !tensor_element_counts ||\n        !tensor_ggml_types || !out_tensor_nbytes)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    if (out_bad_index)\n        *out_bad_index = 0;\n\n    // Pass 1: compute payload byte spans directly from ggml type + element count.\n    // This keeps tensor sizing math centralized in GGUFTensorBytesForType.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorBytesForType(tensor_ggml_types[i],\n                                     tensor_element_counts[i],\n                                     &out_tensor_nbytes[i]);\n        if (err != GGUF_TDBASE_OK)\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return err;\n        }\n    }\n\n    // Pass 2: validate and sort ranges using the computed byte spans.\n    // GGUFValidateTensorRangesSorted reorders offsets and nbytes in-place.\n    return GGUFValidateTensorRangesSorted(tensor_data_base,\n                                          alignment,\n                                          gguf_file_nbytes,\n                                          tensor_count,\n                                          tensor_rel_offsets,\n                                          out_tensor_nbytes,\n                                          out_bad_index);\n}\n\nI64 GGUFTensorInfoResolveAbsRanges(U64 tensor_data_base,\n                                   U32 alignment,\n                                   U64 gguf_file_nbytes,\n                                   U64 tensor_count,\n                                   U64 *tensor_rel_offsets,\n                                   U64 *tensor_element_counts,\n                                   U32 *tensor_ggml_types,\n                                   U64 *out_tensor_nbytes,\n                                   U64 *out_abs_starts,\n                                   U64 *out_abs_ends,\n                                   U64 *out_bad_index)\n{\n    U64 i;\n    U64 abs_start;\n    I64 err;\n\n    if (!out_abs_starts || !out_abs_ends)\n        return GGUF_TDBASE_ERR_NULL_PTR;\n\n    // First derive byte spans, enforce alignment/EOF safety, and sort\n    // tensor_rel_offsets + out_tensor_nbytes in-place for monotonic scanning.\n    err = GGUFTensorInfoResolveByteSpans(tensor_data_base,\n                                         alignment,\n                                         gguf_file_nbytes,\n                                         tensor_count,\n                                         tensor_rel_offsets,\n                                         tensor_element_counts,\n                                         tensor_ggml_types,\n                                         out_tensor_nbytes,\n                                         out_bad_index);\n    if (err != GGUF_TDBASE_OK)\n        return err;\n\n    // With validated sorted ranges, resolve absolute [start,end) spans.\n    for (i = 0; i < tensor_count; ++i)\n    {\n        err = GGUFTensorDataBaseOffset(tensor_data_base,\n                                       tensor_rel_offsets[i],\n                                       alignment,\n                                       &abs_start);\n        if (err != GGUF_TDBASE_OK)\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return err;\n        }\n\n        if (abs_start > 0xFFFFFFFFFFFFFFFF - out_tensor_nbytes[i])\n        {\n            if (out_bad_index)\n                *out_bad_index = i;\n            return GGUF_TDBASE_ERR_OVERFLOW;\n        }\n\n        out_abs_starts[i] = abs_start;\n        out_abs_ends[i] = abs_start + out_tensor_nbytes[i];\n    }\n\n    return GGUF_TDBASE_OK;\n}\n\nI64 GGUFTensorInfoBuildOffsetIndex(U64 tensor_data_base,\n                                   U32 alignment,\n                                   U64 gguf_file_nbytes,\n                                   U64 tensor_count,\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUF tensor-data base alignment and offset semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_TDBASE_OK = 0\nGGUF_TDBASE_ERR_NULL_PTR = 1\nGGUF_TDBASE_ERR_BAD_ALIGNMENT = 2\nGGUF_TDBASE_ERR_OVERFLOW = 3\nGGUF_TDBASE_ERR_MISALIGNED_BASE = 4\nGGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET = 5\nGGUF_TDBASE_ERR_BAD_TYPE = 6\nGGUF_TDBASE_ERR_OUT_OF_BOUNDS = 7\nGGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE = 8\nGGUF_TDBASE_ERR_OVERLAP = 9\n\nGGUF_DEFAULT_ALIGNMENT = 32\nU64_MAX = (1 << 64) - 1\n\nGGML_TYPE_F32 = 0\nGGML_TYPE_F16 = 1\nGGML_TYPE_Q4_0 = 2\nGGML_TYPE_Q8_0 = 8\n\n\ndef tensor_type_block_size(ggml_type: int):\n    if ggml_type == GGML_TYPE_F32:\n        return GGUF_TDBASE_OK, 1\n    if ggml_type == GGML_TYPE_F16:\n        return GGUF_TDBASE_OK, 1\n    if ggml_type == GGML_TYPE_Q4_0:\n        return GGUF_TDBASE_OK, 32\n    if ggml_type == GGML_TYPE_Q8_0:\n        return GGUF_TDBASE_OK, 32\n    return GGUF_TDBASE_ERR_BAD_TYPE, 0\n\n\ndef tensor_type_block_bytes(ggml_type: int):\n    if ggml_type == GGML_TYPE_F32:\n        return GGUF_TDBASE_OK, 4\n    if ggml_type == GGML_TYPE_F16:\n        return GGUF_TDBASE_OK, 2\n    if ggml_type == GGML_TYPE_Q4_0:\n        return GGUF_TDBASE_OK, 18\n    if ggml_type == GGML_TYPE_Q8_0:\n        return GGUF_TDBASE_OK, 34\n    return GGUF_TDBASE_ERR_BAD_TYPE, 0\n\n\ndef is_pow2_u32(value: int) -> bool:\n    return value > 0 and (value & (value - 1)) == 0\n\n\ndef tensor_bytes_for_type(ggml_type: int, element_count: int):\n    err, block_size = tensor_type_block_size(ggml_type)\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    err, block_bytes = tensor_type_block_bytes(ggml_type)\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    if element_count % block_size != 0:\n        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0\n\n    block_count = element_count // block_size\n    if block_count > U64_MAX // block_bytes:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0\n\n    return GGUF_TDBASE_OK, block_count * block_bytes\n\n\ndef validate_alignment(alignment: int) -> int:\n    if not is_pow2_u32(alignment):\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    return GGUF_TDBASE_OK\n\n\ndef align_up_u64(value: int, alignment: int):\n    err = validate_alignment(alignment)\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    mask = alignment - 1\n    if value > U64_MAX - mask:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0\n\n    out = (value + mask) & ~mask\n    return GGUF_TDBASE_OK, out\n\n\ndef tensor_data_base_align(cursor_after_tensor_info: int, alignment: int):\n    return align_up_u64(cursor_after_tensor_info, alignment)\n\n\ndef tensor_data_base_align_default(cursor_after_tensor_info: int):\n    return tensor_data_base_align(cursor_after_tensor_info, GGUF_DEFAULT_ALIGNMENT)\n\n\ndef tensor_data_base_is_aligned(offset: int, alignment: int) -> bool:\n    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n        return False\n    return (offset & (alignment - 1)) == 0\n\n\ndef tensor_data_base_offset(tensor_data_base: int, tensor_rel_offset: int, alignment: int):\n    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n        return GGUF_TDBASE_ERR_BAD_ALIGNMENT, 0\n    if not tensor_data_base_is_aligned(tensor_data_base, alignment):\n        return GGUF_TDBASE_ERR_MISALIGNED_BASE, 0\n    if not tensor_data_base_is_aligned(tensor_rel_offset, alignment):\n        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET, 0\n    if tensor_data_base > U64_MAX - tensor_rel_offset:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    return GGUF_TDBASE_OK, tensor_data_base + tensor_rel_offset\n\n\ndef tensor_data_base_offset_default(tensor_data_base: int, tensor_rel_offset: int):\n    return tensor_data_base_offset(tensor_data_base, tensor_rel_offset, GGUF_DEFAULT_ALIGNMENT)\n\n\ndef tensor_resolve_range(\n    tensor_data_base: int,\n    tensor_rel_offset: int,\n    tensor_nbytes: int,\n    gguf_file_nbytes: int,\n    alignment: int,\n):\n    err, abs_start = tensor_data_base_offset(tensor_data_base, tensor_rel_offset, alignment)\n    if err != GGUF_TDBASE_OK:\n        return err, 0, 0\n\n    if abs_start > U64_MAX - tensor_nbytes:\n        return GGUF_TDBASE_ERR_OVERFLOW, 0, 0\n\n    abs_end = abs_start + tensor_nbytes\n    if abs_end > gguf_file_nbytes:\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0\n\n    return GGUF_TDBASE_OK, abs_start, abs_end\n\n\ndef tensor_resolve_range_default(\n    tensor_data_base: int,\n    tensor_rel_offset: int,\n    tensor_nbytes: int,\n    gguf_file_nbytes: int,\n):\n    return tensor_resolve_range(\n        tensor_data_base,\n        tensor_rel_offset,\n        tensor_nbytes,\n        gguf_file_nbytes,\n        GGUF_DEFAULT_ALIGNMENT,\n    )\n\n\ndef validate_tensor_ranges(\n    tensor_data_base: int,\n    alignment: int,\n    gguf_file_nbytes: int,\n    tensor_rel_offsets: list[int],\n    tensor_nbytes: list[int],\n):\n    if len(tensor_rel_offsets) != len(tensor_nbytes):\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    count = len(tensor_rel_offsets)\n\n    for i in range(count):\n        err, _, _ = tensor_resolve_range(\n            tensor_data_base,\n            tensor_rel_offsets[i],\n            tensor_nbytes[i],\n            gguf_file_nbytes,\n            alignment,\n        )\n        if err != GGUF_TDBASE_OK:\n            return err, i\n\n    for i in range(count):\n        err, start_i, end_i = tensor_resolve_range(\n            tensor_data_base,\n            tensor_rel_offsets[i],\n            tensor_nbytes[i],\n            gguf_file_nbytes,\n            alignment,\n        )\n        assert err == GGUF_TDBASE_OK\n\n        for j in range(i + 1, count):\n            err, start_j, end_j = tensor_resolve_range(\n                tensor_data_base,\n                tensor_rel_offsets[j],\n                tensor_nbytes[j],\n                gguf_file_nbytes,\n                alignment,\n            )\n            assert err == GGUF_TDBASE_OK\n\n            if (start_i < end_j) and (start_j < end_i):\n                return GGUF_TDBASE_ERR_OVERLAP, j\n\n    return GGUF_TDBASE_OK, 0\n\n\ndef _sift_down(rel_offsets: list[int], nbytes: list[int], root: int, end: int) -> None:\n    def greater(i: int, j: int) -> bool:\n        if rel_offsets[i] > rel_offsets[j]:\n            return True\n        if rel_offsets[i] < rel_offsets[j]:\n            return False\n        return nbytes[i] > nbytes[j]\n\n    while True:\n        child = root * 2 + 1\n        if child > end:\n            return\n\n        swap_idx = root\n        if greater(child, swap_idx):\n            swap_idx = child\n        if child + 1 <= end and greater(child + 1, swap_idx):\n            swap_idx = child + 1\n\n        if swap_idx == root:\n            return\n\n        rel_offsets[root], rel_offsets[swap_idx] = rel_offsets[swap_idx], rel_offsets[root]\n        nbytes[root], nbytes[swap_idx] = nbytes[swap_idx], nbytes[root]\n        root = swap_idx\n\n\ndef _heapsort_ranges_in_place(rel_offsets: list[int], nbytes: list[int]) -> None:\n    count = len(rel_offsets)\n    if count < 2:\n        return\n\n    start = ((count - 2) // 2) + 1\n    while start > 0:\n        start -= 1\n        _sift_down(rel_offsets, nbytes, start, count - 1)\n\n    end = count - 1\n    while end > 0:\n        rel_offsets[0], rel_offsets[end] = rel_offsets[end], rel_offsets[0]\n        nbytes[0], nbytes[end] = nbytes[end], nbytes[0]\n        end -= 1\n        _sift_down(rel_offsets, nbytes, 0, end)\n\n\ndef validate_tensor_ranges_sorted(\n    tensor_data_base: int,\n    alignment: int,\n    gguf_file_nbytes: int,\n    tensor_rel_offsets: list[int],\n    tensor_nbytes: list[int],\n):\n    if len(tensor_rel_offsets) != len(tensor_nbytes):\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    count = len(tensor_rel_offsets)\n\n    for i in range(count):\n        err, _, _ = tensor_resolve_range(\n            tensor_data_base,\n            tensor_rel_offsets[i],\n            tensor_nbytes[i],\n            gguf_file_nbytes,\n            alignment,\n        )\n        if err != GGUF_TDBASE_OK:\n            return err, i\n\n    if count < 2:\n        return GGUF_TDBASE_OK, 0\n\n    _heapsort_ranges_in_place(tensor_rel_offsets, tensor_nbytes)\n\n    err, _, max_end = tensor_resolve_range(\n        tensor_data_base,\n        tensor_rel_offsets[0],\n        tensor_nbytes[0],\n        gguf_file_nbytes,\n        alignment,\n    )\n    assert err == GGUF_TDBASE_OK\n\n    for i in range(1, count):\n        err, start_i, end_i = tensor_resolve_range(\n            tensor_data_base,\n            tensor_rel_offsets[i],\n            tensor_nbytes[i],\n            gguf_file_nbytes,\n            alignment,\n        )\n        assert err == GGUF_TDBASE_OK\n\n        if start_i < max_end:\n            return GGUF_TDBASE_ERR_OVERLAP, i\n\n        if end_i > max_end:\n            max_end = end_i\n\n    return GGUF_TDBASE_OK, 0\n\n\ndef tensor_info_resolve_byte_spans(\n    tensor_data_base: int,\n    alignment: int,\n    gguf_file_nbytes: int,\n    tensor_rel_offsets: list[int],\n    tensor_element_counts: list[int],\n    tensor_ggml_types: list[int],\n    out_tensor_nbytes: list[int],\n):\n    count = len(tensor_rel_offsets)\n\n---\n\n    if len(tensor_element_counts) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n    if len(tensor_ggml_types) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n    if len(out_tensor_nbytes) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    for i in range(count):\n        err, nbytes = tensor_bytes_for_type(tensor_ggml_types[i], tensor_element_counts[i])\n        if err != GGUF_TDBASE_OK:\n            return err, i\n        out_tensor_nbytes[i] = nbytes\n\n    return validate_tensor_ranges_sorted(\n        tensor_data_base=tensor_data_base,\n        alignment=alignment,\n        gguf_file_nbytes=gguf_file_nbytes,\n        tensor_rel_offsets=tensor_rel_offsets,\n        tensor_nbytes=out_tensor_nbytes,\n    )\n\n\ndef tensor_info_resolve_abs_ranges(\n    tensor_data_base: int,\n    alignment: int,\n    gguf_file_nbytes: int,\n    tensor_rel_offsets: list[int],\n    tensor_element_counts: list[int],\n    tensor_ggml_types: list[int],\n    out_tensor_nbytes: list[int],\n    out_abs_starts: list[int],\n    out_abs_ends: list[int],\n):\n    count = len(tensor_rel_offsets)\n\n    if len(out_abs_starts) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n    if len(out_abs_ends) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    err, bad = tensor_info_resolve_byte_spans(\n        tensor_data_base=tensor_data_base,\n        alignment=alignment,\n        gguf_file_nbytes=gguf_file_nbytes,\n        tensor_rel_offsets=tensor_rel_offsets,\n        tensor_element_counts=tensor_element_counts,\n        tensor_ggml_types=tensor_ggml_types,\n        out_tensor_nbytes=out_tensor_nbytes,\n    )\n    if err != GGUF_TDBASE_OK:\n        return err, bad\n\n    for i in range(count):\n        err_off, abs_start = tensor_data_base_offset(\n            tensor_data_base, tensor_rel_offsets[i], alignment\n        )\n        if err_off != GGUF_TDBASE_OK:\n            return err_off, i\n\n        nbytes = out_tensor_nbytes[i]\n        if abs_start > U64_MAX - nbytes:\n            return GGUF_TDBASE_ERR_OVERFLOW, i\n\n        out_abs_starts[i] = abs_start\n        out_abs_ends[i] = abs_start + nbytes\n\n    return GGUF_TDBASE_OK, 0\n\n\ndef tensor_range_find_by_abs_offset(\n    abs_offset: int,\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n):\n    count = len(tensor_abs_starts)\n    if len(tensor_abs_ends) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n    if count == 0:\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0\n\n    lo = 0\n    hi = count\n    while lo < hi:\n        mid = lo + ((hi - lo) >> 1)\n        start_mid = tensor_abs_starts[mid]\n        end_mid = tensor_abs_ends[mid]\n\n        if end_mid < start_mid:\n            return GGUF_TDBASE_ERR_OVERFLOW, 0\n\n        if abs_offset < start_mid:\n            hi = mid\n            continue\n\n        if abs_offset >= end_mid:\n            lo = mid + 1\n            continue\n\n        return GGUF_TDBASE_OK, mid\n\n    return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0\n\n\ndef tensor_range_find_by_rel_offset(\n    tensor_rel_offset: int,\n    tensor_data_base: int,\n    alignment: int,\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n):\n    err, abs_offset = tensor_data_base_offset(\n        tensor_data_base=tensor_data_base,\n        tensor_rel_offset=tensor_rel_offset,\n        alignment=alignment,\n    )\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    return tensor_range_find_by_abs_offset(\n        abs_offset=abs_offset,\n        tensor_abs_starts=tensor_abs_starts,\n        tensor_abs_ends=tensor_abs_ends,\n    )\n\n\ndef tensor_range_find_by_rel_offset_default(\n    tensor_rel_offset: int,\n    tensor_data_base: int,\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n):\n    return tensor_range_find_by_rel_offset(\n        tensor_rel_offset=tensor_rel_offset,\n        tensor_data_base=tensor_data_base,\n        alignment=GGUF_DEFAULT_ALIGNMENT,\n        tensor_abs_starts=tensor_abs_starts,\n        tensor_abs_ends=tensor_abs_ends,\n    )\n\n\ndef tensor_range_find_index_by_abs_offset(\n    abs_offset: int,\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n    sorted_tensor_indices: list[int],\n):\n    count = len(tensor_abs_starts)\n    if len(tensor_abs_ends) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n    if len(sorted_tensor_indices) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    err, sorted_pos = tensor_range_find_by_abs_offset(\n        abs_offset=abs_offset,\n        tensor_abs_starts=tensor_abs_starts,\n        tensor_abs_ends=tensor_abs_ends,\n    )\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    if sorted_pos >= count:\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0\n\n    orig_idx = sorted_tensor_indices[sorted_pos]\n    if orig_idx >= count:\n        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0\n\n    return GGUF_TDBASE_OK, orig_idx\n\n\ndef tensor_range_find_index_by_rel_offset(\n    tensor_rel_offset: int,\n    tensor_data_base: int,\n    alignment: int,\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n    sorted_tensor_indices: list[int],\n):\n    err, abs_offset = tensor_data_base_offset(\n        tensor_data_base=tensor_data_base,\n        tensor_rel_offset=tensor_rel_offset,\n        alignment=alignment,\n    )\n    if err != GGUF_TDBASE_OK:\n        return err, 0\n\n    return tensor_range_find_index_by_abs_offset(\n        abs_offset=abs_offset,\n        tensor_abs_starts=tensor_abs_starts,\n        tensor_abs_ends=tensor_abs_ends,\n        sorted_tensor_indices=sorted_tensor_indices,\n    )\n\n\ndef tensor_range_find_index_by_rel_offset_default(\n    tensor_rel_offset: int,\n    tensor_data_base: int,\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n    sorted_tensor_indices: list[int],\n):\n    return tensor_range_find_index_by_rel_offset(\n        tensor_rel_offset=tensor_rel_offset,\n        tensor_data_base=tensor_data_base,\n        alignment=GGUF_DEFAULT_ALIGNMENT,\n        tensor_abs_starts=tensor_abs_starts,\n        tensor_abs_ends=tensor_abs_ends,\n        sorted_tensor_indices=sorted_tensor_indices,\n    )\n\n\ndef validate_sorted_tensor_index(\n    tensor_abs_starts: list[int],\n    tensor_abs_ends: list[int],\n    sorted_tensor_indices: list[int],\n):\n    count = len(tensor_abs_starts)\n    if len(tensor_abs_ends) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n    if len(sorted_tensor_indices) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    for i in range(count):\n        start_i = tensor_abs_starts[i]\n        end_i = tensor_abs_ends[i]\n        idx_i = sorted_tensor_indices[i]\n\n        if end_i < start_i:\n            return GGUF_TDBASE_ERR_OVERFLOW, i\n\n        if i > 0:\n            prev_start = tensor_abs_starts[i - 1]\n            prev_end = tensor_abs_ends[i - 1]\n\n            if start_i < prev_start:\n                return GGUF_TDBASE_ERR_OVERLAP, i\n            if start_i == prev_start and end_i < prev_end:\n                return GGUF_TDBASE_ERR_OVERLAP, i\n            if start_i < prev_end:\n                return GGUF_TDBASE_ERR_OVERLAP, i\n\n        if idx_i >= count:\n            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, i\n\n        for j in range(i):\n            if sorted_tensor_indices[j] == idx_i:\n                return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, i\n\n    return GGUF_TDBASE_OK, 0\n\n\ndef build_tensor_sorted_position_map(\n    sorted_tensor_indices: list[int],\n    out_sorted_position_by_tensor: list[int],\n):\n    count = len(sorted_tensor_indices)\n    if len(out_sorted_position_by_tensor) != count:\n        return GGUF_TDBASE_ERR_NULL_PTR, 0\n\n    for i in range(count):\n        out_sorted_position_by_tensor[i] = count\n\n    for i in range(count):\n        tensor_index = sorted_tensor_indices[i]\n\n        if tensor_index >= count:\n            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, i\n\n        if out_sorted_position_by_tensor[tensor_index] != count:\n            return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, i\n\n        out_sorted_position_by_tensor[tensor_index] = i\n\n    for i in range(count):\n        if out_sorted_position_by_tensor[i] == count:\n            return GGUF_TDBASE