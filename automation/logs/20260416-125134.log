{"type":"item.completed","item":{"id":"item_46","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/matmul/q8_0_matmul.HC | sed -n '1,240p'; echo '---'; nl -ba tests/test_q8_0_matmul_tiled_checked.py | sed -n '1,260p'; echo '---'; nl -ba MASTER_TASKS.md | sed -n '282,304p'\"","aggregated_output":"     1\t// q8_0_matmul.HC\n     2\t// Checked tiled Q8_0 matmul kernel for TempleOS.\n     3\t//\n     4\t// Runtime contract:\n     5\t//   - lhs is an MxK matrix in row-major block layout (Q8_0 blocks).\n     6\t//   - rhs is an NxK matrix in row-major \"column bank\" layout where each output\n     7\t//     column of logical B (KxN) is stored as one contiguous row of K blocks.\n     8\t//     This keeps every output cell as an explicit row-dot between two block rows.\n     9\t//   - out is MxN Q16 matrix (I64 lanes) with explicit output row stride.\n    10\t\n    11\t#define Q8_0_MATMUL_VALUES_PER_BLOCK 32\n    12\t#define Q8_0_MATMUL_PACKED_BYTES     32\n    13\t\n    14\t#define Q8_0_MATMUL_OK               0\n    15\t#define Q8_0_MATMUL_ERR_NULL_PTR     1\n    16\t#define Q8_0_MATMUL_ERR_BAD_DST_LEN  2\n    17\t#define Q8_0_MATMUL_ERR_OVERFLOW     3\n    18\t#define Q8_0_MATMUL_I64_MAX          0x7FFFFFFFFFFFFFFF\n    19\t\n    20\tclass Q8_0Block\n    21\t{\n    22\t    U16 d_fp16;\n    23\t    I8 qs[Q8_0_MATMUL_PACKED_BYTES];\n    24\t};\n    25\t\n    26\t// Declared in src/quant/q8_0_dot.HC.\n    27\tI32 Q8_0DotProductBlocksQ16AccumulateChecked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16);\n    28\t\n    29\tBool Q8_0MatMulTryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n    30\t{\n    31\t    if (!out_prod)\n    32\t        return FALSE;\n    33\t    if (lhs < 0 || rhs < 0)\n    34\t        return FALSE;\n    35\t\n    36\t    if (!lhs || !rhs)\n    37\t    {\n    38\t        *out_prod = 0;\n    39\t        return TRUE;\n    40\t    }\n    41\t\n    42\t    if (lhs > Q8_0_MATMUL_I64_MAX / rhs)\n    43\t        return FALSE;\n    44\t\n    45\t    *out_prod = lhs * rhs;\n    46\t    return TRUE;\n    47\t}\n    48\t\n    49\tBool Q8_0MatMulTryAddI64NonNeg(I64 lhs, I64 rhs, I64 *out_sum)\n    50\t{\n    51\t    if (!out_sum)\n    52\t        return FALSE;\n    53\t    if (lhs < 0 || rhs < 0)\n    54\t        return FALSE;\n    55\t    if (lhs > Q8_0_MATMUL_I64_MAX - rhs)\n    56\t        return FALSE;\n    57\t\n    58\t    *out_sum = lhs + rhs;\n    59\t    return TRUE;\n    60\t}\n    61\t\n    62\tI64 Q8_0MatMulMinI64(I64 lhs, I64 rhs)\n    63\t{\n    64\t    if (lhs < rhs)\n    65\t        return lhs;\n    66\t    return rhs;\n    67\t}\n    68\t\n    69\tI32 Q8_0MatMulQ16TiledChecked(\n    70\t    Q8_0Block *lhs_blocks,\n    71\t    I64 lhs_block_capacity,\n    72\t    I64 row_count,\n    73\t    I64 lhs_row_stride_blocks,\n    74\t    Q8_0Block *rhs_col_blocks,\n    75\t    I64 rhs_block_capacity,\n    76\t    I64 col_count,\n    77\t    I64 rhs_col_stride_blocks,\n    78\t    I64 k_block_count,\n    79\t    I64 tile_rows,\n    80\t    I64 tile_cols,\n    81\t    I64 *out_cells_q16,\n    82\t    I64 out_cell_capacity,\n    83\t    I64 out_row_stride_cells)\n    84\t{\n    85\t    I64 lhs_required_blocks;\n    86\t    I64 rhs_required_blocks;\n    87\t    I64 out_required_cells;\n    88\t    I64 row_tile_start;\n    89\t    I64 col_tile_start;\n    90\t    I64 row_tile_end;\n    91\t    I64 col_tile_end;\n    92\t    I64 row_index;\n    93\t    I64 col_index;\n    94\t    I64 lhs_row_base;\n    95\t    I64 rhs_col_base;\n    96\t    I64 out_row_base;\n    97\t    I64 out_index;\n    98\t    I64 cell_dot_q16;\n    99\t    Q8_0Block *lhs_row_ptr;\n   100\t    Q8_0Block *rhs_col_ptr;\n   101\t    I32 status;\n   102\t\n   103\t    if (!lhs_blocks || !rhs_col_blocks || !out_cells_q16)\n   104\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n   105\t\n   106\t    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_cell_capacity < 0)\n   107\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   108\t    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n   109\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   110\t    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n   111\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   112\t    if (tile_rows <= 0 || tile_cols <= 0)\n   113\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   114\t\n   115\t    // Active K span must fit inside each source row stride.\n   116\t    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n   117\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   118\t\n   119\t    // Output row stride must cover active output columns.\n   120\t    if (row_count > 0 && out_row_stride_cells < col_count)\n   121\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   122\t\n   123\t    // Capacity proofs for full row-strided views.\n   124\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n   125\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   126\t    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n   127\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   128\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n   129\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   130\t\n   131\t    if (lhs_required_blocks > lhs_block_capacity)\n   132\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   133\t    if (rhs_required_blocks > rhs_block_capacity)\n   134\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   135\t    if (out_required_cells > out_cell_capacity)\n   136\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   137\t\n   138\t    // Tiled traversal keeps working-set bounded while preserving direct math visibility.\n   139\t    row_tile_start = 0;\n   140\t    while (row_tile_start < row_count)\n   141\t    {\n   142\t        if (!Q8_0MatMulTryAddI64NonNeg(row_tile_start, tile_rows, &row_tile_end))\n   143\t            return Q8_0_MATMUL_ERR_OVERFLOW;\n   144\t        row_tile_end = Q8_0MatMulMinI64(row_tile_end, row_count);\n   145\t\n   146\t        col_tile_start = 0;\n   147\t        while (col_tile_start < col_count)\n   148\t        {\n   149\t            if (!Q8_0MatMulTryAddI64NonNeg(col_tile_start, tile_cols, &col_tile_end))\n   150\t                return Q8_0_MATMUL_ERR_OVERFLOW;\n   151\t            col_tile_end = Q8_0MatMulMinI64(col_tile_end, col_count);\n   152\t\n   153\t            for (row_index = row_tile_start; row_index < row_tile_end; ++row_index)\n   154\t            {\n   155\t                if (!Q8_0MatMulTryMulI64NonNeg(row_index, lhs_row_stride_blocks, &lhs_row_base))\n   156\t                    return Q8_0_MATMUL_ERR_OVERFLOW;\n   157\t                if (!Q8_0MatMulTryMulI64NonNeg(row_index, out_row_stride_cells, &out_row_base))\n   158\t                    return Q8_0_MATMUL_ERR_OVERFLOW;\n   159\t\n   160\t                lhs_row_ptr = &lhs_blocks[lhs_row_base];\n   161\t\n   162\t                for (col_index = col_tile_start; col_index < col_tile_end; ++col_index)\n   163\t                {\n   164\t                    if (!Q8_0MatMulTryMulI64NonNeg(col_index, rhs_col_stride_blocks, &rhs_col_base))\n   165\t                        return Q8_0_MATMUL_ERR_OVERFLOW;\n   166\t                    if (!Q8_0MatMulTryAddI64NonNeg(out_row_base, col_index, &out_index))\n   167\t                        return Q8_0_MATMUL_ERR_OVERFLOW;\n   168\t\n   169\t                    rhs_col_ptr = &rhs_col_blocks[rhs_col_base];\n   170\t                    cell_dot_q16 = 0;\n   171\t\n   172\t                    status = Q8_0DotProductBlocksQ16AccumulateChecked(lhs_row_ptr, rhs_col_ptr, k_block_count, &cell_dot_q16);\n   173\t                    if (status != Q8_0_MATMUL_OK)\n   174\t                        return status;\n   175\t\n   176\t                    out_cells_q16[out_index] = cell_dot_q16;\n   177\t                }\n   178\t            }\n   179\t\n   180\t            col_tile_start = col_tile_end;\n   181\t        }\n   182\t\n   183\t        row_tile_start = row_tile_end;\n   184\t    }\n   185\t\n   186\t    return Q8_0_MATMUL_OK;\n   187\t}\n   188\t\n---\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Parity harness for checked tiled Q8_0 matmul semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\timport sys\n     8\tfrom pathlib import Path\n     9\t\n    10\tsys.path.insert(0, str(Path(__file__).resolve().parent))\n    11\t\n    12\tfrom test_q8_0_dot import (\n    13\t    Q8_0_ERR_BAD_DST_LEN,\n    14\t    Q8_0_ERR_OVERFLOW,\n    15\t    Q8_0_I64_MAX,\n    16\t    Q8_0_OK,\n    17\t    Q8_0_VALUES_PER_BLOCK,\n    18\t    dot_product_blocks_q16_accumulate_checked,\n    19\t    half_bits,\n    20\t    pack_signed,\n    21\t)\n    22\t\n    23\t\n    24\tdef try_mul_i64_nonneg(lhs: int, rhs: int) -> tuple[bool, int]:\n    25\t    if lhs < 0 or rhs < 0:\n    26\t        return False, 0\n    27\t    if lhs == 0 or rhs == 0:\n    28\t        return True, 0\n    29\t    if lhs > Q8_0_I64_MAX // rhs:\n    30\t        return False, 0\n    31\t    return True, lhs * rhs\n    32\t\n    33\t\n    34\tdef try_add_i64_nonneg(lhs: int, rhs: int) -> tuple[bool, int]:\n    35\t    if lhs < 0 or rhs < 0:\n    36\t        return False, 0\n    37\t    if lhs > Q8_0_I64_MAX - rhs:\n    38\t        return False, 0\n    39\t    return True, lhs + rhs\n    40\t\n    41\t\n    42\tdef q8_0_matmul_q16_tiled_checked(\n    43\t    lhs_blocks: list[tuple[int, bytes]],\n    44\t    lhs_block_capacity: int,\n    45\t    row_count: int,\n    46\t    lhs_row_stride_blocks: int,\n    47\t    rhs_col_blocks: list[tuple[int, bytes]],\n    48\t    rhs_block_capacity: int,\n    49\t    col_count: int,\n    50\t    rhs_col_stride_blocks: int,\n    51\t    k_block_count: int,\n    52\t    tile_rows: int,\n    53\t    tile_cols: int,\n    54\t    out_cell_capacity: int,\n    55\t    out_row_stride_cells: int,\n    56\t) -> tuple[int, list[int]]:\n    57\t    if lhs_block_capacity < 0 or rhs_block_capacity < 0 or out_cell_capacity < 0:\n    58\t        return Q8_0_ERR_BAD_DST_LEN, []\n    59\t    if row_count < 0 or col_count < 0 or k_block_count < 0:\n    60\t        return Q8_0_ERR_BAD_DST_LEN, []\n    61\t    if lhs_row_stride_blocks < 0 or rhs_col_stride_blocks < 0 or out_row_stride_cells < 0:\n    62\t        return Q8_0_ERR_BAD_DST_LEN, []\n    63\t    if tile_rows <= 0 or tile_cols <= 0:\n    64\t        return Q8_0_ERR_BAD_DST_LEN, []\n    65\t\n    66\t    if k_block_count > lhs_row_stride_blocks or k_block_count > rhs_col_stride_blocks:\n    67\t        return Q8_0_ERR_BAD_DST_LEN, []\n    68\t    if row_count > 0 and out_row_stride_cells < col_count:\n    69\t        return Q8_0_ERR_BAD_DST_LEN, []\n    70\t\n    71\t    ok, lhs_required = try_mul_i64_nonneg(row_count, lhs_row_stride_blocks)\n    72\t    if not ok:\n    73\t        return Q8_0_ERR_OVERFLOW, []\n    74\t    ok, rhs_required = try_mul_i64_nonneg(col_count, rhs_col_stride_blocks)\n    75\t    if not ok:\n    76\t        return Q8_0_ERR_OVERFLOW, []\n    77\t    ok, out_required = try_mul_i64_nonneg(row_count, out_row_stride_cells)\n    78\t    if not ok:\n    79\t        return Q8_0_ERR_OVERFLOW, []\n    80\t\n    81\t    if lhs_required > lhs_block_capacity:\n    82\t        return Q8_0_ERR_BAD_DST_LEN, []\n    83\t    if rhs_required > rhs_block_capacity:\n    84\t        return Q8_0_ERR_BAD_DST_LEN, []\n    85\t    if out_required > out_cell_capacity:\n    86\t        return Q8_0_ERR_BAD_DST_LEN, []\n    87\t\n    88\t    out_cells_q16 = [0] * out_required\n    89\t\n    90\t    row_tile_start = 0\n    91\t    while row_tile_start < row_count:\n    92\t        ok, row_tile_end = try_add_i64_nonneg(row_tile_start, tile_rows)\n    93\t        if not ok:\n    94\t            return Q8_0_ERR_OVERFLOW, []\n    95\t        row_tile_end = min(row_tile_end, row_count)\n    96\t\n    97\t      