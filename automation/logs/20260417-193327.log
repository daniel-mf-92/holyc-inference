ur,\n                                       table_end,\n                                       &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadU16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadU16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &third);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadU16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &fourth);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *out_fourth = fourth;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I16 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value)\n{\n    U64 cur;\n    U16 raw_u16;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared U16 checked reader so signed-I16 decode keeps\n    // identical cursor/bounds/no-partial-write behavior.\n    err = GGUFMetadataReadU16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &raw_u16);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Two's-complement reinterpretation is a plain cast in HolyC.\n    *out_value = (I16)raw_u16;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I16 tuple reader for compact metadata pair fields.\n// Contract: stages both I16 decodes through GGUFMetadataReadI16LEChecked and\n// commits outputs + cursor only when both lanes succeed.\nI32 GGUFMetadataReadI16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second)\n{\n    U64 cur;\n    I16 first;\n    I16 second;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage both scalar reads through the canonical signed-I16 helper so pair\n    // reads preserve identical bounds/overflow and no-partial-write behavior.\n    err = GGUFMetadataReadI16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian I16 triple reader for compact metadata tuple fields.\n// Contract: stages three I16 decodes through GGUFMetadataReadI16LEChecked and\n// commits outputs + cursor only when all lanes succeed.\nI32 GGUFMetadataReadI16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     I16 *out_first,\n                                     I16 *out_second,\n                                     I16 *out_third)\n{\n    U64 cur;\n    I16 first;\n    I16 second;\n    I16 third;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second || !out_third)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage all scalar reads through the canonical signed-I16 helper so\n    // triple reads preserve identical bounds/overflow semantics.\n    err = GGUFMetadataReadI16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadI16LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &third);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U32 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U32 *out_value)\n{\n    U64 cur;\n    U8 b0;\n    U8 b1;\n    U8 b2;\n    U8 b3;\n    I32 err;\n\n    if (!buf || !cursor || !out_value)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Reuse the canonical checked 1-byte reader so cursor/bounds semantics are\n    // identical across scalar-width metadata decoders.\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b0);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b1);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b2);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n    err = GGUFMetadataReadU8Checked(buf, buf_nbytes, &cur, table_end, &b3);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_value = ((U32)b0)\n               | (((U32)b1) << 8)\n               | (((U32)b2) << 16)\n               | (((U32)b3) << 24);\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U32 tuple reader for compact metadata pair fields.\n// Contract: stages both U32 decodes through GGUFMetadataReadU32LEChecked and\n// commits outputs + cursor only when both lanes succeed.\nI32 GGUFMetadataReadU32PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U32 *out_first,\n                                   U32 *out_second)\n{\n    U64 cur;\n    U32 first;\n    U32 second;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage both scalar reads through the canonical U32 helper so pair reads\n    // preserve identical bounds/overflow and no-partial-write behavior.\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U32 tuple reader for compact metadata triple fields.\n// Contract: stages three U32 decodes through GGUFMetadataReadU32LEChecked and\n// commits outputs + cursor only when all lanes succeed.\nI32 GGUFMetadataReadU32TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U32 *out_first,\n                                     U32 *out_second,\n                                     U32 *out_third)\n{\n    U64 cur;\n    U32 first;\n    U32 second;\n    U32 third;\n    I32 err;\n\n    if (!buf || !cursor || !out_first || !out_second || !out_third)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage all scalar reads through the canonical U32 helper so triple reads\n    // preserve identical bounds/overflow and no-partial-write behavior.\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &first);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &second);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadU32LEChecked(buf,\n                                       buf_nbytes,\n                                       &cur,\n                                       table_end,\n                                       &third);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first = first;\n    *out_second = second;\n    *out_third = third;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian U64 metadata reader.\n// Contract: writes `*out_value` and advances `*cursor` only on success.\nI32 GGUFMetadataReadU64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U64 *out_value)\n{\n    // Keep legacy symbol as the canonical parser entrypoint while routing\n    // decode through the explicit no-partial-write helper.\n    return GGUFMetadataReadU64LECheckedNoPartial(buf,\n                                                 buf_nbytes,\n                                                 cursor,\n                                                 table_end,\n                                                 out_value);\n}\n\n// Checked little-endian U64 metadata reader with explicit all-or-nothing\n// staging contract. Cursor/output are committed only after all 8 byte reads\n// succeed through the shared checked U8 reader.\nI32 GGUFMetadataReadU64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          U64 *out_value)\n{\n    U64 cur;\n    U8 b0;\n---f32 triple area---\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Stage both float32 lanes through the canonical checked scalar reader so\n    // pair decode preserves identical bounds/overflow/no-partial-write rules.\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &first_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &second_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first_bits = first_bits;\n    *out_second_bits = second_bits;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked metadata FLOAT32 raw-bit triple reader.\n// Contract: decodes three sequential little-endian FLOAT32 payload\n// bit-patterns through shared checked scalar staging and commits all\n// outputs + cursor only after all three lanes pass\n// (strict no-partial-write tuple semantics).\nI32 GGUFMetadataReadF32BitsTripleChecked(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n                                         U64 table_end,\n                                         U32 *out_first_bits,\n                                         U32 *out_second_bits,\n                                         U32 *out_third_bits)\n{\n    U64 cur;\n    U32 first_bits;\n    U32 second_bits;\n    U32 third_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_first_bits || !out_second_bits || !out_third_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode each lane through the canonical float32-bit checked reader so\n    // triple decode preserves identical bounds/overflow/no-partial-write rules.\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &first_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &second_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    err = GGUFMetadataReadF32BitsLEChecked(buf,\n                                           buf_nbytes,\n                                           &cur,\n                                           table_end,\n                                           &third_bits);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_first_bits = first_bits;\n    *out_second_bits = second_bits;\n    *out_third_bits = third_bits;\n    *cursor = cur;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked little-endian FLOAT64 bit-pattern metadata reader.\n// Runtime remains integer-only: the 64-bit payload is returned as raw bits\n// so callers can audit exact IEEE754 encodings without float math.\n// Contract: writes `*out_bits` and advances `*cursor` only on success.\nI32 GGUFMetadataReadF64BitsLEChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U64 *out_bits)\n{\n    U64 cur;\n    U64 raw_bits;\n    I32 err;\n\n    if (!buf || !cursor || !out_bits)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    cur = *cursor;\n\n    // Decode through the shared U64 checked reader so float64 payload bit\n    // extraction inherits identical cursor/bounds/no-partial-write behavior.\n","exit_code":0,"status":"completed"}}
