{"type":"item.completed","item":{"id":"item_18","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/math/softmax.HC; echo '---'; rg -n \\\"TopP|TopK|Sample|Argsort|Prefix|Checked\\\" src/math/softmax.HC | head -n 200; echo '---'; ls tests | rg \\\"softmax|topp|topk\\\" | sort\"","aggregated_output":"// softmax.HC\n// Integer-only Q16.16 softmax for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n#define U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\nI64 FPQ16Exp(I64 x);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Ln(I64 x_q16);\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16);\nI32 FPQ16ExpArrayFromClampedInputChecked(I64 *input_q16,\n                                         I64 *output_q16,\n                                         I64 count);\nI32 FPQ16ExpArrayCheckedNoAliasChecked(I64 *input_q16,\n                                       I64 *output_q16,\n                                       I64 count);\n\n// Checked Q16 temperature scaling helper for logits:\n//   scaled_logits_q16[i] = round_half_up(logits_q16[i] / temperature_q16)\n// which is equivalent to multiplying by reciprocal-temperature in Q16.\n// Contracts:\n//   - logits_q16 and scaled_logits_q16 are non-null.\n//   - lane_count >= 0.\n//   - temperature_q16 > 0 (rejects divide-by-zero and non-physical negative T).\n//   - logits_q16 and scaled_logits_q16 each address lane_count I64 lanes.\n//   - No partial writes: full lane preflight runs before output commit.\n// Notes:\n//   - Arithmetic routes through FPQ16MulDivRoundedChecked with b=1.0_q16 so\n//     scaling uses the same one-rounding checked divider as the rest of Q16\n//     softmax math.\nI32 FPQ16TemperatureScaleLogitsChecked(I64 *logits_q16,\n                                       I64 lane_count,\n                                       I64 temperature_q16,\n                                       I64 *scaled_logits_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 lane_value;\n    I32 status;\n\n    if (!logits_q16 || !scaled_logits_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (temperature_q16 <= 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic before indexed lane access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)scaled_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Preflight all lanes first so error paths never partially write output.\n    for (i = 0; i < lane_count; i++)\n    {\n        status = FPQ16MulDivRoundedChecked(logits_q16[i],\n                                           FP_Q16_ONE,\n                                           temperature_q16,\n                                           &lane_value);\n        if (status)\n            return status;\n    }\n\n    for (i = 0; i < lane_count; i++)\n    {\n        status = FPQ16MulDivRoundedChecked(logits_q16[i],\n                                           FP_Q16_ONE,\n                                           temperature_q16,\n                                           &scaled_logits_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked softmax split-phase helper for pre-clamped logits.\n// Phase performed here:\n//   1) exp_lanes_q16[i] = exp(preclamped_logits_q16[i])\n//   2) out_exp_sum_q16  = sum_i exp_lanes_q16[i] (checked I64 add)\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - preclamped_logits_q16 and exp_lanes_q16 must each address lane_count I64s\n//   - Any I64 accumulation overflow returns FP_Q16_ERR_OVERFLOW\n// Notes:\n//   - Pre-clamped domain validation and lane exp math are delegated to\n//     FPQ16ExpArrayFromClampedInputChecked so scalar/vector exp semantics stay\n//     centralized and auditable.\nI32 FPQ16SoftmaxExpPhaseFromPreclampedChecked(I64 *preclamped_logits_q16,\n                                              I64 *exp_lanes_q16,\n                                              I64 lane_count,\n                                              I64 *out_exp_sum_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !out_exp_sum_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Empty vectors are valid: no lanes, zero sum.\n    if (!lane_count)\n    {\n        *out_exp_sum_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Guard pointer-span arithmetic before any indexed access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)preclamped_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    status = FPQ16ExpArrayFromClampedInputChecked(preclamped_logits_q16,\n                                                  exp_lanes_q16,\n                                                  lane_count);\n    if (status)\n        return status;\n\n    exp_sum_q16 = 0;\n    for (i = 0; i < lane_count; i++)\n    {\n        if (exp_lanes_q16[i] > (I64_MAX_VALUE - exp_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        exp_sum_q16 += exp_lanes_q16[i];\n    }\n\n    *out_exp_sum_q16 = exp_sum_q16;\n    return FP_Q16_OK;\n}\n\n// Checked no-alias softmax exp-phase helper for immutable-logit callers.\n// Phase performed here:\n//   1) exp_lanes_q16[i] = exp(preclamped_logits_q16[i])\n//   2) out_exp_sum_q16  = sum_i exp_lanes_q16[i] (checked I64 add)\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - preclamped_logits_q16 and exp_lanes_q16 must each address lane_count I64s\n//   - preclamped_logits_q16 and exp_lanes_q16 must be disjoint buffers\n// Notes:\n//   - This reuses shared checked span+sum logic from\n//     FPQ16SoftmaxExpPhaseFromPreclampedChecked so no-alias and alias-permitted\n//     callers stay bit-identical other than explicit alias rejection.\nI32 FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n                                                     I64 *exp_lanes_q16,\n                                                     I64 lane_count,\n                                                     I64 *out_exp_sum_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !out_exp_sum_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (preclamped_logits_q16 == exp_lanes_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Empty vectors are valid: no lanes, zero sum.\n    if (!lane_count)\n    {\n        *out_exp_sum_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Guard pointer-span arithmetic before any indexed access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)preclamped_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    status = FPQ16ExpArrayCheckedNoAliasChecked(preclamped_logits_q16,\n                                                exp_lanes_q16,\n                                                lane_count);\n    if (status)\n        return status;\n\n    exp_sum_q16 = 0;\n    for (i = 0; i < lane_count; i++)\n    {\n        if (exp_lanes_q16[i] > (I64_MAX_VALUE - exp_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        exp_sum_q16 += exp_lanes_q16[i];\n    }\n\n    *out_exp_sum_q16 = exp_sum_q16;\n    return FP_Q16_OK;\n}\n\n// Checked softmax split-phase normalization helper.\n// Phase performed here:\n//   1) probs_q16[i] = round_half_up(exp_lanes_q16[i] / exp_sum_q16)\n//   2) Deterministic remainder correction to force sum(probs_q16) == 1.0_q16\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - exp_sum_q16 must be strictly positive\n//   - Input/output buffers must each address lane_count I64s\n// Notes:\n//   - Uses FPQ16MulDivRoundedChecked with b=1.0_q16 to keep one-rounding,\n//     auditable fixed-point divide semantics.\n//   - Remainder correction is deterministic: positive remainder goes to the\n//     max-exp lane; negative remainder is removed in stable lane order\n//     (max lane first, then wrap) without allowing negative probabilities.\nI32 FPQ16SoftmaxNormalizePhaseChecked(I64 *exp_lanes_q16,\n                                      I64 lane_count,\n                                      I64 exp_sum_q16,\n                                      I64 *probs_q16)\n{\n    I64 i;\n    I64 pass;\n    I64 idx;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 prob_q16;\n    I64 prob_sum_q16;\n    I64 diff_q16;\n---\n21:I32 FPQ16MulDivRoundedChecked(I64 a_q16,\n25:I32 FPQ16ExpArrayFromClampedInputChecked(I64 *input_q16,\n28:I32 FPQ16ExpArrayCheckedNoAliasChecked(I64 *input_q16,\n32:// Checked Q16 temperature scaling helper for logits:\n42://   - Arithmetic routes through FPQ16MulDivRoundedChecked with b=1.0_q16 so\n45:I32 FPQ16TemperatureScaleLogitsChecked(I64 *logits_q16,\n80:        status = FPQ16MulDivRoundedChecked(logits_q16[i],\n90:        status = FPQ16MulDivRoundedChecked(logits_q16[i],\n101:// Checked softmax split-phase helper for pre-clamped logits.\n112://     FPQ16ExpArrayFromClampedInputChecked so scalar/vector exp semantics stay\n114:I32 FPQ16SoftmaxExpPhaseFromPreclampedChecked(I64 *preclamped_logits_q16,\n148:    status = FPQ16ExpArrayFromClampedInputChecked(preclamped_logits_q16,\n166:// Checked no-alias softmax exp-phase helper for immutable-logit callers.\n177://     FPQ16SoftmaxExpPhaseFromPreclampedChecked so no-alias and alias-permitted\n179:I32 FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n215:    status = FPQ16ExpArrayCheckedNoAliasChecked(preclamped_logits_q16,\n233:// Checked softmax split-phase normalization helper.\n243://   - Uses FPQ16MulDivRoundedChecked with b=1.0_q16 to keep one-rounding,\n248:I32 FPQ16SoftmaxNormalizePhaseChecked(I64 *exp_lanes_q16,\n295:        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[i],\n350:// Checked no-alias normalization helper for immutable exp-lane callers.\n353://   - Otherwise delegates to FPQ16SoftmaxNormalizePhaseChecked so rounding,\n356:I32 FPQ16SoftmaxNormalizePhaseNoAliasChecked(I64 *exp_lanes_q16,\n368:    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\n378:// Contracts mirror FPQ16SoftmaxNormalizePhaseChecked except no output pointer.\n379:I32 FPQ16SoftmaxNormalizePhasePreflightChecked(I64 *exp_lanes_q16,\n421:        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[i],\n445:        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[max_exp_index],\n463:        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[idx],\n482:// Checked composed helper for alias-permitted split-phase softmax.\n495:I32 FPQ16SoftmaxFromPreclampedChecked(I64 *preclamped_logits_q16,\n508:    status = FPQ16SoftmaxExpPhaseFromPreclampedChecked(preclamped_logits_q16,\n518:    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n524:    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\n530:// Checked composed helper for immutable-logit, no-alias split-phase softmax.\n543:I32 FPQ16SoftmaxFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n565:    status = FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(preclamped_logits_q16,\n576:    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n583:    return FPQ16SoftmaxNormalizePhaseNoAliasChecked(exp_lanes_q16,\n589:// Checked composed helper for immutable-logit, no-alias split-phase softmax\n604:I32 FPQ16SoftmaxFromPreclampedNoAliasCheckedWithSumOut(I64 *preclamped_logits_q16,\n625:    status = FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(preclamped_logits_q16,\n637:    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n643:    return FPQ16SoftmaxNormalizePhaseNoAliasChecked(exp_lanes_q16,\n649:// Checked composed helper for alias-permitted split-phase softmax\n664:I32 FPQ16SoftmaxFromPreclampedCheckedWithSumOut(I64 *preclamped_logits_q16,\n678:    status = FPQ16SoftmaxExpPhaseFromPreclampedChecked(preclamped_logits_q16,\n690:    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n696:    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\n702:// Checked deterministic top-k selector over Q16 logits.\n708:// Checked guards:\n716:I32 FPQ16TopKSelectIndicesChecked(I64 *logits_q16,\n807:// Checked deterministic top-p nucleus-prefix selector over descending Q16\n816:// Checked guards:\n823://   - Checked cumulative-sum monotonicity + I64 overflow guards.\n825:I32 FPQ16TopPSelectPrefixLenChecked(I64 *probs_q16,\n896:// Checked deterministic top-k sampler over normalized Q16 probabilities.\n903:// Checked guards:\n915:I32