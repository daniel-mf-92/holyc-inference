{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' src/math/fixedpoint.HC; echo '-----'; sed -n '1,260p' src/math/intexp.HC; echo '-----'; sed -n '1,260p' src/math/intlog.HC; echo '-----'; sed -n '1,260p' src/math/softmax.HC\"","aggregated_output":"// fixedpoint.HC\n// Q16.16 fixed-point helpers for integer-only inference math.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define FP_Q16_HALF  (1 << (FP_Q16_SHIFT - 1))\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n#define U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\nU64 FPAbsToU64(I64 x)\n{\n    if (x >= 0)\n        return (U64)x;\n\n    // Avoid overflow for I64_MIN by using two's-complement identity.\n    return ((U64)(-(x + 1))) + 1;\n}\n\nI64 FPSignApplyFromU64(U64 mag, I64 is_negative)\n{\n    if (is_negative)\n    {\n        if (mag >= 0x8000000000000000)\n            return I64_MIN_VALUE;\n        return -(I64)mag;\n    }\n\n    if (mag > (U64)I64_MAX_VALUE)\n        return I64_MAX_VALUE;\n    return (I64)mag;\n}\n\nI64 FPQ16RoundShiftSigned(I64 value, I64 shift)\n{\n    U64 abs_value;\n    U64 round_bias;\n    U64 rounded;\n    I64 is_negative;\n\n    if (shift <= 0)\n        return value;\n    if (shift >= 63)\n        return 0;\n\n    is_negative = value < 0;\n    abs_value = FPAbsToU64(value);\n    round_bias = (U64)1 << (shift - 1);\n\n    if (abs_value > U64_MAX_VALUE - round_bias)\n        rounded = U64_MAX_VALUE >> shift;\n    else\n        rounded = (abs_value + round_bias) >> shift;\n\n    return FPSignApplyFromU64(rounded, is_negative);\n}\n\nI64 FPQ16MulSat(I64 a, I64 b)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 limit;\n    I64 is_negative;\n    I64 prod;\n\n    if (!a || !b)\n        return 0;\n\n    abs_a = FPAbsToU64(a);\n    abs_b = FPAbsToU64(b);\n    is_negative = ((a < 0) ^ (b < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (abs_a > (limit / abs_b))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    prod = a * b;\n    return FPQ16RoundShiftSigned(prod, FP_Q16_SHIFT);\n}\n\nI64 FPQ16Abs(I64 x)\n{\n    if (x == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    if (x < 0)\n        return -x;\n    return x;\n}\n\nI64 FPQ16FromInt(I64 x)\n{\n    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n        return I64_MAX_VALUE;\n    if (x < (I64_MIN_VALUE >> FP_Q16_SHIFT))\n        return I64_MIN_VALUE;\n\n    return x << FP_Q16_SHIFT;\n}\n\nI64 FPQ16ToInt(I64 x)\n{\n    if (x >= 0)\n        return (x + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-x) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Mul(I64 a, I64 b)\n{\n    return FPQ16MulSat(a, b);\n}\n\nI64 FPQ16Div(I64 num, I64 den)\n{\n    U64 abs_num;\n    U64 abs_den;\n    U64 limit;\n    U64 int_part;\n    U64 rem;\n    U64 result_mag;\n    I64 is_negative;\n    I64 bit;\n\n    if (!den)\n        return 0;\n\n    abs_num = FPAbsToU64(num);\n    abs_den = FPAbsToU64(den);\n    is_negative = ((num < 0) ^ (den < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    int_part = abs_num / abs_den;\n    if (int_part > (limit >> FP_Q16_SHIFT))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    result_mag = int_part << FP_Q16_SHIFT;\n    rem = abs_num % abs_den;\n\n    // Emit 16 fractional bits using integer long division.\n    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n    {\n        rem <<= 1;\n        if (rem >= abs_den)\n        {\n            rem -= abs_den;\n            if (result_mag <= limit - (((U64)1) << bit))\n                result_mag |= ((U64)1) << bit;\n            else\n                result_mag = limit;\n        }\n    }\n\n    // Half-up rounding by checking whether residual remainder is >= 0.5.\n    if (rem >= ((abs_den + 1) >> 1))\n    {\n        if (result_mag < limit)\n            result_mag++;\n        else\n            result_mag = limit;\n    }\n\n    return FPSignApplyFromU64(result_mag, is_negative);\n}\n-----\n// intexp.HC\n// Integer-only Q16.16 exponential approximation for TempleOS HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define EXP_Q16_LN2       45426   // round(ln(2) * 65536)\n#define EXP_Q16_MAX_INPUT 655360  // +10.0 in Q16\n#define EXP_Q16_MIN_INPUT -655360 // -10.0 in Q16\n\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n\nI64 FPQ16Mul(I64 a, I64 b);\n\nI64 FPQ16Exp(I64 x)\n{\n    I64 k;\n    I64 r;\n    I64 r2;\n    I64 r3;\n    I64 r4;\n    I64 t1;\n    I64 t2;\n    I64 t3;\n    I64 t4;\n    I64 poly;\n\n    if (x >= EXP_Q16_MAX_INPUT)\n        return I64_MAX_VALUE;\n    if (x <= EXP_Q16_MIN_INPUT)\n        return 0;\n\n    // Range reduction: x = k*ln(2) + r, where r in [0, ln(2))\n    k = x / EXP_Q16_LN2;\n    if (x < 0 && (x % EXP_Q16_LN2))\n        k--;\n\n    r = x - (k * EXP_Q16_LN2);\n\n    // exp(r) ~= 1 + r + r^2/2 + r^3/6 + r^4/24\n    r2 = FPQ16Mul(r, r);\n    r3 = FPQ16Mul(r2, r);\n    r4 = FPQ16Mul(r3, r);\n\n    t1 = r;\n    t2 = r2 / 2;\n    t3 = r3 / 6;\n    t4 = r4 / 24;\n\n    poly = FP_Q16_ONE + t1 + t2 + t3 + t4;\n\n    if (k >= 0)\n    {\n        if (k >= 30)\n            return I64_MAX_VALUE;\n\n        if (poly > (I64_MAX_VALUE >> k))\n            return I64_MAX_VALUE;\n\n        return poly << k;\n    }\n\n    if (k <= -63)\n        return 0;\n\n    return poly >> (-k);\n}\n-----\n// intlog.HC\n// Integer-only Q16.16 natural-log approximation for TempleOS HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define LOG_Q16_LN2  45426 // round(ln(2) * 65536)\n#define LOG_Q16_INV_LN2 94549 // round((1/ln(2)) * 65536)\n#define LOG_Q16_HALF (1 << (FP_Q16_SHIFT - 1))\n#define LOG_Q16_SPLIT ((FP_Q16_ONE * 3) / 2) // 1.5 in Q16\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n\nI64 FPQ16Mul(I64 a, I64 b);\n\nI64 FPQ16Ln1pPoly(I64 y_q16)\n{\n    I64 y2;\n    I64 y3;\n    I64 y4;\n    I64 y5;\n\n    // 5th-order alternating series:\n    // ln(1+y) ~= y - y^2/2 + y^3/3 - y^4/4 + y^5/5\n    // Accurate and monotonic on y in [-0.25, 0.5].\n    y2 = FPQ16Mul(y_q16, y_q16);\n    y3 = FPQ16Mul(y2, y_q16);\n    y4 = FPQ16Mul(y3, y_q16);\n    y5 = FPQ16Mul(y4, y_q16);\n\n    return y_q16 - (y2 / 2) + (y3 / 3) - (y4 / 4) + (y5 / 5);\n}\n\nI64 FPQ16LnReduce(I64 x_q16, I64 *k_out)\n{\n    U64 m_q16;\n    I64 k;\n\n    if (!k_out)\n        return 0;\n    if (x_q16 <= 0)\n    {\n        *k_out = 0;\n        return 0;\n    }\n\n    // Normalize x = m * 2^k where m in [1, 2) in Q16.\n    m_q16 = (U64)x_q16;\n    k = 0;\n\n    while (m_q16 >= (((U64)FP_Q16_ONE) << 1))\n    {\n        m_q16 >>= 1;\n        k++;\n    }\n    while (m_q16 < (U64)FP_Q16_ONE)\n    {\n        m_q16 <<= 1;\n        k--;\n    }\n\n    *k_out = k;\n    return (I64)m_q16;\n}\n\nI64 FPQ16Ln(I64 x_q16)\n{\n    I64 k;\n    I64 m_q16;\n    I64 y_q16;\n    I64 poly_q16;\n    I64 base_q16;\n    I64 ln_q16;\n\n    // ln(x) is undefined for x <= 0. Saturate to a deterministic floor.\n    if (x_q16 <= 0)\n        return I64_MIN_VALUE;\n\n    m_q16 = FPQ16LnReduce(x_q16, &k);\n\n    // Piecewise range split for monotonic polynomial accuracy:\n    // branch A: y in [0, 0.5), branch B: y in [-0.25, 0).\n    if (m_q16 >= LOG_Q16_SPLIT)\n    {\n        m_q16 = (m_q16 + 1) >> 1;\n        k++;\n    }\n\n    y_q16 = m_q16 - FP_Q16_ONE;\n    poly_q16 = FPQ16Ln1pPoly(y_q16);\n\n    base_q16 = k * LOG_Q16_LN2;\n\n    if (base_q16 > 0 && poly_q16 > I64_MAX_VALUE - base_q16)\n        return I64_MAX_VALUE;\n    if (base_q16 < 0 && poly_q16 < I64_MIN_VALUE - base_q16)\n        return I64_MIN_VALUE;\n\n    ln_q16 = base_q16 + poly_q16;\n    return ln_q16;\n}\n\nI64 FPQ16Log2(I64 x_q16)\n{\n    I64 ln_q16;\n    I64 abs_ln;\n    I64 abs_inv;\n    I64 max_abs_ln;\n    I64 prod;\n\n    ln_q16 = FPQ16Ln(x_q16);\n\n    // Preserve ln(x<=0) deterministic domain floor.\n    if (ln_q16 == I64_MIN_VALUE)\n        return I64_MIN_VALUE;\n\n    // log2(x) = ln(x) * (1/ln(2)).\n    // Keep overflow checks explicit before multiply.\n    abs_ln = ln_q16;\n    if (abs_ln < 0)\n        abs_ln = -abs_ln;\n\n    abs_inv = LOG_Q16_INV_LN2;\n    max_abs_ln = I64_MAX_VALUE / abs_inv;\n    if (abs_ln > max_abs_ln)\n    {\n        if (ln_q16 < 0)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    prod = ln_q16 * LOG_Q16_INV_LN2;\n\n    // Q16*Q16 -> Q32. Round to Q16 with sign-aware half-up policy.\n    if (prod >= 0)\n        return (prod + LOG_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-prod) + LOG_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16LnRatio(I64 num_q16, I64 den_q16)\n{\n    I64 num_k;\n    I64 den_k;\n    I64 num_m_q16;\n    I64 den_m_q16;\n    I64 num_y_q16;\n    I64 den_y_q16;\n    I64 num_poly_q16;\n    I64 den_poly_q16;\n    I64 poly_delta_q16;\n    I64 k_delta;\n    I64 abs_k_delta;\n    I64 max_k_delta;\n    I64 base_q16;\n    I64 ln_ratio_q16;\n\n    // ln(num/den) is undefined when either side is non-positive.\n    if (num_q16 <= 0 || den_q16 <= 0)\n        return I64_MIN_VALUE;\n\n    num_m_q16 = FPQ16LnReduce(num_q16, &num_k);\n    den_m_q16 = FPQ16LnReduce(den_q16, &den_k);\n\n    // Mirror FPQ16Ln split to keep polynomial range tightly bounded.\n    if (num_m_q16 >= LOG_Q16_SPLIT)\n    {\n        num_m_q16 = (num_m_q16 + 1) >> 1;\n        num_k++;\n    }\n    if (den_m_q16 >= LOG_Q16_SPLIT)\n    {\n        den_m_q16 = (den_m_q16 + 1) >> 1;\n        den_k++;\n    }\n\n    num_y_q16 = num_m_q16 - FP_Q16_ONE;\n    den_y_q16 = den_m_q16 - FP_Q16_ONE;\n    num_poly_q16 = FPQ16Ln1pPoly(num_y_q16);\n    den_poly_q16 = FPQ16Ln1pPoly(den_y_q16);\n\n    // poly_delta = ln(m_num) - ln(m_den) with explicit overflow guards.\n    if (den_poly_q16 < 0 && num_poly_q16 > I64_MAX_VALUE + den_poly_q16)\n        return I64_MAX_VALUE;\n    if (den_poly_q16 > 0 && num_poly_q16 < I64_MIN_VALUE + den_poly_q16)\n        return I64_MIN_VALUE;\n    poly_delta_q16 = num_poly_q16 - den_poly_q16;\n\n    // base = (k_num - k_den) * ln(2) in Q16.\n    if (den_k < 0 && num_k > I64_MAX_VALUE + den_k)\n        return I64_MAX_VALUE;\n    if (den_k > 0 && num_k < I64_MIN_VALUE + den_k)\n        return I64_MIN_VALUE;\n    k_delta = num_k - den_k;\n\n    abs_k_delta = k_delta;\n    if (abs_k_delta < 0)\n        abs_k_delta = -abs_k_delta;\n    max_k_delta = I64_MAX_VALUE / LOG_Q16_LN2;\n    if (abs_k_delta > max_k_delta)\n    {\n        if (k_delta < 0)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n    base_q16 = k_delta * LOG_Q16_LN2;\n\n    if (base_q16 > 0 && poly_delta_q16 > I64_MAX_VALUE - base_q16)\n        return I64_MAX_VALUE;\n    if (base_q16 < 0 && poly_delta_q16 < I64_MIN_VALUE - base_q16)\n        return I64_MIN_VALUE;\n\n    ln_ratio_q16 = base_q16 + poly_delta_q16;\n    return ln_ratio_q16;\n}\n-----\n// softmax.HC\n// Integer-only Q16.16 softmax for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n\nI64 FPQ16Exp(I64 x);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Ln(I64 x_q16);\n\nU0 FPQ16Softmax(I64 *logits, I64 *probs, I64 count)\n{\n    I64 i;\n    I64 max_logit;\n    I64 shifted;\n    I64 exp_val;\n    I64 exp_sum;\n    I64 prob_sum;\n    I64 diff;\n    I64 max_idx;\n\n    if (!logits || !probs || count <= 0)\n        return;\n\n    max_logit = logits[0];\n    max_idx = 0;\n    for (i = 1; i < count; i++)\n    {\n        if (logits[i] > max_logit)\n        {\n            max_logit = logits[i];\n            max_idx = i;\n        }\n    }\n\n    exp_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        shifted = logits[i] - max_logit;\n        exp_val = FPQ16Exp(shifted);\n        probs[i] = exp_val;\n\n        if (exp_sum > 0x7FFFFFFFFFFFFFFF - exp_val)\n            exp_sum = 0x7FFFFFFFFFFFFFFF;\n        else\n            exp_sum += exp_val;\n    }\n\n    if (exp_sum <= 0)\n    {\n        exp_val = FPQ16Div(FP_Q16_ONE, FPQ16FromInt(count));\n        for (i = 0; i < count; i++)\n            probs[i] = exp_val;\n        return;\n    }\n\n    prob_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        probs[i] = FPQ16Div(probs[i], exp_sum);\n        prob_sum += probs[i];\n    }\n\n    diff = FP_Q16_ONE - prob_sum;\n    probs[max_idx] += diff;\n}\n\nI64 FPQ16EntropyFromProbs(I64 *probs, I64 count)\n{\n    I64 i;\n    I64 p_q16;\n    I64 ln_p_q16;\n    I64 plnp_q16;\n    I64 sum_plnp_q16;\n\n    // Shannon entropy in natural-log units:\n    // H(p) = -sum_i p_i * ln(p_i)\n    // Input probabilities are Q16.16 fixed-point values.\n    if (!probs || count <= 0)\n        return 0;\n\n    sum_plnp_q16 = 0;\n\n    for (i = 0; i < count; i++)\n    {\n        p_q16 = probs[i];\n\n        // p=0 contributes exactly 0 in the limit p*ln(p)->0.\n        if (p_q16 <= 0)\n            continue;\n\n        // Keep diagnostics stable if callers pass slightly out-of-range values.\n        if (p_q16 > FP_Q16_ONE)\n            p_q16 = FP_Q16_ONE;\n\n        ln_p_q16 = FPQ16Ln(p_q16);\n        if (ln_p_q16 == I64_MIN_VALUE)\n            continue;\n\n        plnp_q16 = FPQ16Mul(p_q16, ln_p_q16);\n\n        // For p in (0,1], p*ln(p) <= 0. Clamp tiny positive approximation noise.\n        if (plnp_q16 > 0)\n            plnp_q16 = 0;\n\n        if (sum_plnp_q16 < I64_MIN_VALUE - plnp_q16)\n            sum_plnp_q16 = I64_MIN_VALUE;\n        else\n            sum_plnp_q16 += plnp_q16;\n    }\n\n    if (sum_plnp_q16 == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    return -sum_plnp_q16;\n}\n","exit_code":0,"status":"completed"}}
