   assert err == GGUF_META_TABLE_ERR_OVERFLOW\n    assert cursor == [0]\n    assert out_first == [1]\n    assert out_second == [2]\n    assert out_third == [3]\n    assert out_fourth == [4]\n\n\ndef test_random_reference_parity() -> None:\n    rng = random.Random(0x7788_99AA)\n\n    for _ in range(300):\n        first = rng.randint(-(1 << 31), (1 << 31) - 1)\n        second = rng.randint(-(1 << 31), (1 << 31) - 1)\n        third = rng.randint(-(1 << 31), (1 << 31) - 1)\n        fourth = rng.randint(-(1 << 31), (1 << 31) - 1)\n\n        prefix = [rng.randint(0, 255) for _ in range(rng.randint(0, 6))]\n        suffix = [rng.randint(0, 255) for _ in range(rng.randint(0, 6))]\n        buf = prefix + _le_i32(first) + _le_i32(second) + _le_i32(third) + _le_i32(fourth) + suffix\n\n        cursor = [len(prefix)]\n        out_first = [0]\n        out_second = [0]\n        out_third = [0]\n        out_fourth = [0]\n\n        err = gguf_metadata_read_i32_quad_checked(\n            buf,\n            len(buf),\n            cursor,\n            len(buf),\n            out_first,\n            out_second,\n            out_third,\n            out_fourth,\n        )\n        assert err == GGUF_META_TABLE_OK\n        assert out_first[0] == first\n        assert out_second[0] == second\n        assert out_third[0] == third\n        assert out_fourth[0] == fourth\n        assert cursor[0] == len(prefix) + 16\n\n\nif __name__ == \"__main__\":\n    test_null_ptr_and_no_partial_write()\n    test_fourth_scalar_fail_does_not_commit_prior_lanes_or_cursor()\n    test_success_reads_four_i32_and_advances()\n    test_overflow_passthrough_and_no_commit()\n    test_random_reference_parity()\n    print(\"ok\")\nPY'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
