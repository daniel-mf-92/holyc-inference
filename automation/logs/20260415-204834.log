  5520\t\n  5521\t        rel_end = rel_start + nbytes\n  5522\t        out_full = tensor_info_load_payload_window_by_index_rel(\n  5523\t            original_idx,\n  5524\t            rel_start,\n  5525\t            rel_end,\n  5526\t            0x7200,\n  5527\t            64,\n  5528\t            starts,\n  5529\t            ends,\n  5530\t            sorted_pos,\n  5531\t        )\n  5532\t        assert out_full == (\n  5533\t            GGUF_TDBASE_OK,\n  5534\t            starts[sorted_pos[original_idx]],\n  5535\t            ends[sorted_pos[original_idx]],\n  5536\t            0,\n  5537\t            nbytes,\n  5538\t        )\n  5539\t\n  5540\t        if nbytes >= 64:\n  5541\t            mid_rel = rel_start + (nbytes // 2)\n  5542\t            mid_rel = ((mid_rel + 63) // 64) * 64\n  5543\t            if mid_rel <= rel_end:\n  5544\t                err_mid, out_abs_start, out_abs_end, span_start, span_end = tensor_info_load_payload_window_by_index_rel(\n  5545\t                    original_idx,\n  5546\t                    mid_rel,\n  5547\t                    mid_rel,\n  5548\t                    0x7200,\n  5549\t                    64,\n  5550\t                    starts,\n  5551\t                    ends,\n  5552\t                    sorted_pos,\n  5553\t                )\n  5554\t                assert err_mid == GGUF_TDBASE_OK\n  5555\t                assert out_abs_start == 0x7200 + mid_rel\n  5556\t                assert out_abs_end == 0x7200 + mid_rel\n  5557\t                assert span_start == (0x7200 + mid_rel - starts[sorted_pos[original_idx]])\n  5558\t                assert span_end == span_start\n  5559\t\n  5560\t\n  5561\tdef test_inverse_map_and_range_index_random_permutation_parity() -> None:\n  5562\t    rng = random.Random(764311)\n  5563\t\n  5564\t    for _ in range(220):\n  5565\t        count = rng.randint(1, 36)\n  5566\t        alignment = 1 << rng.randint(5, 7)\n  5567\t        base = rng.randint(0x2000, 0xA000)\n  5568\t     