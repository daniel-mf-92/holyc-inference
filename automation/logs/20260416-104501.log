  for row_index in range(row_count):\n   206\t        row_base = row_index * row_stride_blocks\n   207\t        row_slice = matrix_blocks[row_base : row_base + vec_block_count]\n   208\t        if len(row_slice) != vec_block_count:\n   209\t            return Q8_0_ERR_BAD_DST_LEN, []\n   210\t\n   211\t        err, row_dot_q16 = dot_row_blocks_q16(row_slice, vec_blocks[:vec_block_count])\n   212\t        if err != Q8_0_OK:\n   213\t            return err, []\n   214\t\n   215\t        out_rows_q16[row_index] = row_dot_q16\n   216\t\n   217\t    return Q8_0_OK, out_rows_q16\n   218\t\n   219\t\n   220\tdef dot_rows_q16_matrix_vector_checked(\n   221\t    matrix_blocks: list[tuple[int, bytes]],\n   222\t    matrix_block_capacity: int,\n   223\t    row_count: int,\n   224\t    row_stride_blocks: int,\n   225\t    vec_blocks: list[tuple[int, bytes]],\n   226\t    vec_block_capacity: int,\n   227\t    vec_block_count: int,\n   228\t) -> tuple[int, list[int]]:\n   229\t    if matrix_block_capacity < 0 or vec_block_capacity < 0:\n   230\t        return Q8_0_ERR_BAD_DST_LEN, []\n   231\t    if row_count < 0 or row_stride_blocks < 0 or vec_block_count < 0:\n   232\t        return Q8_0_ERR_BAD_DST_LEN, []\n   233\t    if row_count > 0 and row_stride_blocks < vec_block_count:\n   234\t        return Q8_0_ERR_BAD_DST_LEN, []\n   235\t    if vec_block_count > vec_block_capacity:\n   236\t        return Q8_0_ERR_BAD_DST_LEN, []\n   237\t\n   238\t    required_matrix_blocks = row_count * row_stride_blocks\n   239\t    if required_matrix_blocks > Q8_0_I64_MAX:\n   240\t        return Q8_0_ERR_OVERFLOW, []\n   241\t    if required_matrix_blocks > matrix_block_capacity:\n   242\t        return Q8_0_ERR_BAD_DST_LEN, []\n   243\t\n   244\t    out_rows_q16 = [0] * row_count\n   245\t    for row_index in range(row_count):\n   246\t        row_base = row_index * row_stride_blocks\n   247\t        if row_base > Q8_0_I64_MAX:\n   248\t            return Q8_0_ERR_OVERFLOW, []\n   249\t\n   250\t        row_slice = matrix_blocks[row_base : row_base + vec_block_count]\n   251\t        if len(row_slice) != vec_block_count:\n   252\t            return Q8_0_ERR_BAD_DST_LEN, []\n   253\t\n   254\t        err, row_dot_q16 = dot_product_blocks_q16_accumulate_checked(\n   255\t            row_slice,\n   256\t            vec_blocks[:vec_block_count],\n   257\t            0,\n   258\t        )\n   259\t        if err != Q8_0_OK:\n   260\t            return err, []\n   261\t\n   262\t        out_rows_q16[row_index] = row_dot_q16\n   263\t\n   264\t    return Q8_0_OK, out_rows_q16\n   265\t\n   266\t\n   267\tdef dot_product_blocks_q32_to_q16(\n   268\t    lhs_blocks: list[tuple[int, bytes]],\n   269\t    rhs_blocks: list[tuple[int, bytes]],\n   270\t) -> tuple[int, int]:\n   271\t    err, total_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   272\t    if err != Q8_0_OK:\n   273\t        return err, 0\n   274\t    return Q8_0_OK, dot_q32_to_q16(total_q32)\n   275\t\n   276\t\n   277\tdef test_identity_block() -> None:\n   278\t    lhs_scale_fp16 = half_bits(1.0)\n   279\t    rhs_scale_fp16 = half_bits(1.0)\n   280\t    signed = list(range(-16, 16))\n   281\t    packed = pack_signed(signed)\n   282\t\n   283\t    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, packed, rhs_scale_fp16, packed)\n   284\t    assert err == Q8_0_OK\n   285\t\n   286\t    expected_q0 = sum(v * v for v in signed)\n   287\t    expected_q32 = expected_q0 * (1 << 32)\n   288\t    assert got_q32 == expected_q32\n   289\t    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n   290\t\n   291\t\n   292\tdef test_negative_scale_sign() -> None:\n   293\t    lhs_scale_fp16 = half_bits(-0.5)\n   294\t    rhs_scale_fp16 = half_bits(2.0)\n   295\t\n   296\t    lhs_signed = [5] * Q8_0_VALUES_PER_BLOCK\n   297\t    rhs_signed = [3] * Q8_0_VALUES_PER_BLOCK\n   298\t\n   299\t    err, got_q32 = dot_product_block_q32(\n   300\t        lhs_scale_fp16,\n   301\t        pack_signed(lhs_signed),\n   302\t        rhs_scale_fp16,\n   303\t        pack_signed(rhs_signed),\n   304\t    )\n   305\t    assert err == Q8_0_OK\n   306\t\n   307\t    expected_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n   308\t    expected_q32 = -expected_q0 * (1 << 32)\n   309\t    assert got_q32 == expected_q32\n   310\t\n   311\t\n   312\tdef test_random_blocks_match_float_reference_bounds() -> None:\n   313\t    rng = random.Random(992244)\n   314\t\n   315\t    for _ in range(400):\n   316\t        lhs_scale = rng.uniform(-3.0, 3.0)\n   317\t        rhs_scale = rng.uniform(-3.0, 3.0)\n   318\t        lhs_scale_fp16 = half_bits(lhs_scale)\n   319\t        rhs_scale_fp16 = half_bits(rhs_scale)\n   320\t\n   321\t        lhs_signed = [rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)]\n   322\t        rhs_signed = [rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)]\n   323\t\n   324\t        err, got_q32 = dot_product_block_q32(\n   325\t            lhs_scale_fp16,\n   326\t            pack_signed(lhs_signed),\n   327\t            rhs_scale_fp16,\n   328\t            pack_signed(rhs_signed),\n   329\t        )\n   330\t        assert err == Q8_0_OK\n   331\t\n   332\t        dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n   333\t        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   334\t        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n   335\t        expected_int_q32 = lhs_scale_q16 * rhs_scale_q16 * dot_q0\n   336\t        assert got_q32 == expected_int_q32\n   337\t\n   338\t        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n   339\t        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n   340\t        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * dot_q0 * (1 << 32))\n   341\t\n   342\t        # Integer path rounds scales once to Q16. Tight deterministic bound.\n   343\t        assert abs(got_q32 - expected_float_q32) <= 700_000_000\n   344\t\n   345\t\n   346\tdef test_multiblock_accumulation() -> None:\n   347\t    lhs_blocks = [\n   348\t        (half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK)),\n   349\t        (half_bits(0.5), pack_signed([2] * Q8_0_VALUES_PER_BLOCK)),\n   350\t    ]\n   351\t    rhs_blocks = [\n   352\t        (half_bits(1.0), pack_signed([3] * Q8_0_VALUES_PER_BLOCK)),\n   353\t        (half_bits(-2.0), pack_signed([4] * Q8_0_VALUES_PER_BLOCK)),\n   354\t    ]\n   355\t\n   356\t    err, got_total_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   357\t    assert err == Q8_0_OK\n   358\t\n   359\t    _, block0 = dot_product_block_q32(*lhs_blocks[0], *rhs_blocks[0])\n   360\t    _, block1 = dot_product_block_q32(*lhs_blocks[1], *rhs_blocks[1])\n   361\t    assert got_total_q32 == block0 + block1\n   362\t\n   363\t\n   364\tdef test_error_on_bad_input_length() -> None:\n   365\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 31, half_bits(1.0), b\"\\x00\" * 32)\n   366\t    assert err == Q8_0_ERR_BAD_DST_LEN\n   367\t\n   368\t\n   369\tdef test_q16_accumulator_helper_matches_blockwise_rounding() -> None:\n   370\t    rng = random.Random(662900)\n   371\t\n   372\t    for _ in range(250):\n   373\t        block_count = rng.randint(1, 6)\n   374\t        lhs_blocks: list[tuple[int, bytes]] = []\n   375\t        rhs_blocks: list[tuple[int, bytes]] = []\n   376\t\n   377\t        for _ in range(block_count):\n   378\t            lhs_scale = half_bits(rng.uniform(-2.5, 2.5))\n   379\t            rhs_scale = half_bits(rng.uniform(-2.5, 2.5))\n   380\t            lhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   381\t            rhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   382\t            lhs_blocks.append((lhs_scale, lhs_qs))\n   383\t            rhs_blocks.append((rhs_scale, rhs_qs))\n   384\t\n   385\t        initial_accum = rng.randint(-(1 << 28), (1 << 28))\n   386\t        err, got_q16 = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, initial_accum)\n   387\t        assert err == Q8_0_OK\n   388\t\n   389\t        expected_q16 = initial_accum\n   390\t        for lhs_block, rhs_block in zip(lhs_blocks, rhs_blocks):\n   391\t            err, block_q32 = dot_product_block_q32(*lhs_block, *rhs_block)\n   392\t            assert err == Q8_0_OK\n   393\t            expected_q16 += dot_q32_to_q16(block_q32)\n   394\t\n   395\t        assert got_q16 == expected_q16\n   396\t\n   397\t\n   398\tdef test_q16_accumulator_bad_length_error() -> None:\n   399\t    lhs_blocks = [(half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK))]\n   400\t    rhs_blocks: list[tuple[int, bytes]] = []\n   401\t    err, _ = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n   402\t    assert err == Q8_0_ERR_BAD_DST_LEN\n   403\t\n   404\t\n   405\tdef test_row_blocks_q16_matches_per_block_rounding() -> None:\n   406\t    rng = random.Random(321909)\n   407\t\n   408\t    for _ in range(250):\n   409\t        block_count = rng.randint(1, 8)\n   410\t        lhs_blocks: list[tuple[int, bytes]] = []\n   411\t        rhs_blocks: list[tuple[int, bytes]] = []\n   412\t\n   413\t        for _ in range(block_count):\n   414\t            lhs_scale = half_bits(rng.uniform(-2.5, 2.5))\n   415\t            rhs_scale = half_bits(rng.uniform(-2.5, 2.5))\n   416\t            lhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   417\t            rhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   418\t            lhs_blocks.append((lhs_scale, lhs_qs))\n   419\t            rhs_blocks.append((rhs_scale, rhs_qs))\n   420\t\n   421\t        err, got_row_q16 = dot_row_blocks_q16(lhs_blocks, rhs_blocks)\n   422\t        assert err == Q8_0_OK\n   423\t\n   424\t        expected_q16 = 0\n   425\t        for lhs_block, rhs_block in zip(lhs_blocks, rhs_blocks):\n   426\t            