n range(block_count):\n   472\t            lhs_scale = half_bits(rng.uniform(-2.5, 2.5))\n   473\t            rhs_scale = half_bits(rng.uniform(-2.5, 2.5))\n   474\t            lhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   475\t            rhs_qs = pack_signed([rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)])\n   476\t            lhs_blocks.append((lhs_scale, lhs_qs))\n   477\t            rhs_blocks.append((rhs_scale, rhs_qs))\n   478\t\n   479\t        err, got_q16 = dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks)\n   480\t        assert err == Q8_0_OK\n   481\t\n   482\t        err, total_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   483\t        assert err == Q8_0_OK\n   484\t        assert got_q16 == dot_q32_to_q16(total_q32)\n   485\t\n   486\t\n   487\tdef test_q32_to_q16_length_mismatch_error() -> None:\n   488\t    lhs_blocks = [(half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK))]\n   489\t    rhs_blocks: list[tuple[int, bytes]] = []\n   490\t    err, _ = dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks)\n   491\t    assert err == Q8_0_ERR_BAD_DST_LEN\n   492\t\n   493\t\n   494\tdef test_matrix_vector_rows_stride_and_values() -> None:\n   495\t    row_count = 3\n   496\t    vec_block_count = 2\n   497\t    row_stride_blocks = 3\n   498\t\n   499\t    vec_blocks = [\n   500\t        (half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK)),\n   501\t        (half_bits(-0.5), pack_signed([2] * Q8_0_VALUES_PER_BLOCK)),\n   502\t    ]\n   503\t\n   504\t    matrix_blocks: list[tuple[int, bytes]] = []\n   505\t    expected_rows: list[int] = []\n   506\t    for row_index in range(row_count):\n   507\t        active_blocks: list[tuple[int, bytes]] = []\n   508\t        for block_index in range(vec_block_count):\n   509\t            scale = half_bits(1.0 + 0.25 * (row_index + block_index))\n   510\t            q = (row_index + 1) * (block_index + 1)\n   511\t            packed = p