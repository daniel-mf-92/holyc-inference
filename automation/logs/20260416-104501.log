 magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n   126\t\n   127\t    if (sign_bit)\n   128\t        return -magnitude_q16;\n   129\t    return magnitude_q16;\n   130\t}\n   131\t\n   132\tI32 Q8_0DotProductBlockQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 *out_dot_q32)\n   133\t{\n   134\t    I64 lhs_scale_q16;\n   135\t    I64 rhs_scale_q16;\n   136\t    I64 scale_prod_q32;\n   137\t    I64 byte_index;\n   138\t    I64 q_dot_q0;\n   139\t\n   140\t    if (!lhs || !rhs || !out_dot_q32)\n   141\t        return Q8_0_ERR_NULL_PTR;\n   142\t\n   143\t    lhs_scale_q16 = Q8_0F16ToQ16(lhs->d_fp16);\n   144\t    rhs_scale_q16 = Q8_0F16ToQ16(rhs->d_fp16);\n   145\t    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n   146\t\n   147\t    // Keep the integer dot explicit and auditable:\n   148\t    // q_dot_q0 = Sum(qA_i * qB_i), with q in signed byte domain [-128, 127].\n   149\t    q_dot_q0 = 0;\n   150\t    for (byte_index = 0; byte_index < Q8_0_PACKED_BYTES; ++byte_index)\n   151\t        q_dot_q0 += lhs->qs[byte_index] * rhs->qs[byte_index];\n   152\t\n   153\t    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n   154\t    return Q8_0_OK;\n   155\t}\n   156\t\n   157\tI32 Q8_0DotProductBlocksQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n   158\t{\n   159\t    I64 block_index;\n   160\t    I64 block_dot_q32;\n   161\t    I64 total_dot_q32;\n   162\t    I32 status;\n   163\t\n   164\t    if (!lhs || !rhs || !out_dot_q32)\n   165\t        return Q8_0_ERR_NULL_PTR;\n   166\t    if (block_count < 0)\n   167\t        return Q8_0_ERR_BAD_DST_LEN;\n   168\t\n   169\t    total_dot_q32 = 0;\n   170\t    for (block_index = 0; block_index < block_count; ++block_index)\n   171\t    {\n   172\t        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n   173\t        if (status != Q8_0_OK)\n   174\t            return status;\n   175\t\n   176\t        total_dot_q32 += block_dot_q32;\n   177\t    }\n   178\t