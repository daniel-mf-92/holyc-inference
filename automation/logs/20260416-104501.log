 < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n   331\t        return Q8_0_ERR_BAD_DST_LEN;\n   332\t\n   333\t    // Each row begins at:\n   334\t    //   matrix_blocks + row_index * row_stride_blocks\n   335\t    // and consumes vec_block_count contiguous blocks.\n   336\t    // Require stride >= active vector span so row windows are valid and auditable.\n   337\t    if (row_count > 0 && row_stride_blocks < vec_block_count)\n   338\t        return Q8_0_ERR_BAD_DST_LEN;\n   339\t\n   340\t    for (row_index = 0; row_index < row_count; ++row_index)\n   341\t    {\n   342\t        row_ptr = &matrix_blocks[row_index * row_stride_blocks];\n   343\t        status = Q8_0DotRowBlocksQ16(row_ptr, vec_blocks, vec_block_count, &row_dot_q16);\n   344\t        if (status != Q8_0_OK)\n   345\t            return status;\n   346\t\n   347\t        out_rows_q16[row_index] = row_dot_q16;\n   348\t    }\n   349\t\n   350\t    return Q8_0_OK;\n   351\t}\n   352\t\n   353\tI32 Q8_0DotRowsQ16MatrixVectorChecked(\n   354\t    Q8_0Block *matrix_blocks,\n   355\t    I64 matrix_block_capacity,\n   356\t    I64 row_count,\n   357\t    I64 row_stride_blocks,\n   358\t    Q8_0Block *vec_blocks,\n   359\t    I64 vec_block_capacity,\n   360\t    I64 vec_block_count,\n   361\t    I64 *out_rows_q16)\n   362\t{\n   363\t    I64 row_index;\n   364\t    I64 row_dot_q16;\n   365\t    I64 required_matrix_blocks;\n   366\t    I64 row_base;\n   367\t    Q8_0Block *row_ptr;\n   368\t    I32 status;\n   369\t\n   370\t    if (!matrix_blocks || !vec_blocks || !out_rows_q16)\n   371\t        return Q8_0_ERR_NULL_PTR;\n   372\t    if (matrix_block_capacity < 0 || vec_block_capacity < 0)\n   373\t        return Q8_0_ERR_BAD_DST_LEN;\n   374\t    if (row_count < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n   375\t        return Q8_0_ERR_BAD_DST_LEN;\n   376\t\n   377\t    if (row_count > 0 && row_stride_blocks < vec_block_count)\n   378\t        return Q8_0_ERR_BAD_DST_LEN;\n   379\t    if (vec