logits.\n// Phase performed here:\n//   1) exp_lanes_q16[i] = exp(preclamped_logits_q16[i])\n//   2) out_exp_sum_q16  = sum_i exp_lanes_q16[i] (checked I64 add)\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - preclamped_logits_q16 and exp_lanes_q16 must each address lane_count I64s\n//   - Any I64 accumulation overflow returns FP_Q16_ERR_OVERFLOW\n// Notes:\n//   - Pre-clamped domain validation and lane exp math are delegated to\n//     FPQ16ExpArrayFromClampedInputChecked so scalar/vector exp semantics stay\n//     centralized and auditable.\nI32 FPQ16SoftmaxExpPhaseFromPreclampedChecked(I64 *preclamped_logits_q16,\n                                              I64 *exp_lanes_q16,\n                                              I64 lane_count,\n                                              I64 *out_exp_sum_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !out_exp_sum_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Empty vectors are valid: no lanes, zero sum.\n    if (!lane_count)\n    {\n        *out_exp_sum_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Guard pointer-span arithmetic before any indexed access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)preclamped_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    status = FPQ16ExpArrayFromClampedInputChecked(preclamped_logits_q16,\n                                                  exp_lanes_q16,\n                                                  lane_count);\n    if (status)\n        return status;\n\n    exp_sum_q16 = 0;\n    for (i = 0; i < lane_count; i++)\n    {\n        if (exp_lanes_q16[i] > (I64_MAX_VALUE - exp_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        exp_sum_q16 += exp_lanes_q16[i];\n    }\n\n    *out_exp_sum_q16 = exp_sum_q16;\n    return FP_Q16_OK;\n}\n\n// Checked no-alias softmax exp-phase helper for immutable-logit callers.\n// Phase performed here:\n//   1) exp_lanes_q16[i] = exp(preclamped_logits_q16[i])\n//   2) out_exp_sum_q16  = sum_i exp_lanes_q16[i] (checked I64 add)\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - preclamped_logits_q16 and exp_lanes_q16 must each address lane_count I64s\n//   - preclamped_logits_q16 and exp_lanes_q16 must be disjoint buffers\n// Notes:\n//   - This reuses shared checked span+sum logic from\n//     FPQ16SoftmaxExpPhaseFromPreclampedChecked so no-alias and alias-permitted\n//     callers stay bit-identical other than explicit alias rejection.\nI32 FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n                                                     I64 *exp_lanes_q16,\n                                                     I64 lane_count,\n                                                     I64 *out_exp_sum_q16)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !out_exp_sum_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (preclamped_logits_q16 == exp_lanes_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Empty vectors are valid: no lanes, zero sum.\n    if (!lane_count)\n    {\n        *out_exp_sum_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Guard pointer-span arithmetic before any indexed access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)preclamped_logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    status = FPQ16ExpArrayCheckedNoAliasChecked(preclamped_logits_q16,\n                                                exp_lanes_q16,\n                                                lane_count);\n    if (status)\n        return status;\n\n    exp_sum_q16 = 0;\n    for (i = 0; i < lane_count; i++)\n    {\n        if (exp_lanes_q16[i] > (I64_MAX_VALUE - exp_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        exp_sum_q16 += exp_lanes_q16[i];\n    }\n\n    *out_exp_sum_q16 = exp_sum_q16;\n    return FP_Q16_OK;\n}\n\n// Checked softmax split-phase normalization helper.\n// Phase performed here:\n//   1) probs_q16[i] = round_half_up(exp_lanes_q16[i] / exp_sum_q16)\n//   2) Deterministic remainder correction to force sum(probs_q16) == 1.0_q16\n// Contracts:\n//   - All pointers must be non-null\n//   - lane_count must be >= 0\n//   - exp_sum_q16 must be strictly positive\n//   - Input/output buffers must each address lane_count I64s\n// Notes:\n//   - Uses FPQ16MulDivRoundedChecked with b=1.0_q16 to keep one-rounding,\n//     auditable fixed-point divide semantics.\n//   - Remainder correction is deterministic: positive remainder goes to the\n//     max-exp lane; negative remainder is removed in stable lane order\n//     (max lane first, then wrap) without allowing negative probabilities.\nI32 FPQ16SoftmaxNormalizePhaseChecked(I64 *exp_lanes_q16,\n                                      I64 lane_count,\n                                      I64 exp_sum_q16,\n                                      I64 *probs_q16)\n{\n    I64 i;\n    I64 pass;\n    I64 idx;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 prob_q16;\n    I64 prob_sum_q16;\n    I64 diff_q16;\n    I64 remaining_q16;\n    I64 take_q16;\n    I64 max_exp_q16;\n    I64 max_exp_index;\n    I32 status;\n\n    if (!exp_lanes_q16 || !probs_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (exp_sum_q16 <= 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic before indexed lane access.\n    last_index = lane_count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)probs_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Normalize lanes and keep running probability sum for remainder fixup.\n    max_exp_q16 = exp_lanes_q16[0];\n    max_exp_index = 0;\n    prob_sum_q16 = 0;\n\n    for (i = 0; i < lane_count; i++)\n    {\n        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[i],\n                                           FP_Q16_ONE,\n                                           exp_sum_q16,\n                                           &prob_q16);\n        if (status)\n            return status;\n\n        probs_q16[i] = prob_q16;\n\n        if (prob_q16 > (I64_MAX_VALUE - prob_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        prob_sum_q16 += prob_q16;\n\n        if (exp_lanes_q16[i] > max_exp_q16)\n        {\n            max_exp_q16 = exp_lanes_q16[i];\n            max_exp_index = i;\n        }\n    }\n\n    diff_q16 = FP_Q16_ONE - prob_sum_q16;\n    if (!diff_q16)\n        return FP_Q16_OK;\n\n    // If sum is low, add full residual to argmax lane.\n    if (diff_q16 > 0)\n    {\n        if (probs_q16[max_exp_index] > (I64_MAX_VALUE - diff_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        probs_q16[max_exp_index] += diff_q16;\n        return FP_Q16_OK;\n    }\n\n    // If sum is high, subtract excess deterministically without going < 0.\n    remaining_q16 = -diff_q16;\n    for (pass = 0; pass < lane_count && remaining_q16 > 0; pass++)\n    {\n        idx = max_exp_index + pass;\n        if (idx >= lane_count)\n            idx -= lane_count;\n\n        take_q16 = probs_q16[idx];\n        if (take_q16 > remaining_q16)\n            take_q16 = remaining_q16;\n\n        probs_q16[idx] -= take_q16;\n        remaining_q16 -= take_q16;\n    }\n\n    if (remaining_q16)\n        return FP_Q16_ERR_OVERFLOW;\n\n    return FP_Q16_OK;\n}\n\n// Checked no-alias normalization helper for immutable exp-lane callers.\n// Behavior:\n//   - Rejects exp_lanes_q16 == probs_q16 with BAD_PARAM.\n//   - Otherwise delegates to FPQ16SoftmaxNormalizePhaseChecked so rounding,\n//     deterministic remainder correction, and overflow contracts remain\n//     byte-for-byte identical with the alias-permitted path.\nI32 FPQ16SoftmaxNormalizePhaseNoAliasChecked(I64 *exp_lanes_q16,\n                                             I64 lane_count,\n                                             I64 exp_sum_q16,\n                                             I64 *probs_q16)\n{\n    if (!exp_lanes_q16 || !probs_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (exp_lanes_q16 == probs_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\n                                             lane_count,\n                                             exp_sum_q16,\n                                             probs_q16);\n}\n\n// Internal checked preflight for normalization math.\n// Purpose:\n//   - Re-run normalize arithmetic checks without writing output lanes.\n//   - Lets composed helpers fail before mutating caller probability buffers.\n// Contracts mirror FPQ16SoftmaxNormalizePhaseChecked except no output pointer.\nI32 FPQ16SoftmaxNormalizePhasePreflightChecked(I64 *exp_lanes_q16,\n                                               I64 lane_count,\n                                               I64 exp_sum_q16)\n{\n    I64 i;\n    I64 pass;\n    I64 idx;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 prob_q16;\n    I64 prob_sum_q16;\n--- test\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxExpPhaseFromPreclampedChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_OVERFLOW = 4\n\nEXP_Q16_LN2 = 45426\nEXP_Q16_MAX_INPUT = 655360\nEXP_Q16_MIN_INPUT = -655360\n\nI64_MAX_VALUE = 0x7FFFFFFFFFFFFFFF\nU64_MAX_VALUE = 0xFFFFFFFFFFFFFFFF\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    half = 1 << (shift - 1)\n    return (value + half) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef fpq16_mul(a: int, b: int) -> int:\n    return round_shift_right_signed(a * b, FP_Q16_SHIFT)\n\n\ndef fpq16_exp_from_clamped_input_checked(clamped_input_q16: int) -> tuple[int, int]:\n    if clamped_input_q16 < EXP_Q16_MIN_INPUT or clamped_input_q16 > EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM, 0\n\n    if clamped_input_q16 >= EXP_Q16_MAX_INPUT:\n        return FP_Q16_OK, I64_MAX_VALUE\n    if clamped_input_q16 <= EXP_Q16_MIN_INPUT:\n        return FP_Q16_OK, 0\n\n    k = clamped_input_q16 // EXP_Q16_LN2\n    if clamped_input_q16 < 0 and (clamped_input_q16 % EXP_Q16_LN2):\n        k -= 1\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2)\n\n    r2 = fpq16_mul(r, r)\n    r3 = fpq16_mul(r2, r)\n    r4 = fpq16_mul(r3, r)\n\n    poly = FP_Q16_ONE + r + (r2 // 2) + (r3 // 6) + (r4 // 24)\n\n    if k >= 0:\n        if k >= 30:\n            return FP_Q16_OK, I64_MAX_VALUE\n        if poly > (I64_MAX_VALUE >> k):\n            return FP_Q16_OK, I64_MAX_VALUE\n        return FP_Q16_OK, poly << k\n\n    if k <= -63:\n        return FP_Q16_OK, 0\n\n    return FP_Q16_OK, poly >> (-k)\n\n\ndef fpq16_exp_array_from_clamped_input_checked_reference(input_q16: list[int], count: int) -> tuple[int, list[int]]:\n    if count < 0:\n        return FP_Q16_ERR_BAD_PARAM, []\n    if count == 0:\n        return FP_Q16_OK, []\n\n    last_index = count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, []\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, []\n\n    for i in range(count):\n        if input_q16[i] < EXP_Q16_MIN_INPUT or input_q16[i] > EXP_Q16_MAX_INPUT:\n            return FP_Q16_ERR_BAD_PARAM, []\n\n    output_q16: list[int] = []\n    for i in range(count):\n        err, value = fpq16_exp_from_clamped_input_checked(input_q16[i])\n        if err != FP_Q16_OK:\n            return err, []\n        output_q16.append(value)\n\n    return FP_Q16_OK, output_q16\n\n\ndef fpq16_softmax_exp_phase_from_preclamped_checked_reference(\n    preclamped_logits_q16: list[int],\n    lane_count: int,\n) -> tuple[int, list[int], int]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, [], 0\n    if lane_count == 0:\n        return FP_Q16_OK, [], 0\n\n    last_index = lane_count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, [], 0\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, [], 0\n\n    err, exp_lanes_q16 = fpq16_exp_array_from_clamped_input_checked_reference(\n        preclamped_logits_q16,\n        lane_count,\n    )\n    if err != FP_Q16_OK:\n        return err, [], 0\n\n    exp_sum_q16 = 0\n    for lane in exp_lanes_q16:\n        if lane > I64_MAX_VALUE - exp_sum_q16:\n            return FP_Q16_ERR_OVERFLOW, exp_lanes_q16, 0\n        exp_sum_q16 += lane\n\n    return FP_Q16_OK, exp_lanes_q16, exp_sum_q16\n\n\ndef q16_from_float(value: float) -> int:\n    return int(round(value * FP_Q16_ONE))\n\n\ndef q16_to_float(value: int) -> float:\n    return value / FP_Q16_ONE\n\n\ndef test_empty_vector_returns_zero_sum() -> None:\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference([], 0)\n    assert err == FP_Q16_OK\n    assert exp_lanes == []\n    assert exp_sum == 0\n\n\ndef test_negative_count_is_bad_param() -> None:\n    err, _, _ = fpq16_softmax_exp_phase_from_preclamped_checked_reference([], -1)\n    assert err == FP_Q16_ERR_BAD_PARAM\n\n\ndef test_domain_violation_preserves_no_partial_writes() -> None:\n    logits = [q16_from_float(-0.25), EXP_Q16_MAX_INPUT + 1, q16_from_float(0.10)]\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference(logits, len(logits))\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_lanes == []\n    assert exp_sum == 0\n\n\ndef test_known_vector_matches_float_exp_sum() -> None:\n    logits = [q16_from_float(-1.5), q16_from_float(0.0), q16_from_float(0.75)]\n\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference(logits, len(logits))\n    assert err == FP_Q16_OK\n\n    want_exp_lanes: list[int] = []\n    for lane in logits:\n        lane_err, lane_exp = fpq16_exp_from_clamped_input_checked(lane)\n        assert lane_err == FP_Q16_OK\n        want_exp_lanes.append(lane_exp)\n\n    assert exp_lanes == want_exp_lanes\n    assert exp_sum == sum(want_exp_lanes)\n\n    got_sum = q16_to_float(exp_sum)\n    want_sum = sum(math.exp(q16_to_float(x)) for x in logits)\n    assert abs(got_sum - want_sum) <= 0.08\n\n    assert len(exp_lanes) == len(logits)\n    for lane_in, lane_out in zip(logits, exp_lanes):\n        want_lane = math.exp(q16_to_float(lane_in))\n        got_lane = q16_to_float(lane_out)\n        assert abs(got_lane - want_lane) <= 0.08\n\n\ndef test_random_preclamped_vectors_track_float_reference() -> None:\n    rng = random.Random(20260417)\n\n    for _ in range(1200):\n        count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(count)]\n\n        err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference(logits, count)\n        assert err == FP_Q16_OK\n\n        want_exp_lanes: list[int] = []\n        for lane in logits:\n            lane_err, lane_exp = fpq16_exp_from_clamped_input_checked(lane)\n            assert lane_err == FP_Q16_OK\n            want_exp_lanes.append(lane_exp)\n\n        assert exp_lanes == want_exp_lanes\n        assert exp_sum == sum(want_exp_lanes)\n\n        got_sum = q16_to_float(exp_sum)\n        want_sum = sum(math.exp(q16_to_float(x)) for x in logits)\n        assert abs(got_sum - want_sum) <= 2500.0\n\n        for lane_in, lane_out in zip(logits, exp_lanes):\n            want_lane = math.exp(q16_to_float(lane_in))\n            got_lane = q16_to_float(lane_out)\n            assert abs(got_lane - want_lane) <= 100.0\n\n\ndef run() -> None:\n    test_empty_vector_returns_zero_sum()\n    test_negative_count_is_bad_param()\n    test_domain_violation_preserves_no_partial_writes()\n    test_known_vector_matches_float_exp_sum()\n    test_random_preclamped_vectors_track_float_reference()\n    print(\"softmax_exp_phase_from_preclamped_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
