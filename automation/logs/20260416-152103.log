 224\t\n   225\t    if (!lhs_blocks || !rhs_col_blocks || !out_cells_q32)\n   226\t        return Q8_0_MATMUL_ERR_NULL_PTR;\n   227\t\n   228\t    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_cell_capacity < 0)\n   229\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   230\t    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n   231\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   232\t    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n   233\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   234\t    if (tile_rows <= 0 || tile_cols <= 0)\n   235\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   236\t\n   237\t    // Active K span must fit inside each source row stride.\n   238\t    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n   239\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   240\t\n   241\t    // Output row stride must cover active output columns.\n   242\t    if (row_count > 0 && out_row_stride_cells < col_count)\n   243\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   244\t\n   245\t    // Capacity proofs for full row-strided views.\n   246\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n   247\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   248\t    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n   249\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   250\t    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n   251\t        return Q8_0_MATMUL_ERR_OVERFLOW;\n   252\t\n   253\t    if (lhs_required_blocks > lhs_block_capacity)\n   254\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   255\t    if (rhs_required_blocks > rhs_block_capacity)\n   256\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   257\t    if (out_required_cells > out_cell_capacity)\n   258\t        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n   259\t\n   260\t    // Tiled traversal mirr