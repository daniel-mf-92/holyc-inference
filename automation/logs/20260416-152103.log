s < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (tile_rows <= 0 || tile_cols <= 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Active K span must fit inside each source row stride.\n    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Output row stride must cover active output columns.\n    if (row_count > 0 && out_row_stride_cells < col_count)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Capacity proofs for full row-strided views.\n    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    if (lhs_required_blocks > lhs_block_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (rhs_required_blocks > rhs_block_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (out_required_cells > out_cell_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Tiled traversal mirrors Q16 path but preserves Q32 accumulator results.\n---\n// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n#define Q8_0_AVX2_PAIR_COUNT         16\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n#define Q8_0_AVX2_ERR_OVERFLOW       3\n\n#define Q8_0_AVX2_I64_MAX            0x7FFFFFFFFFFFFFFF\n#define Q8_0_AVX2_I64_MIN            (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nBool Q8_0AVX2TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q8_0_AVX2_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q8_0_AVX2_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nBool Q8_0AVX2TryMulI64(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs == -1 && rhs == Q8_0_AVX2_I64_MIN)\n        return FALSE;\n    if (rhs == -1 && lhs == Q8_0_AVX2_I64_MIN)\n        return FALSE;\n\n    if (lhs > 0)\n    {\n        if (rhs > 0)\n        {\n            if (lhs > Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (rhs < Q8_0_AVX2_I64_MIN / lhs)\n                return FALSE;\n        }\n    }\n    else\n    {\n        if (rhs > 0)\n        {\n            if (lhs < Q8_0_AVX2_I64_MIN / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (lhs < Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n    }\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI64 Q8_0AVX2RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0AVX2RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0AVX2RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0AVX2RoundShiftRightUnsigned(-value, shift);\n}\n