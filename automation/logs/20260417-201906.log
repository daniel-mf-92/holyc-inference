{"type":"item.completed","item":{"id":"item_24","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,280p' tests/test_gguf_metadata_read_u8_triple_checked.py\"","aggregated_output":"#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadU8TripleChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u8_triple_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_first_ref: list[int] | None,\n    out_second_ref: list[int] | None,\n    out_third_ref: list[int] | None,\n) -> int:\n    if (\n        buf is None\n        or cursor_ref is None\n        or out_first_ref is None\n        or out_second_ref is None\n        or out_third_ref is None\n    ):\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    first = [0]\n    second = [0]\n    third = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, first)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, second)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, third)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_first_ref[0] = first[0]\n    out_second_ref[0] = second[0]\n    out_third_ref[0] = third[0]\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [2]\n    out_first = [0x11]\n    out_second = [0x22]\n    out_third = [0x33]\n\n    assert (\n        gguf_metadata_read_u8_triple_checked(\n            None,\n            8,\n            cursor,\n            8,\n            out_first,\n            out_second,\n            out_third,\n        )\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [2]\n    assert out_first == [0x11]\n    assert out_second == [0x22]\n    assert out_third == [0x33]\n\n\ndef test_short_read_does_not_commit_first_second_or_cursor() -> None:\n    buf = [0xAA, 0xBB, 0xCC]\n    cursor = [1]\n    out_first = [0x44]\n    out_second = [0x55]\n    out_third = [0x66]\n\n    err = gguf_metadata_read_u8_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [1]\n    assert out_first == [0x44]\n    assert out_second == [0x55]\n    assert out_third == [0x66]\n\n\ndef test_success_reads_three_bytes_and_advances() -> None:\n    buf = [10, 20, 30, 40, 50]\n    cursor = [1]\n    out_first = [0]\n    out_second = [0]\n    out_third = [0]\n\n    err = gguf_metadata_read_u8_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_OK\n    assert out_first[0] == 20\n    assert out_second[0] == 30\n    assert out_third[0] == 40\n    assert cursor[0] == 4\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_245)\n\n    for _ in range(6000):\n        n = rng.randint(1, 320)\n        table_end = rng.randint(0, n)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out_first = [123]\n        out_second = [231]\n        out_third = [77]\n\n        err = gguf_metadata_read_u8_triple_checked(\n            buf,\n            n,\n            cursor,\n            table_end,\n            out_first,\n            out_second,\n            out_third,\n        )\n\n        if cursor0 + 3 <= table_end and cursor0 + 3 <= n:\n            assert err == GGUF_META_TABLE_OK\n            assert out_first[0] == buf[cursor0]\n            assert out_second[0] == buf[cursor0 + 1]\n            assert out_third[0] == buf[cursor0 + 2]\n            assert cursor[0] == cursor0 + 3\n        else:\n            assert err in (\n                GGUF_META_TABLE_ERR_OUT_OF_BOUNDS,\n                GGUF_META_TABLE_ERR_BAD_PARAM,\n                GGUF_META_TABLE_ERR_OVERFLOW,\n            )\n            assert out_first[0] == 123\n            assert out_second[0] == 231\n            assert out_third[0] == 77\n            assert cursor[0] == cursor0\n\n\nif __name__ == \"__main__\":\n    test_null_ptr_and_no_partial_write()\n    test_short_read_does_not_commit_first_second_or_cursor()\n    test_success_reads_three_bytes_and_advances()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_u8_triple_checked_reference_checks=ok\")\n","exit_code":0,"status":"completed"}}
