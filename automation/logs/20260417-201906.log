{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' src/gguf/metadata.HC; echo '---'; sed -n '320,760p' src/gguf/metadata.HC; echo '--- tests similar ---'; ls tests/test_gguf_metadata_read_* | sed -n '1,160p'; echo '--- sample i8 pair + triple patterns in tests ---'; sed -n '1,220p' tests/test_gguf_metadata_read_i8_pair_checked.py; sed -n '1,240p' tests/test_gguf_metadata_read_u8_triple_checked.py; sed -n '1,260p' tests/test_gguf_metadata_read_u16_triple_checked.py\"","aggregated_output":"// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n#define GGUF_META_PARSE_ERR_NOT_FOUND 9\n#define GGUF_META_PARSE_ERR_TYPE_MISMATCH 10\n\n#define GGUF_META_TABLE_OK 0\n#define GGUF_META_TABLE_ERR_NULL_PTR 1\n#define GGUF_META_TABLE_ERR_BAD_PARAM 2\n#define GGUF_META_TABLE_ERR_OVERFLOW 3\n#define GGUF_META_TABLE_ERR_OUT_OF_BOUNDS 4\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTable\n{\n    U64 count;\n    GGUFMetadataKV *items;\n};\n\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor);\n\nI32 GGUFMetadataReadU8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              U8 *out_value);\n\nI32 GGUFMetadataReadI8Checked(U8 *buf,\n                              U64 buf_nbytes,\n                              U64 *cursor,\n                              U64 table_end,\n                              I8 *out_value);\n\nI32 GGUFMetadataReadI8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  I8 *out_first,\n                                  I8 *out_second);\n\nI32 GGUFMetadataReadU8PairChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_first,\n                                  U8 *out_second);\n\nI32 GGUFMetadataReadU8TripleChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    U8 *out_first,\n                                    U8 *out_second,\n                                    U8 *out_third);\n\nI32 GGUFMetadataReadU16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U16 *out_value);\n\nI32 GGUFMetadataReadU16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out_second);\n\nI32 GGUFMetadataReadU16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U16 *out_first,\n                                     U16 *out_second,\n                                     U16 *out_third);\n\nI32 GGUFMetadataReadU16QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U16 *out_first,\n                                   U16 *out_second,\n                                   U16 *out_third,\n                                   U16 *out_fourth);\n\nI32 GGUFMetadataReadI16LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I16 *out_value);\n\nI32 GGUFMetadataReadI16PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second);\n\nI32 GGUFMetadataReadI16TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     I16 *out_first,\n                                     I16 *out_second,\n                                     I16 *out_third);\n\nI32 GGUFMetadataReadI16QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I16 *out_first,\n                                   I16 *out_second,\n                                   I16 *out_third,\n                                   I16 *out_fourth);\n\nI32 GGUFMetadataReadU32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U32 *out_value);\n\nI32 GGUFMetadataReadU32PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U32 *out_first,\n                                   U32 *out_second);\n\nI32 GGUFMetadataReadU32TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U32 *out_first,\n                                     U32 *out_second,\n                                     U32 *out_third);\n\nI32 GGUFMetadataReadU32QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   U32 *out_first,\n                                   U32 *out_second,\n                                   U32 *out_third,\n                                   U32 *out_fourth);\n\nI32 GGUFMetadataReadU64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 U64 *out_value);\n\nI32 GGUFMetadataReadU64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          U64 *out_value);\n\nI32 GGUFMetadataReadU64PairCheckedNoPartial(U8 *buf,\n                                            U64 buf_nbytes,\n                                            U64 *cursor,\n                                            U64 table_end,\n                                            U64 *out_first,\n                                            U64 *out_second);\n\nI32 GGUFMetadataReadU64TripleCheckedNoPartial(U8 *buf,\n                                              U64 buf_nbytes,\n                                              U64 *cursor,\n                                              U64 table_end,\n                                              U64 *out_first,\n                                              U64 *out_second,\n                                              U64 *out_third);\n\nI32 GGUFMetadataReadU64QuadCheckedNoPartial(U8 *buf,\n                                            U64 buf_nbytes,\n                                            U64 *cursor,\n                                            U64 table_end,\n                                            U64 *out_first,\n                                            U64 *out_second,\n                                            U64 *out_third,\n                                            U64 *out_fourth);\n\nI32 GGUFMetadataReadI32LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I32 *out_value);\n\nI32 GGUFMetadataReadI32PairChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I32 *out_first,\n                                   I32 *out_second);\n\nI32 GGUFMetadataReadI32TripleChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     I32 *out_first,\n                                     I32 *out_second,\n                                     I32 *out_third);\n\nI32 GGUFMetadataReadI32QuadChecked(U8 *buf,\n                                   U64 buf_nbytes,\n                                   U64 *cursor,\n                                   U64 table_end,\n                                   I32 *out_first,\n                                   I32 *out_second,\n                                   I32 *out_third,\n                                   I32 *out_fourth);\n\nI32 GGUFMetadataReadI64LEChecked(U8 *buf,\n                                 U64 buf_nbytes,\n                                 U64 *cursor,\n                                 U64 table_end,\n                                 I64 *out_value);\n\nI32 GGUFMetadataReadI64LECheckedNoPartial(U8 *buf,\n                                          U64 buf_nbytes,\n                                          U64 *cursor,\n                                          U64 table_end,\n                                          I64 *out_value);\n\nI32 GGUFMetadataReadI64PairCheckedNoPartial(U8 *buf,\n                                            U64 buf_nbytes,\n                                            U64 *cursor,\n                                            U64 table_end,\n                                            I64 *out_first,\n                                            I64 *out_second);\n\nI32 GGUFMetadataReadI64TripleCheckedNoPartial(U8 *buf,\n                                              U64 buf_nbytes,\n                                              U64 *cursor,\n                                              U64 table_end,\n                                              I64 *out_first,\n                                              I64 *out_second,\n                                              I64 *out_third);\n\nI32 GGUFMetadataReadF32BitsLEChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U32 *out_bits);\n\nI32 GGUFMetadataReadF32BitsLECheckedNoPartial(U8 *buf,\n                                              U64 buf_nbytes,\n                                              U64 *cursor,\n                                              U64 table_end,\n                                              U32 *out_bits);\n\nI32 GGUFMetadataReadF32BitsPairChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U32 *out_first_bits,\n                                       U32 *out_second_bits);\n\nI32 GGUFMetadataReadF32BitsTripleChecked(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n---\n                                         U64 *cursor,\n                                         U64 table_end,\n                                         U32 *out_first_bits,\n                                         U32 *out_second_bits,\n                                         U32 *out_third_bits);\n\nI32 GGUFMetadataReadF32BitsQuadChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U32 *out_first_bits,\n                                       U32 *out_second_bits,\n                                       U32 *out_third_bits,\n                                       U32 *out_fourth_bits);\n\nI32 GGUFMetadataReadF64BitsLEChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U64 *out_bits);\n\nI32 GGUFMetadataReadF64BitsPairChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U64 *out_first_bits,\n                                       U64 *out_second_bits);\n\nI32 GGUFMetadataReadF64BitsTripleChecked(U8 *buf,\n                                         U64 buf_nbytes,\n                                         U64 *cursor,\n                                         U64 table_end,\n                                         U64 *out_first_bits,\n                                         U64 *out_second_bits,\n                                         U64 *out_third_bits);\n\nI32 GGUFMetadataReadBoolChecked(U8 *buf,\n                                U64 buf_nbytes,\n                                U64 *cursor,\n                                U64 table_end,\n                                Bool *out_value);\n\nI32 GGUFMetadataReadBoolPairChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    Bool *out_first,\n                                    Bool *out_second);\n\nI32 GGUFMetadataReadBoolTripleChecked(U8 *buf,\n                                      U64 buf_nbytes,\n                                      U64 *cursor,\n                                      U64 table_end,\n                                      Bool *out_first,\n                                      Bool *out_second,\n                                      Bool *out_third);\n\nI32 GGUFMetadataReadBoolQuadChecked(U8 *buf,\n                                    U64 buf_nbytes,\n                                    U64 *cursor,\n                                    U64 table_end,\n                                    Bool *out_first,\n                                    Bool *out_second,\n                                    Bool *out_third,\n                                    Bool *out_fourth);\n\nI32 GGUFMetadataReadStringLenU64Checked(U8 *buf,\n                                        U64 buf_nbytes,\n                                        U64 *cursor,\n                                        U64 table_end,\n                                        U64 *out_len);\n\nI32 GGUFMetadataReadStringU64HeaderAndBoundsChecked(U8 *buf,\n                                                    U64 buf_nbytes,\n                                                    U64 *cursor,\n                                                    U64 table_end,\n                                                    U64 *out_len,\n                                                    U64 *out_payload_end);\n\nI32 GGUFMetadataReadStringBytesChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U64 str_len,\n                                       U8 *out_bytes,\n                                       U64 out_nbytes);\n\nI32 GGUFMetadataReadStringChecked(U8 *buf,\n                                  U64 buf_nbytes,\n                                  U64 *cursor,\n                                  U64 table_end,\n                                  U8 *out_bytes,\n                                  U64 out_nbytes,\n                                  U64 *out_len);\n\nI32 GGUFMetadataReadKeyStringChecked(U8 *buf,\n                                     U64 buf_nbytes,\n                                     U64 *cursor,\n                                     U64 table_end,\n                                     U8 *out_key_bytes,\n                                     U64 out_key_nbytes,\n                                     U64 *out_key_len);\n\nI32 GGUFMetadataReadArrayHeaderChecked(U8 *buf,\n                                       U64 buf_nbytes,\n                                       U64 *cursor,\n                                       U64 table_end,\n                                       U32 *out_elem_type,\n                                       U64 *out_elem_count);\n\nI32 GGUFMetadataArrayPayloadSpanValidateChecked(U64 payload_start,\n                                                U64 payload_bytes,\n                                                U64 table_end,\n                                                U64 buf_nbytes,\n                                                U64 *out_payload_end);\n\nI32 GGUFMetadataArrayPayloadSpanValidateFromCursorChecked(U64 *cursor,\n                                                          U64 payload_bytes,\n                                                          U64 table_end,\n                                                          U64 buf_nbytes,\n                                                          U64 *out_payload_end);\n\nI32 GGUFMetadataArrayFixedElemWidthBytesChecked(U32 elem_type,\n                                                U64 *out_elem_width_bytes);\n\nI32 GGUFMetadataArrayFixedPayloadBytesChecked(U64 elem_count,\n                                              U64 elem_width_bytes,\n                                              U64 *out_payload_bytes);\n\nI32 GGUFMetadataArrayPayloadSpanFromFixedTypeChecked(U32 elem_type,\n                                                     U64 elem_count,\n                                                     U64 payload_start,\n                                                     U64 table_end,\n                                                     U64 buf_nbytes,\n                                                     U64 *out_payload_bytes,\n                                                     U64 *out_payload_end);\n\nI32 GGUFMetadataArrayPayloadSpanFromFixedTypeAtCursorChecked(U32 elem_type,\n                                                             U64 elem_count,\n                                                             U64 *cursor,\n                                                             U64 table_end,\n                                                             U64 buf_nbytes,\n                                                             U64 *out_payload_bytes,\n                                                             U64 *out_payload_end);\n\nI32 GGUFMetadataArrayPayloadSpanFromFixedTypeAtCursorCheckedDefault(U32 elem_type,\n                                                                    U64 elem_count,\n                                                                    U64 *cursor,\n                                                                    U64 buf_nbytes,\n                                                                    U64 *out_payload_bytes,\n                                                                    U64 *out_payload_end);\n\n// Validate metadata table byte-window math before any parser cursor movement.\n// Contract: `out_table_end` is written only on success.\nI32 GGUFMetadataTableSpanValidateChecked(U64 table_start,\n                                         U64 table_nbytes,\n                                         U64 file_nbytes,\n                                         U64 *out_table_end)\n{\n    U64 table_end;\n\n    if (!out_table_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Parser cursors are signed in multiple call sites; reject spans that do\n    // not fit cleanly in positive I64 address space.\n    if (table_start > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (table_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (file_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (table_start > file_nbytes)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    if (table_nbytes > (0xFFFFFFFFFFFFFFFF - table_start))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    table_end = table_start + table_nbytes;\n    if (table_end > file_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_table_end = table_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate metadata table bounds, then derive a checked cursor position at\n// `table_start + cursor_advance`. This helper keeps parser entrypoints on one\n// auditable range-math path before any field reads happen.\n// Contract: out pointers are written only on success.\nI32 GGUFMetadataTableCursorAdvanceChecked(U64 table_start,\n                                          U64 table_nbytes,\n                                          U64 file_nbytes,\n                                          U64 cursor_advance,\n                                          U64 *out_cursor,\n                                          U64 *out_table_end)\n{\n    U64 table_end;\n    I32 err;\n\n    if (!out_cursor || !out_table_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    err = GGUFMetadataTableSpanValidateChecked(table_start,\n                                               table_nbytes,\n                                               file_nbytes,\n                                               &table_end);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Advance is relative to table_start. Equal-to-end is legal and matches\n    // cursor semantics used by metadata table loops.\n    err = GGUFMetadataCursorCanAdvanceChecked(table_start,\n                                              cursor_advance,\n                                              table_end,\n                                              out_cursor);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_table_end = table_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate `cursor + need <= table_end` with explicit signed/unsigned overflow\n// guards. On success, `out_next_cursor` is the advanced cursor position.\n// Contract: out pointer is written only on success.\nI32 GGUFMetadataCursorCanAdvanceChecked(U64 cursor,\n                                        U64 need,\n                                        U64 table_end,\n                                        U64 *out_next_cursor)\n{\n    U64 next_cursor;\n\n    if (!out_next_cursor)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep cursor math in positive I64 space because parser entrypoints route\n    // through signed cursors.\n    if (cursor > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (need > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (table_end > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (cursor > table_end)\n        return GGUF_META_TABLE_ERR_BAD_PARAM;\n\n    if (cursor > (0xFFFFFFFFFFFFFFFF - need))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    next_cursor = cursor + need;\n    if (next_cursor > table_end)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_next_cursor = next_cursor;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate a metadata-array payload window `[payload_start, payload_end)` where\n// `payload_end = payload_start + payload_bytes`.\n// Contract: `*out_payload_end` is written only on success.\nI32 GGUFMetadataArrayPayloadSpanValidateChecked(U64 payload_start,\n                                                U64 payload_bytes,\n                                                U64 table_end,\n                                                U64 buf_nbytes,\n                                                U64 *out_payload_end)\n{\n    U64 payload_end;\n    I32 err;\n\n    if (!out_payload_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep data-plane indexing in positive I64 space, matching all checked\n    // metadata cursor/table helpers used by parser entrypoints.\n    if (buf_nbytes > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    // Compose payload window math through shared checked cursor helper so\n    // signed-space + unsigned-overflow surfaces stay identical.\n    err = GGUFMetadataCursorCanAdvanceChecked(payload_start,\n                                              payload_bytes,\n                                              table_end,\n                                              &payload_end);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    // Backing byte span must contain the validated payload window.\n    if (payload_end > buf_nbytes)\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS;\n\n    *out_payload_end = payload_end;\n    return GGUF_META_TABLE_OK;\n}\n\n// Validate fixed-width metadata ARRAY payload window starting at `*cursor`\n// and return checked payload end cursor for decode loops.\n// Contract: writes `*out_payload_end` only on success and never mutates\n// `*cursor` (caller decides when to commit cursor movement).\nI32 GGUFMetadataArrayPayloadSpanValidateFromCursorChecked(U64 *cursor,\n                                                          U64 payload_bytes,\n                                                          U64 table_end,\n                                                          U64 buf_nbytes,\n                                                          U64 *out_payload_end)\n{\n    U64 payload_start;\n\n    if (!cursor || !out_payload_end)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    payload_start = *cursor;\n\n    // Compose through canonical payload-span validator so cursor-sourced\n    // windows keep identical checked bounds/overflow semantics.\n    return GGUFMetadataArrayPayloadSpanValidateChecked(payload_start,\n                                                       payload_bytes,\n                                                       table_end,\n                                                       buf_nbytes,\n                                                       out_payload_end);\n}\n\n// Return canonical fixed-width byte size for metadata ARRAY element types.\n// Reject variable-width ARRAY element tags (STRING/ARRAY) because payload-byte\n// math for those must use per-element decoding instead of fixed `count*width`.\n// Contract: `*out_elem_width_bytes` is written only on success.\nI32 GGUFMetadataArrayFixedElemWidthBytesChecked(U32 elem_type,\n                                                U64 *out_elem_width_bytes)\n{\n    U64 width_bytes;\n\n    if (!out_elem_width_bytes)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    switch (elem_type)\n    {\n        case GGUF_TYPE_UINT8:\n        case GGUF_TYPE_INT8:\n        case GGUF_TYPE_BOOL:\n            width_bytes = 1;\n            break;\n\n        case GGUF_TYPE_UINT16:\n        case GGUF_TYPE_INT16:\n            width_bytes = 2;\n            break;\n\n        case GGUF_TYPE_UINT32:\n        case GGUF_TYPE_INT32:\n        case GGUF_TYPE_FLOAT32:\n            width_bytes = 4;\n            break;\n\n        case GGUF_TYPE_UINT64:\n        case GGUF_TYPE_INT64:\n        case GGUF_TYPE_FLOAT64:\n            width_bytes = 8;\n            break;\n\n        // Variable-width element payloads require non-fixed decoding paths.\n        case GGUF_TYPE_STRING:\n        case GGUF_TYPE_ARRAY:\n        default:\n            return GGUF_META_TABLE_ERR_BAD_PARAM;\n    }\n\n    *out_elem_width_bytes = width_bytes;\n    return GGUF_META_TABLE_OK;\n}\n\n// Checked multiplication helper used by metadata table math where callers keep\n// cursor/index values in positive I64 space.\n// Contract: writes `*out_product` only on success.\nI32 GGUFMetadataMulU64Checked(U64 lhs,\n                              U64 rhs,\n                              U64 *out_product)\n{\n    U64 product;\n\n    if (!out_product)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Keep table/index arithmetic in positive I64 space for compatibility with\n    // parser entrypoints that route through signed cursors.\n    if (lhs > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n    if (rhs > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    if (rhs && lhs > (0xFFFFFFFFFFFFFFFF / rhs))\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    product = lhs * rhs;\n    if (product > 0x7FFFFFFFFFFFFFFF)\n        return GGUF_META_TABLE_ERR_OVERFLOW;\n\n    *out_product = product;\n    return GGUF_META_TABLE_OK;\n}\n\n// Compute fixed-width metadata ARRAY payload bytes (`elem_count*elem_width`).\n// Intended for callers that first validate/resolve fixed element widths, then\n// compose this payload-byte result with payload-span validation helpers.\n// Contract: writes `*out_payload_bytes` only on success.\nI32 GGUFMetadataArrayFixedPayloadBytesChecked(U64 elem_count,\n                                              U64 elem_width_bytes,\n                                              U64 *out_payload_bytes)\n{\n    U64 payload_bytes;\n    I32 err;\n\n    if (!out_payload_bytes)\n        return GGUF_META_TABLE_ERR_NULL_PTR;\n\n    // Compose through shared checked multiply guards so all fixed-width array\n    // payload math follows one overflow/sign-domain contract.\n    err = GGUFMetadataMulU64Checked(elem_count,\n                                    elem_width_bytes,\n                                    &payload_bytes);\n    if (err != GGUF_META_TABLE_OK)\n        return err;\n\n    *out_payload_bytes = payload_bytes;\n    return GGUF_META_TABLE_OK;\n}\n\n// Compose fixed-width metadata ARRAY payload-byte math and validated payload\n// span bounds in one checked helper for array decode entrypoints.\n// Contract: output pointers are written only on success.\nI32 GGUFMetadataArrayPayloadSpanFromFixedTypeChecked(U32 elem_type,\n                                                     U64 elem_count,\n                                                     U64 payload_start,\n                                                     U64 table_end,\n                                                     U64 buf_nbytes,\n                                                     U64 *out_payload_bytes,\n                                                     U64 *out_payload_end)\n{\n    U64 elem_width_bytes;\n    U64 payload_bytes;\n    U64 payload_end;\n--- tests similar ---\ntests/test_gguf_metadata_read_array_header_checked.py\ntests/test_gguf_metadata_read_bool_checked.py\ntests/test_gguf_metadata_read_bool_pair_checked.py\ntests/test_gguf_metadata_read_bool_quad_checked.py\ntests/test_gguf_metadata_read_bool_triple_checked.py\ntests/test_gguf_metadata_read_f32bits_pair_checked.py\ntests/test_gguf_metadata_read_f32bits_quad_checked.py\ntests/test_gguf_metadata_read_f32bits_triple_checked.py\ntests/test_gguf_metadata_read_f32bitsle_checked.py\ntests/test_gguf_metadata_read_f32bitsle_checked_no_partial.py\ntests/test_gguf_metadata_read_f64bits_pair_checked.py\ntests/test_gguf_metadata_read_f64bits_triple_checked.py\ntests/test_gguf_metadata_read_f64bitsle_checked.py\ntests/test_gguf_metadata_read_i16_pair_checked.py\ntests/test_gguf_metadata_read_i16_quad_checked.py\ntests/test_gguf_metadata_read_i16_triple_checked.py\ntests/test_gguf_metadata_read_i16le_checked.py\ntests/test_gguf_metadata_read_i32_pair_checked.py\ntests/test_gguf_metadata_read_i32_quad_checked.py\ntests/test_gguf_metadata_read_i32_triple_checked.py\ntests/test_gguf_metadata_read_i32le_checked.py\ntests/test_gguf_metadata_read_i64_pair_checked_no_partial.py\ntests/test_gguf_metadata_read_i64_triple_checked_no_partial.py\ntests/test_gguf_metadata_read_i64le_checked.py\ntests/test_gguf_metadata_read_i64le_checked_no_partial.py\ntests/test_gguf_metadata_read_i8_checked.py\ntests/test_gguf_metadata_read_i8_pair_checked.py\ntests/test_gguf_metadata_read_key_string_checked.py\ntests/test_gguf_metadata_read_string_bytes_checked.py\ntests/test_gguf_metadata_read_string_checked.py\ntests/test_gguf_metadata_read_string_len_u64_checked.py\ntests/test_gguf_metadata_read_string_u64_header_bounds_checked.py\ntests/test_gguf_metadata_read_u16_pair_checked.py\ntests/test_gguf_metadata_read_u16_quad_checked.py\ntests/test_gguf_metadata_read_u16_triple_checked.py\ntests/test_gguf_metadata_read_u16le_checked.py\ntests/test_gguf_metadata_read_u32_pair_checked.py\ntests/test_gguf_metadata_read_u32_quad_checked.py\ntests/test_gguf_metadata_read_u32_triple_checked.py\ntests/test_gguf_metadata_read_u32le_checked.py\ntests/test_gguf_metadata_read_u64_pair_checked_no_partial.py\ntests/test_gguf_metadata_read_u64_quad_checked_no_partial.py\ntests/test_gguf_metadata_read_u64_triple_checked_no_partial.py\ntests/test_gguf_metadata_read_u64le_checked.py\ntests/test_gguf_metadata_read_u64le_checked_no_partial.py\ntests/test_gguf_metadata_read_u8_checked.py\ntests/test_gguf_metadata_read_u8_pair_checked.py\ntests/test_gguf_metadata_read_u8_triple_checked.py\n--- sample i8 pair + triple patterns in tests ---\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadI8PairChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\nU8_MASK = (1 << 8) - 1\n\n\ndef reinterpret_u8_as_i8(value: int) -> int:\n    value &= U8_MASK\n    if value >= (1 << 7):\n        return value - (1 << 8)\n    return value\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_i8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    raw_u8 = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, raw_u8)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = reinterpret_u8_as_i8(raw_u8[0])\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_i8_pair_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_first_ref: list[int] | None,\n    out_second_ref: list[int] | None,\n) -> int:\n    if (\n        buf is None\n        or cursor_ref is None\n        or out_first_ref is None\n        or out_second_ref is None\n    ):\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    first = [0]\n    second = [0]\n\n    err = gguf_metadata_read_i8_checked(buf, buf_nbytes, cur, table_end, first)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_i8_checked(buf, buf_nbytes, cur, table_end, second)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_first_ref[0] = first[0]\n    out_second_ref[0] = second[0]\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [1]\n    out_first = [7]\n    out_second = [8]\n\n    assert (\n        gguf_metadata_read_i8_pair_checked(None, 4, cursor, 4, out_first, out_second)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_first == [7]\n    assert out_second == [8]\n\n    assert (\n        gguf_metadata_read_i8_pair_checked([1, 2, 3], 3, None, 3, out_first, out_second)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert out_first == [7]\n    assert out_second == [8]\n\n    assert (\n        gguf_metadata_read_i8_pair_checked([1, 2, 3], 3, cursor, 3, None, out_second)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_second == [8]\n\n    assert (\n        gguf_metadata_read_i8_pair_checked([1, 2, 3], 3, cursor, 3, out_first, None)\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [1]\n    assert out_first == [7]\n\n\ndef test_short_read_does_not_commit_first_or_cursor() -> None:\n    buf = [0x7F, 0x80, 0xFF]\n    cursor = [2]\n    out_first = [11]\n    out_second = [22]\n\n    err = gguf_metadata_read_i8_pair_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [2]\n    assert out_first == [11]\n    assert out_second == [22]\n\n\ndef test_success_reads_two_i8_and_advances() -> None:\n    buf = [0x7F, 0x80, 0xFF, 0x01]\n    cursor = [0]\n    out_first = [0]\n    out_second = [0]\n\n    err = gguf_metadata_read_i8_pair_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n    )\n    assert err == GGUF_META_TABLE_OK\n    assert out_first[0] == 127\n    assert out_second[0] == -128\n    assert cursor[0] == 2\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_226)\n\n    for _ in range(5000):\n        n = rng.randint(1, 256)\n        table_end = rng.randint(0, n)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out_first = [101]\n        out_second = [202]\n\n        err = gguf_metadata_read_i8_pair_checked(\n            buf,\n            n,\n            cursor,\n            table_end,\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadU8TripleChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u8_triple_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_first_ref: list[int] | None,\n    out_second_ref: list[int] | None,\n    out_third_ref: list[int] | None,\n) -> int:\n    if (\n        buf is None\n        or cursor_ref is None\n        or out_first_ref is None\n        or out_second_ref is None\n        or out_third_ref is None\n    ):\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    first = [0]\n    second = [0]\n    third = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, first)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, second)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, third)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_first_ref[0] = first[0]\n    out_second_ref[0] = second[0]\n    out_third_ref[0] = third[0]\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [2]\n    out_first = [0x11]\n    out_second = [0x22]\n    out_third = [0x33]\n\n    assert (\n        gguf_metadata_read_u8_triple_checked(\n            None,\n            8,\n            cursor,\n            8,\n            out_first,\n            out_second,\n            out_third,\n        )\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [2]\n    assert out_first == [0x11]\n    assert out_second == [0x22]\n    assert out_third == [0x33]\n\n\ndef test_short_read_does_not_commit_first_second_or_cursor() -> None:\n    buf = [0xAA, 0xBB, 0xCC]\n    cursor = [1]\n    out_first = [0x44]\n    out_second = [0x55]\n    out_third = [0x66]\n\n    err = gguf_metadata_read_u8_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [1]\n    assert out_first == [0x44]\n    assert out_second == [0x55]\n    assert out_third == [0x66]\n\n\ndef test_success_reads_three_bytes_and_advances() -> None:\n    buf = [10, 20, 30, 40, 50]\n    cursor = [1]\n    out_first = [0]\n    out_second = [0]\n    out_third = [0]\n\n    err = gguf_metadata_read_u8_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_OK\n    assert out_first[0] == 20\n    assert out_second[0] == 30\n    assert out_third[0] == 40\n    assert cursor[0] == 4\n\n\ndef test_randomized_parity() -> None:\n    rng = random.Random(20260417_245)\n\n    for _ in range(6000):\n        n = rng.randint(1, 320)\n        table_end = rng.randint(0, n)\n        buf = [rng.randint(0, 255) for _ in range(n)]\n        cursor0 = rng.randint(0, table_end)\n\n        cursor = [cursor0]\n        out_first = [123]\n        out_second = [231]\n        out_third = [77]\n\n        err = gguf_metadata_read_u8_triple_checked(\n            buf,\n            n,\n            cursor,\n            table_end,\n            out_first,\n            out_second,\n            out_third,\n        )\n\n        if cursor0 + 3 <= table_end and cursor0 + 3 <= n:\n            assert err == GGUF_META_TABLE_OK\n            assert out_first[0] == buf[cursor0]\n            assert out_second[0] == buf[cursor0 + 1]\n            assert out_third[0] == buf[cursor0 + 2]\n            assert cursor[0] == cursor0 + 3\n        else:\n            assert err in (\n                GGUF_META_TABLE_ERR_OUT_OF_BOUNDS,\n                GGUF_META_TABLE_ERR_BAD_PARAM,\n                GGUF_META_TABLE_ERR_OVERFLOW,\n            )\n            assert out_first[0] == 123\n            assert out_second[0] == 231\n            assert out_third[0] == 77\n            assert cursor[0] == cursor0\n\n\nif __name__ == \"__main__\":\n    test_null_ptr_and_no_partial_write()\n    test_short_read_does_not_commit_first_second_or_cursor()\n    test_success_reads_three_bytes_and_advances()\n    test_randomized_parity()\n    print(\"gguf_metadata_read_u8_triple_checked_reference_checks=ok\")\n#!/usr/bin/env python3\n\"\"\"Reference checks for GGUFMetadataReadU16TripleChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nGGUF_META_TABLE_OK = 0\nGGUF_META_TABLE_ERR_NULL_PTR = 1\nGGUF_META_TABLE_ERR_BAD_PARAM = 2\nGGUF_META_TABLE_ERR_OVERFLOW = 3\nGGUF_META_TABLE_ERR_OUT_OF_BOUNDS = 4\n\nI64_MAX = (1 << 63) - 1\n\n\ndef gguf_metadata_cursor_can_advance_checked(\n    cursor: int,\n    need: int,\n    table_end: int,\n) -> tuple[int, int | None]:\n    if cursor > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if need > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if table_end > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n    if cursor > table_end:\n        return GGUF_META_TABLE_ERR_BAD_PARAM, None\n    if cursor > ((1 << 64) - 1) - need:\n        return GGUF_META_TABLE_ERR_OVERFLOW, None\n\n    next_cursor = cursor + need\n    if next_cursor > table_end:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS, None\n\n    return GGUF_META_TABLE_OK, next_cursor\n\n\ndef gguf_metadata_read_u8_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n    if buf_nbytes > I64_MAX:\n        return GGUF_META_TABLE_ERR_OVERFLOW\n\n    cur = cursor_ref[0]\n    err, next_cursor = gguf_metadata_cursor_can_advance_checked(cur, 1, table_end)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    assert next_cursor is not None\n    if next_cursor > buf_nbytes:\n        return GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n\n    out_value_ref[0] = buf[cur]\n    cursor_ref[0] = next_cursor\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u16le_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_value_ref: list[int] | None,\n) -> int:\n    if buf is None or cursor_ref is None or out_value_ref is None:\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    b0 = [0]\n    b1 = [0]\n\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, b0)\n    if err != GGUF_META_TABLE_OK:\n        return err\n    err = gguf_metadata_read_u8_checked(buf, buf_nbytes, cur, table_end, b1)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_value_ref[0] = b0[0] | (b1[0] << 8)\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef gguf_metadata_read_u16_triple_checked(\n    buf: list[int] | None,\n    buf_nbytes: int,\n    cursor_ref: list[int] | None,\n    table_end: int,\n    out_first_ref: list[int] | None,\n    out_second_ref: list[int] | None,\n    out_third_ref: list[int] | None,\n) -> int:\n    if (\n        buf is None\n        or cursor_ref is None\n        or out_first_ref is None\n        or out_second_ref is None\n        or out_third_ref is None\n    ):\n        return GGUF_META_TABLE_ERR_NULL_PTR\n\n    cur = [cursor_ref[0]]\n    first = [0]\n    second = [0]\n    third = [0]\n\n    err = gguf_metadata_read_u16le_checked(buf, buf_nbytes, cur, table_end, first)\n    if err != GGUF_META_TABLE_OK:\n        return err\n    err = gguf_metadata_read_u16le_checked(buf, buf_nbytes, cur, table_end, second)\n    if err != GGUF_META_TABLE_OK:\n        return err\n    err = gguf_metadata_read_u16le_checked(buf, buf_nbytes, cur, table_end, third)\n    if err != GGUF_META_TABLE_OK:\n        return err\n\n    out_first_ref[0] = first[0]\n    out_second_ref[0] = second[0]\n    out_third_ref[0] = third[0]\n    cursor_ref[0] = cur[0]\n    return GGUF_META_TABLE_OK\n\n\ndef _le_u16(value: int) -> list[int]:\n    return [value & 0xFF, (value >> 8) & 0xFF]\n\n\ndef test_null_ptr_and_no_partial_write() -> None:\n    cursor = [3]\n    out_first = [0xAAAA]\n    out_second = [0xBBBB]\n    out_third = [0xCCCC]\n\n    assert (\n        gguf_metadata_read_u16_triple_checked(\n            None,\n            10,\n            cursor,\n            10,\n            out_first,\n            out_second,\n            out_third,\n        )\n        == GGUF_META_TABLE_ERR_NULL_PTR\n    )\n    assert cursor == [3]\n    assert out_first == [0xAAAA]\n    assert out_second == [0xBBBB]\n    assert out_third == [0xCCCC]\n\n\ndef test_pair_stage_fail_does_not_commit_outputs_or_cursor() -> None:\n    # Only three bytes available in-table: first U16 can decode, but the second\n    # lane inside pair staging fails. Triple reader must keep cursor/outputs unchanged.\n    buf = [0x34, 0x12, 0xAB]\n\n    cursor = [0]\n    out_first = [0x1111]\n    out_second = [0x2222]\n    out_third = [0x3333]\n\n    err = gguf_metadata_read_u16_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [0]\n    assert out_first == [0x1111]\n    assert out_second == [0x2222]\n    assert out_third == [0x3333]\n\n\ndef test_third_scalar_fail_does_not_commit_prior_lanes_or_cursor() -> None:\n    first = 0x1234\n    second = 0x5678\n    buf = _le_u16(first) + _le_u16(second) + [0xAA]\n\n    cursor = [0]\n    out_first = [0xDEAD]\n    out_second = [0xBEEF]\n    out_third = [0xC0DE]\n\n    err = gguf_metadata_read_u16_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_ERR_OUT_OF_BOUNDS\n    assert cursor == [0]\n    assert out_first == [0xDEAD]\n    assert out_second == [0xBEEF]\n    assert out_third == [0xC0DE]\n\n\ndef test_success_reads_three_u16_and_advances() -> None:\n    first = 0xBEEF\n    second = 0x1234\n    third = 0xCAFE\n    buf = [0x77] + _le_u16(first) + _le_u16(second) + _le_u16(third) + [0x88]\n\n    cursor = [1]\n    out_first = [0]\n    out_second = [0]\n    out_third = [0]\n\n    err = gguf_metadata_read_u16_triple_checked(\n        buf,\n        len(buf),\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_OK\n    assert out_first[0] == first\n    assert out_second[0] == second\n    assert out_third[0] == third\n    assert cursor[0] == 7\n\n\ndef test_overflow_passthrough_and_no_commit() -> None:\n    buf = [0] * 20\n\n    cursor = [0]\n    out_first = [1]\n    out_second = [2]\n    out_third = [3]\n    err = gguf_metadata_read_u16_triple_checked(\n        buf,\n        I64_MAX + 1,\n        cursor,\n        len(buf),\n        out_first,\n        out_second,\n        out_third,\n    )\n    assert err == GGUF_META_TABLE_ERR_OVERFLOW\n    assert cursor == [0]\n    assert out_first == [1]\n    assert out_second == [2]\n    assert out_third == [3]\n\n","exit_code":0,"status":"completed"}}
