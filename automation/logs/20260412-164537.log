{"type":"item.completed","item":{"id":"item_34","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/gguf/tensor_data_base.HC | sed -n '1,180p'; echo '---'; nl -ba tests/test_gguf_tensor_data_base.py | sed -n '1,260p'; echo '---'; nl -ba MASTER_TASKS.md | sed -n '220,230p'; nl -ba MASTER_TASKS.md | sed -n '252,260p'\"","aggregated_output":"     1\t// tensor_data_base.HC\n     2\t// GGUF tensor-data base alignment helpers for HolyC inference runtime.\n     3\t\n     4\t#define GGUF_TDBASE_OK 0\n     5\t#define GGUF_TDBASE_ERR_NULL_PTR 1\n     6\t#define GGUF_TDBASE_ERR_BAD_ALIGNMENT 2\n     7\t#define GGUF_TDBASE_ERR_OVERFLOW 3\n     8\t#define GGUF_TDBASE_ERR_MISALIGNED_BASE 4\n     9\t#define GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET 5\n    10\t#define GGUF_TDBASE_ERR_BAD_TYPE 6\n    11\t\n    12\t// GGUF default tensor alignment when metadata key `general.alignment`\n    13\t// is absent.\n    14\t#define GGUF_DEFAULT_ALIGNMENT 32\n    15\t\n    16\t// Subset of ggml tensor types currently enabled in HolyC inference runtime.\n    17\t// Keep this list strict and explicit so sizing math never silently accepts\n    18\t// unknown quantization tags from malformed GGUF files.\n    19\t#define GGML_TYPE_F32   0\n    20\t#define GGML_TYPE_F16   1\n    21\t#define GGML_TYPE_Q4_0  2\n    22\t#define GGML_TYPE_Q8_0  8\n    23\t\n    24\t// GGML quantization blocks for runtime-critical formats:\n    25\t// - F32/F16 are scalar types (block size 1).\n    26\t// - Q4_0 and Q8_0 are packed in 32-element blocks.\n    27\t#define GGML_BLCK_SIZE_F32   1\n    28\t#define GGML_BLCK_SIZE_F16   1\n    29\t#define GGML_BLCK_SIZE_Q4_0  32\n    30\t#define GGML_BLCK_SIZE_Q8_0  32\n    31\t\n    32\t// Block payload byte widths from ggml struct layouts:\n    33\t// - Q4_0: fp16 scale (2 bytes) + 16 packed nibbles = 18 bytes.\n    34\t// - Q8_0: fp16 scale (2 bytes) + 32 signed bytes = 34 bytes.\n    35\t#define GGML_TYPE_SIZE_F32   4\n    36\t#define GGML_TYPE_SIZE_F16   2\n    37\t#define GGML_TYPE_SIZE_Q4_0  18\n    38\t#define GGML_TYPE_SIZE_Q8_0  34\n    39\t\n    40\tI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n    41\t{\n    42\t    if (!out_block_size)\n    43\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    44\t\n    45\t    switch (ggml_type)\n    46\t    {\n    47\t        case GGML_TYPE_F32:\n    48\t            *out_block_size = GGML_BLCK_SIZE_F32;\n    49\t            return GGUF_TDBASE_OK;\n    50\t        case GGML_TYPE_F16:\n    51\t            *out_block_size = GGML_BLCK_SIZE_F16;\n    52\t            return GGUF_TDBASE_OK;\n    53\t        case GGML_TYPE_Q4_0:\n    54\t            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n    55\t            return GGUF_TDBASE_OK;\n    56\t        case GGML_TYPE_Q8_0:\n    57\t            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n    58\t            return GGUF_TDBASE_OK;\n    59\t    }\n    60\t\n    61\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    62\t}\n    63\t\n    64\tI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n    65\t{\n    66\t    if (!out_block_bytes)\n    67\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    68\t\n    69\t    switch (ggml_type)\n    70\t    {\n    71\t        case GGML_TYPE_F32:\n    72\t            *out_block_bytes = GGML_TYPE_SIZE_F32;\n    73\t            return GGUF_TDBASE_OK;\n    74\t        case GGML_TYPE_F16:\n    75\t            *out_block_bytes = GGML_TYPE_SIZE_F16;\n    76\t            return GGUF_TDBASE_OK;\n    77\t        case GGML_TYPE_Q4_0:\n    78\t            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n    79\t            return GGUF_TDBASE_OK;\n    80\t        case GGML_TYPE_Q8_0:\n    81\t            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n    82\t            return GGUF_TDBASE_OK;\n    83\t    }\n    84\t\n    85\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    86\t}\n    87\t\n    88\tBool GGUFIsPow2U32(U32 value)\n    89\t{\n    90\t    if (!value)\n    91\t        return FALSE;\n    92\t    return (value & (value - 1)) == 0;\n    93\t}\n    94\t\n    95\tI64 GGUFValidateAlignment(U32 alignment)\n    96\t{\n    97\t    if (!GGUFIsPow2U32(alignment))\n    98\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n    99\t    return GGUF_TDBASE_OK;\n   100\t}\n   101\t\n   102\tI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n   103\t{\n   104\t    U64 mask;\n   105\t\n   106\t    if (!out)\n   107\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   108\t\n   109\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   110\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   111\t\n   112\t    // For power-of-two alignments, align-up is:\n   113\t    //   (value + (alignment - 1)) & ~(alignment - 1)\n   114\t    // Keep overflow checks explicit so giant malformed offsets are rejected.\n   115\t    mask = (U64)alignment - 1;\n   116\t    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n   117\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   118\t\n   119\t    *out = (value + mask) & ~mask;\n   120\t    return GGUF_TDBASE_OK;\n   121\t}\n   122\t\n   123\tI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n   124\t                            U32 alignment,\n   125\t                            U64 *out_tensor_data_base)\n   126\t{\n   127\t    return GGUFAlignUpU64(cursor_after_tensor_info,\n   128\t                          alignment,\n   129\t                          out_tensor_data_base);\n   130\t}\n   131\t\n   132\tI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n   133\t                                   U64 *out_tensor_data_base)\n   134\t{\n   135\t    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n   136\t                                   GGUF_DEFAULT_ALIGNMENT,\n   137\t                                   out_tensor_data_base);\n   138\t}\n   139\t\n   140\tBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n   141\t{\n   142\t    U64 mask;\n   143\t\n   144\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   145\t        return FALSE;\n   146\t\n   147\t    mask = (U64)alignment - 1;\n   148\t    return (offset & mask) == 0;\n   149\t}\n   150\t\n   151\tI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n   152\t                             U64 tensor_rel_offset,\n   153\t                             U32 alignment,\n   154\t                             U64 *out_tensor_abs)\n   155\t{\n   156\t    if (!out_tensor_abs)\n   157\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   158\t\n   159\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   160\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   161\t\n   162\t    // Both base and relative tensor offsets must preserve GGUF alignment.\n   163\t    // Enforcing this here keeps every downstream payload read auditable.\n   164\t    if (!GGUFTensorDataBaseIsAligned(tensor_data_base, alignment))\n   165\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE;\n   166\t    if (!GGUFTensorDataBaseIsAligned(tensor_rel_offset, alignment))\n   167\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET;\n   168\t\n   169\t    // Absolute payload pointer is base + relative offset.\n   170\t    // Keep overflow check explicit for malformed large files.\n   171\t    if (tensor_data_base > 0xFFFFFFFFFFFFFFFF - tensor_rel_offset)\n   172\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   173\t\n   174\t    *out_tensor_abs = tensor_data_base + tensor_rel_offset;\n   175\t    return GGUF_TDBASE_OK;\n   176\t}\n   177\t\n   178\tI64 GGUFTensorDataBaseOffsetDefault(U64 tensor_data_base,\n   179\t                                    U64 tensor_rel_offset,\n   180\t                                    U64 *out_tensor_abs)\n---\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for GGUF tensor-data base alignment and offset semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\t\n     8\tGGUF_TDBASE_OK = 0\n     9\tGGUF_TDBASE_ERR_NULL_PTR = 1\n    10\tGGUF_TDBASE_ERR_BAD_ALIGNMENT = 2\n    11\tGGUF_TDBASE_ERR_OVERFLOW = 3\n    12\tGGUF_TDBASE_ERR_MISALIGNED_BASE = 4\n    13\tGGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET = 5\n    14\tGGUF_TDBASE_ERR_BAD_TYPE = 6\n    15\t\n    16\tGGUF_DEFAULT_ALIGNMENT = 32\n    17\tU64_MAX = (1 << 64) - 1\n    18\t\n    19\tGGML_TYPE_F32 = 0\n    20\tGGML_TYPE_F16 = 1\n    21\tGGML_TYPE_Q4_0 = 2\n    22\tGGML_TYPE_Q8_0 = 8\n    23\t\n    24\t\n    25\tdef tensor_type_block_size(ggml_type: int):\n    26\t    if ggml_type == GGML_TYPE_F32:\n    27\t        return GGUF_TDBASE_OK, 1\n    28\t    if ggml_type == GGML_TYPE_F16:\n    29\t        return GGUF_TDBASE_OK, 1\n    30\t    if ggml_type == GGML_TYPE_Q4_0:\n    31\t        return GGUF_TDBASE_OK, 32\n    32\t    if ggml_type == GGML_TYPE_Q8_0:\n    33\t        return GGUF_TDBASE_OK, 32\n    34\t    return GGUF_TDBASE_ERR_BAD_TYPE, 0\n    35\t\n    36\t\n    37\tdef tensor_type_block_bytes(ggml_type: int):\n    38\t    if ggml_type == GGML_TYPE_F32:\n    39\t        return GGUF_TDBASE_OK, 4\n    40\t    if ggml_type == GGML_TYPE_F16:\n    41\t        return GGUF_TDBASE_OK, 2\n    42\t    if ggml_type == GGML_TYPE_Q4_0:\n    43\t        return GGUF_TDBASE_OK, 18\n    44\t    if ggml_type == GGML_TYPE_Q8_0:\n    45\t        return GGUF_TDBASE_OK, 34\n    46\t    return GGUF_TDBASE_ERR_BAD_TYPE, 0\n    47\t\n    48\t\n    49\tdef is_pow2_u32(value: int) -> bool:\n    50\t    return value > 0 and (value & (value - 1)) == 0\n    51\t\n    52\t\n    53\tdef validate_alignment(alignment: int) -> int:\n    54\t    if not is_pow2_u32(alignment):\n    55\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    56\t    return GGUF_TDBASE_OK\n    57\t\n    58\t\n    59\tdef align_up_u64(value: int, alignment: int):\n    60\t    err = validate_alignment(alignment)\n    61\t    if err != GGUF_TDBASE_OK:\n    62\t        return err, 0\n    63\t\n    64\t    mask = alignment - 1\n    65\t    if value > U64_MAX - mask:\n    66\t        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    67\t\n    68\t    out = (value + mask) & ~mask\n    69\t    return GGUF_TDBASE_OK, out\n    70\t\n    71\t\n    72\tdef tensor_data_base_align(cursor_after_tensor_info: int, alignment: int):\n    73\t    return align_up_u64(cursor_after_tensor_info, alignment)\n    74\t\n    75\t\n    76\tdef tensor_data_base_align_default(cursor_after_tensor_info: int):\n    77\t    return tensor_data_base_align(cursor_after_tensor_info, GGUF_DEFAULT_ALIGNMENT)\n    78\t\n    79\t\n    80\tdef tensor_data_base_is_aligned(offset: int, alignment: int) -> bool:\n    81\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n    82\t        return False\n    83\t    return (offset & (alignment - 1)) == 0\n    84\t\n    85\t\n    86\tdef tensor_data_base_offset(tensor_data_base: int, tensor_rel_offset: int, alignment: int):\n    87\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n    88\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT, 0\n    89\t    if not tensor_data_base_is_aligned(tensor_data_base, alignment):\n    90\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE, 0\n    91\t    if not tensor_data_base_is_aligned(tensor_rel_offset, alignment):\n    92\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET, 0\n    93\t    if tensor_data_base > U64_MAX - tensor_rel_offset:\n    94\t        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    95\t    return GGUF_TDBASE_OK, tensor_data_base + tensor_rel_offset\n    96\t\n    97\t\n    98\tdef tensor_data_base_offset_default(tensor_data_base: int, tensor_rel_offset: int):\n    99\t    return tensor_data_base_offset(tensor_data_base, tensor_rel_offset, GGUF_DEFAULT_ALIGNMENT)\n   100\t\n   101\t\n   102\tdef test_default_alignment_examples() -> None:\n   103\t    assert tensor_data_base_align_default(0) == (GGUF_TDBASE_OK, 0)\n   104\t    assert tensor_data_base_align_default(1) == (GGUF_TDBASE_OK, 32)\n   105\t    assert tensor_data_base_align_default(31) == (GGUF_TDBASE_OK, 32)\n   106\t    assert tensor_data_base_align_default(32) == (GGUF_TDBASE_OK, 32)\n   107\t    assert tensor_data_base_align_default(33) == (GGUF_TDBASE_OK, 64)\n   108\t\n   109\t\n   110\tdef test_tensor_type_block_size_known_types() -> None:\n   111\t    assert tensor_type_block_size(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 1)\n   112\t    assert tensor_type_block_size(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 1)\n   113\t    assert tensor_type_block_size(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 32)\n   114\t    assert tensor_type_block_size(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 32)\n   115\t\n   116\t\n   117\tdef test_tensor_type_block_bytes_known_types() -> None:\n   118\t    assert tensor_type_block_bytes(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 4)\n   119\t    assert tensor_type_block_bytes(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 2)\n   120\t    assert tensor_type_block_bytes(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 18)\n   121\t    assert tensor_type_block_bytes(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 34)\n   122\t\n   123\t\n   124\tdef test_tensor_type_helpers_reject_unknown_type() -> None:\n   125\t    assert tensor_type_block_size(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   126\t    assert tensor_type_block_bytes(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   127\t\n   128\t\n   129\tdef test_custom_power_of_two_alignment() -> None:\n   130\t    err, base = tensor_data_base_align(0x1234, 64)\n   131\t    assert err == GGUF_TDBASE_OK\n   132\t    assert base == 0x1240\n   133\t    assert tensor_data_base_is_aligned(base, 64)\n   134\t\n   135\t\n   136\tdef test_reject_non_power_of_two_alignment() -> None:\n   137\t    assert tensor_data_base_align(100, 0)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   138\t    assert tensor_data_base_align(100, 3)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   139\t    assert tensor_data_base_align(100, 24)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   140\t    assert tensor_data_base_is_aligned(128, 24) is False\n   141\t\n   142\t\n   143\tdef test_overflow_guard_near_u64_max() -> None:\n   144\t    err, _ = tensor_data_base_align(U64_MAX - 7, 16)\n   145\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   146\t\n   147\t    err, base = tensor_data_base_align(U64_MAX - 15, 16)\n   148\t    assert err == GGUF_TDBASE_OK\n   149\t    assert base == U64_MAX - 15\n   150\t\n   151\t\n   152\tdef test_random_alignment_matches_reference_formula() -> None:\n   153\t    rng = random.Random(760031)\n   154\t\n   155\t    for _ in range(1000):\n   156\t        alignment = 1 << rng.randint(0, 20)\n   157\t        cursor = rng.randrange(0, 1 << 56)\n   158\t\n   159\t        err, got = tensor_data_base_align(cursor, alignment)\n   160\t        assert err == GGUF_TDBASE_OK\n   161\t\n   162\t        reference = ((cursor + (alignment - 1)) // alignment) * alignment\n   163\t        assert got == reference\n   164\t        assert got >= cursor\n   165\t        assert tensor_data_base_is_aligned(got, alignment)\n   166\t\n   167\t\n   168\tdef test_tensor_data_base_offset_happy_path() -> None:\n   169\t    err, abs_off = tensor_data_base_offset(0x2000, 0x80, 32)\n   170\t    assert err == GGUF_TDBASE_OK\n   171\t    assert abs_off == 0x2080\n   172\t\n   173\t\n   174\t\n   175\tdef test_tensor_data_base_offset_default_alignment() -> None:\n   176\t    err, abs_off = tensor_data_base_offset_default(0x100, 0x40)\n   177\t    assert err == GGUF_TDBASE_OK\n   178\t    assert abs_off == 0x140\n   179\t\n   180\t\n   181\t\n   182\tdef test_tensor_data_base_offset_reject_bad_alignment() -> None:\n   183\t    err, _ = tensor_data_base_offset(0x1000, 0x40, 24)\n   184\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   185\t\n   186\t\n   187\t\n   188\tdef test_tensor_data_base_offset_reject_misaligned_base() -> None:\n   189\t    err, _ = tensor_data_base_offset(0x1010, 0x40, 32)\n   190\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   191\t\n   192\t\n   193\t\n   194\tdef test_tensor_data_base_offset_reject_misaligned_rel() -> None:\n   195\t    err, _ = tensor_data_base_offset(0x1000, 0x48, 32)\n   196\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n   197\t\n   198\t\n   199\t\n   200\tdef test_tensor_data_base_offset_overflow_guard() -> None:\n   201\t    err, _ = tensor_data_base_offset(U64_MAX - 31, 32, 32)\n   202\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   203\t\n   204\t\n   205\t\n   206\tdef test_tensor_data_base_offset_random_aligned_cases() -> None:\n   207\t    rng = random.Random(761113)\n   208\t\n   209\t    for _ in range(1000):\n   210\t        alignment = 1 << rng.randint(0, 15)\n   211\t        base_units = rng.randrange(0, 1 << 24)\n   212\t        rel_units = rng.randrange(0, 1 << 20)\n   213\t        base = base_units * alignment\n   214\t        rel = rel_units * alignment\n   215\t\n   216\t        err, got = tensor_data_base_offset(base, rel, alignment)\n   217\t        assert err == GGUF_TDBASE_OK\n   218\t        assert got == base + rel\n   219\t        assert tensor_data_base_is_aligned(got, alignment)\n   220\t\n   221\t\n   222\tdef run() -> None:\n   223\t    test_default_alignment_examples()\n   224\t    test_tensor_type_block_size_known_types()\n   225\t    test_tensor_type_block_bytes_known_types()\n   226\t    test_tensor_type_helpers_reject_unknown_type()\n   227\t    test_custom_power_of_two_alignment()\n   228\t    test_reject_non_power_of_two_alignment()\n   229\t    test_overflow_guard_near_u64_max()\n   230\t    test_random_alignment_matches_reference_formula()\n   231\t    test_tensor_data_base_offset_happy_path()\n   232\t    test_tensor_data_base_offset_default_alignment()\n   233\t    test_tensor_data_base_offset_reject_bad_alignment()\n   234\t    test_tensor_data_base_offset_reject_misaligned_base()\n   235\t    test_tensor_data_base_offset_reject_misaligned_rel()\n   236\t    test_tensor_data_base_offset_overflow_guard()\n   237\t    test_tensor_data_base_offset_random_aligned_cases()\n   238\t    print(\"gguf_tensor_data_base_reference_checks=ok\")\n   239\t\n   240\t\n   241\tif __name__ == \"__main__\":\n   242\t    run()\n---\n   220\t- [ ] IQ-032 Add mixed Q4_0 x Q8_0 dot parity harness in `tests/test_q4_0_q8_0_dot.py` with GGML-math bounds (WS3-05)\n   221\t- [x] IQ-033 Implement Q4_0 row-dot helper (`Q4_0DotRowBlocksQ16`) in `src/quant/q4_0_dot.HC` for quant matmul row kernels (WS4-01)\n   222\t- [x] IQ-034 Implement Q4_0 x Q8_0 blockwise Q16 accumulation helper in `src/quant/q4_0_q8_0_dot.HC` for mixed matmul callers (WS4-01)\n   223\t- [ ] IQ-035 Add Q8_0 Q16-accumulator parity harness in `tests/test_q8_0_dot_accum_q16.py` with seeded blockwise rounding checks (WS4-01)\n   224\t- [x] IQ-036 Implement GGUF tensor data offset resolver (`GGUFTensorDataBaseOffset`) in `src/gguf/tensor_data_base.HC` with alignment validation (WS2-04)\n   225\t- [x] IQ-037 Implement GGML tensor block-size/byte-size helpers in `src/gguf/tensor_data_base.HC` for F32/F16/Q4_0/Q8_0 sizing math (WS2-04)\n   226\t- [ ] IQ-038 Implement GGUF tensor absolute range validator (`GGUFTensorResolveRange`) in `src/gguf/tensor_data_base.HC` with overflow-safe `abs+size` checks (WS2-04)\n   227\t- [ ] IQ-039 Implement GGUF tensor payload byte-size helper (`GGUFTensorBytesForType`) in `src/gguf/tensor_data_base.HC` for F32/F16/Q4_0/Q8_0 (WS2-04)\n   228\t\n   229\t## Progress Ledger\n   230\t\n   252\t| 2026-04-12 | loop-019 | IQ-033 Q4_0 row-dot helper | done | Added `Q4_0DotRowBlocksQ16` + parity rounding tests; `python3 tests/test_q4_0_dot.py && python3 tests/test_q4_0_dequant.py && python3 tests/test_q4_0_q8_0_dot_kernel.py` passed |\n   253\t| 2026-04-12 | loop-020 | IQ-034 Q4_0 x Q8_0 Q16 accumulator | done | Added mixed Q16 blockwise accumulator helper + parity checks; `python3 tests/test_q4_0_q8_0_dot_kernel.py && python3 tests/test_q4_0_dot.py && python3 tests/test_q8_0_dot.py` passed |\n   254\t| 2026-04-12 | loop-021 | IQ-026 metadata key lookup helpers | done | Added `GGUFMetaFindByKey` + typed scalar extractors; `python3 tests/test_gguf_metadata_parse.py` passed |\n   255\t| 2026-04-12 | loop-022 | IQ-028 tensor data base alignment helper | done | Added `src/gguf/tensor_data_base.HC` alignment/overflow checks + `tests/test_gguf_tensor_data_base.py`; `python3 tests/test_gguf_tensor_data_base.py && python3 tests/test_gguf_metadata_parse.py && python3 tests/test_gguf_tensorinfo_parse.py` passed |\n   256\t| 2026-04-12 | loop-023 | IQ-036 tensor data offset resolver | done | Added `GGUFTensorDataBaseOffset`/default in `src/gguf/tensor_data_base.HC` with base/relative alignment and overflow guards; `python3 tests/test_gguf_tensor_data_base.py && python3 tests/test_gguf_tensorinfo_parse.py && python3 tests/test_gguf_metadata_parse.py` passed |\n   257\t| 2026-04-12 | loop-024 | IQ-037 tensor block-size/byte-size helpers | done | Added `GGUFTensorTypeBlockSize`/`GGUFTensorTypeBlockBytes` in `src/gguf/tensor_data_base.HC`; `python3 tests/test_gguf_tensor_data_base.py && python3 tests/test_gguf_tensorinfo_parse.py && python3 tests/test_gguf_metadata_parse.py` passed |\n   258\t\n   259\t## Blockers & Decisions\n   260\t\n","exit_code":0,"status":"completed"}}
