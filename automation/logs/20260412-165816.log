 0\n    52\t\n    53\t\n    54\tdef validate_alignment(alignment: int) -> int:\n    55\t    if not is_pow2_u32(alignment):\n    56\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT\n    57\t    return GGUF_TDBASE_OK\n    58\t\n    59\t\n    60\tdef align_up_u64(value: int, alignment: int):\n    61\t    err = validate_alignment(alignment)\n    62\t    if err != GGUF_TDBASE_OK:\n    63\t        return err, 0\n    64\t\n    65\t    mask = alignment - 1\n    66\t    if value > U64_MAX - mask:\n    67\t        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    68\t\n    69\t    out = (value + mask) & ~mask\n    70\t    return GGUF_TDBASE_OK, out\n    71\t\n    72\t\n    73\tdef tensor_data_base_align(cursor_after_tensor_info: int, alignment: int):\n    74\t    return align_up_u64(cursor_after_tensor_info, alignment)\n    75\t\n    76\t\n    77\tdef tensor_data_base_align_default(cursor_after_tensor_info: int):\n    78\t    return tensor_data_base_align(cursor_after_tensor_info, GGUF_DEFAULT_ALIGNMENT)\n    79\t\n    80\t\n    81\tdef tensor_data_base_is_aligned(offset: int, alignment: int) -> bool:\n    82\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n    83\t        return False\n    84\t    return (offset & (alignment - 1)) == 0\n    85\t\n    86\t\n    87\tdef tensor_data_base_offset(tensor_data_base: int, tensor_rel_offset: int, alignment: int):\n    88\t    if validate_alignment(alignment) != GGUF_TDBASE_OK:\n    89\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT, 0\n    90\t    if not tensor_data_base_is_aligned(tensor_data_base, alignment):\n    91\t        return GGUF_TDBASE_ERR_MISALIGNED_BASE, 0\n    92\t    if not tensor_data_base_is_aligned(tensor_rel_offset, alignment):\n    93\t        return GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET, 0\n    94\t    if tensor_data_base > U64_MAX - tensor_rel_offset:\n    95\t        return GGUF_TDBASE_ERR_OVERFLOW, 0\n    96\t    return GGUF_TDBASE_OK, tensor_data_base + tensor_rel_offset\n    97\t\n    98\t\n    99\tdef tensor_d