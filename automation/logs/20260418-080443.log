tSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0AVX2RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0AVX2RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0AVX2DotQ32ToQ16(I64 dot_q32)\n{\n    // Dot products carry Q16*Q16 scale in Q32 during accumulation.\n    // Handoff to Q16 row kernels is one rounded signed downshift by 16.\n    return Q4_0AVX2RoundShiftRightSigned(dot_q32, 16);\n}\n\nI64 Q4_0AVX2F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0AVX2RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n","exit_code":0,"status":"completed"}}
