ked(buf,\n1008:    err = GGUFMetadataReadU16LEChecked(buf,\n1023:// Contract: stages three U16 decodes through GGUFMetadataReadU16LEChecked and\n1025:I32 GGUFMetadataReadU16TripleChecked(U8 *buf,\n1046:    err = GGUFMetadataReadU16LEChecked(buf,\n1054:    err = GGUFMetadataReadU16LEChecked(buf,\n1062:    err = GGUFMetadataReadU16LEChecked(buf,\n1096:    err = GGUFMetadataReadU16LEChecked(buf,\n1113:I32 GGUFMetadataReadI16PairChecked(U8 *buf,\n1157:I32 GGUFMetadataReadI16TripleChecked(U8 *buf,\n1255:I32 GGUFMetadataReadU32PairChecked(U8 *buf,\n1299:I32 GGUFMetadataReadU32TripleChecked(U8 *buf,\n1361:    return GGUFMetadataReadU64LECheckedNoPartial(buf,\n1371:I32 GGUFMetadataReadU64LECheckedNoPartial(U8 *buf,\n1435:I32 GGUFMetadataReadU64PairCheckedNoPartial(U8 *buf,\n1455:    err = GGUFMetadataReadU64LECheckedNoPartial(buf,\n1463:    err = GGUFMetadataReadU64LECheckedNoPartial(buf,\n1480:I32 GGUFMetadataReadU64TripleCheckedNoPartial(U8 *buf,\n1502:    err = GGUFMetadataReadU64LECheckedNoPartial(buf,\n1510:    err = GGUFMetadataReadU64LECheckedNoPartial(buf,\n1518:    err = GGUFMetadataReadU64LECheckedNoPartial(buf,\n1569:I32 GGUFMetadataReadI32PairChecked(U8 *buf,\n1613:I32 GGUFMetadataReadI32TripleChecked(U8 *buf,\n1676:    return GGUFMetadataReadI64LECheckedNoPartial(buf,\n1686:I32 GGUFMetadataReadI64LECheckedNoPartial(U8 *buf,\n1719:I32 GGUFMetadataReadI64PairCheckedNoPartial(U8 *buf,\n1739:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n1747:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n1764:I32 GGUFMetadataReadI64TripleCheckedNoPartial(U8 *buf,\n1786:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n1794:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n1802:    err = GGUFMetadataReadI64LECheckedNoPartial(buf,\n1829:    return GGUFMetadataReadF32BitsLECheckedNoPartial(buf,\n1839:I32 GGUFMetadataReadF32BitsLECheckedNoPartial(U8 *buf,\n1873:I32 GGUFMetadataReadF32BitsPairChecked(U8 *buf,\n1919:I32 GGUFMetadataReadF32BitsTripleChecked(U8 *buf,\n2146:I32 GGUFMetadataReadBoolPairChecked(U8 *buf,\n2191:I32 GGUFMetadataReadBoolTripleChecked(U8 *buf,\n// metadata.HC\n// GGUF metadata key/value parser for HolyC inference runtime.\n\n#define GGUF_META_PARSE_OK 0\n#define GGUF_META_PARSE_ERR_NULL_PTR 1\n#define GGUF_META_PARSE_ERR_TRUNCATED 2\n#define GGUF_META_PARSE_ERR_BAD_TYPE 3\n#define GGUF_META_PARSE_ERR_BAD_STRING_LEN 4\n#define GGUF_META_PARSE_ERR_BAD_ARRAY_LEN 5\n#define GGUF_META_PARSE_ERR_ALLOC 6\n#define GGUF_META_PARSE_ERR_NESTED_ARRAY 7\n#define GGUF_META_PARSE_ERR_BAD_COUNT 8\n#define GGUF_META_PARSE_ERR_NOT_FOUND 9\n#define GGUF_META_PARSE_ERR_TYPE_MISMATCH 10\n\n#define GGUF_META_TABLE_OK 0\n#define GGUF_META_TABLE_ERR_NULL_PTR 1\n#define GGUF_META_TABLE_ERR_BAD_PARAM 2\n#define GGUF_META_TABLE_ERR_OVERFLOW 3\n#define GGUF_META_TABLE_ERR_OUT_OF_BOUNDS 4\n\n#define GGUF_MAX_METADATA_COUNT (1 << 20)\n#define GGUF_MAX_STRING_BYTES   (1 << 20)\n#define GGUF_MAX_ARRAY_ELEMS    (1 << 24)\n\n#define GGUF_TYPE_UINT8   0\n#define GGUF_TYPE_INT8    1\n#define GGUF_TYPE_UINT16  2\n#define GGUF_TYPE_INT16   3\n#define GGUF_TYPE_UINT32  4\n#define GGUF_TYPE_INT32   5\n#define GGUF_TYPE_FLOAT32 6\n#define GGUF_TYPE_BOOL    7\n#define GGUF_TYPE_STRING  8\n#define GGUF_TYPE_ARRAY   9\n#define GGUF_TYPE_UINT64  10\n#define GGUF_TYPE_INT64   11\n#define GGUF_TYPE_FLOAT64 12\n\nclass GGUFString\n{\n    U64 len;\n    U8 *data;\n};\n\nclass GGUFMetaValue\n{\n    U32 type;\n\n    // Scalar slots. Float payloads are preserved as raw bits (u32/u64) because\n    // TempleOS runtime stays integer-only.\n    U64 u64;\n    I64 i64;\n    Bool b;\n    GGUFString str;\n\n    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    // later systems can decode lazily without reparsing the table.\n    U32 array_elem_type;\n    U64 array_len;\n    U64 array_payload_off;\n    U64 array_payload_bytes;\n};\n\nclass GGUFMetadataKV\n{\n    GGUFString key;\n    GGUFMetaValue value;\n};\n\nclass GGUFMetadataTab