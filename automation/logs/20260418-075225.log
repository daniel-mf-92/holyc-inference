  902\t        {\n   903\t            lane_order_rank = 0;\n   904\t            for (j = 0; j < lane_count; j++)\n   905\t            {\n   906\t                if (logits_q16[j] > logits_q16[i])\n   907\t                    lane_order_rank++;\n   908\t                else if (logits_q16[j] == logits_q16[i] && j < i)\n   909\t                    lane_order_rank++;\n   910\t            }\n   911\t\n   912\t            if (lane_order_rank == rank)\n   913\t            {\n   914\t                selected_index = i;\n   915\t                selected_logit_q16 = logits_q16[i];\n   916\t                break;\n   917\t            }\n   918\t        }\n   919\t\n   920\t        if (selected_index < 0)\n   921\t            return FP_Q16_ERR_OVERFLOW;\n   922\t    }\n   923\t\n   924\t    // Commit pass writes both output vectors in rank order.\n   925\t    for (rank = 0; rank < k; rank++)\n   926\t    {\n   927\t        selected_index = -1;\n   928\t        selected_logit_q16 = 0;\n   929\t\n   930\t        for (i = 0; i < lane_count; i++)\n   931\t        {\n   932\t            lane_order_rank = 0;\n   933\t            for (j = 0; j < lane_count; j++)\n   934\t            {\n   935\t                if (logits_q16[j] > logits_q16[i])\n   936\t                    lane_order_rank++;\n   937\t                else if (logits_q16[j] == logits_q16[i] && j < i)\n   938\t                    lane_order_rank++;\n   939\t            }\n   940\t\n   941\t            if (lane_order_rank == rank)\n   942\t            {\n   943\t                selected_index = i;\n   944\t                selected_logit_q16 = logits_q16[i];\n   945\t                break;\n   946\t            }\n   947\t        }\n   948\t\n   949\t        if (selected_index < 0)\n   950\t            return FP_Q16_ERR_OVERFLOW;\n   951\t\n   952\t        out_topk_indices[rank] = selected_index;\n   953\t        out_topk_logits_q16[rank] = selected_logit_q16;\n   954\t    }\n   955\t\n   956\t    return FP_Q16_OK;\n   957\t}\n   958\t\n   959\t// Checked deterministic stable descending argsort over Q16 logits.\n   960\t// Output contract:\n   961\t//   - Writes exactly lane_count indices into out_indices[0..lane_count-1].\n   962\t//   - Order is descending logit value.\n   963\t//   - Tie-break is deterministic and stable: lower token index wins.\n   964\t//   - No partial writes on all parameter/preflight failure paths.\n   965\t// Checked guards:\n   966\t//   - logits_q16 and out_indices are non-null.\n   967\t//   - lane_count >= 0 and out_index_capacity >= 0.\n   968\t//   - out_index_capacity >= lane_count.\n   969\t//   - Pointer-span arithmetic for indexed logits/out accesses cannot overflow U64.\n   970\tI32 FPQ16ArgsortDescStableChecked(I64 *logits_q16,\n   971\t                                  I64 lane_count,\n   972\t                                  I64 *out_indices,\n   973\t                                  I64 out_index_capacity)\n   974\t{\n   975\t    I64 i;\n   976\t    I64 j;\n   977\t    I64 last_index;\n   978\t    I64 last_byte_offset;\n   979\t    I64 key_index;\n   980\t    I64 key_logit_q16;\n   981\t    I64 scan_index;\n   982\t    I64 scan_logit_q16;\n   983\t\n   984\t    if (!logits_q16 || !out_indices)\n   985\t        return FP_Q16_ERR_NULL_PTR;\n   986\t    if (lane_count < 0 || out_index_capacity < 0)\n   987\t        return FP_Q16_ERR_BAD_PARAM;\n   988\t    if (out_index_capacity < lane_count)\n   989\t        return FP_Q16_ERR_BAD_PARAM;\n   990\t\n   991\t    if (!lane_count)\n   992\t        return FP_Q16_OK;\n   993\t\n   994\t    // Guard pointer-span arithmetic before indexed logits/out writes.\n   995\t    last_index = lane_count - 1;\n   996\t    if (last_index > (I64_MAX_VALUE >> 3))\n   997\t        return FP_Q16_ERR_OVERFLOW;\n   998\t\n   999\t    last_byte_offset = last_index << 3;\n  1000\t    if ((U64)logits_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n  1001\t        return FP_Q16_ERR_OVERFLOW;\n  1002\t    if ((U64)out_indices > (U64_MAX_VALUE - (U64)last_byte_offset))\n  1003\t        return FP_Q16_ERR_OVERFLOW;\n  1004\t\n  1005\t    // Seed index identity mapping before stable insertion sort.\n  1006\t    for (i = 0; i < lane_count; i++)\n  1007\t        out_indices[i] = i;\n  1008\t\n  1009\t    // Stable insertion sort:\n  1010\t    //   - Higher logit lanes move earlier.\n  1011\t    //   - Equal logits resolve by lower token index first.\n  1012\t    for (i = 1; i < lane_count; i++)\n  1013\t    {\n  1014\t        key_index = out_indices[i];\n  1015\t        key_logit_q16 = logits_q16[key_index];\n","exit_code":0,"status":"completed"}}
