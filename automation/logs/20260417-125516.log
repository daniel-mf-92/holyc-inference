rtial-write semantics.\n+    err = GGUFMetadataReadBoolChecked(buf,\n+                                      buf_nbytes,\n+                                      &cur,\n+                                      table_end,\n+                                      &first);\n+    if (err != GGUF_META_TABLE_OK)\n+        return err;\n+\n+    err = GGUFMetadataReadBoolChecked(buf,\n+                                      buf_nbytes,\n+                                      &cur,\n+                                      table_end,\n+                                      &second);\n+    if (err != GGUF_META_TABLE_OK)\n+        return err;\n+\n+    *out_first = first;\n+    *out_second = second;\n+    *cursor = cur;\n+    return GGUF_META_TABLE_OK;\n+}\n*** End Patch\"'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
