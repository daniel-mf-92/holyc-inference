{"type":"item.completed","item":{"id":"item_22","type":"command_execution","command":"/bin/zsh -lc \"rg -n \\\"RMSNormChecked|InPlace|InvDenom|Preflight|FPQ16RMSNorm\\\" src/math/rmsnorm.HC; nl -ba src/math/rmsnorm.HC | sed -n '1,340p'; ls tests | rg 'rmsnorm'\"","aggregated_output":"44:I32 FPQ16RMSNormComputeInvDenomChecked(I64 *input_q16,\n115:I32 FPQ16RMSNormChecked(I64 *input_q16,\n137:    status = FPQ16RMSNormComputeInvDenomChecked(input_q16,\n186:I32 FPQ16RMSNormApplyInvDenomChecked(I64 *input_q16,\n226:I32 FPQ16RMSNormApplyInvDenomWeightedChecked(I64 *input_q16,\n272:I32 FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked(I64 *input_q16,\n317:I32 FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked(I64 *input_q16,\n371:I32 FPQ16RMSNormApplyInvDenomWeightedAutoSelectPathChecked(I64 *input_q16,\n393:I32 FPQ16RMSNormApplyInvDenomWeightedAutoChecked(I64 *input_q16,\n403:    status = FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked(input_q16,\n412:    status = FPQ16RMSNormApplyInvDenomWeightedAutoSelectPathChecked(input_q16,\n420:        return FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked(input_q16,\n430:    return FPQ16RMSNormApplyInvDenomWeightedChecked(input_q16,\n444:I32 FPQ16RMSNormApplyInvDenomWeightedAutoCheckedWithPathOut(I64 *input_q16,\n458:    status = FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked(input_q16,\n467:    status = FPQ16RMSNormApplyInvDenomWeightedAutoSelectPathChecked(input_q16,\n477:        return FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked(input_q16,\n487:    return FPQ16RMSNormApplyInvDenomWeightedChecked(input_q16,\n495:U0 FPQ16RMSNorm(I64 *input, I64 *weight, I64 *output, I64 count, I64 eps_q16)\n     1\t// rmsnorm.HC\n     2\t// Integer-only Q16.16 RMSNorm for HolyC inference.\n     3\t\n     4\t#define FP_Q16_SHIFT 16\n     5\t#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n     6\t#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n     7\t#define FP_Q16_ERR_NULL_PTR  1\n     8\t#define FP_Q16_ERR_BAD_PARAM 2\n     9\t#define FP_Q16_ERR_DOMAIN    3\n    10\t#define FP_Q16_ERR_OVERFLOW  4\n    11\t#define U64_MAX_VALUE 0xFFFFFFFFFFFFFFFF\n    12\t#define FP_Q16_RMSNORM_AUTO_PATH_OUT_OF_PLACE 0\n    13\t#define FP_Q16_RMSNORM_AUTO_PATH_IN_PLACE     1\n    14\t\n    15\tI64 FPQ16Mul(I64 a, I64 b);\n    16\tI64 FPQ16Div(I64 num, I64 den);\n    17\tI64 FPQ16FromInt(I64 x);\n    18\tI64 FPQ16Sqrt(I64 x);\n    19\tI32 FPQ16MulChecked(I64 a_q16,\n    20\t                    I64 b_q16,\n    21\t                    I64 *out_q16);\n    22\tI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n    23\t                              I64 b_q16,\n    24\t                              I64 d_q16,\n    25\t                              I64 *out_q16);\n    26\tI32 FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(I64 a_q16,\n    27\t                                                     I64 b_q16,\n    28\t                                                     I64 d_q16,\n    29\t                                                     I64 *out_q16);\n    30\t\n    31\t// WS1-04 RMSNorm assumptions (Q16 tensors):\n    32\t// - `count` is the feature width for one normalized row/token/head slice.\n    33\t// - `input_q16`, `gamma_q16`, `output_q16` each contain at least `count`\n    34\t//   contiguous I64 Q16 lanes.\n    35\t// - mean-square and denominator are scalar per-slice values.\n    36\t// TODO(WS4/WS5): Add tiled/strided variants for batched matmul/attention paths.\n    37\t// TODO(WS4/WS5): Add AVX2 lane kernels once scalar checked semantics are frozen.\n    38\t\n    39\t// Compute checked RMSNorm inverse denominator from one Q16 slice:\n    40\t//   mean_sq_q16 = (sum_i input[i]^2) / count\n    41\t//   denom_q16   = sqrt(mean_sq_q16 + eps_q16)\n    42\t//   inv_q16     = 1.0_q16 / denom_q16\n    43\t// All intermediate math is integer-only with explicit overflow/domain checks.\n    44\tI32 FPQ16RMSNormComputeInvDenomChecked(I64 *input_q16,\n    45\t                                       I64 count,\n    46\t                                       I64 eps_q16,\n    47\t                                       I64 *inv_denom_q16_out,\n    48\t                                       I64 *denom_q16_out)\n    49\t{\n    50\t    I64 lane_index;\n    51\t    I64 lane_sq_q16;\n    52\t    I64 sum_sq_q16;\n    53\t    I64 count_q16;\n    54\t    I64 mean_sq_q16;\n    55\t    I64 denom_arg_q16;\n    56\t    I64 denom_q16;\n    57\t    I64 inv_denom_q16;\n    58\t    I32 status;\n    59\t\n    60\t    if (!input_q16 || !inv_denom_q16_out || !denom_q16_out)\n    61\t        return FP_Q16_ERR_NULL_PTR;\n    62\t    if (count <= 0)\n    63\t        return FP_Q16_ERR_BAD_PARAM;\n    64\t    if (eps_q16 < 0)\n    65\t        return FP_Q16_ERR_BAD_PARAM;\n    66\t\n    67\t    if (count > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n    68\t        return FP_Q16_ERR_OVERFLOW;\n    69\t\n    70\t    sum_sq_q16 = 0;\n    71\t    for (lane_index = 0; lane_index < count; lane_index++)\n    72\t    {\n    73\t        status = FPQ16MulChecked(input_q16[lane_index],\n    74\t                                 input_q16[lane_index],\n    75\t                                 &lane_sq_q16);\n    76\t        if (status)\n    77\t            return status;\n    78\t\n    79\t        if (sum_sq_q16 > I64_MAX_VALUE - lane_sq_q16)\n    80\t            return FP_Q16_ERR_OVERFLOW;\n    81\t\n    82\t        sum_sq_q16 += lane_sq_q16;\n    83\t    }\n    84\t\n    85\t    count_q16 = FPQ16FromInt(count);\n    86\t    if (count_q16 <= 0)\n    87\t        return FP_Q16_ERR_OVERFLOW;\n    88\t\n    89\t    mean_sq_q16 = FPQ16Div(sum_sq_q16, count_q16);\n    90\t    if (mean_sq_q16 < 0)\n    91\t        return FP_Q16_ERR_DOMAIN;\n    92\t\n    93\t    if (mean_sq_q16 > I64_MAX_VALUE - eps_q16)\n    94\t        return FP_Q16_ERR_OVERFLOW;\n    95\t\n    96\t    denom_arg_q16 = mean_sq_q16 + eps_q16;\n    97\t    denom_q16 = FPQ16Sqrt(denom_arg_q16);\n    98\t    if (denom_q16 <= 0)\n    99\t        return FP_Q16_ERR_DOMAIN;\n   100\t\n   101\t    inv_denom_q16 = FPQ16Div(FP_Q16_ONE, denom_q16);\n   102\t    if (inv_denom_q16 <= 0)\n   103\t        return FP_Q16_ERR_DOMAIN;\n   104\t\n   105\t    *inv_denom_q16_out = inv_denom_q16;\n   106\t    *denom_q16_out = denom_q16;\n   107\t\n   108\t    return 0;\n   109\t}\n   110\t\n   111\t// Checked full RMSNorm (no-alias output contract):\n   112\t//   out[i] = ((input[i] / sqrt(mean(input^2)+eps)) * gamma[i])\n   113\t// The function performs a no-write validation pass first, then commits writes,\n   114\t// so any error returns with `output_q16` unchanged.\n   115\tI32 FPQ16RMSNormChecked(I64 *input_q16,\n   116\t                        I64 *gamma_q16,\n   117\t                        I64 *output_q16,\n   118\t                        I64 count,\n   119\t                        I64 eps_q16)\n   120\t{\n   121\t    I64 lane_index;\n   122\t    I64 inv_denom_q16;\n   123\t    I64 denom_q16;\n   124\t    I64 norm_lane_q16;\n   125\t    I64 weighted_lane_q16;\n   126\t    I32 status;\n   127\t\n   128\t    if (!input_q16 || !gamma_q16 || !output_q16)\n   129\t        return FP_Q16_ERR_NULL_PTR;\n   130\t    if (count <= 0)\n   131\t        return FP_Q16_ERR_BAD_PARAM;\n   132\t    if (eps_q16 < 0)\n   133\t        return FP_Q16_ERR_BAD_PARAM;\n   134\t    if (input_q16 == output_q16)\n   135\t        return FP_Q16_ERR_BAD_PARAM;\n   136\t\n   137\t    status = FPQ16RMSNormComputeInvDenomChecked(input_q16,\n   138\t                                                count,\n   139\t                                                eps_q16,\n   140\t                                                &inv_denom_q16,\n   141\t                                                &denom_q16);\n   142\t    if (status)\n   143\t        return status;\n   144\t\n   145\t    // Validation pass: prove every lane arithmetic operation succeeds before\n   146\t    // writing output, preserving no-partial-write behavior.\n   147\t    for (lane_index = 0; lane_index < count; lane_index++)\n   148\t    {\n   149\t        status = FPQ16MulChecked(input_q16[lane_index],\n   150\t                                 inv_denom_q16,\n   151\t                                 &norm_lane_q16);\n   152\t        if (status)\n   153\t            return status;\n   154\t\n   155\t        status = FPQ16MulChecked(norm_lane_q16,\n   156\t                                 gamma_q16[lane_index],\n   157\t                                 &weighted_lane_q16);\n   158\t        if (status)\n   159\t            return status;\n   160\t    }\n   161\t\n   162\t    for (lane_index = 0; lane_index < count; lane_index++)\n   163\t    {\n   164\t        status = FPQ16MulChecked(input_q16[lane_index],\n   165\t                                 inv_denom_q16,\n   166\t                                 &norm_lane_q16);\n   167\t        if (status)\n   168\t            return status;\n   169\t\n   170\t        status = FPQ16MulChecked(norm_lane_q16,\n   171\t                                 gamma_q16[lane_index],\n   172\t                                 &weighted_lane_q16);\n   173\t        if (status)\n   174\t            return status;\n   175\t\n   176\t        output_q16[lane_index] = weighted_lane_q16;\n   177\t    }\n   178\t\n   179\t    return 0;\n   180\t}\n   181\t\n   182\t// Apply precomputed RMSNorm inverse denominator to a Q16 vector with explicit\n   183\t// checked error surfaces. This uses one-rounding math:\n   184\t//   out[i] = round_half_up((input[i] * inv_denom_q16) / den_q16)\n   185\t// where den_q16 is a positive Q16 whole integer (d_int << 16).\n   186\tI32 FPQ16RMSNormApplyInvDenomChecked(I64 *input_q16,\n   187\t                                     I64 *output_q16,\n   188\t                                     I64 count,\n   189\t                                     I64 inv_denom_q16,\n   190\t                                     I64 den_q16)\n   191\t{\n   192\t    I64 i;\n   193\t    I64 scaled_q16;\n   194\t    I32 status;\n   195\t\n   196\t    if (!input_q16 || !output_q16)\n   197\t        return FP_Q16_ERR_NULL_PTR;\n   198\t    if (count < 0)\n   199\t        return FP_Q16_ERR_BAD_PARAM;\n   200\t    if (inv_denom_q16 <= 0)\n   201\t        return FP_Q16_ERR_DOMAIN;\n   202\t\n   203\t    // Delegate denominator contract + checked one-rounding to fixedpoint core.\n   204\t    // That keeps RMSNorm scaling error behavior identical to shared math helpers.\n   205\t    for (i = 0; i < count; i++)\n   206\t    {\n   207\t        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n   208\t                                                                   inv_denom_q16,\n   209\t                                                                   den_q16,\n   210\t                                                                   &scaled_q16);\n   211\t        if (status)\n   212\t            return status;\n   213\t\n   214\t        output_q16[i] = scaled_q16;\n   215\t    }\n   216\t\n   217\t    return 0;\n   218\t}\n   219\t\n   220\t// Apply precomputed RMSNorm inverse denominator and per-channel gamma to a\n   221\t// Q16 vector with explicit checked error surfaces:\n   222\t//   out[i] = round_half_up(round_half_up((input[i] * inv_denom_q16) / den_q16)\n   223\t//                          * gamma[i] / FP_Q16_ONE)\n   224\t// The first stage enforces the positive whole-Q16 denominator contract used by\n   225\t// WS5 norm call chains. The second stage is checked Q16*Q16 scaling.\n   226\tI32 FPQ16RMSNormApplyInvDenomWeightedChecked(I64 *input_q16,\n   227\t                                             I64 *gamma_q16,\n   228\t                                             I64 *output_q16,\n   229\t                                             I64 count,\n   230\t                                             I64 inv_denom_q16,\n   231\t                                             I64 den_q16)\n   232\t{\n   233\t    I64 i;\n   234\t    I64 scaled_q16;\n   235\t    I64 weighted_q16;\n   236\t    I32 status;\n   237\t\n   238\t    if (!input_q16 || !gamma_q16 || !output_q16)\n   239\t        return FP_Q16_ERR_NULL_PTR;\n   240\t    if (count < 0)\n   241\t        return FP_Q16_ERR_BAD_PARAM;\n   242\t    if (inv_denom_q16 <= 0)\n   243\t        return FP_Q16_ERR_DOMAIN;\n   244\t\n   245\t    for (i = 0; i < count; i++)\n   246\t    {\n   247\t        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n   248\t                                                                   inv_denom_q16,\n   249\t                                                                   den_q16,\n   250\t                                                                   &scaled_q16);\n   251\t        if (status)\n   252\t            return status;\n   253\t\n   254\t        status = FPQ16MulDivRoundedChecked(scaled_q16,\n   255\t                                           gamma_q16[i],\n   256\t                                           FP_Q16_ONE,\n   257\t                                           &weighted_q16);\n   258\t        if (status)\n   259\t            return status;\n   260\t\n   261\t        output_q16[i] = weighted_q16;\n   262\t    }\n   263\t\n   264\t    return 0;\n   265\t}\n   266\t\n   267\t// In-place variant of weighted inverse-denominator RMSNorm scaling:\n   268\t//   input[i] = round_half_up(round_half_up((input[i] * inv_denom_q16) / den_q16)\n   269\t//                            * gamma[i] / FP_Q16_ONE)\n   270\t// This preserves the same checked contracts as the out-of-place helper while\n   271\t// explicitly supporting alias-safe writes when caller uses one buffer.\n   272\tI32 FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked(I64 *input_q16,\n   273\t                                                    I64 *gamma_q16,\n   274\t                                                    I64 count,\n   275\t                                                    I64 inv_denom_q16,\n   276\t                                                    I64 den_q16)\n   277\t{\n   278\t    I64 i;\n   279\t    I64 scaled_q16;\n   280\t    I64 weighted_q16;\n   281\t    I32 status;\n   282\t\n   283\t    if (!input_q16 || !gamma_q16)\n   284\t        return FP_Q16_ERR_NULL_PTR;\n   285\t    if (count < 0)\n   286\t        return FP_Q16_ERR_BAD_PARAM;\n   287\t    if (inv_denom_q16 <= 0)\n   288\t        return FP_Q16_ERR_DOMAIN;\n   289\t\n   290\t    for (i = 0; i < count; i++)\n   291\t    {\n   292\t        // Read one element, compute checked scaling, then write back to the\n   293\t        // same slot. No later iteration depends on previous slot values.\n   294\t        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n   295\t                                                                   inv_denom_q16,\n   296\t                                                                   den_q16,\n   297\t                                                                   &scaled_q16);\n   298\t        if (status)\n   299\t            return status;\n   300\t\n   301\t        status = FPQ16MulDivRoundedChecked(scaled_q16,\n   302\t                                           gamma_q16[i],\n   303\t                                           FP_Q16_ONE,\n   304\t                                           &weighted_q16);\n   305\t        if (status)\n   306\t            return status;\n   307\t\n   308\t        input_q16[i] = weighted_q16;\n   309\t    }\n   310\t\n   311\t    return 0;\n   312\t}\n   313\t\n   314\t// Shared preflight for auto-dispatch weighted inverse-denominator RMSNorm.\n   315\t// This centralizes parameter/domain checks so alias and non-alias paths\n   316\t// surface identical BAD_PARAM/DOMAIN/OVERFLOW behavior before any writes.\n   317\tI32 FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked(I64 *input_q16,\n   318\t                                                         I64 *gamma_q16,\n   319\t                                                         I64 *output_q16,\n   320\t   