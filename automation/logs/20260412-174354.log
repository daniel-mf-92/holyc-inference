    return GGUF_TDBASE_ERR_NULL_PTR, 0\n   360\t\n   361\t    err, bad = tensor_info_resolve_byte_spans(\n   362\t        tensor_data_base=tensor_data_base,\n   363\t        alignment=alignment,\n   364\t        gguf_file_nbytes=gguf_file_nbytes,\n   365\t        tensor_rel_offsets=tensor_rel_offsets,\n   366\t        tensor_element_counts=tensor_element_counts,\n   367\t        tensor_ggml_types=tensor_ggml_types,\n   368\t        out_tensor_nbytes=out_tensor_nbytes,\n   369\t    )\n   370\t    if err != GGUF_TDBASE_OK:\n   371\t        return err, bad\n   372\t\n   373\t    for i in range(count):\n   374\t        err_off, abs_start = tensor_data_base_offset(\n   375\t            tensor_data_base, tensor_rel_offsets[i], alignment\n   376\t        )\n   377\t        if err_off != GGUF_TDBASE_OK:\n   378\t            return err_off, i\n   379\t\n   380\t        nbytes = out_tensor_nbytes[i]\n   381\t        if abs_start > U64_MAX - nbytes:\n   382\t            return GGUF_TDBASE_ERR_OVERFLOW, i\n   383\t\n   384\t        out_abs_starts[i] = abs_start\n   385\t        out_abs_ends[i] = abs_start + nbytes\n   386\t\n   387\t    return GGUF_TDBASE_OK, 0\n   388\t\n   389\t\n   390\t\n   391\t\n   392\tdef test_tensor_bytes_for_type_scalars() -> None:\n   393\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 0) == (GGUF_TDBASE_OK, 0)\n   394\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 7) == (GGUF_TDBASE_OK, 28)\n   395\t    assert tensor_bytes_for_type(GGML_TYPE_F16, 7) == (GGUF_TDBASE_OK, 14)\n   396\t\n   397\t\n   398\tdef test_tensor_bytes_for_type_quantized_exact_blocks() -> None:\n   399\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 32) == (GGUF_TDBASE_OK, 18)\n   400\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 64) == (GGUF_TDBASE_OK, 36)\n   401\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 32) == (GGUF_TDBASE_OK, 34)\n   402\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 96) == (GGUF_TDBASE_OK, 102)\n   403\t\n   404\t\n   405\tdef test_tensor_bytes_for_type_reject_non_multiple_block() -> None:\n   406\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 31) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   407\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 33) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   408\t\n   409\t\n   410\tdef test_tensor_bytes_for_type_reject_unknown_type() -> None:\n   411\t    assert tensor_bytes_for_type(999, 32) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   412\t\n   413\t\n   414\tdef test_tensor_bytes_for_type_overflow_guard() -> None:\n   415\t    q8_block = 32\n   416\t    q8_bytes = 34\n   417\t    max_blocks = U64_MAX // q8_bytes\n   418\t    ok_elements = max_blocks * q8_block\n   419\t    err, nbytes = tensor_bytes_for_type(GGML_TYPE_Q8_0, ok_elements)\n   420\t    assert err == GGUF_TDBASE_OK\n   421\t    assert nbytes == max_blocks * q8_bytes\n   422\t\n   423\t    overflow_elements = (max_blocks + 1) * q8_block\n   424\t    err, _ = tensor_bytes_for_type(GGML_TYPE_Q8_0, overflow_elements)\n   425\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   426\t\n   427\tdef test_default_alignment_examples() -> None:\n   428\t    assert tensor_data_base_align_default(0) == (GGUF_TDBASE_OK, 0)\n   429\t    assert tensor_data_base_align_default(1) == (GGUF_TDBASE_OK, 32)\n   430\t    assert tensor_data_base_align_default(31) == (GGUF_TDBASE_OK, 32)\n   431\t    assert tensor_data_base_align_default(32) == (GGUF_TDBASE_OK, 32)\n   432\t    assert tensor_data_base_align_default(33) == (GGUF_TDBASE_OK, 64)\n   433\t\n   434\t\n   435\tdef test_tensor_type_block_size_known_types() -> None:\n   436\t    assert tensor_type_block_size(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 1)\n   437\t    assert tensor_type_block_size(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 1)\n   438\t    assert tensor_type_block_size(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 32)\n   439\t    assert tensor_type_block_size(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 32)\n   440\t\n   441\t\n   442\tdef test_tensor_type_block_bytes_known_types() -> None:\n   443\t    assert tensor_type_block_bytes(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 4)\n   444\t    assert tensor_type_block_bytes(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 2)\n   445\t    assert tensor_type_block_bytes(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 18)\n   446\t    assert tensor_type_block_bytes(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 34)\n   447\t\n   448\t\n   449\tdef test_tensor_type_helpers_reject_unknown_type() -> None:\n   450\t    assert tensor_type_block_size(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   451\t    assert tensor_type_block_bytes(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   452\t\n   453\t\n   454\tdef test_custom_power_of_two_alignment() -> None:\n   455\t    err, base = tensor_data_base_align(0x1234, 64)\n   456\t    assert err == GGUF_TDBASE_OK\n   457\t    assert base == 0x1240\n   458\t    assert tensor_data_base_is_aligned(base, 64)\n   459\t\n   460\t\n   461\tdef test_reject_non_power_of_two_alignment() -> None:\n   462\t    assert tensor_data_base_align(100, 0)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   463\t    assert tensor_data_base_align(100, 3)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   464\t    assert tensor_data_base_align(100, 24)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   465\t    assert tensor_data_base_is_aligned(128, 24) is False\n   466\t\n   467\t\n   468\tdef test_overflow_guard_near_u64_max() -> None:\n   469\t    err, _ = tensor_data_base_align(U64_MAX - 7, 16)\n   470\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   471\t\n   472\t    err, base = tensor_data_base_align(U64_MAX - 15, 16)\n   473\t    assert err == GGUF_TDBASE_OK\n   474\t    assert base == U64_MAX - 15\n   475\t\n   476\t\n   477\tdef test_random_alignment_matches_reference_formula() -> None:\n   478\t    rng = random.Random(760031)\n   479\t\n   480\t    for _ in range(1000):\n   481\t        alignment = 1 << rng.randint(0, 20)\n   482\t        cursor = rng.randrange(0, 1 << 56)\n   483\t\n   484\t        err, got = tensor_data_base_align(cursor, alignment)\n   485\t        assert err == GGUF_TDBASE_OK\n   486\t\n   487\t        reference = ((cursor + (alignment - 1)) // alignment) * alignment\n   488\t        assert got == reference\n   489\t        assert got >= cursor\n   490\t        assert tensor_data_base_is_aligned(got, alignment)\n   491\t\n   492\t\n   493\tdef test_tensor_data_base_offset_happy_path() -> None:\n   494\t    err, abs_off = tensor_data_base_offset(0x2000, 0x80, 32)\n   495\t    assert err == GGUF_TDBASE_OK\n   496\t    assert abs_off == 0x2080\n   497\t\n   498\t\n   499\t\n   500\tdef test_tensor_data_base_offset_default_alignment() -> None:\n   501\t    err, abs_off = tensor_data_base_offset_default(0x100, 0x40)\n   502\t    assert err == GGUF_TDBASE_OK\n   503\t    assert abs_off == 0x140\n   504\t\n   505\t\n   506\t\n   507\tdef test_tensor_data_base_offset_reject_bad_alignment() -> None:\n   508\t    err, _ = tensor_data_base_offset(0x1000, 0x40, 24)\n   509\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   510\t\n   511\t\n   512\t\n   513\tdef test_tensor_data_base_offset_reject_misaligned_base() -> None:\n   514\t    err, _ = tensor_data_base_offset(0x1010, 0x40, 32)\n   515\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   516\t\n   517\t\n   518\t\n   519\tdef test_tensor_data_base_offset_reject_misaligned_rel() -> None:\n   520\t    err, _ = tensor_data_base_offset(0x1000, 0x48, 32)\n","exit_code":0,"status":"completed"}}
