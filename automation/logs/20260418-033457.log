ows(rows, lhs_stride, k_blocks, rng)\n    rhs = build_q4_matrix_cols(cols, rhs_stride, k_blocks, rng)\n\n    err, out = q4_0_matmul_tiled_avx2_q32_checked(\n        lhs,\n        len(lhs),\n        rows,\n        lhs_stride,\n        rhs,\n        len(rhs),\n        cols,\n        rhs_stride,\n        k_blocks,\n        2,\n        2,\n        rows * out_stride,\n        out_stride,\n    )\n    assert err == Q4_0_OK\n\n    expected = q4_0_scalar_matmul_reference(\n        lhs,\n        rows,\n        lhs_stride,\n        rhs,\n        cols,\n        rhs_stride,\n        k_blocks,\n        out_stride,\n    )\n\n    for row in range(rows):\n        start = row * out_stride\n        assert out[start : start + cols] == expected[start : start + cols]\n\n\ndef test_bad_len_guards() -> None:\n    rng = random.Random(7)\n    lhs = build_q4_matrix_rows(1, 2, 1, rng)\n    rhs = build_q4_matrix_cols(1, 2, 1, rng)\n\n    err, _ = q4_0_matmul_tiled_avx2_q32_checked(\n        lhs,\n        len(lhs),\n        1,\n        2,\n        rhs,\n        len(rhs),\n        1,\n        2,\n        1,\n        0,\n        1,\n        2,\n        2,\n    )\n    assert err == Q4_0_ERR_BAD_LEN\n\n    err, _ = q4_0_matmul_tiled_avx2_q32_checked(\n        lhs,\n        len(lhs),\n        1,\n        0,\n        rhs,\n        len(rhs),\n        1,\n        2,\n        1,\n        1,\n        1,\n        2,\n        2,\n    )\n    assert err == Q4_0_ERR_BAD_LEN\n\n\ndef test_capacity_and_overflow_guards() -> None:\n    rng = random.Random(123)\n    lhs = build_q4_matrix_rows(2, 2, 2, rng)\n    rhs = build_q4_matrix_cols(2, 2, 2, rng)\n\n    err, _ = q4_0_matmul_tiled_avx2_q32_checked(\n        lhs,\n        len(lhs) - 1,\n        2,\n        2,\n        rhs,\n        len(rhs),\n        2,\n        2,\n        2,\n        1,\n        1,\n        4,\n        2,\n    )\n    assert err == Q4_0_ERR_BAD_LEN\n\n    huge = (1 << 62)\n    err, _ = q4_0_matmul_tiled_avx2_q32_checked(\n        lhs,\n        len(lhs),\n        huge,\n        4,\n        rhs,\n        len(rhs),\n        1,\n        2,\n        1,\n        1,\n        1,\n        8,\n        1,\n    )\n    assert err == Q4_0_ERR_OVERFLOW\n\n\ndef test_randomized_tiling_parity() -> None:\n    rng = random.Random(0x24031599)\n\n    for _ in range(100):\n        rows = rng.randint(1, 4)\n        cols = rng.randint(1, 4)\n        k_blocks = rng.randint(1, 3)\n        lhs_stride = k_blocks + rng.randint(0, 2)\n        rhs_stride = k_blocks + rng.randint(0, 2)\n        out_stride = cols + rng.randint(0, 2)\n        tile_rows = rng.randint(1, 3)\n        tile_cols = rng.randint(1, 3)\n\n        lhs = build_q4_matrix_rows(rows, lhs_stride, k_blocks, rng)\n        rhs = build_q4_matrix_cols(cols, rhs_stride, k_blocks, rng)\n\n        err, out = q4_0_matmul_tiled_avx2_q32_checked(\n            lhs,\n            len(lhs),\n            rows,\n            lhs_stride,\n            rhs,\n            len(rhs),\n            cols,\n            rhs_stride,\n            k_blocks,\n            tile_rows,\n            tile_cols,\n            rows * out_stride,\n            out_stride,\n        )\n        assert err == Q4_0_OK\n\n        expected = q4_0_scalar_matmul_reference(\n            lhs,\n            rows,\n            lhs_stride,\n            rhs,\n            cols,\n            rhs_stride,\n            k_blocks,\n            out_stride,\n        )\n\n        for row in range(rows):\n            start = row * out_stride\n            assert out[start : start + cols] == expected[start : start + cols]\n\n\nif __name__ == \"__main__\":\n    test_known_small_matches_reference()\n    test_bad_len_guards()\n    test_capacity_and_overflow_guards()\n    test_randomized_tiling_parity()\n    print(\"ok\")\nEOF'","aggregated_output":"","exit_code":0,"status":"completed"}}
