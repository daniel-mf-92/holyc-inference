  if (required_matrix_blocks > matrix_block_capacity)\n        return Q4_0_AVX2_ERR_BAD_LEN;\n\n    for (row_index = 0; row_index < row_count; ++row_index)\n    {\n        if (!Q4_0AVX2TryMulI64(row_index, row_stride_blocks, &row_base))\n            return Q4_0_AVX2_ERR_OVERFLOW;\n\n        row_ptr = &matrix_blocks[row_base];\n        status = Q4_0DotProductBlocksQ32AVX2Checked(row_ptr,\n                                                    matrix_block_capacity - row_base,\n                                                    vec_blocks,\n                                                    vec_block_capacity,\n                                                    vec_block_count,\n                                                    &row_dot_q32);\n        if (status != Q4_0_AVX2_OK)\n            return status;\n\n        out_rows_q32[row_index] = row_dot_q32;\n    }\n\n    return Q4_0_AVX2_OK;\n}\n\nI32 Q4_0DotProductBlocksQ32AVX2CheckedDefault(\n    Q4_0Block *lhs,\n    Q4_0Block *rhs,\n    I64 block_count,\n    I64 *out_dot_q32)\n{\n    // IQ-301 canonical default-capacity wrapper:\n    // - Caller provides the active block span only.\n    // - Capacity defaults to `block_count` on both sides.\n    // - All null/bounds/no-partial-write contracts come from the checked core.\n    return Q4_0DotProductBlocksQ32AVX2Checked(lhs,\n                                              block_count,\n                                              rhs,\n                                              block_count,\n                                              block_count,\n                                              out_dot_q32);\n}\n\nI32 Q4_0DotRowsAVX2Q32CheckedDefault(\n    Q4_0Block *matrix_blocks,\n    I64 row_count,\n    I64 row_stride_blocks,\n    Q4_0Block *vec_blocks,\n    I64 vec_block_count,\n    I64 *out_rows_q32)\n{\n    I64 matrix_block_capacity;\n\n    // IQ-311 canonical default-capacity row wrapper:\n    // - Matrix capacity defaults to `row_count * row_stride_blocks`.\n    // - Vector capacity defaults to `vec_block_count`.\n    // - Negative lengths keep BAD_LEN semantics from checked row core.\n    // - Multiplication is checked so default-capacity derivation never wraps.\n    if (row_count < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n        return Q4_0_AVX2_ERR_BAD_LEN;\n\n    if (!Q4_0AVX2TryMulI64(row_count, row_stride_blocks, &matrix_block_capacity))\n        return Q4_0_AVX2_ERR_OVERFLOW;\n\n    return Q4_0DotRowsAVX2Q32Checked(matrix_blocks,\n                                     matrix_block_capacity,\n                                     row_count,\n                                     row_stride_blocks,\n                                     vec_blocks,\n                                     vec_block_count,\n                                     vec_block_count,\n                                     out_rows_q32);\n}\n","exit_code":0,"status":"completed"}}
