     out_row_stride_cells,\n                                          &out_required_cells))\n        return Q4_0_MATMUL_AVX2_Q32_ERR_OVERFLOW;\n\n    if (lhs_required_blocks > lhs_q4_block_capacity)\n        return Q4_0_MATMUL_AVX2_Q32_ERR_BAD_LEN;\n    if (rhs_required_blocks > rhs_q4_block_capacity)\n        return Q4_0_MATMUL_AVX2_Q32_ERR_BAD_LEN;\n    if (out_required_cells > out_cell_capacity)\n        return Q4_0_MATMUL_AVX2_Q32_ERR_BAD_LEN;\n\n    // Tiled traversal keeps cache behavior sane while exposing each output cell\n    // as one explicit checked row-dot against a column-bank vector.\n    row_tile_start = 0;\n    while (row_tile_start < row_count)\n    {\n        status = Q4_0MatMulAVX2Q32ComputeSpanBoundsChecked(row_tile_start,\n                                                           tile_rows,\n                                                           row_count,\n                                                           &row_tile_end);\n        if (status != Q4_0_MATMUL_AVX2_Q32_OK)\n            return status;\n\n        col_tile_start = 0;\n        while (col_tile_start < col_count)\n        {\n            status = Q4_0MatMulAVX2Q32ComputeSpanBoundsChecked(col_tile_start,\n                                                               tile_cols,\n                                                               col_count,\n                                                               &col_tile_end);\n            if (status != Q4_0_MATMUL_AVX2_Q32_OK)\n                return status;\n\n            for (row_index = row_tile_start; row_index < row_tile_end; ++row_index)\n            {\n                if (!Q4_0MatMulAVX2Q32TryMulI64NonNeg(row_index,\n                                                      lhs_row_stride_blocks,\n                                                      &lhs_row_base))\n                    return Q4_0_MATMUL_AVX2_Q32_ERR_OVERFLOW;\n                if (!Q4_0MatMulAVX2Q32TryMulI64NonNeg(row_index,\n                         