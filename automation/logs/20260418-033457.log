{"type":"item.started","item":{"id":"item_35","type":"command_execution","command":"/bin/zsh -lc \"cat > tests/test_q4_0_matmul_tiled_avx2_q32_checked.py <<'EOF'\n#\"'!/usr/bin/env python3\n\"\"\"Parity checks for Q4_0MatMulTiledAVX2Q32Checked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nQ4_0_OK = 0\nQ4_0_ERR_NULL_PTR = 1\nQ4_0_ERR_BAD_LEN = 2\nQ4_0_ERR_OVERFLOW = 3\n\nI64_MAX = (1 << 63) - 1\nI64_MIN = -(1 << 63)\n\n\ndef try_mul_i64_nonneg(lhs: int, rhs: int):\n    if lhs < 0 or rhs < 0:\n        return False, 0\n    if lhs == 0 or rhs == 0:\n        return True, 0\n    if lhs > I64_MAX // rhs:\n        return False, 0\n    return True, lhs * rhs\n\n\ndef try_add_i64_nonneg(lhs: int, rhs: int):\n    if lhs < 0 or rhs < 0:\n        return False, 0\n    if lhs > I64_MAX - rhs:\n        return False, 0\n    return True, lhs + rhs\n\n\ndef span_bounds_checked(span_start: int, span_len: int, axis_len: int):\n    if span_start < 0 or span_len < 0 or axis_len < 0:\n        return Q4_0_ERR_BAD_LEN, 0\n    if span_start > axis_len:\n        return Q4_0_ERR_BAD_LEN, 0\n\n    ok, span_end = try_add_i64_nonneg(span_start, span_len)\n    if not ok:\n        return Q4_0_ERR_OVERFLOW, 0\n\n    return Q4_0_OK, min(span_end, axis_len)\n\n\ndef out_index_checked(out_row_base: int, col_index: int, out_cell_capacity: int):\n    if out_row_base < 0 or col_index < 0 or out_cell_capacity < 0:\n        return Q4_0_ERR_BAD_LEN, 0\n\n    ok, out_index = try_add_i64_nonneg(out_row_base, col_index)\n    if not ok:\n        return Q4_0_ERR_OVERFLOW, 0\n\n    if out_index >= out_cell_capacity:\n        return Q4_0_ERR_BAD_LEN, 0\n\n    return Q4_0_OK, out_index\n\n\ndef q4_0_f16_to_q16(fp16_bits: int) -> int:\n    sign_bit = (fp16_bits >> 15) & 1\n    exponent_bits = (fp16_bits >> 10) & 0x1F\n    fraction_bits = fp16_bits & 0x03FF\n\n    if exponent_bits == 0:\n        if fraction_bits == 0:\n            return 0\n        magnitude_q16 = (fraction_bits + (1 << 7))