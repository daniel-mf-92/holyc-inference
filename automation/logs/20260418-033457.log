           return Q4_0_ERR_BAD_LEN, []\n\n                ok, out_row_base = try_mul_i64_nonneg(row_index, out_row_stride_cells)\n                if not ok:\n                    return Q4_0_ERR_OVERFLOW, []\n\n                for col_index in range(col_tile_start, col_tile_end):\n                    ok, rhs_col_base = try_mul_i64_nonneg(col_index, rhs_col_stride_blocks)\n                    if not ok:\n                        return Q4_0_ERR_OVERFLOW, []\n\n                    ok, rhs_col_end = try_add_i64_nonneg(rhs_col_base, k_block_count)\n                    if not ok:\n                        return Q4_0_ERR_OVERFLOW, []\n                    if rhs_col_end > rhs_q4_block_capacity:\n                        return Q4_0_ERR_BAD_LEN, []\n\n                    err, out_index = out_index_checked(out_row_base, col_index, out_cell_capacity)\n                    if err != Q4_0_OK:\n                        return err, []\n\n                    err, dot_rows = q4_0_dot_rows_avx2_q32_checked(\n                        lhs_q4_blocks[lhs_row_base:],\n                        lhs_q4_block_capacity - lhs_row_base,\n                        1,\n                        lhs_row_stride_blocks,\n                        rhs_q4_col_blocks[rhs_col_base:],\n                        rhs_q4_block_capacity - rhs_col_base,\n                        k_block_count,\n                    )\n                    if err != Q4_0_OK:\n                        return err, []\n\n                    out[out_index] = dot_rows[0]\n\n            col_tile_start = col_tile_end\n\n        row_tile_start = row_tile_end\n\n    return Q4_0_OK, out\n\n\ndef q4_0_scalar_matmul_reference(lhs, rows, lhs_stride, rhs, cols, rhs_stride, k_blocks, out_stride):\n    out = [0] * (rows * out_stride)\n    for row in range(rows):\n        row_base = row * lhs_stride\n        for col in range(cols):\n            col_base = col * rhs_stride\n            err, dot_rows = q4_0_dot_rows_avx2_q32_checked(\n                lhs[row_base: