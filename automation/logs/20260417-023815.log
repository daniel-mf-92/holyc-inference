{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/math/fixedpoint.HC; sed -n '1,280p' src/math/rmsnorm.HC; rg -n \\\"ERR_|BAD_PARAM|OVERFLOW|Checked\\\\(\\\" src/math/*.HC | head -n 200\"","aggregated_output":"// fixedpoint.HC\n// Q16.16 fixed-point helpers for integer-only inference math.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define FP_Q16_HALF  (1 << (FP_Q16_SHIFT - 1))\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_DOMAIN    3\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n#define U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\nU64 FPAbsToU64(I64 x)\n{\n    if (x >= 0)\n        return (U64)x;\n\n    // Avoid overflow for I64_MIN by using two's-complement identity.\n    return ((U64)(-(x + 1))) + 1;\n}\n\nI64 FPSignApplyFromU64(U64 mag, I64 is_negative)\n{\n    if (is_negative)\n    {\n        if (mag >= 0x8000000000000000)\n            return I64_MIN_VALUE;\n        return -(I64)mag;\n    }\n\n    if (mag > (U64)I64_MAX_VALUE)\n        return I64_MAX_VALUE;\n    return (I64)mag;\n}\n\nI32 FPTryApplySignFromU64Checked(U64 mag, I64 is_negative, I64 *out_value)\n{\n    U64 limit;\n\n    if (!out_value)\n        return FP_Q16_ERR_NULL_PTR;\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (mag > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    *out_value = FPSignApplyFromU64(mag, is_negative);\n    return FP_Q16_OK;\n}\n\nI64 FPQ16RoundShiftSigned(I64 value, I64 shift)\n{\n    U64 abs_value;\n    U64 round_bias;\n    U64 rounded;\n    I64 is_negative;\n\n    if (shift <= 0)\n        return value;\n    if (shift >= 63)\n        return 0;\n\n    is_negative = value < 0;\n    abs_value = FPAbsToU64(value);\n    round_bias = (U64)1 << (shift - 1);\n\n    if (abs_value > U64_MAX_VALUE - round_bias)\n        rounded = U64_MAX_VALUE >> shift;\n    else\n        rounded = (abs_value + round_bias) >> shift;\n\n    return FPSignApplyFromU64(rounded, is_negative);\n}\n\nI64 FPQ16MulSat(I64 a, I64 b)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 limit;\n    I64 is_negative;\n    I64 prod;\n\n    if (!a || !b)\n        return 0;\n\n    abs_a = FPAbsToU64(a);\n    abs_b = FPAbsToU64(b);\n    is_negative = ((a < 0) ^ (b < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (abs_a > (limit / abs_b))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    prod = a * b;\n    return FPQ16RoundShiftSigned(prod, FP_Q16_SHIFT);\n}\n\nI64 FPQ16Abs(I64 x)\n{\n    if (x == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    if (x < 0)\n        return -x;\n    return x;\n}\n\nI64 FPQ16FromInt(I64 x)\n{\n    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n        return I64_MAX_VALUE;\n    if (x < (I64_MIN_VALUE >> FP_Q16_SHIFT))\n        return I64_MIN_VALUE;\n\n    return x << FP_Q16_SHIFT;\n}\n\nI64 FPQ16ToInt(I64 x)\n{\n    if (x >= 0)\n        return (x + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-x) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Mul(I64 a, I64 b)\n{\n    return FPQ16MulSat(a, b);\n}\n\nI64 FPQ16Div(I64 num, I64 den)\n{\n    U64 abs_num;\n    U64 abs_den;\n    U64 limit;\n    U64 int_part;\n    U64 rem;\n    U64 result_mag;\n    I64 is_negative;\n    I64 bit;\n\n    if (!den)\n        return 0;\n\n    abs_num = FPAbsToU64(num);\n    abs_den = FPAbsToU64(den);\n    is_negative = ((num < 0) ^ (den < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    int_part = abs_num / abs_den;\n    if (int_part > (limit >> FP_Q16_SHIFT))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    result_mag = int_part << FP_Q16_SHIFT;\n    rem = abs_num % abs_den;\n\n    // Emit 16 fractional bits using integer long division.\n    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n    {\n        rem <<= 1;\n        if (rem >= abs_den)\n        {\n            rem -= abs_den;\n            if (result_mag <= limit - (((U64)1) << bit))\n                result_mag |= ((U64)1) << bit;\n            else\n                result_mag = limit;\n        }\n    }\n\n    // Half-up rounding by checking whether residual remainder is >= 0.5.\n    if (rem >= ((abs_den + 1) >> 1))\n    {\n        if (result_mag < limit)\n            result_mag++;\n        else\n            result_mag = limit;\n    }\n\n    return FPSignApplyFromU64(result_mag, is_negative);\n}\n\n// Checked one-rounding Q16 helper for:\n//   out_q16 = round_half_up((a_q16 * b_q16) / d_q16)\n//\n// Inputs/outputs are Q16.16 integers, so this computes the exact Q16 result\n// of (a*b)/d without an intermediate Q16 downshift between mul and div.\n// That avoids double-rounding drift in RMSNorm/softmax scale paths.\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 abs_d;\n    U64 abs_num;\n    U64 q;\n    U64 r;\n    U64 limit;\n    I64 is_negative;\n\n    if (!out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (!d_q16)\n        return FP_Q16_ERR_DOMAIN;\n\n    abs_a = FPAbsToU64(a_q16);\n    abs_b = FPAbsToU64(b_q16);\n    abs_d = FPAbsToU64(d_q16);\n    is_negative = ((a_q16 < 0) ^ (b_q16 < 0) ^ (d_q16 < 0));\n\n    if (abs_a && abs_b && abs_a > (U64_MAX_VALUE / abs_b))\n        return FP_Q16_ERR_OVERFLOW;\n\n    abs_num = abs_a * abs_b;\n    q = abs_num / abs_d;\n    r = abs_num % abs_d;\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (q > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Half-up rounding: bump quotient when residual >= 0.5 denominator.\n    if (r >= ((abs_d + 1) >> 1))\n    {\n        if (q == limit)\n            return FP_Q16_ERR_OVERFLOW;\n        q++;\n    }\n\n    return FPTryApplySignFromU64Checked(q,\n                                        is_negative,\n                                        out_q16);\n}\n\n// rmsnorm.HC\n// Integer-only Q16.16 RMSNorm for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_DOMAIN    3\n#define FP_Q16_ERR_OVERFLOW  4\n#define U64_MAX_VALUE 0xFFFFFFFFFFFFFFFF\n#define FP_Q16_RMSNORM_AUTO_PATH_OUT_OF_PLACE 0\n#define FP_Q16_RMSNORM_AUTO_PATH_IN_PLACE     1\n\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Sqrt(I64 x);\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16);\nI32 FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(I64 a_q16,\n                                                     I64 b_q16,\n                                                     I64 d_q16,\n                                                     I64 *out_q16);\n\n// Apply precomputed RMSNorm inverse denominator to a Q16 vector with explicit\n// checked error surfaces. This uses one-rounding math:\n//   out[i] = round_half_up((input[i] * inv_denom_q16) / den_q16)\n// where den_q16 is a positive Q16 whole integer (d_int << 16).\nI32 FPQ16RMSNormApplyInvDenomChecked(I64 *input_q16,\n                                     I64 *output_q16,\n                                     I64 count,\n                                     I64 inv_denom_q16,\n                                     I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    // Delegate denominator contract + checked one-rounding to fixedpoint core.\n    // That keeps RMSNorm scaling error behavior identical to shared math helpers.\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        output_q16[i] = scaled_q16;\n    }\n\n    return 0;\n}\n\n// Apply precomputed RMSNorm inverse denominator and per-channel gamma to a\n// Q16 vector with explicit checked error surfaces:\n//   out[i] = round_half_up(round_half_up((input[i] * inv_denom_q16) / den_q16)\n//                          * gamma[i] / FP_Q16_ONE)\n// The first stage enforces the positive whole-Q16 denominator contract used by\n// WS5 norm call chains. The second stage is checked Q16*Q16 scaling.\nI32 FPQ16RMSNormApplyInvDenomWeightedChecked(I64 *input_q16,\n                                             I64 *gamma_q16,\n                                             I64 *output_q16,\n                                             I64 count,\n                                             I64 inv_denom_q16,\n                                             I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I64 weighted_q16;\n    I32 status;\n\n    if (!input_q16 || !gamma_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        status = FPQ16MulDivRoundedChecked(scaled_q16,\n                                           gamma_q16[i],\n                                           FP_Q16_ONE,\n                                           &weighted_q16);\n        if (status)\n            return status;\n\n        output_q16[i] = weighted_q16;\n    }\n\n    return 0;\n}\n\n// In-place variant of weighted inverse-denominator RMSNorm scaling:\n//   input[i] = round_half_up(round_half_up((input[i] * inv_denom_q16) / den_q16)\n//                            * gamma[i] / FP_Q16_ONE)\n// This preserves the same checked contracts as the out-of-place helper while\n// explicitly supporting alias-safe writes when caller uses one buffer.\nI32 FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked(I64 *input_q16,\n                                                    I64 *gamma_q16,\n                                                    I64 count,\n                                                    I64 inv_denom_q16,\n                                                    I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I64 weighted_q16;\n    I32 status;\n\n    if (!input_q16 || !gamma_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    for (i = 0; i < count; i++)\n    {\n        // Read one element, compute checked scaling, then write back to the\n        // same slot. No later iteration depends on previous slot values.\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        status = FPQ16MulDivRoundedChecked(scaled_q16,\n                                           gamma_q16[i],\n                                           FP_Q16_ONE,\n                                           &weighted_q16);\n        if (status)\n            return status;\n\n        input_q16[i] = weighted_q16;\n    }\n\n    return 0;\n}\n\n// Shared preflight for auto-dispatch weighted inverse-denominator RMSNorm.\n// This centralizes parameter/domain checks so alias and non-alias paths\n// surface identical BAD_PARAM/DOMAIN/OVERFLOW behavior before any writes.\nI32 FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked(I64 *input_q16,\n                                                         I64 *gamma_q16,\n                                                         I64 *output_q16,\n                                                         I64 count,\n                                                         I64 inv_denom_q16,\n                                                         I64 den_q16)\n{\n    I64 last_index;\n    I64 last_byte_offset;\n\n    if (!input_q16 || !gamma_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    // Keep denominator contract explicit at auto-dispatch boundary:\n    // - positive\n    // - exact Q16 whole integer (d_int << 16)\n    // - d_int strictly positive after decode\n    if (den_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n    if (den_q16 & (FP_Q16_ONE - 1))\n        return FP_Q16_ERR_BAD_PARAM;\n    if ((den_q16 >> FP_Q16_SHIFT) <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    if (!count)\n        return 0;\n\n    // Guard pointer-span math used by indexed access in both dispatch paths.\n    // count-1 element index and byte offsets must stay in signed range.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)gamma_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    return 0;\n}\n\n// Select auto-dispatch execution path deterministically from pointer aliasing.\n// The contract is explicit and checked:\n// - in-place path only when input and output pointers are identical\n// - out-of-place path for all other pointer pairs\n// This helper isolates path selection from math kernels so dispatch behavior\n// stays stable as validation and execution logic evolve independently.\nI32 FPQ16RMSNormApplyInvDenomWeightedAutoSelectPathChecked(I64 *input_q16,\n                                                           I64 *output_q16,\n                                                           I32 *path_out)\n{\n    if (!input_q16 || !output_q16 || !path_out)\n        return FP_Q16_ERR_NULL_PTR;\n\n    if (input_q16 == output_q16)\n    {\n        *path_out = FP_Q16_RMSNORM_AUTO_PATH_IN_PLACE;\n        return 0;\n    }\n\n    *path_out = FP_Q16_RMSNORM_AUTO_PATH_OUT_OF_PLACE;\n    return 0;\n}\n\n// Auto-dispatch weighted inverse-denominator RMSNorm scaling:\n// - If input/output alias, use the in-place checked kernel.\n// - If they do not alias, use the out-of-place checked kernel.\n// This keeps the math path fully transparent while preserving the exact\n// checked error surfaces of the selected canonical helper.\nI32 FPQ16RMSNormApplyInvDenomWeightedAutoChecked(I64 *input_q16,\n                                                 I64 *gamma_q16,\n                                                 I64 *output_q16,\n                                                 I64 count,\n                                   