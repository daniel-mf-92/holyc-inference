Q4_0  18\n    41\t#define GGML_TYPE_SIZE_Q8_0  34\n    42\t\n    43\tI64 GGUFTensorTypeBlockSize(U32 ggml_type, U64 *out_block_size)\n    44\t{\n    45\t    if (!out_block_size)\n    46\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    47\t\n    48\t    switch (ggml_type)\n    49\t    {\n    50\t        case GGML_TYPE_F32:\n    51\t            *out_block_size = GGML_BLCK_SIZE_F32;\n    52\t            return GGUF_TDBASE_OK;\n    53\t        case GGML_TYPE_F16:\n    54\t            *out_block_size = GGML_BLCK_SIZE_F16;\n    55\t            return GGUF_TDBASE_OK;\n    56\t        case GGML_TYPE_Q4_0:\n    57\t            *out_block_size = GGML_BLCK_SIZE_Q4_0;\n    58\t            return GGUF_TDBASE_OK;\n    59\t        case GGML_TYPE_Q8_0:\n    60\t            *out_block_size = GGML_BLCK_SIZE_Q8_0;\n    61\t            return GGUF_TDBASE_OK;\n    62\t    }\n    63\t\n    64\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    65\t}\n    66\t\n    67\tI64 GGUFTensorTypeBlockBytes(U32 ggml_type, U64 *out_block_bytes)\n    68\t{\n    69\t    if (!out_block_bytes)\n    70\t        return GGUF_TDBASE_ERR_NULL_PTR;\n    71\t\n    72\t    switch (ggml_type)\n    73\t    {\n    74\t        case GGML_TYPE_F32:\n    75\t            *out_block_bytes = GGML_TYPE_SIZE_F32;\n    76\t            return GGUF_TDBASE_OK;\n    77\t        case GGML_TYPE_F16:\n    78\t            *out_block_bytes = GGML_TYPE_SIZE_F16;\n    79\t            return GGUF_TDBASE_OK;\n    80\t        case GGML_TYPE_Q4_0:\n    81\t            *out_block_bytes = GGML_TYPE_SIZE_Q4_0;\n    82\t            return GGUF_TDBASE_OK;\n    83\t        case GGML_TYPE_Q8_0:\n    84\t            *out_block_bytes = GGML_TYPE_SIZE_Q8_0;\n    85\t            return GGUF_TDBASE_OK;\n    86\t    }\n    87\t\n    88\t    return GGUF_TDBASE_ERR_BAD_TYPE;\n    89\t}\n    90\t\n    91\tI64 GGUFTensorBytesForType(U32 ggml_type,\n    92\t                           U64 element_count,\n    93\t                           U64 *out_tensor_nbytes)\n    94\t{\n    95\t    U64 block_size;\n    96\t    U64 block_bytes;\n    97\t    U64 block_count;\n    98\t    I64 err;\n    99\t\n   100\t    if (!out_tensor_nbytes)\n   101\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   102\t\n   103\t    err = GGUFTensorTypeBlockSize(ggml_type, &block_size);\n   104\t    if (err != GGUF_TDBASE_OK)\n   105\t        return err;\n   106\t\n   107\t    err = GGUFTensorTypeBlockBytes(ggml_type, &block_bytes);\n   108\t    if (err != GGUF_TDBASE_OK)\n   109\t        return err;\n   110\t\n   111\t    // Quantized formats are stored in fixed-size element blocks.\n   112\t    // Reject non-multiples instead of silently rounding/truncating.\n   113\t    if (element_count % block_size)\n   114\t        return GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE;\n   115\t\n   116\t    block_count = element_count / block_size;\n   117\t\n   118\t    // Byte size = number of blocks * bytes per block.\n   119\t    // Guard overflow before multiplication for malformed giant tensors.\n   120\t    if (block_count > 0xFFFFFFFFFFFFFFFF / block_bytes)\n   121\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   122\t\n   123\t    *out_tensor_nbytes = block_count * block_bytes;\n   124\t    return GGUF_TDBASE_OK;\n   125\t}\n   126\t\n   127\tBool GGUFIsPow2U32(U32 value)\n   128\t{\n   129\t    if (!value)\n   130\t        return FALSE;\n   131\t    return (value & (value - 1)) == 0;\n   132\t}\n   133\t\n   134\tI64 GGUFValidateAlignment(U32 alignment)\n   135\t{\n   136\t    if (!GGUFIsPow2U32(alignment))\n   137\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   138\t    return GGUF_TDBASE_OK;\n   139\t}\n   140\t\n   141\tI64 GGUFAlignUpU64(U64 value, U32 alignment, U64 *out)\n   142\t{\n   143\t    U64 mask;\n   144\t\n   145\t    if (!out)\n   146\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   147\t\n   148\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   149\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   150\t\n   151\t    // For power-of-two alignments, align-up is:\n   152\t    //   (value + (alignment - 1)) & ~(alignment - 1)\n   153\t    // Keep overflow checks explicit so giant malformed offsets are rejected.\n   154\t    mask = (U64)alignment - 1;\n   155\t    if (value > 0xFFFFFFFFFFFFFFFF - mask)\n   156\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   157\t\n   158\t    *out = (value + mask) & ~mask;\n   159\t    return GGUF_TDBASE_OK;\n   160\t}\n   161\t\n   162\tI64 GGUFTensorDataBaseAlign(U64 cursor_after_tensor_info,\n   163\t                            U32 alignment,\n   164\t                            U64 *out_tensor_data_base)\n   165\t{\n   166\t    return GGUFAlignUpU64(cursor_after_tensor_info,\n   167\t                          alignment,\n   168\t                          out_tensor_data_base);\n   169\t}\n   170\t\n   171\tI64 GGUFTensorDataBaseAlignDefault(U64 cursor_after_tensor_info,\n   172\t                                   U64 *out_tensor_data_base)\n   173\t{\n   174\t    return GGUFTensorDataBaseAlign(cursor_after_tensor_info,\n   175\t                                   GGUF_DEFAULT_ALIGNMENT,\n   176\t                                   out_tensor_data_base);\n   177\t}\n   178\t\n   179\tBool GGUFTensorDataBaseIsAligned(U64 offset, U32 alignment)\n   180\t{\n   181\t    U64 mask;\n   182\t\n   183\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   184\t        return FALSE;\n   185\t\n   186\t    mask = (U64)alignment - 1;\n   187\t    return (offset & mask) == 0;\n   188\t}\n   189\t\n   190\tI64 GGUFTensorDataBaseOffset(U64 tensor_data_base,\n   191\t                             U64 tensor_rel_offset,\n   192\t                             U32 alignment,\n   193\t                             U64 *out_tensor_abs)\n   194\t{\n   195\t    if (!out_tensor_abs)\n   196\t        return GGUF_TDBASE_ERR_NULL_PTR;\n   197\t\n   198\t    if (GGUFValidateAlignment(alignment) != GGUF_TDBASE_OK)\n   199\t        return GGUF_TDBASE_ERR_BAD_ALIGNMENT;\n   200\t\n   201\t    // Both