 tensor start offset first.\n   243\t    err = GGUFTensorDataBaseOffset(tensor_data_base,\n   244\t                                   tensor_rel_offset,\n   245\t                                   alignment,\n   246\t                                   &abs_start);\n   247\t    if (err != GGUF_TDBASE_OK)\n   248\t        return err;\n   249\t\n   250\t    // Tensor byte-range is [abs_start, abs_start + tensor_nbytes).\n   251\t    // Guard add overflow before constructing the exclusive end.\n   252\t    if (abs_start > 0xFFFFFFFFFFFFFFFF - tensor_nbytes)\n   253\t        return GGUF_TDBASE_ERR_OVERFLOW;\n   254\t    abs_end = abs_start + tensor_nbytes;\n   255\t\n   256\t    // Reject ranges that run past the file boundary.\n   257\t    // A tensor may legally end exactly at gguf_file_nbytes.\n   258\t    if (abs_end > gguf_file_nbytes)\n   259\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n   260\t\n   261\t    *out_tensor_abs_start = abs_start;\n   262\t    *out_tensor_abs_end   = abs_end;\n   263\t    return GGUF_TDBASE_OK;\n   264\t}\n   265\t\n   266\tI64 GGUFTensorResolveRangeDefault(U64 tensor_data_base,\n   267\t                                  U64 tensor_rel_offset,\n   268\t                                  U64 tensor_nbytes,\n   269\t                                  U64 gguf_file_nbytes,\n   270\t                                  U64 *out_tensor_abs_start,\n   271\t                                  U64 *out_tensor_abs_end)\n   272\t{\n   273\t    return GGUFTensorResolveRange(tensor_data_base,\n   274\t                                  tensor_rel_offset,\n   275\t                                  tensor_nbytes,\n   276\t                                  gguf_file_nbytes,\n   277\t                                  GGUF_DEFAULT_ALIGNMENT,\n   278\t                                  out_tensor_abs_start,\n   279\t                                  out_tensor_abs_end);\n   280\t}\n   281\t\n   282\tI64 GGUFValidateTensorRanges(U64 tensor_data_base,\n   283\t 