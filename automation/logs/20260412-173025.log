89\t    assert bad == 1\n   590\t\n   591\t\n   592\tdef test_validate_tensor_ranges_random_non_overlapping() -> None:\n   593\t    rng = random.Random(761991)\n   594\t\n   595\t    for _ in range(300):\n   596\t        alignment = 1 << rng.randint(0, 10)\n   597\t        count = rng.randint(1, 12)\n   598\t        cursor = 0\n   599\t\n   600\t        rel_offsets = []\n   601\t        nbytes = []\n   602\t        for _ in range(count):\n   603\t            gap_units = rng.randint(0, 8)\n   604\t            gap = gap_units * alignment\n   605\t            cursor += gap\n   606\t\n   607\t            span_units = rng.randint(0, 6)\n   608\t            span = span_units * alignment\n   609\t\n   610\t            rel_offsets.append(cursor)\n   611\t            nbytes.append(span)\n   612\t            cursor += span\n   613\t\n   614\t        base_units = rng.randint(0, 1024)\n   615\t        base = base_units * alignment\n   616\t        file_nbytes = base + cursor + (rng.randint(0, 16) * alignment)\n   617\t\n   618\t        err, bad = validate_tensor_ranges(\n   619\t            tensor_data_base=base,\n   620\t            alignment=alignment,\n   621\t            gguf_file_nbytes=file_nbytes,\n   622\t            tensor_rel_offsets=rel_offsets,\n   623\t            tensor_nbytes=nbytes,\n   624\t        )\n   625\t        assert err == GGUF_TDBASE_OK\n   626\t        assert bad == 0\n   627\t\n   628\t\n   629\tdef test_validate_tensor_ranges_random_overlap_cases() -> None:\n   630\t    rng = random.Random(762007)\n   631\t\n   632\t    for _ in range(200):\n   633\t        alignment = 1 << rng.randint(0, 10)\n   634\t        base = rng.randint(0, 1024) * alignment\n   635\t\n   636\t        a_start = rng.randint(0, 128) * alignment\n   637\t        a_len = max(alignment, rng.randint(1, 8) * alignment)\n   638\t        b_start = a_start + rng.randint(0, (a_len // alignment) - 1) * alignment\n   639\t        b_len = max(alignment, rng.randint(1, 8) * alignment)\n   6