 209\tdef _sift_down(rel_offsets: list[int], nbytes: list[int], root: int, end: int) -> None:\n   210\t    def greater(i: int, j: int) -> bool:\n   211\t        if rel_offsets[i] > rel_offsets[j]:\n   212\t            return True\n   213\t        if rel_offsets[i] < rel_offsets[j]:\n   214\t            return False\n   215\t        return nbytes[i] > nbytes[j]\n   216\t\n   217\t    while True:\n   218\t        child = root * 2 + 1\n   219\t        if child > end:\n   220\t            return\n   221\t\n   222\t        swap_idx = root\n   223\t        if greater(child, swap_idx):\n   224\t            swap_idx = child\n   225\t        if child + 1 <= end and greater(child + 1, swap_idx):\n   226\t            swap_idx = child + 1\n   227\t\n   228\t        if swap_idx == root:\n   229\t            return\n   230\t\n   231\t        rel_offsets[root], rel_offsets[swap_idx] = rel_offsets[swap_idx], rel_offsets[root]\n   232\t        nbytes[root], nbytes[swap_idx] = nbytes[swap_idx], nbytes[root]\n   233\t        root = swap_idx\n   234\t\n   235\t\n   236\tdef _heapsort_ranges_in_place(rel_offsets: list[int], nbytes: list[int]) -> None:\n   237\t    count = len(rel_offsets)\n   238\t    if count < 2:\n   239\t        return\n   240\t\n   241\t    start = ((count - 2) // 2) + 1\n   242\t    while start > 0:\n   243\t        start -= 1\n   244\t        _sift_down(rel_offsets, nbytes, start, count - 1)\n   245\t\n   246\t    end = count - 1\n   247\t    while end > 0:\n   248\t        rel_offsets[0], rel_offsets[end] = rel_offsets[end], rel_offsets[0]\n   249\t        nbytes[0], nbytes[end] = nbytes[end], nbytes[0]\n   250\t        end -= 1\n   251\t        _sift_down(rel_offsets, nbytes, 0, end)\n   252\t\n   253\t\n   254\tdef validate_tensor_ranges_sorted(\n   255\t    tensor_data_base: int,\n   256\t    alignment: int,\n   257\t    gguf_file_nbytes: int,\n   258\t    tensor_rel_offsets: list[int],\n   259\t    tensor_nbytes: list[int],\n   260\t):\n","exit_code":0,"statu