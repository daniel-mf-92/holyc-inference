t_validate_tensor_ranges_sorted_detect_overlap() -> None:\n   692\t    rel_offsets = [0x100, 0x00, 0x20]\n   693\t    nbytes = [0x20, 0x40, 0x40]\n   694\t\n   695\t    err, bad = validate_tensor_ranges_sorted(\n   696\t        tensor_data_base=0x1000,\n   697\t        alignment=32,\n   698\t        gguf_file_nbytes=0x5000,\n   699\t        tensor_rel_offsets=rel_offsets,\n   700\t        tensor_nbytes=nbytes,\n   701\t    )\n   702\t    assert err == GGUF_TDBASE_ERR_OVERLAP\n   703\t    assert bad == 1\n   704\t    assert rel_offsets == [0x00, 0x20, 0x100]\n   705\t    assert nbytes == [0x40, 0x40, 0x20]\n   706\t\n   707\t\n   708\tdef test_validate_tensor_ranges_sorted_propagates_bad_alignment_without_sort() -> None:\n   709\t    rel_offsets = [0x80, 0x00]\n   710\t    nbytes = [0x20, 0x20]\n   711\t\n   712\t    err, bad = validate_tensor_ranges_sorted(\n   713\t        tensor_data_base=0x1000,\n   714\t        alignment=24,\n   715\t        gguf_file_nbytes=0x5000,\n   716\t        tensor_rel_offsets=rel_offsets,\n   717\t        tensor_nbytes=nbytes,\n   718\t    )\n   719\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   720\t    assert bad == 0\n   721\t    assert rel_offsets == [0x80, 0x00]\n   722\t    assert nbytes == [0x20, 0x20]\n   723\t\n   724\t\n   725\tdef test_validate_tensor_ranges_sorted_random_matches_quadratic_validator() -> None:\n   726\t    rng = random.Random(762199)\n   727\t\n   728\t    for _ in range(500):\n   729\t        alignment = 1 << rng.randint(0, 10)\n   730\t        count = rng.randint(1, 24)\n   731\t        base = rng.randint(0, 1024) * alignment\n   732\t\n   733\t        rel_offsets = []\n   734\t        nbytes = []\n   735\t        cursor = 0\n   736\t\n   737\t        force_overlap = rng.random() < 0.5 and count >= 2\n   738\t        overlap_i = rng.randint(0, count - 2) if force_overlap else -1\n   739\t\n   740\t        for i in range(count):\n   741\t            gap = rng.randint(0, 6) * alignment\n   742\t            cursor += gap\n   743\t            span = rng.randint(0, 6) * alignment\n   744\t\n   745\t            start = cursor\n   746\t            if force_overlap and i == overlap_i + 1:\n   747\t                prev_start = rel_offsets[-1]\n   748\t                prev_span = nbytes[-1]\n   749\t                if prev_span == 0:\n   750\t                    start = prev_start\n   751\t                else:\n   752\t                    start = prev_start + rng.randint(0, max(0, (prev_span // alignment) - 1)) * alignment\n   753\t\n   754\t            rel_offsets.append(start)\n   755\t            nbytes.append(span)\n   756\t            cursor = max(cursor, start + span)\n   757\t\n   758\t        file_nbytes = base + cursor + rng.randint(0, 8) * alignment + alignment\n   759\t\n   760\t        rel_a = rel_offsets.copy()\n   761\t        nbytes_a = nbytes.copy()\n   762\t        err_quad, bad_quad = validate_tensor_ranges(\n   763\t            tensor_data_base=base,\n   764\t            alignment=alignment,\n   765\t            gguf_file_nbytes=file_nbytes,\n   766\t            tensor_rel_offsets=rel_a,\n   767\t            tensor_nbytes=nbytes_a,\n   768\t        )\n   769\t\n   770\t        rel_b = rel_offsets.copy()\n   771\t        nbytes_b = nbytes.copy()\n   772\t        err_sorted, bad_sorted = validate_tensor_ranges_sorted(\n   773\t            tensor_data_base=base,\n   774\t            alignment=alignment,\n   775\t            gguf_file_nbytes=file_nbytes,\n   776\t            tensor_rel_offsets=rel_b,\n   777\t            tensor_nbytes=nbytes_b,\n   778\t        )\n   779\t\n   780\t        assert err_sorted == err_quad\n   781\t        if err_sorted == GGUF_TDBASE_ERR_OVERLAP:\n   782\t            assert bad_sorted >= 1\n   783\t        elif err_sorted == GGUF_TDBASE_OK:\n   784\t            assert bad_sorted == 0\n   785\t            assert rel_b == sorted(rel_offsets)\n   786\t\n   787\t\n   788\t\n   789\t\n   790\tdef run() -> None:\n   791\t    test_default_alignment_examples()\n   792\t    test_tensor_bytes_for_type_scalars()\n   793\t    test_tensor_bytes_for_type_quantized_exact_blocks()\n   794\t    test_tensor_bytes_for_type_reject_non_multiple_block()\n   795\t    test_tensor_bytes_for_type_reject_unknown_type()\n   796\t    test_tensor_bytes_for_type_overflow_guard()\n   797\t    test_tensor_type_block_size_known_types()\n   798\t    test_tensor_type_block_bytes_known_types()\n   799\t    test_tensor_type_helpers_reject_unknown_type()\n   800\t    test_custom_power_of_two_alignment()\n   801\t    test_reject_non_power_of_two_alignment()\n   802\t    test_overflow_guard_near_u64_max()\n   803\t    test_random_alignment_matches_reference_formula()\n   804\t    test_tensor_data_base_offset_happy_path()\n   805\t    test_tensor_data_base_offset_default_alignment()\n   806\t    test_tensor_data_base_offset_reject_bad_alignment()\n   807\t    test_tensor_data_base_offset_reject_misaligned_base()\n   808\t    test_tensor_data_base_offset_reject_misaligned_rel()\n   809\t    test_tensor_data_base_offset_overflow_guard()\n   810\t    test_tensor_data_base_offset_random_aligned_cases()\n   811\t    test_tensor_resolve_range_happy_path()\n   812\t    test_tensor_resolve_range_default_alignment()\n   813\t    test_tensor_resolve_range_reject_bad_alignment()\n   814\t    test_tensor_resolve_range_reject_misaligned_base()\n   815\t    test_tensor_resolve_range_reject_misaligned_offset()\n   816\t    test_tensor_resolve_range_overflow_guard()\n   817\t    test_tensor_resolve_range_out_of_bounds()\n   818\t    test_tensor_resolve_range_allows_exact_eof()\n   819\t    test_tensor_resolve_range_random_valid_cases()\n   820\t    test_validate_tensor_ranges_non_overlapping_happy_path()\n   821\t    test_validate_tensor_ranges_detect_overlap()\n   822\t    test_validate_tensor_ranges_propagates_bad_alignment()\n   823\t    test_validate_tensor_ranges_propagates_out_of_bounds_with_index()\n   824\t    test_validate_tensor_rang