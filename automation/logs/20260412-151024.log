t    Bool b;\n    47\t    GGUFString str;\n    48\t\n    49\t    // Array descriptor. Payload bytes remain in file buffer; we store offsets so\n    50\t    // later systems can decode lazily without reparsing the table.\n    51\t    U32 array_elem_type;\n    52\t    U64 array_len;\n    53\t    U64 array_payload_off;\n    54\t    U64 array_payload_bytes;\n    55\t};\n    56\t\n    57\tclass GGUFMetadataKV\n    58\t{\n    59\t    GGUFString key;\n    60\t    GGUFMetaValue value;\n    61\t};\n    62\t\n    63\tclass GGUFMetadataTable\n    64\t{\n    65\t    U64 count;\n    66\t    GGUFMetadataKV *items;\n    67\t};\n    68\t\n    69\tBool GGUFMetaCanRead(U8 *buf, I64 size, I64 cursor, I64 need)\n    70\t{\n    71\t    if (!buf)\n    72\t        return FALSE;\n    73\t    if (size < 0 || cursor < 0 || need < 0)\n    74\t        return FALSE;\n    75\t    if (cursor > size)\n    76\t        return FALSE;\n    77\t    if (need > size - cursor)\n    78\t        return FALSE;\n    79\t    return TRUE;\n    80\t}\n    81\t\n    82\tBool GGUFMetaReadU8(U8 *buf, I64 size, I64 *cursor, U8 *out)\n    83\t{\n    84\t    I64 c;\n    85\t\n    86\t    if (!cursor || !out)\n    87\t        return FALSE;\n    88\t\n    89\t    c = *cursor;\n    90\t    if (!GGUFMetaCanRead(buf, size, c, 1))\n    91\t        return FALSE;\n    92\t\n    93\t    *out = buf[c];\n    94\t    *cursor = c + 1;\n    95\t    return TRUE;\n    96\t}\n    97\t\n    98\tBool GGUFMetaReadU16LE(U8 *buf, I64 size, I64 *cursor, U16 *out)\n    99\t{\n   100\t    I64 c;\n   101\t\n   102\t    if (!cursor || !out)\n   103\t        return FALSE;\n   104\t\n   105\t    c = *cursor;\n   106\t    if (!GGUFMetaCanRead(buf, size, c, 2))\n   107\t        return FALSE;\n   108\t\n   109\t    *out = (U16)buf[c]\n   110\t         | ((U16)buf[c + 1] << 8);\n   111\t\n   112\t    *cursor = c + 2;\n   113\t    return TRUE;\n   114\t}\n   115\t\n   116\tBool GGUFMetaReadU32LE(U8 *buf, I64 size, I64 *cursor, U32 *out)\n   117\t{\n   118\t    I64 c;\n   119\t\n   120\t    if (!cursor || !out)\n   121\t        return FALSE;\n   122\t\n   123\t    c = *cursor;\n   124\t    if (!GGUFMetaCanRead(buf, size, c, 4))\n   125\t        return FALSE;\n   126\t\n   127\t    *out = (U32)buf[c]\n   128\t         | ((U32)buf[c + 1] << 8)\n   129\t         | ((U32)buf[c + 2] << 16)\n   130\t         | ((U32)buf[c + 3] << 24);\n   131\t\n   132\t    *cursor = c + 4;\n   133\t    return TRUE;\n   134\t}\n   135\t\n   136\tBool GGUFMetaReadU64LE(U8 *buf, I64 size, I64 *cursor, U64 *out)\n   137\t{\n   138\t    I64 c;\n   139\t\n   140\t    if (!cursor || !out)\n   141\t        return FALSE;\n   142\t\n   143\t    c = *cursor;\n   144\t    if (!GGUFMetaCanRead(buf, size, c, 8))\n   145\t        return FALSE;\n   146\t\n   147\t    *out = (U64)buf[c]\n   148\t         | ((U64)buf[c + 1] << 8)\n   149\t         | ((U64)buf[c + 2] << 16)\n   150\t         | ((U64)buf[c + 3] << 24)\n   151\t         | ((U64)buf[c + 4] << 32)\n   152\t         | ((U64)buf[c + 5] << 40)\n   153\t         | ((U64)buf[c + 6] << 48)\n   154\t         | ((U64)buf[c + 7] << 56);\n   155\t\n   156\t    *cursor = c + 8;\n   157\t    return TRUE;\n   158\t}\n   159\t\n   160\tBool GGUFMetaTypeSupported(U32 type)\n   161\t{\n   162\t    switch (type)\n   163\t    {\n   164\t        case GGUF_TYPE_UINT8:\n   165\t        case GGUF_TYPE_INT8:\n   166\t        case GGUF_TYPE_UINT16:\n   167\t        case GGUF_TYPE_INT16:\n   168\t        case GGUF_TYPE_UINT32:\n   169\t        case GGUF_TYPE_INT32:\n   170\t        case GGUF_TYPE_FLOAT32:\n   171\t        case GGUF_TYPE_BOOL:\n   172\t        case GGUF_TYPE_STRING:\n   173\t        case GGUF_TYPE_ARRAY:\n   174\t        case GGUF_TYPE_UINT64:\n   175\t        case GGUF_TYPE_INT64:\n   176\t        case GGUF_TYPE_FLOAT64:\n   177\t            return TRUE;\n   178\t    }\n   179\t\n   180\t    return FALSE;\n   181\t}\n   182\t\n   183\tU0 GGUFMetaZeroString(GGUFString *s)\n   184\t{\n   185\t    if (!s)\n   186\t        return;\n   187\t    s->len = 0;\n   188\t    s->data = NULL;\n   189\t}\n   190\t\n   191\tU0 GGUFMetaZeroValue(GGUFMetaValue *v)\n   192\t{\n   193\t    if (!v)\n   194\t        return;\n   195\t\n   196\t    v->type = 0;\n   197\t    v->u64 = 0;\n   198\t    v->i64 = 0;\n   199\t    v->b = FALSE;\n   200\t    GGUFMetaZeroString(&v->str);\n   201\t    v->array_elem_type = 0;\n   202\t    v->array_len = 0;\n   203\t    v->array_payload_off = 0;\n   204\t    v->array_payload_bytes = 0;\n   205\t}\n   206\t\n   207\tU0 GGUFMetaZeroKV(GGUFMetadataKV *kv)\n   208\t{\n   209\t    if (!kv)\n   210\t        return;\n   211\t    GGUFMetaZeroString(&kv->key);\n   212\t    GGUFMetaZeroValue(&kv->value);\n   213\t}\n   214\t\n   215\tU0 GGUFMetaFreeString(GGUFString *s)\n   216\t{\n   217\t    if (!s)\n   218\t        return;\n   219\t\n   220\t    if (s->data)\n   221\t        Free(s->data);\n   222\t\n   223\t    s->data = NULL;\n   224\t    s->len = 0;\n   225\t}\n   226\t\n   227\tI64 GGUFMetaReadString(U8 *buf, I64 size, I64 *cursor, GGUFString *out)\n   228\t{\n   229\t    U64 len;\n   230\t    I64 c;\n   231\t    U8 *dst;\n   232\t    I64 i;\n   233\t\n   234\t    if (!cursor || !out)\n   235\t        return GGUF_META_PARSE_ERR_NULL_PTR;\n   236\t\n   237\t    GGUFMetaZeroString(out);\n   238\t\n   239\t    if (!GGUFMetaReadU64LE(buf, size, cursor, &len))\n   240\t        return GGUF_META_PARSE_ERR_TRUNCATED;\n   241\t    if (len > GGUF_MAX_STRING_BYTES)\n   242\t        return GGUF_META_PARSE_ERR_BAD_STRING_LEN;\n   243\t\n   244\t    c = *cursor;\n   245\t    if (!GGUFMetaCanRead(buf, size, c, len))\n   246\t        return GGUF_META_PARSE_ERR_TRUNCATED;\n   247\t\n   248\t    dst = MAlloc(len + 1);\n   249\t    if (!dst)\n   250\t        return GGUF_META_PARSE_ERR_ALLOC;\n   251\t\n   252\t    for (i = 0; i < len; ++i)\n   253\t        dst[i] = buf[c + i];\n   254\t    dst[len] = 0;\n   255\t\n   256\t    *cursor = c + len;\n   257\t\n   258\t    out->len = len;\n   259\t    out->data = dst;\n   260\t    return GGUF_META_PARSE_OK;\n---\n   260\t    return GGUF_META_PARSE_OK;\n   261\t}\n   262\t\n   263\tI64 GGUFMetaSkipValueByType(U8 *buf, I64 size, I64 *cursor, U32 type)\n   264\t{\n   265\t    U8 u8v;\n   266\t    U16 u16v;\n   267\t    U32 u32v;\n   268\t    U64 u64v;\n   269\t    U32 elem_type;\n   270\t    U64 elem_count;\n   271\t    U64 i;\n   272\t    I64 err;\n   273\t\n   274\t    if (!GGUFMetaTypeSupported(type))\n   275\t        return GGUF_META_PARSE_ERR_BAD_TYPE;\n   276\t\n   277\t    switch (type)\n   278\t    {\n   279\t        case GGUF_TYPE_UINT8:\n   280\t        case GGUF_TYPE_INT8:\n   281\t        case GGUF_TYPE_BOOL:\n   282\t            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n   283\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   284\t            return GGUF_META_PARSE_OK;\n   285\t\n   286\t        case GGUF_TYPE_UINT16:\n   287\t        case GGUF_TYPE_INT16:\n   288\t            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n   289\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   290\t            return GGUF_META_PARSE_OK;\n   291\t\n   292\t        case GGUF_TYPE_UINT32:\n   293\t        case GGUF_TYPE_INT32:\n   294\t        case GGUF_TYPE_FLOAT32:\n   295\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n   296\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   297\t            return GGUF_META_PARSE_OK;\n   298\t\n   299\t        case GGUF_TYPE_UINT64:\n   300\t        case GGUF_TYPE_INT64:\n   301\t        case GGUF_TYPE_FLOAT64:\n   302\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n   303\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   304\t            return GGUF_META_PARSE_OK;\n   305\t\n   306\t        case GGUF_TYPE_STRING:\n   307\t            {\n   308\t                GGUFString tmp;\n   309\t\n   310\t                err = GGUFMetaReadString(buf, size, cursor, &tmp);\n   311\t                if (err != GGUF_META_PARSE_OK)\n   312\t                    return err;\n   313\t                GGUFMetaFreeString(&tmp);\n   314\t                return GGUF_META_PARSE_OK;\n   315\t            }\n   316\t\n   317\t        case GGUF_TYPE_ARRAY:\n   318\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n   319\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   320\t            if (elem_type == GGUF_TYPE_ARRAY)\n   321\t                return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n   322\t            if (!GGUFMetaTypeSupported(elem_type))\n   323\t                return GGUF_META_PARSE_ERR_BAD_TYPE;\n   324\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n   325\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   326\t            if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n   327\t                return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n   328\t\n   329\t            for (i = 0; i < elem_count; ++i)\n   330\t            {\n   331\t                err = GGUFMetaSkipValueByType(buf, size, cursor, elem_type);\n   332\t                if (err != GGUF_META_PARSE_OK)\n   333\t                    return err;\n   334\t            }\n   335\t\n   336\t            return GGUF_META_PARSE_OK;\n   337\t    }\n   338\t\n   339\t    return GGUF_META_PARSE_ERR_BAD_TYPE;\n   340\t}\n   341\t\n   342\tI64 GGUFMetaParseScalar(U8 *buf, I64 size, I64 *cursor, U32 type, GGUFMetaValue *out)\n   343\t{\n   344\t    U8 u8v;\n   345\t    U16 u16v;\n   346\t    U32 u32v;\n   347\t    U64 u64v;\n   348\t    I64 err;\n   349\t\n   350\t    if (!out)\n   351\t        return GGUF_META_PARSE_ERR_NULL_PTR;\n   352\t\n   353\t    if (!GGUFMetaTypeSupported(type))\n   354\t        return GGUF_META_PARSE_ERR_BAD_TYPE;\n   355\t\n   356\t    out->type = type;\n   357\t\n   358\t    switch (type)\n   359\t    {\n   360\t        case GGUF_TYPE_UINT8:\n   361\t            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n   362\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   363\t            out->u64 = u8v;\n   364\t            return GGUF_META_PARSE_OK;\n   365\t\n   366\t        case GGUF_TYPE_INT8:\n   367\t            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n   368\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   369\t            out->i64 = (I8)u8v;\n   370\t            return GGUF_META_PARSE_OK;\n   371\t\n   372\t        case GGUF_TYPE_UINT16:\n   373\t            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n   374\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   375\t            out->u64 = u16v;\n   376\t            return GGUF_META_PARSE_OK;\n   377\t\n   378\t        case GGUF_TYPE_INT16:\n   379\t            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n   380\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   381\t            out->i64 = (I16)u16v;\n   382\t            return GGUF_META_PARSE_OK;\n   383\t\n   384\t        case GGUF_TYPE_UINT32:\n   385\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n   386\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   387\t            out->u64 = u32v;\n   388\t            return GGUF_META_PARSE_OK;\n   389\t\n   390\t        case GGUF_TYPE_INT32:\n   391\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n   392\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   393\t            out->i64 = (I32)u32v;\n   394\t            return GGUF_META_PARSE_OK;\n   395\t\n   396\t        case GGUF_TYPE_UINT64:\n   397\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n   398\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   399\t            out->u64 = u64v;\n   400\t            return GGUF_META_PARSE_OK;\n   401\t\n   402\t        case GGUF_TYPE_INT64:\n   403\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n   404\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   405\t            out->i64 = (I64)u64v;\n   406\t            return GGUF_META_PARSE_OK;\n   407\t\n   408\t        case GGUF_TYPE_FLOAT32:\n   409\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n   410\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   411\t            out->u64 = u32v;\n   412\t            return GGUF_META_PARSE_OK;\n   413\t\n   414\t        case GGUF_TYPE_FLOAT64:\n   415\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n   416\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   417\t            out->u64 = u64v;\n   418\t            return GGUF_META_PARSE_OK;\n   419\t\n   420\t        case GGUF_TYPE_BOOL:\n   421\t            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n   422\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   423\t            out->b = (u8v != 0);\n   424\t            out->u64 = out->b;\n   425\t            return GGUF_META_PARSE_OK;\n   426\t\n   427\t        case GGUF_TYPE_STRING:\n   428\t            err = GGUFMetaReadString(buf, size, cursor, &out->str);\n   429\t            if (err != GGUF_META_PARSE_OK)\n   430\t                return err;\n   431\t            return GGUF_META_PARSE_OK;\n   432\t    }\n   433\t\n   434\t    return GGUF_META_PARSE_ERR_BAD_TYPE;\n   435\t}\n   436\t\n   437\tI64 GGUFMetaParseValue(U8 *buf, I64 size, I64 *cursor, GGUFMetaValue *out)\n   438\t{\n   439\t    U32 type;\n   440\t    U32 elem_type;\n   441\t    U64 elem_count;\n   442\t    I64 payload_begin;\n   443\t    I64 err;\n   444\t    U64 i;\n   445\t\n   446\t    if (!cursor || !out)\n   447\t        return GGUF_META_PARSE_ERR_NULL_PTR;\n   448\t\n   449\t    if (!GGUFMetaReadU32LE(buf, size, cursor, &type))\n   450\t        return GGUF_META_PARSE_ERR_TRUNCATED;\n   451\t    if (!GGUFMetaTypeSupported(type))\n   452\t        return GGUF_META_PARSE_ERR_BAD_TYPE;\n   453\t\n   454\t    GGUFMetaZeroValue(out);\n   455\t    out->type = type;\n   456\t\n   457\t    if (type != GGUF_TYPE_ARRAY)\n   458\t        return GGUFMetaParseScalar(buf, size, cursor, type, out);\n   459\t\n   460\t    if (!GGUFMetaReadU32LE(buf, size, cursor, &elem_type))\n   461\t        return GGUF_META_PARSE_ERR_TRUNCATED;\n   462\t    if (elem_type == GGUF_TYPE_ARRAY)\n   463\t        return GGUF_META_PARSE_ERR_NESTED_ARRAY;\n   464\t    if (!GGUFMetaTypeSupported(elem_type))\n   465\t        return GGUF_META_PARSE_ERR_BAD_TYPE;\n   466\t\n   467\t    if (!GGUFMetaReadU64LE(buf, size, cursor, &elem_count))\n   468\t        return GGUF_META_PARSE_ERR_TRUNCATED;\n   469\t    if (elem_count > GGUF_MAX_ARRAY_ELEMS)\n   470\t        return GGUF_META_PARSE_ERR_BAD_ARRAY_LEN;\n   471\t\n   472\t    payload_begin = *cursor;\n   473\t    for (i = 0; i < elem_count; ++i)\n   474\t    {\n   475\t        err = GGUFMetaSkipValueByType(buf, size, cursor, elem_type);\n   476\t        if (err != GGUF_META_PARSE_OK)\n   477\t            return err;\n   478\t    }\n   479\t\n   480\t    out->array_elem_type = elem_type;\n   481\t    out->array_len = elem_count;\n   482\t    out->array_payload_off = payload_begin;\n   483\t    out->array_payload_bytes = *cursor - payload_begin;\n   484\t    return GGUF_META_PARSE_OK;\n   485\t}\n   486\t\n   487\tU0 GGUFFreeMetadataTable(GGUFMetadataTable *table)\n   488\t{\n   489\t    U64 i;\n   490\t\n   491\t    if (!table)\n   492\t        return;\n   493\t\n   494\t    if (!table->items)\n   495\t    {\n   496\t        table->count = 0;\n   497\t        return;\n   498\t    }\n   499\t\n   500\t    for (i = 0; i < table->count; ++i)\n   501\t    {\n   502\t        GGUFMetaFreeString(&table->items[i].key);\n   503\t        if (table->items[i].value.type == GGUF_TYPE_STRING)\n   504\t            GGUFMetaFreeString(&table->items[i].value.str);\n   505\t    }\n   506\t\n   507\t    Free(table->items);\n   508\t    table->items = NULL;\n   509\t    table->count = 0;\n   510\t}\n   511\t\n   512\tI64 GGUFParseMetadata(U8 *buf,\n   513\t                      I64 size,\n   514\t                      U64 metadata_kv_count,\n   515\t                      GGUFMetadataTable *out,\n   516\t                      I64 *cursor)\n   517\t{\n   518\t    GGUFMetadataKV *items;\n   519\t    U64 i;\n   520\t    I64 err;\n---\n   520\t    I64 err;\n   521\t\n   522\t    if (!buf || !out || !cursor)\n   523\t        return GGUF_META_PARSE_ERR_NULL_PTR;\n   524\t    if (metadata_kv_count > GGUF_MAX_METADATA_COUNT)\n   525\t        return GGUF_META_PARSE_ERR_BAD_COUNT;\n   526\t\n   527\t    out->count = 0;\n   528\t    out->items = NULL;\n   529\t\n   530\t    if (!metadata_kv_count)\n   531\t        return GGUF_META_PARSE_OK;\n   532\t\n   533\t    items = MAlloc(sizeof(GGUFMetadataKV) * metadata_kv_count);\n   534\t    if (!items)\n   535\t        return GGUF_META_PARSE_ERR_ALLOC;\n   536\t\n   537\t    for (i = 0; i < metadata_kv_count; ++i)\n   538\t        GGUFMetaZeroKV(&items[i]);\n   539\t\n   540\t    out->items = items;\n   541\t\n   542\t    for (i = 0; i < metadata_kv_count; ++i)\n   543\t    {\n   544\t        err = GGUFMetaReadString(buf, size, cursor, &items[i].key);\n   545\t        if (err != GGUF_META_PARSE_OK)\n   546\t        {\n   547\t            out->count = metadata_kv_count;\n   548\t            GGUFFreeMetadataTable(out);\n   549\t            return err;\n   550\t        }\n   551\t\n   552\t        err = GGUFMetaParseValue(buf, size, cursor, &items[i].value);\n   553\t        if (err != GGUF_META_PARSE_OK)\n   554\t        {\n   555\t            out->count = metadata_kv_count;\n   556\t            GGUFFreeMetadataTable(out);\n   557\t            return err;\n   558\t        }\n   559\t    }\n   560\t\n   561\t    out->count = metadata_kv_count;\n   562\t    return GGUF_META_PARSE_OK;\n   563\t}\n---\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Focused GGUF metadata parser parity fixtures.\n     3\t\n     4\tThis is host-side validation only. It mirrors GGUF metadata binary layout and\n     5\tchecks that expected decode/validation behavior matches HolyC parser intent.\n     6\t\"\"\"\n     7\t\n     8\tfrom __future__ import annotations\n     9\t\n    10\timport struct\n    11\t\n    12\tGGUF_TYPE_UINT8 = 0\n    13\tGGUF_TYPE_INT8 = 1\n    14\tGGUF_TYPE_UINT16 = 2\n    15\tGGUF_TYPE_INT16 = 3\n    16\tGGUF_TYPE_UINT32 = 4\n    17\tGGUF_TYPE_INT32 = 5\n    18\tGGUF_TYPE_FLOAT32 = 6\n    19\tGGUF_TYPE_BOOL = 7\n    20\tGGUF_TYPE_STRING = 8\n    21\tGGUF_TYPE_ARRAY = 9\n    22\tGGUF_TYPE_UINT64 = 10\n    23\tGGUF_TYPE_INT64 = 11\n    24\tGGUF_TYPE_FLOAT64 = 12\n    25\t\n    26\tGGUF_META_PARSE_OK = 0\n    27\tGGUF_META_PARSE_ERR_TRUNCATED = 2\n    28\tGGUF_META_PARSE_ERR_BAD_TYPE = 3\n    29\tGGUF_META_PARSE_ERR_NESTED_ARRAY = 7\n    30\t\n    31\t\n    32\tdef u8(v: int) -> bytes:\n    33\t    return struct.pack(\"<B\", v)\n    34\t\n    35\t\n    36\tdef u16(v: int) -> bytes:\n    37\t    return struct.pack(\"<H\", v)\n    38\t\n    39\t\n    40\tdef u32(v: int) -> bytes:\n    41\t    return struct.pack(\"<I\", v)\n    42\t\n    43\t\n    44\tdef u64(v: int) -> bytes:\n    45\t    return struct.pack(\"<Q\", v)\n    46\t\n    47\t\n    48\tdef i32(v: int) -> bytes:\n    49\t    return struct.pack(\"<i\", v)\n    50\t\n    51\t\n    52\tdef i64(v: int) -> bytes:\n    53\t    return struct.pack(\"<q\", v)\n    54\t\n    55\t\n    56\tdef f32(v: float) -> bytes:\n    57\t    return struct.pack(\"<f\", v)\n    58\t\n    59\t\n    60\tdef gguf_string(s: str) -> bytes:\n    61\t    raw = s.encode(\"utf-8\")\n    62\t    return u64(len(raw)) + raw\n    63\t\n    64\t\n    65\tdef meta_entry(key: str, value_type: int, payload: bytes) -> bytes:\n    66\t    return gguf_string(key) + u32(value_type) + payload\n    67\t\n    68\t\n    69\tdef scalar_payload(t: int, v):\n    70\t    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_BOOL):\n    71\t        return u8(int(v))\n    72\t    if t == GGUF_TYPE_INT8:\n    73\t        return struct.pack(\"<b\", int(v))\n    74\t    if t == GGUF_TYPE_UINT16:\n    75\t        return u16(int(v))\n    76\t    if t == GGUF_TYPE_INT16:\n    77\t        return struct.pack(\"<h\", int(v))\n    78\t    if t == GGUF_TYPE_UINT32:\n    79\t        return u32(int(v))\n    80\t    if t == GGUF_TYPE_INT32:\n    81\t        return i32(int(v))\n    82\t    if t == GGUF_TYPE_UINT64:\n    83\t        return u64(int(v))\n    84\t    if t == GGUF_TYPE_INT64:\n    85\t        return i64(int(v))\n    86\t    if t == GGUF_TYPE_FLOAT32:\n    87\t        return f32(float(v))\n    88\t    if t == GGUF_TYPE_FLOAT64:\n    89\t        return struct.pack(\"<d\", float(v))\n    90\t    if t == GGUF_TYPE_STRING:\n    91\t        return gguf_string(str(v))\n    92\t    raise ValueError(t)\n    93\t\n    94\t\n    95\tdef array_payload(elem_type: int, values: list) -> bytes:\n    96\t    payload = b\"\".join(\n    97\t        scalar_payload(elem_type, value) if elem_type != GGUF_TYPE_STRING else gguf_string(value)\n    98\t        for value in values\n    99\t    )\n   100\t    return u32(elem_type) + u64(len(values)) + payload\n   101\t\n   102\t\n   103\tdef parse_gguf_string(buf: bytes, cursor: int):\n   104\t    if cursor + 8 > len(buf):\n   105\t        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n   106\t    (n,) = struct.unpack_from(\"<Q\", buf, cursor)\n   107\t    cursor += 8\n   108\t    if cursor + n > len(buf):\n   109\t        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n   110\t    s = buf[cursor : cursor + n].decode(\"utf-8\")\n   111\t    cursor += n\n   112\t    return GGUF_META_PARSE_OK, cursor, s\n   113\t\n   114\t\n   115\tdef skip_value_by_type(buf: bytes, cursor: int, t: int):\n   116\t    if t in (GGUF_TYPE_UINT8, GGUF_TYPE_INT8, GGUF_TYPE_BOOL):\n   117\t        return (GGUF_META_PARSE_OK, cursor + 1) if cursor + 1 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n   118\t    if t in (GGUF_TYPE_UINT16, GGUF_TYPE_INT16):\n   119\t        return (GGUF_META_PARSE_OK, cursor + 2) if cursor + 2 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n   120\t    if t in (GGUF_TYPE_UINT32, GGUF_TYPE_INT32, GGUF_TYPE_FLOAT32):\n   121\t        return (GGUF_META_PARSE_OK, cursor + 4) if cursor + 4 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n   122\t    if t in (GGUF_TYPE_UINT64, GGUF_TYPE_INT64, GGUF_TYPE_FLOAT64):\n   123\t        return (GGUF_META_PARSE_OK, cursor + 8) if cursor + 8 <= len(buf) else (GGUF_META_PARSE_ERR_TRUNCATED, cursor)\n   124\t    if t == GGUF_TYPE_STRING:\n   125\t        err, cursor2, _ = parse_gguf_string(buf, cursor)\n   126\t        return err, cursor2\n   127\t    if t == GGUF_TYPE_ARRAY:\n   128\t        return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor\n   129\t    return GGUF_META_PARSE_ERR_BAD_TYPE, cursor\n   130\t\n   131\t\n   132\tdef parse_value(buf: bytes, cursor: int):\n   133\t    if cursor + 4 > len(buf):\n   134\t        return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n   135\t    (t,) = struct.unpack_from(\"<I\", buf, cursor)\n   136\t    cursor += 4\n   137\t\n   138\t    if t == GGUF_TYPE_ARRAY:\n   139\t        if cursor + 12 > len(buf):\n   140\t            return GGUF_META_PARSE_ERR_TRUNCATED, cursor, None\n   141\t        elem_type, n = struct.unpack_from(\"<IQ\", buf, cursor)\n   142\t        cursor += 12\n   143\t        if elem_type == GGUF_TYPE_ARRAY:\n   144\t            return GGUF_META_PARSE_ERR_NESTED_ARRAY, cursor, None\n   145\t        if elem_type > GGUF_TYPE_FLOAT64:\n   146\t            return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n   147\t\n   148\t        payload_start = cursor\n   149\t        for _ in range(n):\n   150\t            err, cursor = skip_value_by_type(buf, cursor, elem_type)\n   151\t            if err != GGUF_META_PARSE_OK:\n   152\t                return err, cursor, None\n   153\t\n   154\t        return GGUF_META_PARSE_OK, cursor, {\n   155\t            \"type\": t,\n   156\t            \"array_elem_type\": elem_type,\n   157\t            \"array_len\": n,\n   158\t            \"array_payload_off\": payload_start,\n   159\t            \"array_payload_bytes\": cursor - payload_start,\n   160\t        }\n   161\t\n   162\t    if t > GGUF_TYPE_FLOAT64:\n   163\t        return GGUF_META_PARSE_ERR_BAD_TYPE, cursor, None\n   164\t\n   165\t    if t == GGUF_TYPE_STRING:\n   166\t        err, cursor, value = parse_gguf_string(buf, cursor)\n   167\t        if err != GGUF_META_PARSE_OK:\n   168\t            return err, cursor, None\n   169\t        return GGUF_META_PARSE_OK, cursor, {\"type\": t, \"value\": value}\n   170\t\n   171\t    err, cursor2 = skip_value_by_type(buf, cursor, t)\n   172\t    if err != GGUF_META_PARSE_OK:\n   173\t        return err, cursor2, None\n   174\t\n   175\t    raw = buf[cursor:cursor2]\n   176\t    return GGUF_META_PARSE_OK, cursor2, {\"type\": t, \"raw\": raw}\n   177\t\n   178\t\n   179\tdef parse_metadata_table(buf: bytes, count: int):\n   180\t    items = []\n   181\t    cursor = 0\n   182\t    for _ in range(count):\n   183\t        err, cursor, key = parse_gguf_string(buf, cursor)\n   184\t        if err != GGUF_META_PARSE_OK:\n   185\t            return err, cursor, items\n   186\t\n   187\t        err, cursor, value = parse_value(buf, cursor)\n   188\t        if err != GGUF_META_PARSE_OK:\n   189\t            return err, cursor, items\n   190\t\n   191\t        items.append((key, value))\n   192\t\n   193\t    return GGUF_META_PARSE_OK, cursor, items\n   194\t\n   195\t\n   196\tdef test_mixed_scalar_and_arrays() -> None:\n   197\t    buf = b\"\".join(\n   198\t        [\n   199\t            meta_entry(\"general.architecture\", GGUF_TYPE_STRING, gguf_string(\"llama\")),\n   200\t            meta_entry(\"llama.block_count\", GGUF_TYPE_UINT32, scalar_payload(GGUF_TYPE_UINT32, 22)),\n   201\t            meta_entry(\"tokenizer.ggml.bos_token_id\", GGUF_TYPE_INT32, scalar_payload(GGUF_TYPE_INT32, 1)),\n   202\t            meta_entry(\"tokenizer.ggml.add_bos_token\", GGUF_TYPE_BOOL, scalar_payload(GGUF_TYPE_BOOL, 1)),\n   203\t            meta_entry(\n   204\t                \"tokenizer.ggml.tokens\",\n   205\t                GGUF_TYPE_ARRAY,\n   206\t                array_payload(GGUF_TYPE_STRING, [\"<unk>\", \"<s>\", \"</s>\"]),\n   207\t            ),\n   208\t            meta_entry(\n   209\t                \"llama.rope.freq_base_train\",\n   210\t                GGUF_TYPE_FLOAT32,\n   211\t                scalar_payload(GGUF_TYPE_FLOAT32, 10000.0),\n   212\t            ),\n   213\t        ]\n   214\t    )\n   215\t\n   216\t    err, cursor, items = parse_metadata_table(buf, 6)\n   217\t    assert err == GGUF_META_PARSE_OK\n   218\t    assert cursor == len(buf)\n   219\t    assert len(items) == 6\n   220\t    assert items[0][0] == \"general.architecture\"\n   221\t    assert items[0][1][\"value\"] == \"llama\"\n   222\t    assert items[4][1][\"array_elem_type\"] == GGUF_TYPE_STRING\n   223\t    assert items[4][1][\"array_len\"] == 3\n   224\t    assert items[4][1][\"array_payload_bytes\"] > 0\n   225\t\n   226\t\n   227\tdef test_nested_array_rejected() -> None:\n   228\t    bad_nested = meta_entry(\n   229\t        \"bad.nested\",\n   230\t        GGUF_TYPE_ARRAY,\n   231\t        u32(GGUF_TYPE_ARRAY) + u64(1) + b\"\\x00\",\n   232\t    )\n   233\t    err, _cursor, _items = parse_metadata_table(bad_nested, 1)\n   234\t    assert err == GGUF_META_PARSE_ERR_NESTED_ARRAY\n   235\t\n   236\t\n   237\tdef test_truncation_detected() -> None:\n   238\t    truncated = meta_entry(\"x\", GGUF_TYPE_STRING, gguf_string(\"abc\"))[:-1]\n   239\t    err, _cursor, _items = parse_metadata_table(truncated, 1)\n   240\t    assert err == GGUF_META_PARSE_ERR_TRUNCATED\n   241\t\n   242\t\n   243\tdef run() -> None:\n   244\t    test_mixed_scalar_and_arrays()\n   245\t    test_nested_array_rejected()\n   246\t    test_truncation_detected()\n   247\t    print(\"gguf_metadata_reference_checks=ok\")\n   248\t\n   249\t\n   250\tif __name__ == \"__main__\":\n   251\t    run()\n---\n   176\t- [x] IQ-004 Write LLaMA architecture reference doc at `docs/LLAMA_ARCH.md` (WS0-04)\n   177\t- [x] IQ-005 Implement fixed-point multiply/divide helpers in `src/math/fixedpoint.HC` (WS1-01)\n   178\t- [x] IQ-006 Implement integer exp approximation in `src/math/intexp.HC` (WS1-02)\n   179\t- [x] IQ-007 Implement integer sqrt approximation in `src/math/intsqrt.HC` (WS1-02)\n   180\t- [x] IQ-008 Implement integer softmax in `src/math/softmax.HC` (WS1-03)\n   181\t- [x] IQ-009 Implement RMSNorm (integer path) in `src/math/rmsnorm.HC` (WS1-04)\n   182\t- [x] IQ-010 Implement GGUF magic/version/header parser in `src/gguf/header.HC` (WS2-01)\n   183\t- [x] IQ-011 Implement GGUF metadata KV reader in `src/gguf/metadata.HC` (WS2-02)\n   184\t- [ ] IQ-012 Implement GGUF tensor info reader in `src/gguf/tensorinfo.HC` (WS2-03)\n   185\t- [ ] IQ-013 Implement Q4_0 block struct and dequantize in `src/quant/q4_0.HC` (WS3-01, WS3-02)\n   186\t- [ ] IQ-014 Implement Q4_0 dot product (naive) in `src/quant/q4_0_dot.HC` (WS3-03)\n   187\t- [ ] IQ-015 Implement Q8_0 block struct and dequantize in `src/quant/q8_0.HC` (WS3-04)\n   188\t- [ ] IQ-016 Draft `docs/GGUF_FORMAT.md` skeleton with sections for header, metadata, tensor info, and alignment rules (WS0-02)\n   189\t- [ ] IQ-017 Write host-side GGUF header/tensor dump fixture plan in `tests/README.md` for llama.cpp parity checks (WS0-05, WS2-05)\n   190\t- [ ] IQ-018 Create `tests/README.md` skeleton for llama.cpp parity fixtures (header, metadata, tensor offsets) (WS0-05, WS2-05)\n   191\t- [ ] IQ-019 Create `src/math/fixedpoint.HC` skeleton with Q16 constants, core type aliases, and TODO stubs for mul/div helpers (WS1-01)\n   192\t- [ ] IQ-020 Implement Q16 integer exponent range clamp and base constants in `src/math/intexp.HC` (WS1-02)\n   193\t- [ ] IQ-021 Add host-side Q16 exp parity harness in `tests/test_intexp_q16.py` against `math.exp` samples (WS1-05)\n   194\t- [ ] IQ-022 Implement GGUF header constants and struct layout notes in `src/gguf/header.HC` before parser logic (WS2-01)\n   195\t- [ ] IQ-023 Create `src/math/rmsnorm.HC` skeleton with Q16 constants, tensor shape assumptions, and TODO stubs for scale/variance accumulation (WS1-04)\n   196\t- [ ] IQ-024 Create `src/gguf/header.HC` skeleton with `GGUFHeader` struct and endian-safe integer read helper stubs (WS2-01)\n   197\t- [ ] IQ-025 Add host-side GGUF header parser parity fixture in `tests/test_gguf_header_parse.py` covering valid/magic/version/truncation cases (WS2-01, WS2-05)\n   198\t- [ ] IQ-026 Implement metadata key lookup helpers (`GGUFMetaFindByKey`, scalar extractors) in `src/gguf/metadata.HC` (WS2-02)\n   199\t- [ ] IQ-027 Add host-side metadata parser parity fixture for scalar/string/array/nested-array cases in `tests/test_gguf_metadata_parse.py` (WS2-02, WS2-05)\n   200\t- [ ] IQ-028 Implement GGUF tensor data base alignment helper in `src/gguf/tensor_data_base.HC` (WS2-04)\n   201\t\n   202\t## Progress Ledger\n   203\t\n   204\t| Date | Iteration | Task | Result | Notes |\n   205\t|---|---|---|---|---|\n   206\t| 2026-04-12 | bootstrap | MASTER_TASKS init | done | Initial roadmap + queue created |\n   207\t| 2026-04-12 | loop-001 | IQ-001 directory structure | done | Verified `src/`, `tests/`, `docs/`, `automation/`, `models/` exist locally |\n   208\t| 2026-04-12 | loop-002 | IQ-002 GGUF format reference doc | done | Added `docs/GGUF_FORMAT.md` with header/metadata/tensor/alignment rules and HolyC parser safety checks |\n   209\t| 2026-04-12 | loop-003 | IQ-003 quantization reference doc | done | Added `docs/QUANTIZATION.md` with integer-only Q4_0/Q8_0 decode, fixed-point scaling, and dot-product formulas |\n   210\t| 2026-04-12 | loop-004 | IQ-004 LLaMA architecture reference doc | done | Added `docs/LLAMA_ARCH.md` covering decoder flow, RMSNorm, RoPE, GQA, SwiGLU, KV cache, and required GGUF fields |\n   211\t| 2026-04-12 | loop-005 | IQ-005 fixed-point mul/div helpers | done | Added `src/math/fixedpoint.HC` with Q16 helpers (`FPQ16Mul`, `FPQ16Div`, conversions); validated host-side with `python3` arithmetic parity checks |\n   212\t| 2026-04-12 | loop-006 | IQ-006 integer exp approximation | done | Added `src/math/intexp.HC` with Q16 range reduction + 4th-order polynomial; validated host-side over x∈[-8,8] (`max_rel_err=4.48%`) |\n   213\t| 2026-04-12 | loop-007 | IQ-007 integer sqrt approximation | done | Added `src/math/intsqrt.HC` with bitwise `IntSqrtU64` + `FPQ16Sqrt`; validated via host parity checks (`intsqrt_exact_checks=ok`, `max_rel_err=0.007690%`) |\n   214\t| 2026-04-12 | loop-008 | IQ-008 integer softmax | done | Added `src/math/softmax.HC` with stable max-shifted Q16 softmax and sum-to-one correction; validated host-side parity (`softmax_q16_checks=ok`, `max_abs_err=0.003334`) |\n   215\t| 2026-04-12 | loop-009 | IQ-009 integer RMSNorm | done | Added `src/math/rmsnorm.HC` with Q16 RMSNorm (`mean(x^2)+eps`, rsqrt via `FPQ16Sqrt`, per-channel scale); validated host-side parity (`rmsnorm_q16_checks=ok`, `max_abs_err=0.000075`) |\n   216\t| 2026-04-12 | loop-010 | IQ-010 GGUF header parser | done | Added `src/gguf/header.HC` with little-endian U32/U64 readers and `GGUFParseHeader` validation (magic/version/count/truncation); validated via focused host parity check (`gguf_header_reference_checks=ok`) |\n   217\t| 2026-04-12 | loop-011 | IQ-011 GGUF metadata KV reader | done | Added `src/gguf/metadata.HC` with full key/value parsing (scalar, string, array), strict bounds/type checks, and metadata table lifetime helpers; validated with `python3 tests/test_gguf_metadata_parse.py` (`gguf_metadata_reference_checks=ok`) |\n   218\t\n   219\t## Blockers & Decisions\n   220\t\n   221\t- HolyC float support: deferred. Use integer-only quantized inference (Q4_0, Q8_0).\n   222\t- Model architecture: LLaMA family only. Single forward pass implementation.\n   223\t- Target model: TinyLlama 1.1B Q4_0 (~600MB). Proves correctness before scaling up.\n   224\t- All .HC files are HolyC source intended for TempleOS compilation. Host-side test\n   225