n   143\t\n   144\tdef dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks):\n   145\t    err, total_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n   146\t    if err != Q4_0_OK:\n   147\t        return err, 0\n   148\t    return Q4_0_OK, dot_q32_to_q16(total_q32)\n   149\t\n   150\t\n   151\tdef unpack_signed(qs: bytes) -> list[int]:\n   152\t    out: list[int] = []\n   153\t    for packed in qs:\n   154\t        out.append((packed & 0x0F) - 8)\n   155\t        out.append(((packed >> 4) & 0x0F) - 8)\n   156\t    return out\n   157\t\n   158\t\n   159\tdef test_identity_block() -> None:\n   160\t    lhs_scale_fp16 = half_bits(1.0)\n   161\t    rhs_scale_fp16 = half_bits(1.0)\n   162\t\n   163\t    vals = list(range(16)) * 2\n   164\t    lhs_qs = bytes((vals[i] & 0x0F) | ((vals[i + 1] & 0x0F) << 4) for i in range(0, 32, 2))\n   165\t    rhs_qs = lhs_qs\n   166\t\n   167\t    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_qs, rhs_scale_fp16, rhs_qs)\n   168\t    assert err == Q4_0_OK\n   169\t\n   170\t    signed = [v - 8 for v in vals]\n   171\t    expected_dot_q0 = sum(x * x for x in signed)\n   172\t    expected_q32 = (1 << 16) * (1 << 16) * expected_dot_q0\n   173\t    assert got_q32 == expected_q32\n   174\t    assert dot_q32_to_q16(got_q32) == expected_dot_q0 * (1 << 16)\n   175\t\n   176\t\n   177\tdef test_opposite_sign_scales() -> None:\n   178\t    lhs_scale_fp16 = half_bits(0.5)\n   179\t    rhs_scale_fp16 = half_bits(-2.0)\n   180\t    lhs_qs = bytes([0x10, 0x32, 0x54, 0x76, 0x98, 0xBA, 0xDC, 0xFE] * 2)\n---\n   304\t        assert got_q16 == dot_q32_to_q16(total_q32)\n   305\t\n   306\t\n   307\tdef test_q32_to_q16_length_mismatch_error() -> None:\n   308\t    lhs_blocks = [(half_bits(1.0), bytes([0x88] * Q4_0_PACKED_BYTES))]\n   309\t    rhs_blocks = []\n   310\t    err, _ = dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks)\n   311\t    assert err == Q4_0_ERR_BAD_DST_LEN\n   312\t\n   313\t\n   314\tdef test_matrix_vector_stride_padding_ignored_randomized() -> None:\n   315\t    rng = random.Random(20260416)\n   316\t\n   317\t    for _ in range(200):\n   318\t        row_count = rng.randint(1, 8)\n   319\t        vec_block_count = rng.randint(1, 6)\n   320\t        row_stride_blocks = vec_block_count + rng.randint(0, 4)\n   321\t\n   322\t        vec_blocks = []\n   323\t        for _ in range(vec_block_count):\n   324\t            vec_scale = half_bits(rng.uniform(-2.0, 2.0))\n   325\t            vec_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n   326\t            vec_blocks.append((vec_scale, vec_qs))\n   327\t\n   328\t        matrix_blocks = []\n   329\t        expected_rows = []\n   330\t\n   331\t        for _ in range(row_count):\n   332\t            active_blocks = []\n   333\t            for _ in range(vec_block_count):\n   334\t                row_scale = half_bits(rng.uniform(-2.0, 2.0))\n   335\t                row_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n   336\t                block = (row_scale, row_qs)\n   337\t                matrix_blocks.append(block)\n   338\t                active_blocks.append(block)\n   339\t\n   340\t            pad_blocks = row_stride_blocks - vec_block_count\n   341\t            for _ in range(pad_blocks):\n   342\t                pad_scale = half_bits(rng.uniform(-2.0, 2.0))\n   343\t                pad_qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n   344\t                matrix_blocks.append((pad_scale, pad_qs))\n   345\t\n   346\t            err, expected_q16 = dot_row_blocks_q16(active_blocks, vec_blocks)\n   347\t            assert err == Q4_0_OK\n   348\t            expected_rows.append(expected_q16)\n   349\t\n   350\t        err, got_rows = dot_rows_q16_matrix_vector(\n   351\t            matrix_blocks,\n   352\t            row_count,\n   353\t            row_stride_blocks,\n   354\t            vec_blocks,\n   355\t            vec_block_count,\n   356\t        )\n   357\t      