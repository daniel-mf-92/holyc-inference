{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/zsh -lc \"echo 'Loading fixedpoint helpers and related tests.'; sed -n '1,320p' src/math/fixedpoint.HC; sed -n '320,640p' src/math/fixedpoint.HC; sed -n '1,260p' tests/test_fixedpoint_q16_muldiv_array_positive_int_checked.py; sed -n '1,260p' tests/test_fixedpoint_q16_muldiv_positive_int_checked.py; sed -n '1,260p' tests/test_fixedpoint_q16_muldiv_array_checked.py\"","aggregated_output":"Loading fixedpoint helpers and related tests.\n// fixedpoint.HC\n// Q16.16 fixed-point helpers for integer-only inference math.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define FP_Q16_HALF  (1 << (FP_Q16_SHIFT - 1))\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_DOMAIN    3\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n#define U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\n// Core Q16.16 aliases used by inference math call sites.\ntypedef I64 FPQ16;\ntypedef I64 FPStatus;\n\nU64 FPAbsToU64(I64 x)\n{\n    if (x >= 0)\n        return (U64)x;\n\n    // Avoid overflow for I64_MIN by using two's-complement identity.\n    return ((U64)(-(x + 1))) + 1;\n}\n\nI64 FPSignApplyFromU64(U64 mag, I64 is_negative)\n{\n    if (is_negative)\n    {\n        if (mag >= 0x8000000000000000)\n            return I64_MIN_VALUE;\n        return -(I64)mag;\n    }\n\n    if (mag > (U64)I64_MAX_VALUE)\n        return I64_MAX_VALUE;\n    return (I64)mag;\n}\n\nI32 FPTryApplySignFromU64Checked(U64 mag, I64 is_negative, I64 *out_value)\n{\n    U64 limit;\n\n    if (!out_value)\n        return FP_Q16_ERR_NULL_PTR;\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (mag > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    *out_value = FPSignApplyFromU64(mag, is_negative);\n    return FP_Q16_OK;\n}\n\nI64 FPQ16RoundShiftSigned(I64 value, I64 shift)\n{\n    U64 abs_value;\n    U64 round_bias;\n    U64 rounded;\n    I64 is_negative;\n\n    if (shift <= 0)\n        return value;\n    if (shift >= 63)\n        return 0;\n\n    is_negative = value < 0;\n    abs_value = FPAbsToU64(value);\n    round_bias = (U64)1 << (shift - 1);\n\n    if (abs_value > U64_MAX_VALUE - round_bias)\n        rounded = U64_MAX_VALUE >> shift;\n    else\n        rounded = (abs_value + round_bias) >> shift;\n\n    return FPSignApplyFromU64(rounded, is_negative);\n}\n\nI64 FPQ16MulSat(I64 a, I64 b)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 limit;\n    I64 is_negative;\n    I64 prod;\n\n    if (!a || !b)\n        return 0;\n\n    abs_a = FPAbsToU64(a);\n    abs_b = FPAbsToU64(b);\n    is_negative = ((a < 0) ^ (b < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (abs_a > (limit / abs_b))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    prod = a * b;\n    return FPQ16RoundShiftSigned(prod, FP_Q16_SHIFT);\n}\n\nI64 FPQ16Abs(I64 x)\n{\n    if (x == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    if (x < 0)\n        return -x;\n    return x;\n}\n\nI64 FPQ16FromInt(I64 x)\n{\n    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n        return I64_MAX_VALUE;\n    if (x < (I64_MIN_VALUE >> FP_Q16_SHIFT))\n        return I64_MIN_VALUE;\n\n    return x << FP_Q16_SHIFT;\n}\n\nI64 FPQ16ToInt(I64 x)\n{\n    if (x >= 0)\n        return (x + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-x) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Mul(I64 a, I64 b)\n{\n    return FPQ16MulSat(a, b);\n}\n\n// Checked Q16 multiply:\n//   out_q16 = round_half_up((a_q16 * b_q16) / 2^16)\n// Returns OVERFLOW instead of saturating and never writes on failure.\nI32 FPQ16MulChecked(I64 a_q16,\n                    I64 b_q16,\n                    I64 *out_q16)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 round_bias;\n    U64 abs_prod;\n    U64 rounded_mag;\n    U64 limit;\n    I64 is_negative;\n\n    if (!out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n\n    if (!a_q16 || !b_q16)\n    {\n        *out_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    abs_a = FPAbsToU64(a_q16);\n    abs_b = FPAbsToU64(b_q16);\n    is_negative = ((a_q16 < 0) ^ (b_q16 < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    // Detect overflow before signed multiplication.\n    if (abs_a > (U64_MAX_VALUE / abs_b))\n        return FP_Q16_ERR_OVERFLOW;\n\n    abs_prod = abs_a * abs_b;\n    round_bias = (U64)1 << (FP_Q16_SHIFT - 1);\n\n    // Rounded magnitude in Q16.\n    if (abs_prod > U64_MAX_VALUE - round_bias)\n        rounded_mag = (U64_MAX_VALUE >> FP_Q16_SHIFT);\n    else\n        rounded_mag = (abs_prod + round_bias) >> FP_Q16_SHIFT;\n\n    if (rounded_mag > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    return FPTryApplySignFromU64Checked(rounded_mag,\n                                        is_negative,\n                                        out_q16);\n}\n\nI64 FPQ16Div(I64 num, I64 den)\n{\n    U64 abs_num;\n    U64 abs_den;\n    U64 limit;\n    U64 int_part;\n    U64 rem;\n    U64 result_mag;\n    I64 is_negative;\n    I64 bit;\n\n    if (!den)\n        return 0;\n\n    abs_num = FPAbsToU64(num);\n    abs_den = FPAbsToU64(den);\n    is_negative = ((num < 0) ^ (den < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    int_part = abs_num / abs_den;\n    if (int_part > (limit >> FP_Q16_SHIFT))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    result_mag = int_part << FP_Q16_SHIFT;\n    rem = abs_num % abs_den;\n\n    // Emit 16 fractional bits using integer long division.\n    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n    {\n        rem <<= 1;\n        if (rem >= abs_den)\n        {\n            rem -= abs_den;\n            if (result_mag <= limit - (((U64)1) << bit))\n                result_mag |= ((U64)1) << bit;\n            else\n                result_mag = limit;\n        }\n    }\n\n    // Half-up rounding by checking whether residual remainder is >= 0.5.\n    if (rem >= ((abs_den + 1) >> 1))\n    {\n        if (result_mag < limit)\n            result_mag++;\n        else\n            result_mag = limit;\n    }\n\n    return FPSignApplyFromU64(result_mag, is_negative);\n}\n\n// Checked Q16 divide:\n//   out_q16 = round_half_up((num_q16 / den_q16) * 2^16)\n// Returns DOMAIN on divide-by-zero and OVERFLOW on range violations.\n// On any error this performs no output write.\nI32 FPQ16DivChecked(I64 num_q16,\n                    I64 den_q16,\n                    I64 *out_q16)\n{\n    U64 abs_num;\n    U64 abs_den;\n    U64 limit;\n    U64 int_part;\n    U64 rem;\n    U64 result_mag;\n    I64 is_negative;\n    I64 bit;\n\n    if (!out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (!den_q16)\n        return FP_Q16_ERR_DOMAIN;\n\n    abs_num = FPAbsToU64(num_q16);\n    abs_den = FPAbsToU64(den_q16);\n    is_negative = ((num_q16 < 0) ^ (den_q16 < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    int_part = abs_num / abs_den;\n    if (int_part > (limit >> FP_Q16_SHIFT))\n        return FP_Q16_ERR_OVERFLOW;\n\n    result_mag = int_part << FP_Q16_SHIFT;\n    rem = abs_num % abs_den;\n\n    // Long division emits exactly 16 fractional bits.\n    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n    {\n        rem <<= 1;\n        if (rem >= abs_den)\n        {\n            rem -= abs_den;\n            if (result_mag > (limit - (((U64)1) << bit)))\n                return FP_Q16_ERR_OVERFLOW;\n            result_mag |= ((U64)1) << bit;\n        }\n    }\n\n    // Half-up rounding from the remaining fraction.\n    if (rem >= ((abs_den + 1) >> 1))\n    {\n        if (result_mag == limit)\n            return FP_Q16_ERR_OVERFLOW;\n        result_mag++;\n    }\n\n    return FPTryApplySignFromU64Checked(result_mag,\n                                        is_negative,\n                                        is_negative,\n                                        out_q16);\n}\n\n// Checked elementwise Q16 multiply helper for inference vector paths.\n// Contracts:\n//   - count >= 0\n//   - lhs_q16/rhs_q16/out_q16 are valid arrays for count lanes\n//   - out_q16 is unchanged if any lane fails\nI32 FPQ16MulArrayChecked(I64 *lhs_q16,\n                         I64 *rhs_q16,\n                         I64 *out_q16,\n                         I64 count)\n{\n    I64 i;\n    I64 lane_value;\n    I32 err;\n\n    if (!lhs_q16 || !rhs_q16 || !out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Preflight all lanes first so failures never partially write output.\n    for (i = 0; i < count; i++)\n    {\n        err = FPQ16MulChecked(lhs_q16[i],\n                              rhs_q16[i],\n                              &lane_value);\n        if (err)\n            return err;\n    }\n\n    for (i = 0; i < count; i++)\n    {\n        err = FPQ16MulChecked(lhs_q16[i],\n                              rhs_q16[i],\n                              &out_q16[i]);\n        if (err)\n            return err;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked elementwise Q16 divide helper with no-partial-write contract.\nI32 FPQ16DivArrayChecked(I64 *num_q16,\n                         I64 *den_q16,\n                         I64 *out_q16,\n                         I64 count)\n{\n    I64 i;\n    I64 lane_value;\n    I32 err;\n\n    if (!num_q16 || !den_q16 || !out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    for (i = 0; i < count; i++)\n    {\n        err = FPQ16DivChecked(num_q16[i],\n                              den_q16[i],\n                              &lane_value);\n        if (err)\n            return err;\n    }\n\n    for (i = 0; i < count; i++)\n    {\n        err = FPQ16DivChecked(num_q16[i],\n                              den_q16[i],\n                              &out_q16[i]);\n        if (err)\n            return err;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked one-rounding Q16 helper for:\n//   out_q16 = round_half_up((a_q16 * b_q16) / d_q16)\n//\n// Inputs/outputs are Q16.16 integers, so this computes the exact Q16 result\n// of (a*b)/d without an intermediate Q16 downshift between mul and div.\n// That avoids double-rounding drift in RMSNorm/softmax scale paths.\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 abs_d;\n    U64 abs_num;\n    U64 q;\n    U64 r;\n    U64 limit;\n    I64 is_negative;\n\n    if (!out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (!d_q16)\n        return FP_Q16_ERR_DOMAIN;\n\n    abs_a = FPAbsToU64(a_q16);\n    abs_b = FPAbsToU64(b_q16);\n    abs_d = FPAbsToU64(d_q16);\n    is_negative = ((a_q16 < 0) ^ (b_q16 < 0) ^ (d_q16 < 0));\n\n    if (abs_a && abs_b && abs_a > (U64_MAX_VALUE / abs_b))\n        return FP_Q16_ERR_OVERFLOW;\n\n    abs_num = abs_a * abs_b;\n    q = abs_num / abs_d;\n    r = abs_num % abs_d;\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (q > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Half-up rounding: bump quotient when residual >= 0.5 denominator.\n    if (r >= ((abs_d + 1) >> 1))\n    {\n        if (q == limit)\n            return FP_Q16_ERR_OVERFLOW;\n        q++;\n    }\n\n    return FPTryApplySignFromU64Checked(q,\n                                        is_negative,\n                                        out_q16);\n}\n\n// Checked elementwise one-rounding mul/div helper:\n//   out_q16[i] = round_half_up((a_q16[i] * b_q16[i]) / d_q16[i])\n//\n// Contracts:\n// - All pointers are non-null and each points to at least count I64 lanes.\n// - count >= 0.\n// - Per-lane math reuses FPQ16MulDivRoundedChecked (same overflow/domain rules).\n// - No-partial-write: a full preflight pass runs before any out writes.\nI32 FPQ16MulDivArrayRoundedChecked(I64 *a_q16,\n                                   I64 *b_q16,\n                                   I64 *d_q16,\n                                   I64 *out_q16,\n                                   I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 lane_value;\n    I32 err;\n\n    if (!a_q16 || !b_q16 || !d_q16 || !out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span math before indexed lane access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)a_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)b_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)d_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)out_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Preflight all lanes first so failures never partially write output.\n    for (i = 0; i < count; i++)\n    {\n        err = FPQ16MulDivRoundedChecked(a_q16[i],\n                                        b_q16[i],\n                                        d_q16[i],\n                                        &lane_value);\n        if (err)\n            return err;\n    }\n\n    for (i = 0; i < count; i++)\n    {\n        err = FPQ16MulDivRoundedChecked(a_q16[i],\n                                        b_q16[i],\n                                        d_q16[i],\n                                        &out_q16[i]);\n        if (err)\n            return err;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked one-rounding Q16 helper for positive integer divisors:\n//   out_q16 = round_half_up((a_q16 * b_q16) / d_int)\n// where d_int is an integer (not Q16) with d_int > 0.\n//\n// Since a_q16*b_q16 is Q32, dividing by d_int keeps Q32. Returning Q16 means\n// one final divide by 2^16. We combine both denominators into:\n//   denom = d_int * 2^16\n// and perform a single rounded integer divide to avoid double-rounding drift.\nI32 FPQ16MulDivRoundedByPositiveIntChecked(I64 a_q16,\n                                           I64 b_q16,\n                                           I64 d_int,\n                                           I64 *out_q16)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 abs_num;\n    U64 abs_den_q16;\n    U64 q;\n    U64 r;\n    U64 limit;\n    I64 is_negative;\n\n    if (!out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (d_int <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    if ((U64)d_int > (U64_MAX_VALUE >> FP_Q16_SHIFT))\n        return FP_Q16_ERR_OVERFLOW;\n\n    abs_a = FPAbsToU64(a_q16);\n    abs_b = FPAbsToU64(b_q16);\n    is_negative = ((a_q16 < 0) ^ (b_q16 < 0));\n\n    if (abs_a && abs_b && abs_a > (U64_MAX_VALUE / abs_b))\n        return FP_Q16_ERR_OVERFLOW;\n\n    abs_num = abs_a * abs_b;\n    abs_den_q16 = ((U64)d_int) << FP_Q16_SHIFT;\n\n    q = abs_num / abs_den_q16;\n    r = abs_num % abs_den_q16;\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (q > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Half-up rounding: bump quotient when residual >= 0.5 denominator.\n    if (r >= ((abs_den_q16 + 1) >> 1))\n    {\n        if (q == limit)\n            return FP_Q16_ERR_OVERFLOW;\n        q++;\n    }\n\n    return FPTryApplySignFromU64Checked(q,\n                                        is_negative,\n                                        out_q16);\n}\n\n// Checked wrapper for positive integer divisors encoded as Q16 whole values:\n//   d_q16 = d_int << 16, d_int > 0\n//\n// This enforces the encoded-denominator contract used by RMSNorm call sites:\n// - denominator must be positive\n// - denominator must be an exact Q16 whole integer (no fractional bits)\n// - then route to FPQ16MulDivRoundedByPositiveIntChecked for single-rounding\n//   (a_q16*b_q16)/(d_int*2^16) semantics.\nI32 FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(I64 a_q16,\n                                                     I64 b_q16,\n                                                     I64 d_q16,\n                                                     I64 *out_q16)\n{\n    I64 d_int;\n\n    if (!out_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (d_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    // Strict encoding contract: denominator is an integer represented in Q16.\n    if (d_q16 & (FP_Q16_ONE - 1))\n        return FP_Q16_ERR_BAD_PARAM;\n\n    d_int = d_q16 >> FP_Q16_SHIFT;\n    if (d_int <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    return FPQ16MulDivRoundedByPositiveIntChecked(a_q16,\n                                                  b_q16,\n                                                  d_int,\n                                                  out_q16);\n}\n\n// Checked elementwise one-rounding mul/div helper with positive integer\n// denominators:\n//   out_q16[i] = round_half_up((a_q16[i] * b_q16[i]) / d_int[i])\n// where every d_int[i] is required to be > 0.\n//\n// Contracts:\n// - All pointers are non-null and each points to at least count I64 lanes.\n// - count >= 0.\n// - Per-lane math reuses FPQ16MulDivRoundedByPositiveIntChecked.\n// - No-partial-write: a full preflight pass runs before any out writes.\nI32 FPQ16MulDivArrayRoundedByPositiveIntChecked(I64 *a_q16,\n                                                I64 *b_q16,\n                                                I64 *d_int,\n                                                I64 *out_q16,\n                                                I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 lane_value;\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16MulDivArrayRoundedByPositiveIntChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nI64_MAX_VALUE = (1 << 63) - 1\nU64_MAX_VALUE = (1 << 64) - 1\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_DOMAIN = 3\nFP_Q16_ERR_OVERFLOW = 4\n\n\ndef fp_abs_to_u64(x: int) -> int:\n    if x >= 0:\n        return x\n    return (-(x + 1)) + 1\n\n\ndef fp_try_apply_sign_from_u64_checked(mag: int, is_negative: bool) -> tuple[int, int]:\n    limit = I64_MAX_VALUE\n    if is_negative:\n        limit = 1 << 63\n\n    if mag > limit:\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    if is_negative:\n        if mag >= (1 << 63):\n            return FP_Q16_OK, -(1 << 63)\n        return FP_Q16_OK, -mag\n\n    return FP_Q16_OK, mag\n\n\ndef fpq16_mul_div_rounded_by_positive_int_checked(a_q16: int, b_q16: int, d_int: int) -> tuple[int, int]:\n    if d_int <= 0:\n        return FP_Q16_ERR_DOMAIN, 0\n\n    abs_a = fp_abs_to_u64(a_q16)\n    abs_b = fp_abs_to_u64(b_q16)\n    is_negative = (a_q16 < 0) ^ (b_q16 < 0)\n\n    if abs_a != 0 and abs_b != 0 and abs_a > (U64_MAX_VALUE // abs_b):\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    abs_num = abs_a * abs_b\n    abs_den_q16 = d_int << FP_Q16_SHIFT\n\n    q = abs_num // abs_den_q16\n    r = abs_num % abs_den_q16\n\n    limit = I64_MAX_VALUE\n    if is_negative:\n        limit = 1 << 63\n    if q > limit:\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    if r >= ((abs_den_q16 + 1) >> 1):\n        if q == limit:\n            return FP_Q16_ERR_OVERFLOW, 0\n        q += 1\n\n    return fp_try_apply_sign_from_u64_checked(q, is_negative)\n\n\ndef fpq16_mul_div_array_rounded_by_positive_int_checked(\n    a_q16: list[int], b_q16: list[int], d_int: list[int]\n) -> tuple[int, list[int] | None]:\n    if len(a_q16) != len(b_q16) or len(a_q16) != len(d_int):\n        return FP_Q16_ERR_BAD_PARAM, None\n\n    out: list[int] = []\n    for ai, bi, di in zip(a_q16, b_q16, d_int):\n        err, lane = fpq16_mul_div_rounded_by_positive_int_checked(ai, bi, di)\n        if err != FP_Q16_OK:\n            return err, None\n        out.append(lane)\n    return FP_Q16_OK, out\n\n\ndef simulate_holyc_array_call_no_partial_write(\n    a_q16: list[int], b_q16: list[int], d_int: list[int], out_seed: list[int]\n) -> tuple[int, list[int]]:\n    if len(a_q16) != len(b_q16) or len(a_q16) != len(d_int) or len(a_q16) != len(out_seed):\n        return FP_Q16_ERR_BAD_PARAM, out_seed.copy()\n\n    snapshot = out_seed.copy()\n\n    for ai, bi, di in zip(a_q16, b_q16, d_int):\n        err, _ = fpq16_mul_div_rounded_by_positive_int_checked(ai, bi, di)\n        if err != FP_Q16_OK:\n            return err, snapshot\n\n    out = out_seed.copy()\n    for i, (ai, bi, di) in enumerate(zip(a_q16, b_q16, d_int)):\n        err, lane = fpq16_mul_div_rounded_by_positive_int_checked(ai, bi, di)\n        assert err == FP_Q16_OK\n        out[i] = lane\n    return FP_Q16_OK, out\n\n\ndef q16_to_float(x: int) -> float:\n    return x / FP_Q16_ONE\n\n\ndef test_contract_errors_and_rounding_edges() -> None:\n    err, out = fpq16_mul_div_array_rounded_by_positive_int_checked([1], [1], [0])\n    assert err == FP_Q16_ERR_DOMAIN\n    assert out is None\n\n    err, out = fpq16_mul_div_array_rounded_by_positive_int_checked([1], [1], [-7])\n    assert err == FP_Q16_ERR_DOMAIN\n    assert out is None\n\n    one = FP_Q16_ONE\n    err, out = fpq16_mul_div_array_rounded_by_positive_int_checked([one], [one], [2])\n    assert err == FP_Q16_OK\n    assert out == [one // 2]\n\n    err, out = fpq16_mul_div_array_rounded_by_positive_int_checked([one], [one], [3])\n    assert err == FP_Q16_OK\n    assert out == [((one * one + ((3 << FP_Q16_SHIFT) // 2)) // (3 << FP_Q16_SHIFT))]\n\n    err, out = fpq16_mul_div_array_rounded_by_positive_int_checked(\n        [I64_MAX_VALUE, I64_MAX_VALUE],\n        [I64_MAX_VALUE, 1],\n        [1, 1],\n    )\n    assert err == FP_Q16_ERR_OVERFLOW\n    assert out is None\n\n\ndef test_no_partial_write_behavior() -> None:\n    one = FP_Q16_ONE\n    out_seed = [111, 222, 333]\n\n    err, out = simulate_holyc_array_call_no_partial_write(\n        [one, one, I64_MAX_VALUE],\n        [one, one, I64_MAX_VALUE],\n        [1, 2, 1],\n        out_seed,\n    )\n    assert err == FP_Q16_ERR_OVERFLOW\n    assert out == out_seed\n\n    err, out = simulate_holyc_array_call_no_partial_write(\n        [one, -one, 3 * one],\n        [one, 2 * one, 5 * one],\n        [1, 2, 3],\n        out_seed,\n    )\n    assert err == FP_Q16_OK\n    assert out != out_seed\n\n\ndef test_randomized_lane_parity() -> None:\n    rng = random.Random(20260417_189)\n\n    for _ in range(4000):\n        n = rng.randint(1, 24)\n        a = [rng.randint(-(1 << 30), 1 << 30) for _ in range(n)]\n        b = [rng.randint(-(1 << 30), 1 << 30) for _ in range(n)]\n        d = [rng.randint(1, 1 << 15) for _ in range(n)]\n\n        err, out = fpq16_mul_div_array_rounded_by_positive_int_checked(a, b, d)\n        if err != FP_Q16_OK:\n            assert err == FP_Q16_ERR_OVERFLOW\n            assert out is None\n            continue\n\n        assert out is not None\n        for ai, bi, di, got in zip(a, b, d, out):\n            want = (q16_to_float(ai) * q16_to_float(bi)) / float(di)\n            assert abs(q16_to_float(got) - want) <= (1.5 / FP_Q16_ONE)\n\n\ndef run() -> None:\n    test_contract_errors_and_rounding_edges()\n    test_no_partial_write_behavior()\n    test_randomized_lane_parity()\n    print(\"fixedpoint_q16_muldiv_array_positive_int_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16MulDivRoundedByPositiveIntChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nI64_MAX_VALUE = (1 << 63) - 1\nU64_MAX_VALUE = (1 << 64) - 1\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_DOMAIN = 3\nFP_Q16_ERR_OVERFLOW = 4\n\n\ndef fp_abs_to_u64(x: int) -> int:\n    if x >= 0:\n        return x\n    return (-(x + 1)) + 1\n\n\ndef fp_try_apply_sign_from_u64_checked(mag: int, is_negative: bool) -> tuple[int, int]:\n    limit = I64_MAX_VALUE\n    if is_negative:\n        limit = 1 << 63\n\n    if mag > limit:\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    if is_negative:\n        if mag >= (1 << 63):\n            return FP_Q16_OK, -(1 << 63)\n        return FP_Q16_OK, -mag\n\n    return FP_Q16_OK, mag\n\n\ndef fpq16_mul_div_rounded_by_positive_int_checked(a_q16: int, b_q16: int, d_int: int) -> tuple[int, int]:\n    if d_int <= 0:\n        return FP_Q16_ERR_DOMAIN, 0\n\n    if d_int > (U64_MAX_VALUE >> FP_Q16_SHIFT):\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    abs_a = fp_abs_to_u64(a_q16)\n    abs_b = fp_abs_to_u64(b_q16)\n    is_negative = (a_q16 < 0) ^ (b_q16 < 0)\n\n    if abs_a != 0 and abs_b != 0 and abs_a > (U64_MAX_VALUE // abs_b):\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    abs_num = abs_a * abs_b\n    abs_den_q16 = d_int << FP_Q16_SHIFT\n\n    q = abs_num // abs_den_q16\n    r = abs_num % abs_den_q16\n\n    limit = I64_MAX_VALUE\n    if is_negative:\n        limit = 1 << 63\n\n    if q > limit:\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    if r >= ((abs_den_q16 + 1) >> 1):\n        if q == limit:\n            return FP_Q16_ERR_OVERFLOW, 0\n        q += 1\n\n    return fp_try_apply_sign_from_u64_checked(q, is_negative)\n\n\ndef q16_to_float(x: int) -> float:\n    return x / FP_Q16_ONE\n\n\ndef test_domain_and_overflow_contracts() -> None:\n    assert fpq16_mul_div_rounded_by_positive_int_checked(1, 1, 0)[0] == FP_Q16_ERR_DOMAIN\n    assert fpq16_mul_div_rounded_by_positive_int_checked(1, 1, -7)[0] == FP_Q16_ERR_DOMAIN\n    assert fpq16_mul_div_rounded_by_positive_int_checked(I64_MAX_VALUE, I64_MAX_VALUE, 1)[0] == FP_Q16_ERR_OVERFLOW\n\n\ndef test_sign_and_half_up_rounding() -> None:\n    one = FP_Q16_ONE\n\n    err, out = fpq16_mul_div_rounded_by_positive_int_checked(one, one, 2)\n    assert err == FP_Q16_OK\n    assert out == (one // 2)\n\n    err, out = fpq16_mul_div_rounded_by_positive_int_checked(one, one, 3)\n    assert err == FP_Q16_OK\n    assert abs(q16_to_float(out) - (1.0 / 3.0)) <= (1.0 / FP_Q16_ONE)\n\n    err_p, out_p = fpq16_mul_div_rounded_by_positive_int_checked(one, one, 1)\n    err_n, out_n = fpq16_mul_div_rounded_by_positive_int_checked(-one, one, 1)\n    assert (err_p, out_p) == (FP_Q16_OK, one)\n    assert (err_n, out_n) == (FP_Q16_OK, -one)\n\n\ndef test_randomized_real_value_parity() -> None:\n    rng = random.Random(20260417_152)\n\n    for _ in range(10000):\n        a = rng.randint(-(1 << 30), 1 << 30)\n        b = rng.randint(-(1 << 30), 1 << 30)\n        d = rng.randint(1, 1 << 24)\n\n        err, got = fpq16_mul_div_rounded_by_positive_int_checked(a, b, d)\n        if err != FP_Q16_OK:\n            assert err == FP_Q16_ERR_OVERFLOW\n            continue\n\n        want = (q16_to_float(a) * q16_to_float(b)) / float(d)\n        got_f = q16_to_float(got)\n        assert abs(got_f - want) <= (1.5 / FP_Q16_ONE)\n\n\ndef run() -> None:\n    test_domain_and_overflow_contracts()\n    test_sign_and_half_up_rounding()\n    test_randomized_real_value_parity()\n    print(\"fixedpoint_q16_muldiv_positive_int_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16MulDivArrayRoundedChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nI64_MAX_VALUE = (1 << 63) - 1\nU64_MAX_VALUE = (1 << 64) - 1\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_DOMAIN = 3\nFP_Q16_ERR_OVERFLOW = 4\n\n\ndef fp_abs_to_u64(x: int) -> int:\n    if x >= 0:\n        return x\n    return (-(x + 1)) + 1\n\n\ndef fp_try_apply_sign_from_u64_checked(mag: int, is_negative: bool) -> tuple[int, int]:\n    limit = I64_MAX_VALUE\n    if is_negative:\n        limit = 1 << 63\n\n    if mag > limit:\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    if is_negative:\n        if mag >= (1 << 63):\n            return FP_Q16_OK, -(1 << 63)\n        return FP_Q16_OK, -mag\n\n    return FP_Q16_OK, mag\n\n\ndef fpq16_mul_div_rounded_checked(a_q16: int, b_q16: int, d_q16: int) -> tuple[int, int]:\n    if d_q16 == 0:\n        return FP_Q16_ERR_DOMAIN, 0\n\n    abs_a = fp_abs_to_u64(a_q16)\n    abs_b = fp_abs_to_u64(b_q16)\n    abs_d = fp_abs_to_u64(d_q16)\n    is_negative = (a_q16 < 0) ^ (b_q16 < 0) ^ (d_q16 < 0)\n\n    if abs_a != 0 and abs_b != 0 and abs_a > (U64_MAX_VALUE // abs_b):\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    abs_num = abs_a * abs_b\n    q = abs_num // abs_d\n    r = abs_num % abs_d\n\n    limit = I64_MAX_VALUE\n    if is_negative:\n        limit = 1 << 63\n\n    if q > limit:\n        return FP_Q16_ERR_OVERFLOW, 0\n\n    if r >= ((abs_d + 1) >> 1):\n        if q == limit:\n            return FP_Q16_ERR_OVERFLOW, 0\n        q += 1\n\n    return fp_try_apply_sign_from_u64_checked(q, is_negative)\n\n\ndef fpq16_mul_div_array_rounded_checked(\n    a_q16: list[int], b_q16: list[int], d_q16: list[int]\n) -> tuple[int, list[int] | None]:\n    if len(a_q16) != len(b_q16) or len(a_q16) != len(d_q16):\n        return FP_Q16_ERR_BAD_PARAM, None\n\n    out: list[int] = []\n    for ai, bi, di in zip(a_q16, b_q16, d_q16):\n        err, lane = fpq16_mul_div_rounded_checked(ai, bi, di)\n        if err != FP_Q16_OK:\n            return err, None\n        out.append(lane)\n\n    return FP_Q16_OK, out\n\n\ndef q16_to_float(x: int) -> float:\n    return x / FP_Q16_ONE\n\n\ndef test_contract_errors_and_preflight_behavior() -> None:\n    err, out = fpq16_mul_div_array_rounded_checked([1], [1], [0])\n    assert err == FP_Q16_ERR_DOMAIN\n    assert out is None\n\n    err, out = fpq16_mul_div_array_rounded_checked(\n        [1, I64_MAX_VALUE],\n        [1, I64_MAX_VALUE],\n        [1, FP_Q16_ONE],\n    )\n    assert err == FP_Q16_ERR_OVERFLOW\n    assert out is None\n\n\ndef test_randomized_lane_parity() -> None:\n    rng = random.Random(20260417_181)\n\n    for _ in range(4000):\n        n = rng.randint(1, 24)\n        a = [rng.randint(-(1 << 30), 1 << 30) for _ in range(n)]\n        b = [rng.randint(-(1 << 30), 1 << 30) for _ in range(n)]\n        d = [rng.randint(-(1 << 30), 1 << 30) or 1 for _ in range(n)]\n\n        err, out = fpq16_mul_div_array_rounded_checked(a, b, d)\n        if err != FP_Q16_OK:\n            assert err in (FP_Q16_ERR_DOMAIN, FP_Q16_ERR_OVERFLOW)\n            assert out is None\n            continue\n\n        assert out is not None\n        for ai, bi, di, got in zip(a, b, d, out):\n            want = (q16_to_float(ai) * q16_to_float(bi)) / q16_to_float(di)\n            assert abs(q16_to_float(got) - want) <= (1.5 / FP_Q16_ONE)\n\n\ndef run() -> None:\n    test_contract_errors_and_preflight_behavior()\n    test_randomized_lane_parity()\n    print(\"fixedpoint_q16_muldiv_array_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
