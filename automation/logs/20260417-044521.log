{"type":"item.completed","item":{"id":"item_10","type":"command_execution","command":"/bin/zsh -lc 'tail -n 180 src/math/softmax.HC'","aggregated_output":"                                                        &exp_sum_q16);\n    if (status)\n        return status;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n                                                        lane_count,\n                                                        exp_sum_q16);\n    if (status)\n        return status;\n\n    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\n                                             lane_count,\n                                             exp_sum_q16,\n                                             probs_q16);\n}\n\n// Checked composed helper for immutable-logit, no-alias split-phase softmax.\n// Pipeline:\n//   1) exp_lanes_q16 <- exp(preclamped_logits_q16)\n//   2) exp_sum_q16   <- checked sum(exp_lanes_q16)\n//   3) probs_q16     <- normalize(exp_lanes_q16 / exp_sum_q16)\n// Contracts:\n//   - All pointers non-null\n//   - lane_count >= 0\n//   - preclamped_logits_q16, exp_lanes_q16, probs_q16 are pairwise disjoint\n//   - No partial writes to probs_q16 on any failure path\n// Notes:\n//   - Uses no-alias split-phase helpers so arithmetic stays centralized.\n//   - Runs a normalization preflight before writing probs_q16.\nI32 FPQ16SoftmaxFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n                                             I64 *exp_lanes_q16,\n                                             I64 lane_count,\n                                             I64 *probs_q16)\n{\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !probs_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (preclamped_logits_q16 == exp_lanes_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (preclamped_logits_q16 == probs_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (exp_lanes_q16 == probs_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    status = FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(preclamped_logits_q16,\n                                                               exp_lanes_q16,\n                                                               lane_count,\n                                                               &exp_sum_q16);\n    if (status)\n        return status;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n                                                        lane_count,\n                                                        exp_sum_q16);\n    if (status)\n        return status;\n\n    return FPQ16SoftmaxNormalizePhaseNoAliasChecked(exp_lanes_q16,\n                                                    lane_count,\n                                                    exp_sum_q16,\n                                                    probs_q16);\n}\n\nU0 FPQ16Softmax(I64 *logits, I64 *probs, I64 count)\n{\n    I64 i;\n    I64 max_logit;\n    I64 shifted;\n    I64 exp_val;\n    I64 exp_sum;\n    I64 prob_sum;\n    I64 diff;\n    I64 max_idx;\n\n    if (!logits || !probs || count <= 0)\n        return;\n\n    max_logit = logits[0];\n    max_idx = 0;\n    for (i = 1; i < count; i++)\n    {\n        if (logits[i] > max_logit)\n        {\n            max_logit = logits[i];\n            max_idx = i;\n        }\n    }\n\n    exp_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        shifted = logits[i] - max_logit;\n        exp_val = FPQ16Exp(shifted);\n        probs[i] = exp_val;\n\n        if (exp_sum > 0x7FFFFFFFFFFFFFFF - exp_val)\n            exp_sum = 0x7FFFFFFFFFFFFFFF;\n        else\n            exp_sum += exp_val;\n    }\n\n    if (exp_sum <= 0)\n    {\n        exp_val = FPQ16Div(FP_Q16_ONE, FPQ16FromInt(count));\n        for (i = 0; i < count; i++)\n            probs[i] = exp_val;\n        return;\n    }\n\n    prob_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        probs[i] = FPQ16Div(probs[i], exp_sum);\n        prob_sum += probs[i];\n    }\n\n    diff = FP_Q16_ONE - prob_sum;\n    probs[max_idx] += diff;\n}\n\nI64 FPQ16EntropyFromProbs(I64 *probs, I64 count)\n{\n    I64 i;\n    I64 p_q16;\n    I64 ln_p_q16;\n    I64 plnp_q16;\n    I64 sum_plnp_q16;\n\n    // Shannon entropy in natural-log units:\n    // H(p) = -sum_i p_i * ln(p_i)\n    // Input probabilities are Q16.16 fixed-point values.\n    if (!probs || count <= 0)\n        return 0;\n\n    sum_plnp_q16 = 0;\n\n    for (i = 0; i < count; i++)\n    {\n        p_q16 = probs[i];\n\n        // p=0 contributes exactly 0 in the limit p*ln(p)->0.\n        if (p_q16 <= 0)\n            continue;\n\n        // Keep diagnostics stable if callers pass slightly out-of-range values.\n        if (p_q16 > FP_Q16_ONE)\n            p_q16 = FP_Q16_ONE;\n\n        ln_p_q16 = FPQ16Ln(p_q16);\n        if (ln_p_q16 == I64_MIN_VALUE)\n            continue;\n\n        plnp_q16 = FPQ16Mul(p_q16, ln_p_q16);\n\n        // For p in (0,1], p*ln(p) <= 0. Clamp tiny positive approximation noise.\n        if (plnp_q16 > 0)\n            plnp_q16 = 0;\n\n        if (sum_plnp_q16 < I64_MIN_VALUE - plnp_q16)\n            sum_plnp_q16 = I64_MIN_VALUE;\n        else\n            sum_plnp_q16 += plnp_q16;\n    }\n\n    if (sum_plnp_q16 == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    return -sum_plnp_q16;\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_11","type":"reasoning","text":"**Considering pointer aliasing with arrays**\n\nI’m pondering whether to disallow pointer aliasing with arrays. The output is a single I64, which could correspond to one lane pointer, potentially leading to problems if it points to the first element of an array. Writing a sum after normalization could alter values there. I think it might be safer to avoid aliasing with input buffers to maintain determinism. I’ll explore using address comparisons against range checks to avoid aliasing carefully. This might get complex, but I believe we can tackle it.\n**Ensuring no partial writes to probs**\n\nI need to ensure that there are no partial writes to the probabilities array during failures. A normalization preflight check before the main normalization can help here. The plan could include setting *out_exp_sum only after the successful exp phase. If any elements are null, or the lane count is negative, or if pointer aliasing occurs among the arrays, I should return an error. I also want to create a test script to validate the output sum and handle alias rejection properly. It might be easier to leverage existing reference functions to avoid duplication while maintaining clarity. I'll check those test files for reusable code."}}
{"type":"item.started","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' tests/test_softmax_exp_phase_from_preclamped_no_alias_checked.py; sed -n '1,300p' tests/test_softmax_from_preclamped_no_alias_checked.py; sed -n '1,220p' tests/test_softmax_normalize_phase_no_alias_checked.py\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' tests/test_softmax_exp_phase_from_preclamped_no_alias_checked.py; sed -n '1,300p' tests/test_softmax_from_preclamped_no_alias_checked.py; sed -n '1,220p' tests/test_softmax_normalize_phase_no_alias_checked.py\"","aggregated_output":"#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_OVERFLOW = 4\n\nEXP_Q16_LN2 = 45426\nEXP_Q16_MAX_INPUT = 655360\nEXP_Q16_MIN_INPUT = -655360\n\nI64_MAX_VALUE = 0x7FFFFFFFFFFFFFFF\nU64_MAX_VALUE = 0xFFFFFFFFFFFFFFFF\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    half = 1 << (shift - 1)\n    return (value + half) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef fpq16_mul(a: int, b: int) -> int:\n    return round_shift_right_signed(a * b, FP_Q16_SHIFT)\n\n\ndef fpq16_exp_from_clamped_input_checked(clamped_input_q16: int) -> tuple[int, int]:\n    if clamped_input_q16 < EXP_Q16_MIN_INPUT or clamped_input_q16 > EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM, 0\n\n    if clamped_input_q16 >= EXP_Q16_MAX_INPUT:\n        return FP_Q16_OK, I64_MAX_VALUE\n    if clamped_input_q16 <= EXP_Q16_MIN_INPUT:\n        return FP_Q16_OK, 0\n\n    k = clamped_input_q16 // EXP_Q16_LN2\n    if clamped_input_q16 < 0 and (clamped_input_q16 % EXP_Q16_LN2):\n        k -= 1\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2)\n\n    r2 = fpq16_mul(r, r)\n    r3 = fpq16_mul(r2, r)\n    r4 = fpq16_mul(r3, r)\n\n    poly = FP_Q16_ONE + r + (r2 // 2) + (r3 // 6) + (r4 // 24)\n\n    if k >= 0:\n        if k >= 30:\n            return FP_Q16_OK, I64_MAX_VALUE\n        if poly > (I64_MAX_VALUE >> k):\n            return FP_Q16_OK, I64_MAX_VALUE\n        return FP_Q16_OK, poly << k\n\n    if k <= -63:\n        return FP_Q16_OK, 0\n\n    return FP_Q16_OK, poly >> (-k)\n\n\ndef fpq16_exp_array_from_clamped_input_no_alias_checked_reference(\n    input_q16: list[int],\n    output_q16: list[int],\n    count: int,\n) -> tuple[int, list[int]]:\n    if count < 0:\n        return FP_Q16_ERR_BAD_PARAM, output_q16[:]\n\n    if input_q16 is output_q16:\n        return FP_Q16_ERR_BAD_PARAM, output_q16[:]\n\n    if count == 0:\n        return FP_Q16_OK, output_q16[:]\n\n    last_index = count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, output_q16[:]\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, output_q16[:]\n\n    # Fail fast before any writes.\n    for i in range(count):\n        if input_q16[i] < EXP_Q16_MIN_INPUT or input_q16[i] > EXP_Q16_MAX_INPUT:\n            return FP_Q16_ERR_BAD_PARAM, output_q16[:]\n\n    out = output_q16[:]\n    for i in range(count):\n        err, value = fpq16_exp_from_clamped_input_checked(input_q16[i])\n        if err != FP_Q16_OK:\n            return err, output_q16[:]\n        out[i] = value\n\n    return FP_Q16_OK, out\n\n\ndef fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n    preclamped_logits_q16: list[int],\n    exp_lanes_q16: list[int],\n    lane_count: int,\n) -> tuple[int, list[int], int]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], 0\n\n    if preclamped_logits_q16 is exp_lanes_q16:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], 0\n\n    if lane_count == 0:\n        return FP_Q16_OK, exp_lanes_q16[:], 0\n\n    last_index = lane_count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, exp_lanes_q16[:], 0\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, exp_lanes_q16[:], 0\n\n    err, out = fpq16_exp_array_from_clamped_input_no_alias_checked_reference(\n        preclamped_logits_q16,\n        exp_lanes_q16,\n        lane_count,\n    )\n    if err != FP_Q16_OK:\n        return err, exp_lanes_q16[:], 0\n\n    exp_sum_q16 = 0\n    for lane in out[:lane_count]:\n        if lane > I64_MAX_VALUE - exp_sum_q16:\n            return FP_Q16_ERR_OVERFLOW, out, 0\n        exp_sum_q16 += lane\n\n    return FP_Q16_OK, out, exp_sum_q16\n\n\ndef q16_from_float(value: float) -> int:\n    return int(round(value * FP_Q16_ONE))\n\n\ndef test_alias_rejected() -> None:\n    shared = [q16_from_float(-0.2), q16_from_float(0.0), q16_from_float(0.3)]\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        shared,\n        shared,\n        len(shared),\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_lanes == shared\n    assert exp_sum == 0\n\n\ndef test_negative_count_rejected() -> None:\n    err, _, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        [q16_from_float(0.0)],\n        [0],\n        -1,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_sum == 0\n\n\ndef test_zero_count_writes_nothing() -> None:\n    logits = [q16_from_float(-1.0), q16_from_float(1.0)]\n    out = [123, 456]\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        logits,\n        out,\n        0,\n    )\n    assert err == FP_Q16_OK\n    assert exp_lanes == out\n    assert exp_sum == 0\n\n\ndef test_domain_failure_has_no_partial_writes() -> None:\n    logits = [q16_from_float(-0.5), EXP_Q16_MAX_INPUT + 1, q16_from_float(0.1)]\n    out = [777, 888, 999]\n\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        logits,\n        out,\n        len(logits),\n    )\n\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_lanes == out\n    assert exp_sum == 0\n\n\ndef test_random_vectors_match_lane_exp_and_sum() -> None:\n    rng = random.Random(2026041702)\n\n    for _ in range(1000):\n        count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(count)]\n        out_seed = [rng.randint(0, 1024) for _ in range(count)]\n\n        err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n            logits,\n            out_seed,\n            count,\n        )\n\n        assert err == FP_Q16_OK\n\n        want = []\n        for lane in logits:\n            lane_err, lane_exp = fpq16_exp_from_clamped_input_checked(lane)\n            assert lane_err == FP_Q16_OK\n            want.append(lane_exp)\n\n        assert exp_lanes[:count] == want\n        assert exp_sum == sum(want)\n\n\ndef run() -> None:\n    test_alias_rejected()\n    test_negative_count_rejected()\n    test_zero_count_writes_nothing()\n    test_domain_failure_has_no_partial_writes()\n    test_random_vectors_match_lane_exp_and_sum()\n    print(\"softmax_exp_phase_from_preclamped_no_alias_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedNoAliasChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).resolve().parent))\n\nfrom test_softmax_exp_phase_from_preclamped_no_alias_checked import (\n    EXP_Q16_MAX_INPUT,\n    EXP_Q16_MIN_INPUT,\n    FP_Q16_ERR_BAD_PARAM,\n    FP_Q16_ERR_OVERFLOW,\n    FP_Q16_OK,\n    FP_Q16_ONE,\n    fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference,\n)\nfrom test_softmax_normalize_phase_checked import fpq16_softmax_normalize_phase_checked_reference\nfrom test_softmax_normalize_phase_no_alias_checked import (\n    fpq16_softmax_normalize_phase_no_alias_checked_reference,\n)\n\n\ndef fpq16_softmax_from_preclamped_no_alias_checked_reference(\n    preclamped_logits_q16: list[int],\n    exp_lanes_q16: list[int],\n    lane_count: int,\n    probs_q16: list[int],\n    *,\n    logits_exp_alias: bool = False,\n    logits_probs_alias: bool = False,\n    exp_probs_alias: bool = False,\n) -> tuple[int, list[int], list[int]]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], probs_q16[:]\n\n    if logits_exp_alias or logits_probs_alias or exp_probs_alias:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], probs_q16[:]\n\n    exp_err, exp_out, exp_sum_q16 = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        preclamped_logits_q16,\n        exp_lanes_q16,\n        lane_count,\n    )\n    if exp_err != FP_Q16_OK:\n        return exp_err, exp_lanes_q16[:], probs_q16[:]\n\n    if lane_count == 0:\n        return FP_Q16_OK, exp_out, probs_q16[:]\n\n    preflight_err, _ = fpq16_softmax_normalize_phase_checked_reference(\n        exp_out,\n        lane_count,\n        exp_sum_q16,\n    )\n    if preflight_err != FP_Q16_OK:\n        return preflight_err, exp_out, probs_q16[:]\n\n    norm_err, probs_out = fpq16_softmax_normalize_phase_no_alias_checked_reference(\n        exp_out,\n        lane_count,\n        exp_sum_q16,\n        probs_q16,\n        alias=False,\n    )\n    if norm_err != FP_Q16_OK:\n        return norm_err, exp_out, probs_q16[:]\n\n    return FP_Q16_OK, exp_out, probs_out\n\n\ndef test_alias_rejection_all_pairs() -> None:\n    logits = [0, 1, 2]\n    exp_seed = [11, 22, 33]\n    probs_seed = [44, 55, 66]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        logits_exp_alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        logits_probs_alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        exp_probs_alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_domain_failure_no_partial_writes() -> None:\n    logits = [0, EXP_Q16_MAX_INPUT + 1, 1]\n    exp_seed = [101, 202, 303]\n    probs_seed = [404, 505, 606]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_normalize_overflow_is_fail_fast_for_probs() -> None:\n    logits = [EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT]\n    exp_seed = [1234, 5678]\n    probs_seed = [91011, 121314]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n\n    assert err == FP_Q16_ERR_OVERFLOW\n    assert exp_out != exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_random_vectors_match_split_phase_no_alias_reference() -> None:\n    rng = random.Random(2026041716)\n\n    for _ in range(1500):\n        lane_count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(lane_count)]\n        exp_seed = [rng.randint(0, 4096) for _ in range(lane_count)]\n        probs_seed = [rng.randint(0, 4096) for _ in range(lane_count)]\n\n        err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n            logits,\n            exp_seed,\n            lane_count,\n            probs_seed,\n        )\n\n        if err == FP_Q16_ERR_OVERFLOW:\n            # Saturation-heavy vectors can overflow normalization mul/div.\n            assert probs_out == probs_seed\n            continue\n\n        assert err == FP_Q16_OK\n        assert len(exp_out) == lane_count\n        assert len(probs_out) == lane_count\n        assert all(value >= 0 for value in probs_out)\n        assert sum(probs_out) == FP_Q16_ONE\n\n\ndef run() -> None:\n    test_alias_rejection_all_pairs()\n    test_domain_failure_no_partial_writes()\n    test_normalize_overflow_is_fail_fast_for_probs()\n    test_random_vectors_match_split_phase_no_alias_reference()\n    print(\"softmax_from_preclamped_no_alias_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxNormalizePhaseNoAliasChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).resolve().parent))\n\nfrom test_softmax_normalize_phase_checked import (\n    FP_Q16_ERR_BAD_PARAM,\n    FP_Q16_ERR_OVERFLOW,\n    FP_Q16_OK,\n    FP_Q16_ONE,\n    fpq16_softmax_normalize_phase_checked_reference,\n)\n\n\ndef fpq16_softmax_normalize_phase_no_alias_checked_reference(\n    exp_lanes_q16: list[int],\n    lane_count: int,\n    exp_sum_q16: int,\n    probs_q16: list[int],\n    *,\n    alias: bool = False,\n) -> tuple[int, list[int]]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, probs_q16[:]\n    if exp_sum_q16 <= 0:\n        return FP_Q16_ERR_BAD_PARAM, probs_q16[:]\n    if alias:\n        return FP_Q16_ERR_BAD_PARAM, probs_q16[:]\n\n    err, normalized = fpq16_softmax_normalize_phase_checked_reference(\n        exp_lanes_q16,\n        lane_count,\n        exp_sum_q16,\n    )\n    if err != FP_Q16_OK:\n        return err, probs_q16[:]\n\n    out = probs_q16[:]\n    for index in range(lane_count):\n        out[index] = normalized[index]\n    return FP_Q16_OK, out\n\n\ndef test_alias_rejected() -> None:\n    shared = [7, 11, 13]\n    err, out = fpq16_softmax_normalize_phase_no_alias_checked_reference(\n        shared,\n        len(shared),\n        sum(shared),\n        shared,\n        alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert out == shared\n\n\ndef test_bad_params_preserve_output() -> None:\n    seed = [123, 456, 789]\n\n    err, out = fpq16_softmax_normalize_phase_no_alias_checked_reference(\n        [2, 3, 5],\n        -1,\n        10,\n        seed,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert out == seed\n\n    err, out = fpq16_softmax_normalize_phase_no_alias_checked_reference(\n        [2, 3, 5],\n        3,\n        0,\n        seed,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert out == seed\n\n\ndef test_equivalent_to_alias_permitted_path() -> None:\n    rng = random.Random(2026041704)\n\n    for _ in range(2000):\n        lane_count = rng.randint(1, 32)\n        exp_lanes = [rng.randint(1, 1_000_000) for _ in range(lane_count)]\n        exp_sum = sum(exp_lanes)\n        seed = [rng.randint(0, 2048) for _ in range(lane_count)]\n\n        err_no_alias, out_no_alias = fpq16_softmax_normalize_phase_no_alias_checked_reference(\n            exp_lanes,\n            lane_count,\n            exp_sum,\n            seed,\n        )\n        err_checked, out_checked = fpq16_softmax_normalize_phase_checked_reference(\n            exp_lanes,\n            lane_count,\n            exp_sum,\n        )\n\n        assert err_no_alias == FP_Q16_OK\n        assert err_checked == FP_Q16_OK\n        assert out_no_alias == out_checked\n        assert sum(out_no_alias) == FP_Q16_ONE\n\n\ndef test_overflow_passthrough_and_no_partial_write() -> 