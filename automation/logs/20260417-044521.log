{"type":"item.completed","item":{"id":"item_8","type":"command_execution","command":"/bin/zsh -lc \"sed -n '340,620p' src/math/softmax.HC; sed -n '1,260p' tests/test_softmax_from_preclamped_no_alias_checked.py; sed -n '1,260p' tests/test_softmax_from_preclamped_checked.py\"","aggregated_output":"        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)exp_lanes_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    max_exp_q16 = exp_lanes_q16[0];\n    max_exp_index = 0;\n    prob_sum_q16 = 0;\n\n    for (i = 0; i < lane_count; i++)\n    {\n        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[i],\n                                           FP_Q16_ONE,\n                                           exp_sum_q16,\n                                           &prob_q16);\n        if (status)\n            return status;\n\n        if (prob_q16 > (I64_MAX_VALUE - prob_sum_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        prob_sum_q16 += prob_q16;\n\n        if (exp_lanes_q16[i] > max_exp_q16)\n        {\n            max_exp_q16 = exp_lanes_q16[i];\n            max_exp_index = i;\n        }\n    }\n\n    diff_q16 = FP_Q16_ONE - prob_sum_q16;\n    if (!diff_q16)\n        return FP_Q16_OK;\n\n    if (diff_q16 > 0)\n    {\n        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[max_exp_index],\n                                           FP_Q16_ONE,\n                                           exp_sum_q16,\n                                           &prob_q16);\n        if (status)\n            return status;\n        if (prob_q16 > (I64_MAX_VALUE - diff_q16))\n            return FP_Q16_ERR_OVERFLOW;\n        return FP_Q16_OK;\n    }\n\n    remaining_q16 = -diff_q16;\n    for (pass = 0; pass < lane_count && remaining_q16 > 0; pass++)\n    {\n        idx = max_exp_index + pass;\n        if (idx >= lane_count)\n            idx -= lane_count;\n\n        status = FPQ16MulDivRoundedChecked(exp_lanes_q16[idx],\n                                           FP_Q16_ONE,\n                                           exp_sum_q16,\n                                           &take_q16);\n        if (status)\n            return status;\n\n        if (take_q16 > remaining_q16)\n            take_q16 = remaining_q16;\n\n        remaining_q16 -= take_q16;\n    }\n\n    if (remaining_q16)\n        return FP_Q16_ERR_OVERFLOW;\n\n    return FP_Q16_OK;\n}\n\n// Checked composed helper for alias-permitted split-phase softmax.\n// Pipeline:\n//   1) exp_lanes_q16 <- exp(preclamped_logits_q16)\n//   2) exp_sum_q16   <- checked sum(exp_lanes_q16)\n//   3) probs_q16     <- normalize(exp_lanes_q16 / exp_sum_q16)\n// Contracts:\n//   - All pointers non-null\n//   - lane_count >= 0\n//   - Alias is allowed across {preclamped_logits_q16, exp_lanes_q16, probs_q16}\n//   - No partial writes to probs_q16 on normalization failure paths\n// Notes:\n//   - Composes alias-permitted split-phase helpers so checked arithmetic,\n//     rounding, and overflow behavior stay centralized and auditable.\nI32 FPQ16SoftmaxFromPreclampedChecked(I64 *preclamped_logits_q16,\n                                      I64 *exp_lanes_q16,\n                                      I64 lane_count,\n                                      I64 *probs_q16)\n{\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !probs_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    status = FPQ16SoftmaxExpPhaseFromPreclampedChecked(preclamped_logits_q16,\n                                                        exp_lanes_q16,\n                                                        lane_count,\n                                                        &exp_sum_q16);\n    if (status)\n        return status;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n                                                        lane_count,\n                                                        exp_sum_q16);\n    if (status)\n        return status;\n\n    return FPQ16SoftmaxNormalizePhaseChecked(exp_lanes_q16,\n                                             lane_count,\n                                             exp_sum_q16,\n                                             probs_q16);\n}\n\n// Checked composed helper for immutable-logit, no-alias split-phase softmax.\n// Pipeline:\n//   1) exp_lanes_q16 <- exp(preclamped_logits_q16)\n//   2) exp_sum_q16   <- checked sum(exp_lanes_q16)\n//   3) probs_q16     <- normalize(exp_lanes_q16 / exp_sum_q16)\n// Contracts:\n//   - All pointers non-null\n//   - lane_count >= 0\n//   - preclamped_logits_q16, exp_lanes_q16, probs_q16 are pairwise disjoint\n//   - No partial writes to probs_q16 on any failure path\n// Notes:\n//   - Uses no-alias split-phase helpers so arithmetic stays centralized.\n//   - Runs a normalization preflight before writing probs_q16.\nI32 FPQ16SoftmaxFromPreclampedNoAliasChecked(I64 *preclamped_logits_q16,\n                                             I64 *exp_lanes_q16,\n                                             I64 lane_count,\n                                             I64 *probs_q16)\n{\n    I64 exp_sum_q16;\n    I32 status;\n\n    if (!preclamped_logits_q16 || !exp_lanes_q16 || !probs_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (lane_count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (preclamped_logits_q16 == exp_lanes_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (preclamped_logits_q16 == probs_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (exp_lanes_q16 == probs_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    status = FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked(preclamped_logits_q16,\n                                                               exp_lanes_q16,\n                                                               lane_count,\n                                                               &exp_sum_q16);\n    if (status)\n        return status;\n\n    if (!lane_count)\n        return FP_Q16_OK;\n\n    status = FPQ16SoftmaxNormalizePhasePreflightChecked(exp_lanes_q16,\n                                                        lane_count,\n                                                        exp_sum_q16);\n    if (status)\n        return status;\n\n    return FPQ16SoftmaxNormalizePhaseNoAliasChecked(exp_lanes_q16,\n                                                    lane_count,\n                                                    exp_sum_q16,\n                                                    probs_q16);\n}\n\nU0 FPQ16Softmax(I64 *logits, I64 *probs, I64 count)\n{\n    I64 i;\n    I64 max_logit;\n    I64 shifted;\n    I64 exp_val;\n    I64 exp_sum;\n    I64 prob_sum;\n    I64 diff;\n    I64 max_idx;\n\n    if (!logits || !probs || count <= 0)\n        return;\n\n    max_logit = logits[0];\n    max_idx = 0;\n    for (i = 1; i < count; i++)\n    {\n        if (logits[i] > max_logit)\n        {\n            max_logit = logits[i];\n            max_idx = i;\n        }\n    }\n\n    exp_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        shifted = logits[i] - max_logit;\n        exp_val = FPQ16Exp(shifted);\n        probs[i] = exp_val;\n\n        if (exp_sum > 0x7FFFFFFFFFFFFFFF - exp_val)\n            exp_sum = 0x7FFFFFFFFFFFFFFF;\n        else\n            exp_sum += exp_val;\n    }\n\n    if (exp_sum <= 0)\n    {\n        exp_val = FPQ16Div(FP_Q16_ONE, FPQ16FromInt(count));\n        for (i = 0; i < count; i++)\n            probs[i] = exp_val;\n        return;\n    }\n\n    prob_sum = 0;\n    for (i = 0; i < count; i++)\n    {\n        probs[i] = FPQ16Div(probs[i], exp_sum);\n        prob_sum += probs[i];\n    }\n\n    diff = FP_Q16_ONE - prob_sum;\n    probs[max_idx] += diff;\n}\n\nI64 FPQ16EntropyFromProbs(I64 *probs, I64 count)\n{\n    I64 i;\n    I64 p_q16;\n    I64 ln_p_q16;\n    I64 plnp_q16;\n    I64 sum_plnp_q16;\n\n    // Shannon entropy in natural-log units:\n    // H(p) = -sum_i p_i * ln(p_i)\n    // Input probabilities are Q16.16 fixed-point values.\n    if (!probs || count <= 0)\n        return 0;\n\n    sum_plnp_q16 = 0;\n\n    for (i = 0; i < count; i++)\n    {\n        p_q16 = probs[i];\n\n        // p=0 contributes exactly 0 in the limit p*ln(p)->0.\n        if (p_q16 <= 0)\n            continue;\n\n        // Keep diagnostics stable if callers pass slightly out-of-range values.\n        if (p_q16 > FP_Q16_ONE)\n            p_q16 = FP_Q16_ONE;\n\n        ln_p_q16 = FPQ16Ln(p_q16);\n        if (ln_p_q16 == I64_MIN_VALUE)\n            continue;\n\n        plnp_q16 = FPQ16Mul(p_q16, ln_p_q16);\n\n        // For p in (0,1], p*ln(p) <= 0. Clamp tiny positive approximation noise.\n        if (plnp_q16 > 0)\n            plnp_q16 = 0;\n\n        if (sum_plnp_q16 < I64_MIN_VALUE - plnp_q16)\n            sum_plnp_q16 = I64_MIN_VALUE;\n        else\n            sum_plnp_q16 += plnp_q16;\n    }\n\n    if (sum_plnp_q16 == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    return -sum_plnp_q16;\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedNoAliasChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).resolve().parent))\n\nfrom test_softmax_exp_phase_from_preclamped_no_alias_checked import (\n    EXP_Q16_MAX_INPUT,\n    EXP_Q16_MIN_INPUT,\n    FP_Q16_ERR_BAD_PARAM,\n    FP_Q16_ERR_OVERFLOW,\n    FP_Q16_OK,\n    FP_Q16_ONE,\n    fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference,\n)\nfrom test_softmax_normalize_phase_checked import fpq16_softmax_normalize_phase_checked_reference\nfrom test_softmax_normalize_phase_no_alias_checked import (\n    fpq16_softmax_normalize_phase_no_alias_checked_reference,\n)\n\n\ndef fpq16_softmax_from_preclamped_no_alias_checked_reference(\n    preclamped_logits_q16: list[int],\n    exp_lanes_q16: list[int],\n    lane_count: int,\n    probs_q16: list[int],\n    *,\n    logits_exp_alias: bool = False,\n    logits_probs_alias: bool = False,\n    exp_probs_alias: bool = False,\n) -> tuple[int, list[int], list[int]]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], probs_q16[:]\n\n    if logits_exp_alias or logits_probs_alias or exp_probs_alias:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], probs_q16[:]\n\n    exp_err, exp_out, exp_sum_q16 = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        preclamped_logits_q16,\n        exp_lanes_q16,\n        lane_count,\n    )\n    if exp_err != FP_Q16_OK:\n        return exp_err, exp_lanes_q16[:], probs_q16[:]\n\n    if lane_count == 0:\n        return FP_Q16_OK, exp_out, probs_q16[:]\n\n    preflight_err, _ = fpq16_softmax_normalize_phase_checked_reference(\n        exp_out,\n        lane_count,\n        exp_sum_q16,\n    )\n    if preflight_err != FP_Q16_OK:\n        return preflight_err, exp_out, probs_q16[:]\n\n    norm_err, probs_out = fpq16_softmax_normalize_phase_no_alias_checked_reference(\n        exp_out,\n        lane_count,\n        exp_sum_q16,\n        probs_q16,\n        alias=False,\n    )\n    if norm_err != FP_Q16_OK:\n        return norm_err, exp_out, probs_q16[:]\n\n    return FP_Q16_OK, exp_out, probs_out\n\n\ndef test_alias_rejection_all_pairs() -> None:\n    logits = [0, 1, 2]\n    exp_seed = [11, 22, 33]\n    probs_seed = [44, 55, 66]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        logits_exp_alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        logits_probs_alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        exp_probs_alias=True,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_domain_failure_no_partial_writes() -> None:\n    logits = [0, EXP_Q16_MAX_INPUT + 1, 1]\n    exp_seed = [101, 202, 303]\n    probs_seed = [404, 505, 606]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_normalize_overflow_is_fail_fast_for_probs() -> None:\n    logits = [EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT]\n    exp_seed = [1234, 5678]\n    probs_seed = [91011, 121314]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n\n    assert err == FP_Q16_ERR_OVERFLOW\n    assert exp_out != exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_random_vectors_match_split_phase_no_alias_reference() -> None:\n    rng = random.Random(2026041716)\n\n    for _ in range(1500):\n        lane_count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(lane_count)]\n        exp_seed = [rng.randint(0, 4096) for _ in range(lane_count)]\n        probs_seed = [rng.randint(0, 4096) for _ in range(lane_count)]\n\n        err, exp_out, probs_out = fpq16_softmax_from_preclamped_no_alias_checked_reference(\n            logits,\n            exp_seed,\n            lane_count,\n            probs_seed,\n        )\n\n        if err == FP_Q16_ERR_OVERFLOW:\n            # Saturation-heavy vectors can overflow normalization mul/div.\n            assert probs_out == probs_seed\n            continue\n\n        assert err == FP_Q16_OK\n        assert len(exp_out) == lane_count\n        assert len(probs_out) == lane_count\n        assert all(value >= 0 for value in probs_out)\n        assert sum(probs_out) == FP_Q16_ONE\n\n\ndef run() -> None:\n    test_alias_rejection_all_pairs()\n    test_domain_failure_no_partial_writes()\n    test_normalize_overflow_is_fail_fast_for_probs()\n    test_random_vectors_match_split_phase_no_alias_reference()\n    print(\"softmax_from_preclamped_no_alias_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxFromPreclampedChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.insert(0, str(Path(__file__).resolve().parent))\n\nfrom test_softmax_exp_phase_from_preclamped_checked import (\n    EXP_Q16_MAX_INPUT,\n    EXP_Q16_MIN_INPUT,\n    FP_Q16_ERR_BAD_PARAM,\n    FP_Q16_ERR_OVERFLOW,\n    FP_Q16_OK,\n    FP_Q16_ONE,\n    fpq16_softmax_exp_phase_from_preclamped_checked_reference,\n)\nfrom test_softmax_normalize_phase_checked import fpq16_softmax_normalize_phase_checked_reference\n\n\ndef fpq16_softmax_from_preclamped_checked_reference(\n    preclamped_logits_q16: list[int],\n    exp_lanes_q16: list[int],\n    lane_count: int,\n    probs_q16: list[int],\n    *,\n    logits_exp_alias: bool = False,\n    logits_probs_alias: bool = False,\n    exp_probs_alias: bool = False,\n) -> tuple[int, list[int], list[int]]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], probs_q16[:]\n\n    if lane_count == 0:\n        if logits_exp_alias:\n            return FP_Q16_OK, exp_lanes_q16[:], exp_lanes_q16[:]\n        if exp_probs_alias:\n            return FP_Q16_OK, exp_lanes_q16[:], exp_lanes_q16[:]\n        if logits_probs_alias:\n            return FP_Q16_OK, exp_lanes_q16[:], probs_q16[:]\n        return FP_Q16_OK, exp_lanes_q16[:], probs_q16[:]\n\n    read_logits = preclamped_logits_q16\n    if logits_exp_alias:\n        read_logits = exp_lanes_q16\n    elif logits_probs_alias:\n        read_logits = probs_q16\n\n    exp_err, exp_out, exp_sum_q16 = fpq16_softmax_exp_phase_from_preclamped_checked_reference(\n        read_logits,\n        lane_count,\n    )\n    if exp_err != FP_Q16_OK:\n        return exp_err, exp_lanes_q16[:], probs_q16[:]\n\n    if logits_exp_alias:\n        exp_buf = exp_out\n        exp_written = exp_buf[:]\n    elif exp_probs_alias:\n        exp_buf = exp_out\n        exp_written = exp_buf[:]\n    else:\n        exp_buf = exp_out\n        exp_written = exp_out\n\n    preflight_err, _ = fpq16_softmax_normalize_phase_checked_reference(\n        exp_buf,\n        lane_count,\n        exp_sum_q16,\n    )\n    if preflight_err != FP_Q16_OK:\n        if logits_exp_alias or exp_probs_alias:\n            return preflight_err, exp_written, exp_written\n        return preflight_err, exp_written, probs_q16[:]\n\n    norm_err, probs_out = fpq16_softmax_normalize_phase_checked_reference(\n        exp_buf,\n        lane_count,\n        exp_sum_q16,\n    )\n    if norm_err != FP_Q16_OK:\n        if logits_exp_alias or exp_probs_alias:\n            return norm_err, exp_written, exp_written\n        return norm_err, exp_written, probs_q16[:]\n\n    if logits_exp_alias:\n        return FP_Q16_OK, probs_out, probs_out\n    if exp_probs_alias:\n        return FP_Q16_OK, exp_written, probs_out\n\n    return FP_Q16_OK, exp_written, probs_out\n\n\ndef test_negative_count_is_bad_param() -> None:\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference([], [], -1, [])\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == []\n    assert probs_out == []\n\n\ndef test_empty_count_is_noop() -> None:\n    logits = [1, 2]\n    exp_seed = [3, 4]\n    probs_seed = [5, 6]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        0,\n        probs_seed,\n    )\n    assert err == FP_Q16_OK\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_all_alias_modes_are_supported() -> None:\n    logits = [0, 1, -1, 3]\n    exp_seed = [7, 8, 9, 10]\n    probs_seed = [11, 12, 13, 14]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n    assert err == FP_Q16_OK\n    assert sum(probs_out) == FP_Q16_ONE\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        logits_exp_alias=True,\n    )\n    assert err == FP_Q16_OK\n    assert exp_out == probs_out\n    assert sum(probs_out) == FP_Q16_ONE\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        exp_probs_alias=True,\n    )\n    assert err == FP_Q16_OK\n    assert sum(probs_out) == FP_Q16_ONE\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n        logits_probs_alias=True,\n    )\n    assert err == FP_Q16_OK\n    assert sum(probs_out) == FP_Q16_ONE\n\n\ndef test_domain_failure_has_no_partial_writes() -> None:\n    logits = [0, EXP_Q16_MAX_INPUT + 1, 1]\n    exp_seed = [101, 202, 303]\n    probs_seed = [404, 505, 606]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_out == exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_normalize_overflow_is_fail_fast_for_probs() -> None:\n    logits = [EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT]\n    exp_seed = [1234, 5678]\n    probs_seed = [91011, 121314]\n\n    err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n        logits,\n        exp_seed,\n        len(logits),\n        probs_seed,\n    )\n\n    assert err == FP_Q16_ERR_OVERFLOW\n    assert exp_out != exp_seed\n    assert probs_out == probs_seed\n\n\ndef test_random_vectors_match_split_phase_reference() -> None:\n    rng = random.Random(20260417177)\n\n    for _ in range(1500):\n        lane_count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(lane_count)]\n        exp_seed = [rng.randint(0, 4096) for _ in range(lane_count)]\n        probs_seed = [rng.randint(0, 4096) for _ in range(lane_count)]\n\n        err, exp_out, probs_out = fpq16_softmax_from_preclamped_checked_reference(\n            logits,\n            exp_seed,\n            lane_count,\n            probs_seed,\n        )\n\n        if err == FP_Q16_ERR_OVERFLOW:\n            assert probs_out == probs_seed\n            continue\n\n        assert err == FP_Q16_OK\n        assert len(exp_out) == lane_count\n        assert len(probs_out) == lane_count\n        assert all(value >= 0 for value in probs_out)\n        assert sum(probs_out) == FP_Q16_ONE\n\n\ndef run() -> None:\n    test_negative_count_is_bad_param()\n    test_empty_count_is_noop()\n    test_all_alias_modes_are_supported()\n    test_domain_failure_has_no_partial_writes()\n    test_normalize_overflow_is_fail_fast_for_probs()\n    test_random_vectors_match_split_phase_reference()\n    print(\"softmax_from_preclamped_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n","exit_code":0,"status":"completed"}}
