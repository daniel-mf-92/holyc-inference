{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' src/model/rope.HC; echo '---'; sed -n '320,520p' src/model/rope.HC; echo '--- test rotate head range ---'; sed -n '1,280p' tests/test_rope_q16_rotate_head_range_position.py\"","aggregated_output":"// rope.HC\n// Integer-only RoPE helpers for HolyC inference.\n//\n// RoPE frequency step math (for one rotary pair index i):\n//   theta_step(i) = base^(-(2*i)/head_dim)\n//                 = exp(-(2*i/head_dim) * ln(base))\n//\n// This file computes theta_step in Q16.16 with explicit checked arithmetic.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define ROPE_Q16_OK            0\n#define ROPE_Q16_ERR_NULL_PTR  1\n#define ROPE_Q16_ERR_BAD_PARAM 2\n#define ROPE_Q16_ERR_DOMAIN    3\n#define ROPE_Q16_ERR_OVERFLOW  4\n\n#define ROPE_I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define ROPE_I64_MIN_VALUE -0x8000000000000000\n#define ROPE_U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\n#define ROPE_Q16_PI       205887\n#define ROPE_Q16_TWO_PI   411775\n#define ROPE_Q16_HALF_PI  102944\n\n// Declared in src/math/intlog.HC and src/math/intexp.HC.\nI64 FPQ16Ln(I64 x_q16);\nI64 FPQ16Exp(I64 x_q16);\n\nU64 RoPEAbsToU64(I64 x)\n{\n    if (x >= 0)\n        return (U64)x;\n\n    // Keep I64_MIN representable using two's-complement identity.\n    return ((U64)(-(x + 1))) + 1;\n}\n\nI32 RoPEApplySignFromMagnitudeChecked(U64 mag, Bool is_negative, I64 *out_value)\n{\n    if (!out_value)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    if (is_negative)\n    {\n        if (mag > 0x8000000000000000)\n            return ROPE_Q16_ERR_OVERFLOW;\n\n        if (mag == 0x8000000000000000)\n        {\n            *out_value = ROPE_I64_MIN_VALUE;\n            return ROPE_Q16_OK;\n        }\n\n        *out_value = -(I64)mag;\n        return ROPE_Q16_OK;\n    }\n\n    if (mag > (U64)ROPE_I64_MAX_VALUE)\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    *out_value = (I64)mag;\n    return ROPE_Q16_OK;\n}\n\nI32 RoPETryAddI64Checked(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    if (rhs > 0 && lhs > ROPE_I64_MAX_VALUE - rhs)\n        return ROPE_Q16_ERR_OVERFLOW;\n    if (rhs < 0 && lhs < ROPE_I64_MIN_VALUE - rhs)\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    *out_sum = lhs + rhs;\n    return ROPE_Q16_OK;\n}\n\nI32 RoPETryNegateI64Checked(I64 value, I64 *out_neg)\n{\n    if (!out_neg)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    if (value == ROPE_I64_MIN_VALUE)\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    *out_neg = -value;\n    return ROPE_Q16_OK;\n}\n\nI32 RoPETrySubI64Checked(I64 lhs, I64 rhs, I64 *out_diff)\n{\n    I64 neg_rhs;\n    I32 status;\n\n    if (!out_diff)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    status = RoPETryNegateI64Checked(rhs,\n                                     &neg_rhs);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    return RoPETryAddI64Checked(lhs,\n                                neg_rhs,\n                                out_diff);\n}\n\nI32 RoPETryMulI64Checked(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    U64 abs_lhs;\n    U64 abs_rhs;\n    U64 abs_prod;\n    Bool is_negative;\n\n    if (!out_prod)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    abs_lhs = RoPEAbsToU64(lhs);\n    abs_rhs = RoPEAbsToU64(rhs);\n    is_negative = ((lhs < 0) ^ (rhs < 0));\n\n    if (abs_lhs && abs_rhs && abs_lhs > (ROPE_U64_MAX_VALUE / abs_rhs))\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    abs_prod = abs_lhs * abs_rhs;\n    return RoPEApplySignFromMagnitudeChecked(abs_prod,\n                                             is_negative,\n                                             out_prod);\n}\n\nI32 RoPEQ16FromIntChecked(I64 x, I64 *out_q16)\n{\n    if (!out_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    if (x > (ROPE_I64_MAX_VALUE >> FP_Q16_SHIFT) || x < (ROPE_I64_MIN_VALUE >> FP_Q16_SHIFT))\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    *out_q16 = x << FP_Q16_SHIFT;\n    return ROPE_Q16_OK;\n}\n\nI32 RoPEQ16MulChecked(I64 lhs_q16, I64 rhs_q16, I64 *out_q16)\n{\n    U64 abs_lhs;\n    U64 abs_rhs;\n    U64 abs_prod;\n    U64 round_bias;\n    U64 rounded;\n    Bool is_negative;\n\n    if (!out_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    abs_lhs = RoPEAbsToU64(lhs_q16);\n    abs_rhs = RoPEAbsToU64(rhs_q16);\n    is_negative = ((lhs_q16 < 0) ^ (rhs_q16 < 0));\n\n    if (abs_lhs && abs_rhs && abs_lhs > (ROPE_U64_MAX_VALUE / abs_rhs))\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    abs_prod = abs_lhs * abs_rhs;\n    round_bias = (U64)1 << (FP_Q16_SHIFT - 1);\n\n    if (abs_prod > ROPE_U64_MAX_VALUE - round_bias)\n        rounded = ROPE_U64_MAX_VALUE >> FP_Q16_SHIFT;\n    else\n        rounded = (abs_prod + round_bias) >> FP_Q16_SHIFT;\n\n    return RoPEApplySignFromMagnitudeChecked(rounded, is_negative, out_q16);\n}\n\nI32 RoPEQ16DivChecked(I64 num_q16, I64 den_q16, I64 *out_q16)\n{\n    U64 abs_num;\n    U64 abs_den;\n    U64 limit;\n    U64 int_part;\n    U64 rem;\n    U64 result_mag;\n    Bool is_negative;\n    I64 bit;\n\n    if (!out_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n    if (!den_q16)\n        return ROPE_Q16_ERR_DOMAIN;\n\n    abs_num = RoPEAbsToU64(num_q16);\n    abs_den = RoPEAbsToU64(den_q16);\n    is_negative = ((num_q16 < 0) ^ (den_q16 < 0));\n\n    limit = (U64)ROPE_I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    int_part = abs_num / abs_den;\n    if (int_part > (limit >> FP_Q16_SHIFT))\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    result_mag = int_part << FP_Q16_SHIFT;\n    rem = abs_num % abs_den;\n\n    // Emit 16 fractional bits by long division.\n    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n    {\n        rem <<= 1;\n        if (rem >= abs_den)\n        {\n            rem -= abs_den;\n            if (result_mag > limit - (((U64)1) << bit))\n                return ROPE_Q16_ERR_OVERFLOW;\n            result_mag |= ((U64)1) << bit;\n        }\n    }\n\n    // Half-up rounding when residual remainder is >= 0.5.\n    if (rem >= ((abs_den + 1) >> 1))\n    {\n        if (result_mag == limit)\n            return ROPE_Q16_ERR_OVERFLOW;\n        result_mag++;\n    }\n\n    return RoPEApplySignFromMagnitudeChecked(result_mag, is_negative, out_q16);\n}\n\nI32 RoPEQ16DivByPositiveIntRoundedChecked(I64 num_q16, I64 den, I64 *out_q16)\n{\n    U64 abs_num;\n    U64 den_u64;\n    U64 q;\n    U64 r;\n    U64 limit;\n    Bool is_negative;\n\n    if (!out_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n    if (den <= 0)\n        return ROPE_Q16_ERR_BAD_PARAM;\n\n    abs_num = RoPEAbsToU64(num_q16);\n    den_u64 = (U64)den;\n    is_negative = (num_q16 < 0);\n\n    q = abs_num / den_u64;\n    r = abs_num % den_u64;\n\n    limit = (U64)ROPE_I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (q > limit)\n        return ROPE_Q16_ERR_OVERFLOW;\n\n    if (r >= ((den_u64 + 1) >> 1))\n    {\n        if (q == limit)\n            return ROPE_Q16_ERR_OVERFLOW;\n        q++;\n    }\n\n    return RoPEApplySignFromMagnitudeChecked(q,\n                                             is_negative,\n                                             out_q16);\n}\n\nI32 RoPEQ16NormalizeAnglePiChecked(I64 angle_q16,\n                                   I64 *out_norm_q16)\n{\n    I64 reduced;\n    I32 status;\n\n    if (!out_norm_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    reduced = angle_q16 % ROPE_Q16_TWO_PI;\n\n    if (reduced > ROPE_Q16_PI)\n    {\n        status = RoPETrySubI64Checked(reduced,\n                                      ROPE_Q16_TWO_PI,\n                                      &reduced);\n        if (status != ROPE_Q16_OK)\n            return status;\n    }\n    else if (reduced < -ROPE_Q16_PI)\n    {\n        status = RoPETryAddI64Checked(reduced,\n                                      ROPE_Q16_TWO_PI,\n                                      &reduced);\n        if (status != ROPE_Q16_OK)\n            return status;\n    }\n\n    *out_norm_q16 = reduced;\n    return ROPE_Q16_OK;\n}\n\n// Integer-only sine approximation in Q16:\n//   sin(x) ~= x - x^3/6 + x^5/120 - x^7/5040\n// after reducing x to [-pi, pi] and reflecting into [-pi/2, pi/2].\nI32 RoPEQ16SinApproxChecked(I64 angle_q16,\n                            I64 *out_sin_q16)\n{\n    I64 x;\n    I64 x2;\n    I64 x3;\n    I64 x5;\n    I64 x7;\n    I64 t1;\n    I64 t2;\n    I64 t3;\n    I64 sum;\n    I64 tmp;\n    I32 status;\n\n---\n\n    if (!out_sin_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    status = RoPEQ16NormalizeAnglePiChecked(angle_q16,\n                                            &x);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    if (x > ROPE_Q16_HALF_PI)\n    {\n        status = RoPETrySubI64Checked(ROPE_Q16_PI,\n                                      x,\n                                      &x);\n        if (status != ROPE_Q16_OK)\n            return status;\n    }\n    else if (x < -ROPE_Q16_HALF_PI)\n    {\n        status = RoPETrySubI64Checked(-ROPE_Q16_PI,\n                                      x,\n                                      &x);\n        if (status != ROPE_Q16_OK)\n            return status;\n    }\n\n    status = RoPEQ16MulChecked(x,\n                               x,\n                               &x2);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16MulChecked(x2,\n                               x,\n                               &x3);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16MulChecked(x3,\n                               x2,\n                               &x5);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16MulChecked(x5,\n                               x2,\n                               &x7);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16DivByPositiveIntRoundedChecked(x3,\n                                                   6,\n                                                   &t1);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16DivByPositiveIntRoundedChecked(x5,\n                                                   120,\n                                                   &t2);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16DivByPositiveIntRoundedChecked(x7,\n                                                   5040,\n                                                   &t3);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPETrySubI64Checked(x,\n                                  t1,\n                                  &sum);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPETryAddI64Checked(sum,\n                                  t2,\n                                  &tmp);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPETrySubI64Checked(tmp,\n                                  t3,\n                                  out_sin_q16);\n    return status;\n}\n\nI32 RoPEQ16CosApproxChecked(I64 angle_q16,\n                            I64 *out_cos_q16)\n{\n    I64 shifted;\n    I32 status;\n\n    if (!out_cos_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    status = RoPETryAddI64Checked(angle_q16,\n                                  ROPE_Q16_HALF_PI,\n                                  &shifted);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    return RoPEQ16SinApproxChecked(shifted,\n                                   out_cos_q16);\n}\n\n// Compute RoPE per-position angle increment for one rotary pair index:\n//   step_q16 = exp(-(2*pair_index/head_dim) * ln(freq_base_q16))\n//\n// Contracts:\n//   - freq_base_q16 must be > 0.\n//   - head_dim must be positive and even.\n//   - pair_index must satisfy 0 <= pair_index < head_dim/2.\nI32 RoPEQ16AngleStepChecked(I64 freq_base_q16,\n                            I64 head_dim,\n                            I64 pair_index,\n                            I64 *out_step_q16)\n{\n    I64 pair_count;\n    I64 two_i;\n    I64 two_i_q16;\n    I64 head_dim_q16;\n    I64 ratio_q16;\n    I64 ln_base_q16;\n    I64 exponent_mag_q16;\n    I64 exponent_q16;\n    I32 status;\n\n    if (!out_step_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    if (freq_base_q16 <= 0)\n        return ROPE_Q16_ERR_DOMAIN;\n    if (head_dim <= 0 || (head_dim & 1))\n        return ROPE_Q16_ERR_BAD_PARAM;\n    if (pair_index < 0)\n        return ROPE_Q16_ERR_BAD_PARAM;\n\n    pair_count = head_dim >> 1;\n    if (pair_index >= pair_count)\n        return ROPE_Q16_ERR_BAD_PARAM;\n\n    // two_i = 2 * pair_index (checked add avoids signed-mul overflow).\n    status = RoPETryAddI64Checked(pair_index,\n                                  pair_index,\n                                  &two_i);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16FromIntChecked(two_i,\n                                   &two_i_q16);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16FromIntChecked(head_dim,\n                                   &head_dim_q16);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    status = RoPEQ16DivChecked(two_i_q16,\n                               head_dim_q16,\n                               &ratio_q16);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    ln_base_q16 = FPQ16Ln(freq_base_q16);\n    if (ln_base_q16 == ROPE_I64_MIN_VALUE)\n        return ROPE_Q16_ERR_DOMAIN;\n\n    status = RoPEQ16MulChecked(ratio_q16,\n                               ln_base_q16,\n                               &exponent_mag_q16);\n    if (status != ROPE_Q16_OK)\n        return status;\n\n    if (exponent_mag_q16 == ROPE_I64_MIN_VALUE)\n        return ROPE_Q16_ERR_OVERFLOW;\n    exponent_q16 = -exponent_mag_q16;\n\n    *out_step_q16 = FPQ16Exp(exponent_q16);\n    return ROPE_Q16_OK;\n}\n\n// Compute absolute rotary angle in radians (Q16) for one token position:\n//   angle_q16 = position * angle_step_q16\n//\n// Contracts:\n//   - angle_step_q16 must be > 0 (radians per position, Q16).\n//   - position must be >= 0.\n//   - checked Q16 multiply is used so overflow surfaces as ERR_OVERFLOW.\nI32 RoPEQ16AngleForPositionChecked(I64 angle_step_q16,\n                                   I64 position,\n                                   I64 *out_angle_q16)\n{\n    if (!out_angle_q16)\n        return ROPE_Q16_ERR_NULL_PTR;\n\n    if (angle_step_q16 <= 0)\n        return ROPE_Q16_ERR_DOMAIN;\n    if (position < 0)\n        return ROPE_Q16_ERR_BAD_PARAM;\n\n--- test rotate head range ---\n#!/usr/bin/env python3\n\"\"\"Reference checks for RoPE Q16 rotate-head-range-by-position semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.append(str(Path(__file__).resolve().parent))\n\nimport test_rope_q16_angle_step as ref\nimport test_rope_q16_rotate_head_position as head_ref\n\n\ndef rope_try_add_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    if rhs > 0 and lhs > ref.I64_MAX - rhs:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    if rhs < 0 and lhs < ref.I64_MIN - rhs:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return ref.ROPE_Q16_OK, lhs + rhs\n\n\ndef rope_try_mul_i64_checked(lhs: int, rhs: int) -> tuple[int, int]:\n    prod = lhs * rhs\n    if prod > ref.I64_MAX or prod < ref.I64_MIN:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return ref.ROPE_Q16_OK, prod\n\n\ndef rope_q16_rotate_head_range_by_position_checked(\n    head_cells_q16: list[int],\n    head_cell_capacity: int,\n    range_base_index: int,\n    head_count: int,\n    head_stride_cells: int,\n    head_dim: int,\n    pair_stride_cells: int,\n    freq_base_q16: int,\n    position: int,\n) -> tuple[int, list[int]]:\n    if head_cells_q16 is None:\n        return ref.ROPE_Q16_ERR_NULL_PTR, []\n\n    if head_cell_capacity < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n    if range_base_index < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n    if head_count < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n    if head_stride_cells <= 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n\n    if head_count == 0:\n        return ref.ROPE_Q16_OK, list(head_cells_q16)\n\n    if range_base_index >= head_cell_capacity:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n\n    work = list(head_cells_q16)\n\n    for head_index in range(head_count):\n        err, head_offset = rope_try_mul_i64_checked(head_index, head_stride_cells)\n        if err != ref.ROPE_Q16_OK:\n            return err, []\n\n        err, head_base_index = rope_try_add_i64_checked(range_base_index, head_offset)\n        if err != ref.ROPE_Q16_OK:\n            return err, []\n\n        if head_base_index < 0 or head_base_index >= head_cell_capacity:\n            return ref.ROPE_Q16_ERR_BAD_PARAM, []\n\n        err, work = head_ref.rope_q16_rotate_head_by_position_checked(\n            work,\n            head_cell_capacity,\n            head_base_index,\n            head_dim,\n            pair_stride_cells,\n            freq_base_q16,\n            position,\n        )\n        if err != ref.ROPE_Q16_OK:\n            return err, []\n\n    return ref.ROPE_Q16_OK, work\n\n\ndef make_head_buffer(capacity: int, seed: int) -> list[int]:\n    rng = random.Random(seed)\n    return [ref.q16_from_float(rng.uniform(-2.0, 2.0)) for _ in range(capacity)]\n\n\ndef test_bad_param_contracts() -> None:\n    base_q16 = ref.q16_from_float(10000.0)\n    buf = make_head_buffer(96, 1)\n\n    assert rope_q16_rotate_head_range_by_position_checked(buf, -1, 0, 2, 32, 16, 2, base_q16, 1)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_rotate_head_range_by_position_checked(buf, 96, -1, 2, 32, 16, 2, base_q16, 1)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_rotate_head_range_by_position_checked(buf, 96, 0, -1, 32, 16, 2, base_q16, 1)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n    assert rope_q16_rotate_head_range_by_position_checked(buf, 96, 0, 2, 0, 16, 2, base_q16, 1)[0] == ref.ROPE_Q16_ERR_BAD_PARAM\n\n\ndef test_zero_head_count_is_noop() -> None:\n    base_q16 = ref.q16_from_float(10000.0)\n    buf = make_head_buffer(64, 2)\n\n    err, got = rope_q16_rotate_head_range_by_position_checked(\n        buf,\n        64,\n        10,\n        0,\n        32,\n        16,\n        2,\n        base_q16,\n        9,\n    )\n    assert err == ref.ROPE_Q16_OK\n    assert got == buf\n\n\ndef test_range_capacity_bounds_guard() -> None:\n    base_q16 = ref.q16_from_float(10000.0)\n    buf = make_head_buffer(80, 3)\n\n    err, _ = rope_q16_rotate_head_range_by_position_checked(\n        buf,\n        80,\n        64,\n        2,\n        16,\n        16,\n        2,\n        base_q16,\n        3,\n    )\n    assert err == ref.ROPE_Q16_ERR_BAD_PARAM\n\n\ndef test_huge_head_range_surfaces_bad_param_before_overflow() -> None:\n    base_q16 = ref.q16_from_float(10000.0)\n    buf = make_head_buffer(8, 4)\n\n    err, _ = rope_q16_rotate_head_range_by_position_checked(\n        buf,\n        8,\n        0,\n        ref.I64_MAX,\n        ref.I64_MAX,\n        8,\n        2,\n        base_q16,\n        1,\n    )\n    assert err == ref.ROPE_Q16_ERR_BAD_PARAM\n\n\ndef test_checked_index_primitives_report_overflow() -> None:\n    err, _ = rope_try_mul_i64_checked(ref.I64_MAX, 2)\n    assert err == ref.ROPE_Q16_ERR_OVERFLOW\n\n    err, _ = rope_try_add_i64_checked(ref.I64_MAX, 1)\n    assert err == ref.ROPE_Q16_ERR_OVERFLOW\n\n\ndef test_interleaved_head_range_matches_per_head_composition() -> None:\n    base_q16 = ref.q16_from_float(10000.0)\n    head_dim = 16\n    pair_stride = 2\n    head_stride = 48\n    head_count = 3\n    cap = 512\n    base = 23\n    pos = 77\n\n    inp = make_head_buffer(cap, 5)\n\n    err, got = rope_q16_rotate_head_range_by_position_checked(\n        inp,\n        cap,\n        base,\n        head_count,\n        head_stride,\n        head_dim,\n        pair_stride,\n        base_q16,\n        pos,\n    )\n    assert err == ref.ROPE_Q16_OK\n\n    want = list(inp)\n    for head_index in range(head_count):\n        head_base = base + (head_index * head_stride)\n        err_head, want = head_ref.rope_q16_rotate_head_by_position_checked(\n            want,\n            cap,\n            head_base,\n            head_dim,\n            pair_stride,\n            base_q16,\n            pos,\n        )\n        assert err_head == ref.ROPE_Q16_OK\n\n    assert got == want\n\n\ndef test_randomized_contract_and_composition_parity() -> None:\n    rng = random.Random(20260416138)\n    dims = [8, 16, 24, 32]\n    freq_bases = [5000.0, 10000.0, 50000.0]\n\n    for _ in range(1000):\n        head_dim = rng.choice(dims)\n        pair_stride = rng.randint(2, 6)\n        head_span = (head_dim // 2) * pair_stride + 1\n\n        head_stride = rng.randint(head_span, head_span + 12)\n        head_count = rng.randint(0, 4)\n\n        if head_count == 0:\n            cap = rng.randint(head_span, head_span + 64)\n            base = rng.randint(0, cap - 1)\n        else:\n            needed = ((head_count - 1) * head_stride) + head_span\n            cap = rng.randint(needed, needed + 96)\n            base = rng.randint(0, cap - needed)\n\n        pos = rng.randint(0, 4096)\n        freq_base_q16 = ref.q16_from_float(rng.choice(freq_bases))\n        inp = make_head_buffer(cap, rng.randint(0, 10_000_000))\n\n        err_got, got = rope_q16_rotate_head_range_by_position_checked(\n            inp,\n            cap,\n            base,\n            head_count,\n            head_stride,\n            head_dim,\n            pair_stride,\n            freq_base_q16,\n            pos,\n        )\n\n        want = list(inp)\n        err_want = ref.ROPE_Q16_OK\n        if head_count > 0:\n            for head_index in range(head_count):\n                head_base = base + (head_index * head_stride)\n                err_head, want = head_ref.rope_q16_rotate_head_by_position_checked(\n                    want,\n                    cap,\n                    head_base,\n                    head_dim,\n                    pair_stride,\n                    freq_base_q16,\n                    pos,\n                )\n                if err_head != ref.ROPE_Q16_OK:\n                    err_want = err_head\n                    want = []\n                    break\n\n        assert err_got == err_want\n        if err_got == ref.ROPE_Q16_OK:\n            assert got == want\n\n\ndef run() -> None:\n    test_bad_param_contracts()\n    test_zero_head_count_is_noop()\n    test_range_capacity_bounds_guard()\n    test_huge_head_range_surfaces_bad_param_before_overflow()\n    test_checked_index_primitives_report_overflow()\n    test_interleaved_head_range_matches_per_head_composition()\n    test_randomized_contract_and_composition_parity()\n    print(\"rope_q16_rotate_head_range_position_reference_checks=ok\")\n\n\n","exit_code":0,"status":"completed"}}
