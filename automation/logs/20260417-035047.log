{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' tests/test_softmax_exp_phase_from_preclamped_checked.py; sed -n '1,280p' tests/test_softmax_exp_phase_from_preclamped_no_alias_checked.py; ls tests | rg softmax\"","aggregated_output":"#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxExpPhaseFromPreclampedChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport math\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_OVERFLOW = 4\n\nEXP_Q16_LN2 = 45426\nEXP_Q16_MAX_INPUT = 655360\nEXP_Q16_MIN_INPUT = -655360\n\nI64_MAX_VALUE = 0x7FFFFFFFFFFFFFFF\nU64_MAX_VALUE = 0xFFFFFFFFFFFFFFFF\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    half = 1 << (shift - 1)\n    return (value + half) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef fpq16_mul(a: int, b: int) -> int:\n    return round_shift_right_signed(a * b, FP_Q16_SHIFT)\n\n\ndef fpq16_exp_from_clamped_input_checked(clamped_input_q16: int) -> tuple[int, int]:\n    if clamped_input_q16 < EXP_Q16_MIN_INPUT or clamped_input_q16 > EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM, 0\n\n    if clamped_input_q16 >= EXP_Q16_MAX_INPUT:\n        return FP_Q16_OK, I64_MAX_VALUE\n    if clamped_input_q16 <= EXP_Q16_MIN_INPUT:\n        return FP_Q16_OK, 0\n\n    k = clamped_input_q16 // EXP_Q16_LN2\n    if clamped_input_q16 < 0 and (clamped_input_q16 % EXP_Q16_LN2):\n        k -= 1\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2)\n\n    r2 = fpq16_mul(r, r)\n    r3 = fpq16_mul(r2, r)\n    r4 = fpq16_mul(r3, r)\n\n    poly = FP_Q16_ONE + r + (r2 // 2) + (r3 // 6) + (r4 // 24)\n\n    if k >= 0:\n        if k >= 30:\n            return FP_Q16_OK, I64_MAX_VALUE\n        if poly > (I64_MAX_VALUE >> k):\n            return FP_Q16_OK, I64_MAX_VALUE\n        return FP_Q16_OK, poly << k\n\n    if k <= -63:\n        return FP_Q16_OK, 0\n\n    return FP_Q16_OK, poly >> (-k)\n\n\ndef fpq16_exp_array_from_clamped_input_checked_reference(input_q16: list[int], count: int) -> tuple[int, list[int]]:\n    if count < 0:\n        return FP_Q16_ERR_BAD_PARAM, []\n    if count == 0:\n        return FP_Q16_OK, []\n\n    last_index = count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, []\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, []\n\n    for i in range(count):\n        if input_q16[i] < EXP_Q16_MIN_INPUT or input_q16[i] > EXP_Q16_MAX_INPUT:\n            return FP_Q16_ERR_BAD_PARAM, []\n\n    output_q16: list[int] = []\n    for i in range(count):\n        err, value = fpq16_exp_from_clamped_input_checked(input_q16[i])\n        if err != FP_Q16_OK:\n            return err, []\n        output_q16.append(value)\n\n    return FP_Q16_OK, output_q16\n\n\ndef fpq16_softmax_exp_phase_from_preclamped_checked_reference(\n    preclamped_logits_q16: list[int],\n    lane_count: int,\n) -> tuple[int, list[int], int]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, [], 0\n    if lane_count == 0:\n        return FP_Q16_OK, [], 0\n\n    last_index = lane_count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, [], 0\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, [], 0\n\n    err, exp_lanes_q16 = fpq16_exp_array_from_clamped_input_checked_reference(\n        preclamped_logits_q16,\n        lane_count,\n    )\n    if err != FP_Q16_OK:\n        return err, [], 0\n\n    exp_sum_q16 = 0\n    for lane in exp_lanes_q16:\n        if lane > I64_MAX_VALUE - exp_sum_q16:\n            return FP_Q16_ERR_OVERFLOW, exp_lanes_q16, 0\n        exp_sum_q16 += lane\n\n    return FP_Q16_OK, exp_lanes_q16, exp_sum_q16\n\n\ndef q16_from_float(value: float) -> int:\n    return int(round(value * FP_Q16_ONE))\n\n\ndef q16_to_float(value: int) -> float:\n    return value / FP_Q16_ONE\n\n\ndef test_empty_vector_returns_zero_sum() -> None:\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference([], 0)\n    assert err == FP_Q16_OK\n    assert exp_lanes == []\n    assert exp_sum == 0\n\n\ndef test_negative_count_is_bad_param() -> None:\n    err, _, _ = fpq16_softmax_exp_phase_from_preclamped_checked_reference([], -1)\n    assert err == FP_Q16_ERR_BAD_PARAM\n\n\ndef test_domain_violation_preserves_no_partial_writes() -> None:\n    logits = [q16_from_float(-0.25), EXP_Q16_MAX_INPUT + 1, q16_from_float(0.10)]\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference(logits, len(logits))\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_lanes == []\n    assert exp_sum == 0\n\n\ndef test_known_vector_matches_float_exp_sum() -> None:\n    logits = [q16_from_float(-1.5), q16_from_float(0.0), q16_from_float(0.75)]\n\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference(logits, len(logits))\n    assert err == FP_Q16_OK\n\n    want_exp_lanes: list[int] = []\n    for lane in logits:\n        lane_err, lane_exp = fpq16_exp_from_clamped_input_checked(lane)\n        assert lane_err == FP_Q16_OK\n        want_exp_lanes.append(lane_exp)\n\n    assert exp_lanes == want_exp_lanes\n    assert exp_sum == sum(want_exp_lanes)\n\n    got_sum = q16_to_float(exp_sum)\n    want_sum = sum(math.exp(q16_to_float(x)) for x in logits)\n    assert abs(got_sum - want_sum) <= 0.08\n\n    assert len(exp_lanes) == len(logits)\n    for lane_in, lane_out in zip(logits, exp_lanes):\n        want_lane = math.exp(q16_to_float(lane_in))\n        got_lane = q16_to_float(lane_out)\n        assert abs(got_lane - want_lane) <= 0.08\n\n\ndef test_random_preclamped_vectors_track_float_reference() -> None:\n    rng = random.Random(20260417)\n\n    for _ in range(1200):\n        count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(count)]\n\n        err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_checked_reference(logits, count)\n        assert err == FP_Q16_OK\n\n        want_exp_lanes: list[int] = []\n        for lane in logits:\n            lane_err, lane_exp = fpq16_exp_from_clamped_input_checked(lane)\n            assert lane_err == FP_Q16_OK\n            want_exp_lanes.append(lane_exp)\n\n        assert exp_lanes == want_exp_lanes\n        assert exp_sum == sum(want_exp_lanes)\n\n        got_sum = q16_to_float(exp_sum)\n        want_sum = sum(math.exp(q16_to_float(x)) for x in logits)\n        assert abs(got_sum - want_sum) <= 2500.0\n\n        for lane_in, lane_out in zip(logits, exp_lanes):\n            want_lane = math.exp(q16_to_float(lane_in))\n            got_lane = q16_to_float(lane_out)\n            assert abs(got_lane - want_lane) <= 100.0\n\n\ndef run() -> None:\n    test_empty_vector_returns_zero_sum()\n    test_negative_count_is_bad_param()\n    test_domain_violation_preserves_no_partial_writes()\n    test_known_vector_matches_float_exp_sum()\n    test_random_preclamped_vectors_track_float_reference()\n    print(\"softmax_exp_phase_from_preclamped_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n#!/usr/bin/env python3\n\"\"\"Reference checks for FPQ16SoftmaxExpPhaseFromPreclampedNoAliasChecked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\n\nFP_Q16_SHIFT = 16\nFP_Q16_ONE = 1 << FP_Q16_SHIFT\n\nFP_Q16_OK = 0\nFP_Q16_ERR_NULL_PTR = 1\nFP_Q16_ERR_BAD_PARAM = 2\nFP_Q16_ERR_OVERFLOW = 4\n\nEXP_Q16_LN2 = 45426\nEXP_Q16_MAX_INPUT = 655360\nEXP_Q16_MIN_INPUT = -655360\n\nI64_MAX_VALUE = 0x7FFFFFFFFFFFFFFF\nU64_MAX_VALUE = 0xFFFFFFFFFFFFFFFF\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    half = 1 << (shift - 1)\n    return (value + half) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef fpq16_mul(a: int, b: int) -> int:\n    return round_shift_right_signed(a * b, FP_Q16_SHIFT)\n\n\ndef fpq16_exp_from_clamped_input_checked(clamped_input_q16: int) -> tuple[int, int]:\n    if clamped_input_q16 < EXP_Q16_MIN_INPUT or clamped_input_q16 > EXP_Q16_MAX_INPUT:\n        return FP_Q16_ERR_BAD_PARAM, 0\n\n    if clamped_input_q16 >= EXP_Q16_MAX_INPUT:\n        return FP_Q16_OK, I64_MAX_VALUE\n    if clamped_input_q16 <= EXP_Q16_MIN_INPUT:\n        return FP_Q16_OK, 0\n\n    k = clamped_input_q16 // EXP_Q16_LN2\n    if clamped_input_q16 < 0 and (clamped_input_q16 % EXP_Q16_LN2):\n        k -= 1\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2)\n\n    r2 = fpq16_mul(r, r)\n    r3 = fpq16_mul(r2, r)\n    r4 = fpq16_mul(r3, r)\n\n    poly = FP_Q16_ONE + r + (r2 // 2) + (r3 // 6) + (r4 // 24)\n\n    if k >= 0:\n        if k >= 30:\n            return FP_Q16_OK, I64_MAX_VALUE\n        if poly > (I64_MAX_VALUE >> k):\n            return FP_Q16_OK, I64_MAX_VALUE\n        return FP_Q16_OK, poly << k\n\n    if k <= -63:\n        return FP_Q16_OK, 0\n\n    return FP_Q16_OK, poly >> (-k)\n\n\ndef fpq16_exp_array_from_clamped_input_no_alias_checked_reference(\n    input_q16: list[int],\n    output_q16: list[int],\n    count: int,\n) -> tuple[int, list[int]]:\n    if count < 0:\n        return FP_Q16_ERR_BAD_PARAM, output_q16[:]\n\n    if input_q16 is output_q16:\n        return FP_Q16_ERR_BAD_PARAM, output_q16[:]\n\n    if count == 0:\n        return FP_Q16_OK, output_q16[:]\n\n    last_index = count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, output_q16[:]\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, output_q16[:]\n\n    # Fail fast before any writes.\n    for i in range(count):\n        if input_q16[i] < EXP_Q16_MIN_INPUT or input_q16[i] > EXP_Q16_MAX_INPUT:\n            return FP_Q16_ERR_BAD_PARAM, output_q16[:]\n\n    out = output_q16[:]\n    for i in range(count):\n        err, value = fpq16_exp_from_clamped_input_checked(input_q16[i])\n        if err != FP_Q16_OK:\n            return err, output_q16[:]\n        out[i] = value\n\n    return FP_Q16_OK, out\n\n\ndef fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n    preclamped_logits_q16: list[int],\n    exp_lanes_q16: list[int],\n    lane_count: int,\n) -> tuple[int, list[int], int]:\n    if lane_count < 0:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], 0\n\n    if preclamped_logits_q16 is exp_lanes_q16:\n        return FP_Q16_ERR_BAD_PARAM, exp_lanes_q16[:], 0\n\n    if lane_count == 0:\n        return FP_Q16_OK, exp_lanes_q16[:], 0\n\n    last_index = lane_count - 1\n    if last_index > (I64_MAX_VALUE >> 3):\n        return FP_Q16_ERR_OVERFLOW, exp_lanes_q16[:], 0\n\n    last_byte_offset = last_index << 3\n    if last_byte_offset > U64_MAX_VALUE:\n        return FP_Q16_ERR_OVERFLOW, exp_lanes_q16[:], 0\n\n    err, out = fpq16_exp_array_from_clamped_input_no_alias_checked_reference(\n        preclamped_logits_q16,\n        exp_lanes_q16,\n        lane_count,\n    )\n    if err != FP_Q16_OK:\n        return err, exp_lanes_q16[:], 0\n\n    exp_sum_q16 = 0\n    for lane in out[:lane_count]:\n        if lane > I64_MAX_VALUE - exp_sum_q16:\n            return FP_Q16_ERR_OVERFLOW, out, 0\n        exp_sum_q16 += lane\n\n    return FP_Q16_OK, out, exp_sum_q16\n\n\ndef q16_from_float(value: float) -> int:\n    return int(round(value * FP_Q16_ONE))\n\n\ndef test_alias_rejected() -> None:\n    shared = [q16_from_float(-0.2), q16_from_float(0.0), q16_from_float(0.3)]\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        shared,\n        shared,\n        len(shared),\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_lanes == shared\n    assert exp_sum == 0\n\n\ndef test_negative_count_rejected() -> None:\n    err, _, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        [q16_from_float(0.0)],\n        [0],\n        -1,\n    )\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_sum == 0\n\n\ndef test_zero_count_writes_nothing() -> None:\n    logits = [q16_from_float(-1.0), q16_from_float(1.0)]\n    out = [123, 456]\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        logits,\n        out,\n        0,\n    )\n    assert err == FP_Q16_OK\n    assert exp_lanes == out\n    assert exp_sum == 0\n\n\ndef test_domain_failure_has_no_partial_writes() -> None:\n    logits = [q16_from_float(-0.5), EXP_Q16_MAX_INPUT + 1, q16_from_float(0.1)]\n    out = [777, 888, 999]\n\n    err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n        logits,\n        out,\n        len(logits),\n    )\n\n    assert err == FP_Q16_ERR_BAD_PARAM\n    assert exp_lanes == out\n    assert exp_sum == 0\n\n\ndef test_random_vectors_match_lane_exp_and_sum() -> None:\n    rng = random.Random(2026041702)\n\n    for _ in range(1000):\n        count = rng.randint(1, 24)\n        logits = [rng.randint(EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT) for _ in range(count)]\n        out_seed = [rng.randint(0, 1024) for _ in range(count)]\n\n        err, exp_lanes, exp_sum = fpq16_softmax_exp_phase_from_preclamped_no_alias_checked_reference(\n            logits,\n            out_seed,\n            count,\n        )\n\n        assert err == FP_Q16_OK\n\n        want = []\n        for lane in logits:\n            lane_err, lane_exp = fpq16_exp_from_clamped_input_checked(lane)\n            assert lane_err == FP_Q16_OK\n            want.append(lane_exp)\n\n        assert exp_lanes[:count] == want\n        assert exp_sum == sum(want)\n\n\ndef run() -> None:\n    test_alias_rejected()\n    test_negative_count_rejected()\n    test_zero_count_writes_nothing()\n    test_domain_failure_has_no_partial_writes()\n    test_random_vectors_match_lane_exp_and_sum()\n    print(\"softmax_exp_phase_from_preclamped_no_alias_checked_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\ntest_softmax_entropy_q16.py\ntest_softmax_exp_phase_from_preclamped_checked.py\ntest_softmax_exp_phase_from_preclamped_no_alias_checked.py\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_13","type":"reasoning","text":"**Implementing test scripts**\n\nI’m thinking about how there might be some unchecked tests on the list, and I need to implement IQ172 in softmax. It could be a good idea to create a new test script, maybe named test_softmax_normalize_phase_checked.py, if there's no existing one. I’ll need to inspect the coding style in the math files to check for error codes and pointers. I should also look at functions like intexp to make sure everything's in order."}}
{"type":"item.started","item":{"id":"item_14","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' src/math/intexp.HC; sed -n '1,340p' src/math/fixedpoint.HC | head -n 220; sed -n '1,320p' src/math/rmsnorm.HC | head -n 260\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' src/math/intexp.HC; sed -n '1,340p' src/math/fixedpoint.HC | head -n 220; sed -n '1,320p' src/math/rmsnorm.HC | head -n 260\"","aggregated_output":"// intexp.HC\n// Integer-only Q16.16 exponential approximation for TempleOS HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define EXP_Q16_LN2       45426   // round(ln(2) * 65536)\n#define EXP_Q16_MAX_INPUT 655360  // +10.0 in Q16\n#define EXP_Q16_MIN_INPUT -655360 // -10.0 in Q16\n\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n#define U64_MAX_VALUE 0xFFFFFFFFFFFFFFFF\n\nI64 FPQ16Mul(I64 a, I64 b);\n\n// Checked clamp helper used by scalar exp and vector exp callers.\n// Clamps to the saturating exp input domain [-10.0, +10.0] in Q16.\nI32 FPQ16ExpClampToInputDomainChecked(I64 input_q16,\n                                      I64 *out_clamped_q16)\n{\n    if (!out_clamped_q16)\n        return FP_Q16_ERR_NULL_PTR;\n\n    // Protect against accidental constant inversion during refactors.\n    if (EXP_Q16_MIN_INPUT > EXP_Q16_MAX_INPUT)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (input_q16 < EXP_Q16_MIN_INPUT)\n    {\n        *out_clamped_q16 = EXP_Q16_MIN_INPUT;\n        return FP_Q16_OK;\n    }\n\n    if (input_q16 > EXP_Q16_MAX_INPUT)\n    {\n        *out_clamped_q16 = EXP_Q16_MAX_INPUT;\n        return FP_Q16_OK;\n    }\n\n    *out_clamped_q16 = input_q16;\n    return FP_Q16_OK;\n}\n\n// Vector checked clamp helper for Q16 exp input-domain saturation.\n// Applies the same scalar clamp contract lane-by-lane:\n//   out[i] = clamp(in[i], EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT)\n// This keeps scalar and vector behavior identical by delegating each lane to\n// FPQ16ExpClampToInputDomainChecked instead of duplicating clamp logic.\nI32 FPQ16ExpClampArrayToInputDomainChecked(I64 *input_q16,\n                                           I64 *output_q16,\n                                           I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic used by indexed array access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16ExpClampToInputDomainChecked(input_q16[i],\n                                                   &output_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked Q16 exp evaluation for callers that already performed input-domain\n// clamping. This helper refuses out-of-domain inputs instead of clamping:\n//   requires EXP_Q16_MIN_INPUT <= clamped_input_q16 <= EXP_Q16_MAX_INPUT\n//   returns BAD_PARAM on domain violations\n// This keeps split-phase clamp+eval vector paths explicit and auditable.\nI32 FPQ16ExpFromClampedInputChecked(I64 clamped_input_q16,\n                                    I64 *out_exp_q16)\n{\n    I64 k;\n    I64 r;\n    I64 r2;\n    I64 r3;\n    I64 r4;\n    I64 t1;\n    I64 t2;\n    I64 t3;\n    I64 t4;\n    I64 poly;\n\n    if (!out_exp_q16)\n        return FP_Q16_ERR_NULL_PTR;\n\n    if (clamped_input_q16 < EXP_Q16_MIN_INPUT ||\n        clamped_input_q16 > EXP_Q16_MAX_INPUT)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    // Preserve scalar saturation contract exactly on domain boundaries.\n    if (clamped_input_q16 >= EXP_Q16_MAX_INPUT)\n    {\n        *out_exp_q16 = I64_MAX_VALUE;\n        return FP_Q16_OK;\n    }\n    if (clamped_input_q16 <= EXP_Q16_MIN_INPUT)\n    {\n        *out_exp_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    // Range reduction: x = k*ln(2) + r, where r in [0, ln(2)).\n    k = clamped_input_q16 / EXP_Q16_LN2;\n    if (clamped_input_q16 < 0 && (clamped_input_q16 % EXP_Q16_LN2))\n        k--;\n\n    r = clamped_input_q16 - (k * EXP_Q16_LN2);\n\n    // exp(r) ~= 1 + r + r^2/2 + r^3/6 + r^4/24\n    r2 = FPQ16Mul(r, r);\n    r3 = FPQ16Mul(r2, r);\n    r4 = FPQ16Mul(r3, r);\n\n    t1 = r;\n    t2 = r2 / 2;\n    t3 = r3 / 6;\n    t4 = r4 / 24;\n\n    poly = FP_Q16_ONE + t1 + t2 + t3 + t4;\n\n    if (k >= 0)\n    {\n        if (k >= 30)\n        {\n            *out_exp_q16 = I64_MAX_VALUE;\n            return FP_Q16_OK;\n        }\n\n        if (poly > (I64_MAX_VALUE >> k))\n        {\n            *out_exp_q16 = I64_MAX_VALUE;\n            return FP_Q16_OK;\n        }\n\n        *out_exp_q16 = poly << k;\n        return FP_Q16_OK;\n    }\n\n    if (k <= -63)\n    {\n        *out_exp_q16 = 0;\n        return FP_Q16_OK;\n    }\n\n    *out_exp_q16 = poly >> (-k);\n    return FP_Q16_OK;\n}\n\n// Checked vector exp helper for softmax precompute lanes.\n// For each lane i, this composes the scalar checked path directly:\n//   clamped = clamp(input_q16[i], EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT)\n//   output_q16[i] = exp(clamped)\n// This preserves scalar saturation/domain semantics exactly while keeping all\n// pointer/count arithmetic guarded for deterministic TempleOS-safe behavior.\nI32 FPQ16ExpArrayChecked(I64 *input_q16,\n                         I64 *output_q16,\n                         I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I64 clamped_lane;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic used by indexed lane access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16ExpClampToInputDomainChecked(input_q16[i],\n                                                   &clamped_lane);\n        if (status)\n            return status;\n\n        status = FPQ16ExpFromClampedInputChecked(clamped_lane,\n                                                 &output_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked vector exp helper for callers that already pre-clamped lanes into\n// the scalar-domain contract:\n//   EXP_Q16_MIN_INPUT <= input_q16[i] <= EXP_Q16_MAX_INPUT\n// On any out-of-domain lane this returns BAD_PARAM and performs zero writes,\n// so split-phase clamp/eval callers never observe partially-updated output.\nI32 FPQ16ExpArrayFromClampedInputChecked(I64 *input_q16,\n                                         I64 *output_q16,\n                                         I64 count)\n{\n    I64 i;\n    I64 last_index;\n    I64 last_byte_offset;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (!count)\n        return FP_Q16_OK;\n\n    // Guard pointer-span arithmetic used by indexed lane access.\n    last_index = count - 1;\n    if (last_index > (I64_MAX_VALUE >> 3))\n        return FP_Q16_ERR_OVERFLOW;\n\n    last_byte_offset = last_index << 3;\n    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n        return FP_Q16_ERR_OVERFLOW;\n\n    // Fail fast before any writes so output remains untouched on BAD_PARAM.\n    for (i = 0; i < count; i++)\n    {\n        if (input_q16[i] < EXP_Q16_MIN_INPUT ||\n            input_q16[i] > EXP_Q16_MAX_INPUT)\n            return FP_Q16_ERR_BAD_PARAM;\n    }\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16ExpFromClampedInputChecked(input_q16[i],\n                                                 &output_q16[i]);\n        if (status)\n            return status;\n    }\n\n    return FP_Q16_OK;\n}\n\n// Checked no-alias vector exp helper for pre-clamped lanes.\n// Contract is explicit for immutable-source call sites:\n//   - input_q16 and output_q16 must both be non-null\n//   - input_q16 and output_q16 must be different buffers\n//   - all lanes must already satisfy EXP_Q16_MIN_INPUT..EXP_Q16_MAX_INPUT\n// This composes the existing pre-clamped helper so pointer-span overflow\n// checks and lane math stay centralized in one auditable implementation.\nI32 FPQ16ExpArrayCheckedNoAliasChecked(I64 *input_q16,\n                                       I64 *output_q16,\n                                       I64 count)\n{\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (input_q16 == output_q16)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    return FPQ16ExpArrayFromClampedInputChecked(input_q16,\n                                                output_q16,\n                                                count);\n}\n\nI64 FPQ16Exp(I64 x)\n{\n    I32 clamp_status;\n    I64 clamped_x;\n    I64 out_exp_q16;\n\n    clamp_status = FPQ16ExpClampToInputDomainChecked(x,\n                                                     &clamped_x);\n    if (clamp_status)\n        return 0;\n\n    if (FPQ16ExpFromClampedInputChecked(clamped_x, &out_exp_q16))\n        return 0;\n\n    return out_exp_q16;\n}\n// fixedpoint.HC\n// Q16.16 fixed-point helpers for integer-only inference math.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define FP_Q16_HALF  (1 << (FP_Q16_SHIFT - 1))\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_DOMAIN    3\n#define FP_Q16_ERR_OVERFLOW  4\n\n#define I64_MAX_VALUE  0x7FFFFFFFFFFFFFFF\n#define I64_MIN_VALUE -0x8000000000000000\n#define U64_MAX_VALUE  0xFFFFFFFFFFFFFFFF\n\nU64 FPAbsToU64(I64 x)\n{\n    if (x >= 0)\n        return (U64)x;\n\n    // Avoid overflow for I64_MIN by using two's-complement identity.\n    return ((U64)(-(x + 1))) + 1;\n}\n\nI64 FPSignApplyFromU64(U64 mag, I64 is_negative)\n{\n    if (is_negative)\n    {\n        if (mag >= 0x8000000000000000)\n            return I64_MIN_VALUE;\n        return -(I64)mag;\n    }\n\n    if (mag > (U64)I64_MAX_VALUE)\n        return I64_MAX_VALUE;\n    return (I64)mag;\n}\n\nI32 FPTryApplySignFromU64Checked(U64 mag, I64 is_negative, I64 *out_value)\n{\n    U64 limit;\n\n    if (!out_value)\n        return FP_Q16_ERR_NULL_PTR;\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (mag > limit)\n        return FP_Q16_ERR_OVERFLOW;\n\n    *out_value = FPSignApplyFromU64(mag, is_negative);\n    return FP_Q16_OK;\n}\n\nI64 FPQ16RoundShiftSigned(I64 value, I64 shift)\n{\n    U64 abs_value;\n    U64 round_bias;\n    U64 rounded;\n    I64 is_negative;\n\n    if (shift <= 0)\n        return value;\n    if (shift >= 63)\n        return 0;\n\n    is_negative = value < 0;\n    abs_value = FPAbsToU64(value);\n    round_bias = (U64)1 << (shift - 1);\n\n    if (abs_value > U64_MAX_VALUE - round_bias)\n        rounded = U64_MAX_VALUE >> shift;\n    else\n        rounded = (abs_value + round_bias) >> shift;\n\n    return FPSignApplyFromU64(rounded, is_negative);\n}\n\nI64 FPQ16MulSat(I64 a, I64 b)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 limit;\n    I64 is_negative;\n    I64 prod;\n\n    if (!a || !b)\n        return 0;\n\n    abs_a = FPAbsToU64(a);\n    abs_b = FPAbsToU64(b);\n    is_negative = ((a < 0) ^ (b < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    if (abs_a > (limit / abs_b))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    prod = a * b;\n    return FPQ16RoundShiftSigned(prod, FP_Q16_SHIFT);\n}\n\nI64 FPQ16Abs(I64 x)\n{\n    if (x == I64_MIN_VALUE)\n        return I64_MAX_VALUE;\n\n    if (x < 0)\n        return -x;\n    return x;\n}\n\nI64 FPQ16FromInt(I64 x)\n{\n    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\n        return I64_MAX_VALUE;\n    if (x < (I64_MIN_VALUE >> FP_Q16_SHIFT))\n        return I64_MIN_VALUE;\n\n    return x << FP_Q16_SHIFT;\n}\n\nI64 FPQ16ToInt(I64 x)\n{\n    if (x >= 0)\n        return (x + FP_Q16_HALF) >> FP_Q16_SHIFT;\n    return -(((-x) + FP_Q16_HALF) >> FP_Q16_SHIFT);\n}\n\nI64 FPQ16Mul(I64 a, I64 b)\n{\n    return FPQ16MulSat(a, b);\n}\n\nI64 FPQ16Div(I64 num, I64 den)\n{\n    U64 abs_num;\n    U64 abs_den;\n    U64 limit;\n    U64 int_part;\n    U64 rem;\n    U64 result_mag;\n    I64 is_negative;\n    I64 bit;\n\n    if (!den)\n        return 0;\n\n    abs_num = FPAbsToU64(num);\n    abs_den = FPAbsToU64(den);\n    is_negative = ((num < 0) ^ (den < 0));\n\n    limit = (U64)I64_MAX_VALUE;\n    if (is_negative)\n        limit = 0x8000000000000000;\n\n    int_part = abs_num / abs_den;\n    if (int_part > (limit >> FP_Q16_SHIFT))\n    {\n        if (is_negative)\n            return I64_MIN_VALUE;\n        return I64_MAX_VALUE;\n    }\n\n    result_mag = int_part << FP_Q16_SHIFT;\n    rem = abs_num % abs_den;\n\n    // Emit 16 fractional bits using integer long division.\n    for (bit = FP_Q16_SHIFT - 1; bit >= 0; bit--)\n    {\n        rem <<= 1;\n        if (rem >= abs_den)\n        {\n            rem -= abs_den;\n            if (result_mag <= limit - (((U64)1) << bit))\n                result_mag |= ((U64)1) << bit;\n            else\n                result_mag = limit;\n        }\n    }\n\n    // Half-up rounding by checking whether residual remainder is >= 0.5.\n    if (rem >= ((abs_den + 1) >> 1))\n    {\n        if (result_mag < limit)\n            result_mag++;\n        else\n            result_mag = limit;\n    }\n\n    return FPSignApplyFromU64(result_mag, is_negative);\n}\n\n// Checked one-rounding Q16 helper for:\n//   out_q16 = round_half_up((a_q16 * b_q16) / d_q16)\n//\n// Inputs/outputs are Q16.16 integers, so this computes the exact Q16 result\n// of (a*b)/d without an intermediate Q16 downshift between mul and div.\n// That avoids double-rounding drift in RMSNorm/softmax scale paths.\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16)\n{\n    U64 abs_a;\n    U64 abs_b;\n    U64 abs_d;\n    U64 abs_num;\n    U64 q;\n    U64 r;\n// rmsnorm.HC\n// Integer-only Q16.16 RMSNorm for HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n#define FP_Q16_ERR_DOMAIN    3\n#define FP_Q16_ERR_OVERFLOW  4\n#define U64_MAX_VALUE 0xFFFFFFFFFFFFFFFF\n#define FP_Q16_RMSNORM_AUTO_PATH_OUT_OF_PLACE 0\n#define FP_Q16_RMSNORM_AUTO_PATH_IN_PLACE     1\n\nI64 FPQ16Mul(I64 a, I64 b);\nI64 FPQ16Div(I64 num, I64 den);\nI64 FPQ16FromInt(I64 x);\nI64 FPQ16Sqrt(I64 x);\nI32 FPQ16MulDivRoundedChecked(I64 a_q16,\n                              I64 b_q16,\n                              I64 d_q16,\n                              I64 *out_q16);\nI32 FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(I64 a_q16,\n                                                     I64 b_q16,\n                                                     I64 d_q16,\n                                                     I64 *out_q16);\n\n// Apply precomputed RMSNorm inverse denominator to a Q16 vector with explicit\n// checked error surfaces. This uses one-rounding math:\n//   out[i] = round_half_up((input[i] * inv_denom_q16) / den_q16)\n// where den_q16 is a positive Q16 whole integer (d_int << 16).\nI32 FPQ16RMSNormApplyInvDenomChecked(I64 *input_q16,\n                                     I64 *output_q16,\n                                     I64 count,\n                                     I64 inv_denom_q16,\n                                     I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I32 status;\n\n    if (!input_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    // Delegate denominator contract + checked one-rounding to fixedpoint core.\n    // That keeps RMSNorm scaling error behavior identical to shared math helpers.\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        output_q16[i] = scaled_q16;\n    }\n\n    return 0;\n}\n\n// Apply precomputed RMSNorm inverse denominator and per-channel gamma to a\n// Q16 vector with explicit checked error surfaces:\n//   out[i] = round_half_up(round_half_up((input[i] * inv_denom_q16) / den_q16)\n//                          * gamma[i] / FP_Q16_ONE)\n// The first stage enforces the positive whole-Q16 denominator contract used by\n// WS5 norm call chains. The second stage is checked Q16*Q16 scaling.\nI32 FPQ16RMSNormApplyInvDenomWeightedChecked(I64 *input_q16,\n                                             I64 *gamma_q16,\n                                             I64 *output_q16,\n                                             I64 count,\n                                             I64 inv_denom_q16,\n                                             I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I64 weighted_q16;\n    I32 status;\n\n    if (!input_q16 || !gamma_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    for (i = 0; i < count; i++)\n    {\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        status = FPQ16MulDivRoundedChecked(scaled_q16,\n                                           gamma_q16[i],\n                                           FP_Q16_ONE,\n                                           &weighted_q16);\n        if (status)\n            return status;\n\n        output_q16[i] = weighted_q16;\n    }\n\n    return 0;\n}\n\n// In-place variant of weighted inverse-denominator RMSNorm scaling:\n//   input[i] = round_half_up(round_half_up((input[i] * inv_denom_q16) / den_q16)\n//                            * gamma[i] / FP_Q16_ONE)\n// This preserves the same checked contracts as the out-of-place helper while\n// explicitly supporting alias-safe writes when caller uses one buffer.\nI32 FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked(I64 *input_q16,\n                                                    I64 *gamma_q16,\n                                                    I64 count,\n                                                    I64 inv_denom_q16,\n                                                    I64 den_q16)\n{\n    I64 i;\n    I64 scaled_q16;\n    I64 weighted_q16;\n    I32 status;\n\n    if (!input_q16 || !gamma_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count < 0)\n        return FP_Q16_ERR_BAD_PARAM;\n    if (inv_denom_q16 <= 0)\n        return FP_Q16_ERR_DOMAIN;\n\n    for (i = 0; i < count; i++)\n    {\n        // Read one element, compute checked scaling, then write back to the\n        // same slot. No later iteration depends on previous slot values.\n        status = FPQ16MulDivRoundedByPositiveIntFromQ16DenChecked(input_q16[i],\n                                                                   inv_denom_q16,\n                                                                   den_q16,\n                                                                   &scaled_q16);\n        if (status)\n            return status;\n\n        status = FPQ16MulDivRoundedChecked(scaled_q16,\n                                           gamma_q16[i],\n                                           FP_Q16_ONE,\n                                           &weighted_q16);\n        if (status)\n            return status;\n\n        input_q16[i] = weighted_q16;\n    }\n\n    return 0;\n}\n\n// Shared preflight for auto-dispatch weighted inverse-denominator RMSNorm.\n// This centralizes parameter/domain checks so alias and non-alias paths\n// surface identical BAD_PARAM/DOMAIN/OVERFLOW behavior before any writes.\nI32 FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked(I64 *input_q16,\n                                                         I64 *gamma_q16,\n                                                         I64 *output_q16,\n                                                         I64 count,\n                                                         I64 inv_denom_q16,\n                                                         I64 den_q16)\n{\n    I64 last_index;\n    I64 last_byte_offset;\n\n    if (!input_q16 || !gamma_q16 || !output_q16)\n        return FP_Q16_ERR_NULL_PTR;\n    if (count