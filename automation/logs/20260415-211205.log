rmsnorm.HC:13:U0 FPQ16RMSNorm(I64 *input, I64 *weight, I64 *output, I64 count, I64 eps_q16)\nsrc/math/rmsnorm.HC:32:        sq = FPQ16Mul(input[i], input[i]);\nsrc/math/rmsnorm.HC:39:    mean_sq = FPQ16Div(sum_sq, FPQ16FromInt(count));\nsrc/math/rmsnorm.HC:46:    denom = FPQ16Sqrt(mean_sq);\nsrc/math/rmsnorm.HC:54:    inv_denom = FPQ16Div(FP_Q16_ONE, denom);\nsrc/math/rmsnorm.HC:58:        norm = FPQ16Mul(input[i], inv_denom);\nsrc/math/rmsnorm.HC:59:        output[i] = FPQ16Mul(norm, weight[i]);\nsrc/math/intsqrt.HC:2:// Integer square-root helpers for Q16.16 fixed-point inference math.\nsrc/math/intsqrt.HC:4:#define FP_Q16_SHIFT 16\nsrc/math/intsqrt.HC:34:I64 FPQ16Sqrt(I64 x)\nsrc/math/intsqrt.HC:41:    if (x > (I64_MAX_VALUE >> FP_Q16_SHIFT))\nsrc/math/intsqrt.HC:44:        shifted = ((U64)x) << FP_Q16_SHIFT;\n","exit_code":0,"status":"completed"}}
