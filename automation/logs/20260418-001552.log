{"type":"item.started","item":{"id":"item_7","type":"command_execution","command":"/bin/zsh -lc \"set -e\n# check sanhedrin research presence\nif [ -d ~/Documents/local-codebases/temple-sanhedrin/research ]; then\n  echo 'SANHEDRIN_RESEARCH_EXISTS=1'\n  ls -la ~/Documents/local-codebases/temple-sanhedrin/research | head -n 40\nelse\n  echo 'SANHEDRIN_RESEARCH_EXISTS=0'\nfi\n\n# summarize IQ/WS status\npython3 - <<'PY'\nimport re\nfrom pathlib import Path\np=Path('MASTER_TASKS.md').read_text()\nunchecked=re.findall(r'\"'^- '\"\\\\[ \\\\] (IQ-\\\\d+)',p,flags=re.M)\nchecked=re.findall(r'\"'^- '\"\\\\[x\\\\] (IQ-\\\\d+)',p,flags=re.M)\nprint('IQ_UNCHECKED',len(unchecked))\nprint('IQ_CHECKED',len(checked))\nprint('IQ_MAX_ID',max([int(x.split('-')[1]) for x in unchecked+checked]) if (unchecked+checked) else 0)\nprint('FIRST_10_UNCHECKED',unchecked[:10])\nws_unchecked=re.findall(r'\"'^- '\"\\\\[ \\\\] (WS\\\\d+-\\\\d+)',p,flags=re.M)\nprint('WS_UNCHECKED',len(ws_unchecked))\nprint('FIRST_12_WS_UNCHECKED',ws_unchecked[:12])\nPY\n\n# show inference queue block around first unchecked items\nawk 'BEGIN{inQ=0} /\"'^## Inference Queue/{inQ=1} inQ{print} /''^## Progress Ledger/{if(inQ){exit}}'\"' MASTER_TASKS.md | sed -n '1,220p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
