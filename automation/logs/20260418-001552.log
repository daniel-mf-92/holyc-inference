))\n        return Q8_0_AVX2_ERR_OVERFLOW;\n    if (required_rhs_blocks > rhs_block_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    if (!Q8_0AVX2TryMulI64(lhs_rows, out_row_stride_cols, &required_out_cells))\n        return Q8_0_AVX2_ERR_OVERFLOW;\n    if (required_out_cells > out_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Tiled traversal keeps hot row/column windows local for later AVX2 asm.\n    // Dot primitive remains the checked AVX2-shape kernel so arithmetic and\n    // overflow behavior are identical to the audited block-level path.\n    for (tile_row_start = 0; tile_row_start < lhs_rows; tile_row_start += tile_rows)\n    {\n        tile_row_end = tile_row_start + tile_rows;\n        if (tile_row_end > lhs_rows)\n            tile_row_end = lhs_rows;\n\n        for (tile_col_start = 0; tile_col_start < rhs_cols; tile_col_start += tile_cols)\n        {\n            tile_col_end = tile_col_start + tile_cols;\n            if (tile_col_end > rhs_cols)\n                tile_col_end = rhs_cols;\n\n            for (row_index = tile_row_start; row_index < tile_row_end; ++row_index)\n            {\n                if (!Q8_0AVX2TryMulI64(row_index, lhs_row_stride_blocks, &lhs_row_base))\n                    return Q8_0_AVX2_ERR_OVERFLOW;\n\n                for (col_index = tile_col_start; col_index < tile_col_end; ++col_index)\n                {\n---\n// q4_0_dot.HC\n// Naive integer-only Q4_0 dot product kernels for TempleOS.\n//\n// Math:\n//   For each block, GGML Q4_0 stores 32 4-bit values and one fp16 scale d.\n//   Decode uses: x_i = d * (q_i - 8)\n//\n// Integer HolyC form:\n//   d_q16   = Round(d * 2^16)\n//   q_s     = nibble - 8   (in [-8, 7])\n//   x_q16   = d_q16 * q_s\n//   dot_q32 = Sum(x_q16 * y_q16)\n//           = (dA_q16 * dB_q16) * Sum(qA_s * qB_s)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n\n#define Q4_0_OK               0\n#define Q4_0_ERR_NULL_PTR     1\n#define Q4_0_ERR_BAD_DST_LEN  2\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nI64 Q4_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nI32 Q4_0DotProductBlockQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n   