d_abs_end,\n        tensor_abs_starts=tensor_abs_starts,\n        tensor_abs_ends=tensor_abs_ends,\n        sorted_position_by_tensor=sorted_position_by_tensor,\n    )\n    if err != GGUF_TDBASE_OK:\n        return err, 0, 0, 0, 0\n\n    return GGUF_TDBASE_OK, payload_abs_start, payload_abs_end, span_start, span_end\n\n\ndef _abs_range_greater(\n    starts: list[int],\n    ends: list[int],\n    indices: list[int],\n    i: int,\n    j: int,\n) -> bool:\n    if starts[i] > starts[j]:\n        return True\n    if starts[i] < starts[j]:\n        return False\n    if ends[i] > ends[j]:\n        return True\n    if ends[i] < ends[j]:\n        return False\n    return indices[i] > indices[j]\n\n\ndef _abs_range_sift_down(\n    starts: list[int],\n    ends: list[int],\n    indices: list[int],\n    root: int,\n    end: int,\n) -> None:\n    while True:\n        child = root * 2 + 1\n        if child > end:\n            return\n---\n            rel_start,\n            rel_start,\n            0x7000,\n            starts,\n            ends,\n            sorted_pos,\n        ) == (\n            GGUF_TDBASE_OK,\n            starts[sorted_pos[original_idx]],\n            ends[sorted_pos[original_idx]],\n            0,\n            0,\n        )\n\n        rel_end = rel_start + nbytes\n        if nbytes >= GGUF_DEFAULT_ALIGNMENT:\n            mid_rel = rel_start + (nbytes // 2)\n            mid_rel = ((mid_rel + (GGUF_DEFAULT_ALIGNMENT - 1)) // GGUF_DEFAULT_ALIGNMENT) * GGUF_DEFAULT_ALIGNMENT\n            if mid_rel <= rel_end:\n                err_mid, out_start, out_end, span_start, span_end = tensor_lookup_span_by_index_and_rel_range_default(\n                    original_idx,\n                    mid_rel,\n                    mid_rel,\n                    0x7000,\n                    starts,\n                    ends,\n                    sorted_pos,\n                )\n                assert err_mid == GGUF_TDBASE_OK\n                assert out_start == starts[sorted_pos[origi