{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"rg --files -g 'AGENTS.md' /Users/danielmatthews-ferrero/Documents/local-codebases/holyc-inference /Users/danielmatthews-ferrero/Documents/local-codebases/holyc-inference/src /Users/danielmatthews-ferrero/Documents/local-codebases/holyc-inference/tests; echo '--- q8_0_matmul.HC ---'; sed -n '1,320p' src/matmul/q8_0_matmul.HC; echo '--- q8_0_avx2.HC ---'; sed -n '1,320p' src/quant/q8_0_avx2.HC; echo '--- tests matmul ---'; ls tests | rg 'q8_0_matmul|avx2|matmul' ; echo '--- test file ---'; sed -n '1,320p' tests/test_q8_0_matmul_tiled_checked.py\"","aggregated_output":"--- q8_0_matmul.HC ---\n// q8_0_matmul.HC\n// Checked tiled Q8_0 matmul kernel for TempleOS.\n//\n// Runtime contract:\n//   - lhs is an MxK matrix in row-major block layout (Q8_0 blocks).\n//   - rhs is an NxK matrix in row-major \"column bank\" layout where each output\n//     column of logical B (KxN) is stored as one contiguous row of K blocks.\n//     This keeps every output cell as an explicit row-dot between two block rows.\n//   - out is MxN Q16 matrix (I64 lanes) with explicit output row stride.\n\n#define Q8_0_MATMUL_VALUES_PER_BLOCK 32\n#define Q8_0_MATMUL_PACKED_BYTES     32\n\n#define Q8_0_MATMUL_OK               0\n#define Q8_0_MATMUL_ERR_NULL_PTR     1\n#define Q8_0_MATMUL_ERR_BAD_DST_LEN  2\n#define Q8_0_MATMUL_ERR_OVERFLOW     3\n#define Q8_0_MATMUL_I64_MAX          0x7FFFFFFFFFFFFFFF\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_MATMUL_PACKED_BYTES];\n};\n\n// Declared in src/quant/q8_0_dot.HC.\nI32 Q8_0DotProductBlocksQ16AccumulateChecked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16);\n// Declared in src/quant/q8_0_avx2.HC.\nI32 Q8_0DotBlocksAVX2Q32Checked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32);\nI32 Q8_0DotBlocksAVX2Q32ToQ16Checked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q16);\n\nBool Q8_0MatMulTryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs > Q8_0_MATMUL_I64_MAX / rhs)\n        return FALSE;\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nBool Q8_0MatMulTryAddI64NonNeg(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n    if (lhs > Q8_0_MATMUL_I64_MAX - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nI64 Q8_0MatMulMinI64(I64 lhs, I64 rhs)\n{\n    if (lhs < rhs)\n        return lhs;\n    return rhs;\n}\n\n// Shared checked span-bounds math for tiled row/column traversals:\n//   span_end = min(span_start + span_len, axis_len)\n// The helper keeps overflow and BAD_LEN behavior identical across\n// scalar Q16, AVX2 Q32, and AVX2 Q16 entrypoints.\nI32 Q8_0MatMulTiledComputeSpanBoundsChecked(\n    I64 span_start,\n    I64 span_len,\n    I64 axis_len,\n    I64 *out_span_end)\n{\n    I64 span_end;\n\n    if (!out_span_end)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n    if (span_start < 0 || span_len < 0 || axis_len < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (span_start > axis_len)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    if (!Q8_0MatMulTryAddI64NonNeg(span_start,\n                                   span_len,\n                                   &span_end))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    *out_span_end = Q8_0MatMulMinI64(span_end,\n                                     axis_len);\n    return Q8_0_MATMUL_OK;\n}\n\n// Shared tile-shape contract for tiled Q8_0 matmul call-sites.\n// Both tile extents must be strictly positive so tiled traversal always\n// makes forward progress and never loops forever on zero-sized tiles.\nI32 Q8_0MatMulTiledValidateTileShapeChecked(I64 tile_rows,\n                                            I64 tile_cols)\n{\n    if (tile_rows <= 0 || tile_cols <= 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    return Q8_0_MATMUL_OK;\n}\n\n// Shared stride/K-span invariants for tiled Q8_0 matmul call-sites.\n// This centralizes the active-K and output-row-stride checks used by\n// scalar and AVX2 entrypoints so BAD_LEN surfaces stay identical.\nI32 Q8_0MatMulTiledValidateStridesAndKChecked(\n    I64 row_count,\n    I64 col_count,\n    I64 lhs_row_stride_blocks,\n    I64 rhs_col_stride_blocks,\n    I64 k_block_count,\n    I64 out_row_stride_cells)\n{\n    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Active K span must fit inside each source row stride.\n    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Output row stride must cover active output columns.\n    if (row_count > 0 && out_row_stride_cells < col_count)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    return Q8_0_MATMUL_OK;\n}\n\n// Computes full row-strided capacities required for tiled matmul views:\n//   lhs_required_blocks = row_count * lhs_row_stride_blocks\n//   rhs_required_blocks = col_count * rhs_col_stride_blocks\n//   out_required_cells  = row_count * out_row_stride_cells\n// The helper is overflow-checked and shared by preflight and math entrypoints.\nI32 Q8_0MatMulTiledComputeRequiredCapacitiesChecked(\n    I64 row_count,\n    I64 lhs_row_stride_blocks,\n    I64 col_count,\n    I64 rhs_col_stride_blocks,\n    I64 out_row_stride_cells,\n    I64 *out_lhs_required_blocks,\n    I64 *out_rhs_required_blocks,\n    I64 *out_required_cells)\n{\n    if (!out_lhs_required_blocks || !out_rhs_required_blocks || !out_required_cells)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (row_count < 0 || col_count < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, out_lhs_required_blocks))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, out_rhs_required_blocks))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, out_required_cells))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    return Q8_0_MATMUL_OK;\n}\n\n// Shared checked row-base math for tiled Q8_0 matmul inner loops:\n//   lhs_row_base = row_index * lhs_row_stride_blocks\n//   out_row_base = row_index * out_row_stride_cells\n// Centralizing this keeps overflow/BAD_LEN behavior identical across\n// scalar Q16, AVX2 Q32, and AVX2 Q16 tiled entrypoints.\nI32 Q8_0MatMulTiledComputeRowBaseChecked(\n    I64 row_index,\n    I64 lhs_row_stride_blocks,\n    I64 out_row_stride_cells,\n    I64 *out_lhs_row_base,\n    I64 *out_out_row_base)\n{\n    if (!out_lhs_row_base || !out_out_row_base)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (row_index < 0 || lhs_row_stride_blocks < 0 || out_row_stride_cells < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    if (!Q8_0MatMulTryMulI64NonNeg(row_index,\n                                   lhs_row_stride_blocks,\n                                   out_lhs_row_base))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    if (!Q8_0MatMulTryMulI64NonNeg(row_index,\n                                   out_row_stride_cells,\n                                   out_out_row_base))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    return Q8_0_MATMUL_OK;\n}\n\n// Shared checked output-index math for tiled Q8_0 matmul inner loops:\n//   out_index = out_row_base + col_index\n// Centralizing this keeps overflow/BAD_LEN behavior identical across\n// scalar Q16, AVX2 Q32, and AVX2 Q16 tiled entrypoints.\nI32 Q8_0MatMulTiledComputeOutIndexChecked(\n    I64 out_row_base,\n    I64 col_index,\n    I64 *out_out_index)\n{\n    if (!out_out_index)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (out_row_base < 0 || col_index < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    if (!Q8_0MatMulTryAddI64NonNeg(out_row_base,\n                                   col_index,\n                                   out_out_index))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    return Q8_0_MATMUL_OK;\n}\n\n// Shared checked RHS-column base math for tiled Q8_0 matmul inner loops:\n//   rhs_col_base = col_index * rhs_col_stride_blocks\n// Centralizing this keeps overflow/BAD_LEN behavior identical across\n// scalar Q16, AVX2 Q32, and AVX2 Q16 tiled entrypoints.\nI32 Q8_0MatMulTiledComputeRhsColBaseChecked(\n    I64 col_index,\n    I64 rhs_col_stride_blocks,\n    I64 *out_rhs_col_base)\n{\n    if (!out_rhs_col_base)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (col_index < 0 || rhs_col_stride_blocks < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    if (!Q8_0MatMulTryMulI64NonNeg(col_index,\n                                   rhs_col_stride_blocks,\n                                   out_rhs_col_base))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    return Q8_0_MATMUL_OK;\n}\n\nI32 Q8_0MatMulTiledValidateArgsChecked(\n    Q8_0Block *lhs_blocks,\n    I64 lhs_block_capacity,\n    I64 row_count,\n    I64 lhs_row_stride_blocks,\n    Q8_0Block *rhs_col_blocks,\n    I64 rhs_block_capacity,\n    I64 col_count,\n    I64 rhs_col_stride_blocks,\n    I64 k_block_count,\n    I64 tile_rows,\n    I64 tile_cols,\n    I64 *out_cells,\n    I64 out_cell_capacity,\n    I64 out_row_stride_cells,\n    I64 *out_lhs_required_blocks,\n    I64 *out_rhs_required_blocks,\n    I64 *out_required_cells)\n{\n    I32 status;\n\n    if (!lhs_blocks || !rhs_col_blocks || !out_cells)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n    if (!out_lhs_required_blocks || !out_rhs_required_blocks || !out_required_cells)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_cell_capacity < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    status = Q8_0MatMulTiledValidateStridesAndKChecked(row_count,\n                                                       col_count,\n                                                       lhs_row_stride_blocks,\n                                                       rhs_col_stride_blocks,\n                                                       k_block_count,\n                                                       out_row_stride_cells);\n    if (status != Q8_0_MATMUL_OK)\n        return status;\n\n    status = Q8_0MatMulTiledValidateTileShapeChecked(tile_rows,\n                                                     tile_cols);\n    if (status != Q8_0_MATMUL_OK)\n        return status;\n\n    status = Q8_0MatMulTiledComputeRequiredCapacitiesChecked(row_count,\n                                                             lhs_row_stride_blocks,\n                                                             col_count,\n                                                             rhs_col_stride_blocks,\n                                                             out_row_stride_cells,\n                                                             out_lhs_required_blocks,\n                                                             out_rhs_required_blocks,\n                                                             out_required_cells);\n    if (status != Q8_0_MATMUL_OK)\n        return status;\n\n    if (*out_lhs_required_blocks > lhs_block_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (*out_rhs_required_blocks > rhs_block_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (*out_required_cells > out_cell_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    return Q8_0_MATMUL_OK;\n}\n\n// Compatibility alias for existing callers during matmul preflight unification.\nI32 Q8_0MatMulValidateTiledArgsChecked(\n    Q8_0Block *lhs_blocks,\n    I64 lhs_block_capacity,\n    I64 row_count,\n    I64 lhs_row_stride_blocks,\n    Q8_0Block *rhs_col_blocks,\n    I64 rhs_block_capacity,\n--- q8_0_avx2.HC ---\n// q8_0_avx2.HC\n// AVX2-preparatory lane packing helpers for Q8_0 kernels.\n//\n// Why this exists:\n// - Upcoming tiled AVX2 matmul kernels need signed 8-bit quant lanes widened to\n//   signed 16-bit lanes before pairwise multiply-accumulate.\n// - This helper defines the exact widening contract in auditable HolyC first.\n// - Hot loops can later replace the scalar widening body with AVX2 asm\n//   (`vpmovsxbw`) without changing call-site semantics.\n\n#define Q8_0_AVX2_VALUES_PER_BLOCK   32\n#define Q8_0_AVX2_PAIR_COUNT         16\n\n#define Q8_0_AVX2_OK                 0\n#define Q8_0_AVX2_ERR_NULL_PTR       1\n#define Q8_0_AVX2_ERR_BAD_LEN        2\n#define Q8_0_AVX2_ERR_OVERFLOW       3\n\n#define Q8_0_AVX2_I64_MAX            0x7FFFFFFFFFFFFFFF\n#define Q8_0_AVX2_I64_MIN            (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_AVX2_VALUES_PER_BLOCK];\n};\n\nBool Q8_0AVX2TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q8_0_AVX2_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q8_0_AVX2_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nBool Q8_0AVX2TryMulI64(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs == -1 && rhs == Q8_0_AVX2_I64_MIN)\n        return FALSE;\n    if (rhs == -1 && lhs == Q8_0_AVX2_I64_MIN)\n        return FALSE;\n\n    if (lhs > 0)\n    {\n        if (rhs > 0)\n        {\n            if (lhs > Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (rhs < Q8_0_AVX2_I64_MIN / lhs)\n                return FALSE;\n        }\n    }\n    else\n    {\n        if (rhs > 0)\n        {\n            if (lhs < Q8_0_AVX2_I64_MIN / rhs)\n                return FALSE;\n        }\n        else\n        {\n            if (lhs < Q8_0_AVX2_I64_MAX / rhs)\n                return FALSE;\n        }\n    }\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI64 Q8_0AVX2RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0AVX2RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0AVX2RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0AVX2RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q8_0AVX2DotQ32ToQ16(I64 dot_q32)\n{\n    // Dot products carry Q16*Q16 scale in Q32 during accumulation.\n    // Hand-off to Q16 row kernels is one rounded signed downshift by 16.\n    return Q8_0AVX2RoundShiftRightSigned(dot_q32, 16);\n}\n\nI64 Q8_0AVX2F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0AVX2RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0AVX2RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0Pack32ToI16LanesAVX2(I8 *src_q8, I64 src_len, I16 *dst_i16, I64 dst_len)\n{\n    I64 lane;\n\n    if (!src_q8 || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (src_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Lane contract:\n    //   dst_i16[i] = SignExtend16(src_q8[i]) for i in [0, 31]\n    // This exact order matches the two AVX2 16-lane halves that would be\n    // produced by widening bytes 0..15 then 16..31.\n    for (lane = 0; lane < Q8_0_AVX2_VALUES_PER_BLOCK; ++lane)\n        dst_i16[lane] = (I16)src_q8[lane];\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0PackBlockToI16LanesAVX2(Q8_0Block *block, I16 *dst_i16, I64 dst_len)\n{\n    if (!block || !dst_i16)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    return Q8_0Pack32ToI16LanesAVX2(block->qs,\n                                    Q8_0_AVX2_VALUES_PER_BLOCK,\n                                    dst_i16,\n                                    dst_len);\n}\n\nI32 Q8_0MulI16LanesToI32PairsAVX2(I16 *lhs_i16,\n                                  I64 lhs_len,\n                                  I16 *rhs_i16,\n                                  I64 rhs_len,\n                                  I32 *dst_i32,\n                                  I64 dst_len)\n{\n    I64 pair_index;\n    I64 lane_base;\n    I32 product0;\n    I32 product1;\n\n    if (!lhs_i16 || !rhs_i16 || !dst_i32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (lhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_len < Q8_0_AVX2_VALUES_PER_BLOCK)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (dst_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Contract mirrors AVX2 `vpmaddwd` lane behavior used by quantized dot kernels:\n    // - Multiply lane pairs independently in signed 16-bit domain.\n    // - Accumulate each adjacent pair into one signed 32-bit output.\n    // - Preserve lane order so output pair k maps to input lanes [2k, 2k+1].\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        lane_base = pair_index << 1;\n\n        product0 = lhs_i16[lane_base] * rhs_i16[lane_base];\n        product1 = lhs_i16[lane_base + 1] * rhs_i16[lane_base + 1];\n\n        dst_i32[pair_index] = product0 + product1;\n    }\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0HSumI32PairsAVX2(I32 *pairs_i32,\n                         I64 pairs_len,\n                         I64 *out_sum_i64)\n{\n    I64 pair_index;\n    I64 running_sum;\n    I64 term;\n\n    if (!pairs_i32 || !out_sum_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n    if (pairs_len < Q8_0_AVX2_PAIR_COUNT)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Horizontal reduction contract:\n    // - Sum all 16 pairwise I32 partial products into one signed I64 scalar.\n    // - Preserve deterministic lane order (0..15) for auditability parity\n    //   against the scalar reference path.\n    // - Explicit overflow checks keep reduction safe if this helper is reused\n    //   for wider accumulation streams in future kernels.\n    running_sum = 0;\n    for (pair_index = 0; pair_index < Q8_0_AVX2_PAIR_COUNT; ++pair_index)\n    {\n        term = (I64)pairs_i32[pair_index];\n\n        if (term > 0 && running_sum > Q8_0_AVX2_I64_MAX - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (term < 0 && running_sum < Q8_0_AVX2_I64_MIN - term)\n            return Q8_0_AVX2_ERR_OVERFLOW;\n\n        running_sum += term;\n    }\n\n    *out_sum_i64 = running_sum;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotI16LanesAVX2(I16 *lhs_i16,\n                        I64 lhs_len,\n                        I16 *rhs_i16,\n                        I64 rhs_len,\n                        I64 *out_dot_i64)\n{\n    I32 pairs_i32[Q8_0_AVX2_PAIR_COUNT];\n    I64 dot_i64;\n    I32 status;\n\n    if (!lhs_i16 || !rhs_i16 || !out_dot_i64)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    // Compose the lane-dot from the two audited AVX2-shape primitives:\n    // 1) `vpmaddwd`-equivalent pairwise multiply-add over 32 I16 lanes.\n    // 2) Horizontal sum over 16 I32 pair partials into one I64 scalar.\n    // Keeping this composition explicit preserves bit-level auditability while\n    // allowing future inline-asm replacement of each stage independently.\n    status = Q8_0MulI16LanesToI32PairsAVX2(lhs_i16,\n                                           lhs_len,\n                                           rhs_i16,\n                                           rhs_len,\n                                           pairs_i32,\n                                           Q8_0_AVX2_PAIR_COUNT);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    status = Q8_0HSumI32PairsAVX2(pairs_i32,\n                                  Q8_0_AVX2_PAIR_COUNT,\n                                  &dot_i64);\n    if (status != Q8_0_AVX2_OK)\n        return status;\n\n    *out_dot_i64 = dot_i64;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotBlocksAVX2Q32Checked(Q8_0Block *lhs,\n                                Q8_0Block *rhs,\n                                I64 block_count,\n                                I64 *out_dot_q32)\n{\n    I64 block_index;\n    I16 lhs_lanes_i16[Q8_0_AVX2_VALUES_PER_BLOCK];\n    I16 rhs_lanes_i16[Q8_0_AVX2_VALUES_PER_BLOCK];\n    I64 q_dot_q0;\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n--- tests matmul ---\ntest_q4_0_q8_0_avx2_blocks_q32.py\ntest_q4_0_q8_0_matmul_tiled_avx2_q32.py\ntest_q4_0_q8_0_matmul_tiled_checked.py\ntest_q8_0_avx2_blocks_q32.py\ntest_q8_0_avx2_blocks_q32_to_q16.py\ntest_q8_0_avx2_dot_lanes.py\ntest_q8_0_avx2_hsum_pairs.py\ntest_q8_0_avx2_mul_pairs.py\ntest_q8_0_avx2_pa