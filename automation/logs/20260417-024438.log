{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"ls -la src/math; ls -la tests | rg intexp; sed -n '1,260p' src/math/intexp.HC; sed -n '260,620p' src/math/intexp.HC\"","aggregated_output":"total 96\ndrwxr-xr-x  8 danielmatthews-ferrero  staff    256 Apr 15 21:15 .\ndrwxr-xr-x  7 danielmatthews-ferrero  staff    224 Apr 16 22:11 ..\n-rw-r--r--  1 danielmatthews-ferrero  staff   8859 Apr 17 01:34 fixedpoint.HC\n-rw-r--r--  1 danielmatthews-ferrero  staff   2498 Apr 17 02:40 intexp.HC\n-rw-r--r--  1 danielmatthews-ferrero  staff   5233 Apr 15 21:32 intlog.HC\n-rw-r--r--  1 danielmatthews-ferrero  staff    733 Apr 15 16:33 intsqrt.HC\n-rw-r--r--  1 danielmatthews-ferrero  staff  12331 Apr 17 02:28 rmsnorm.HC\n-rw-r--r--  1 danielmatthews-ferrero  staff   2686 Apr 15 21:38 softmax.HC\n-rw-r--r--   1 danielmatthews-ferrero  staff    4240 Apr 17 02:40 test_intexp_clamp_to_input_domain_checked.py\n// intexp.HC\n// Integer-only Q16.16 exponential approximation for TempleOS HolyC inference.\n\n#define FP_Q16_SHIFT 16\n#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n\n#define FP_Q16_OK            0\n#define FP_Q16_ERR_NULL_PTR  1\n#define FP_Q16_ERR_BAD_PARAM 2\n\n#define EXP_Q16_LN2       45426   // round(ln(2) * 65536)\n#define EXP_Q16_MAX_INPUT 655360  // +10.0 in Q16\n#define EXP_Q16_MIN_INPUT -655360 // -10.0 in Q16\n\n#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n\nI64 FPQ16Mul(I64 a, I64 b);\n\n// Checked clamp helper used by scalar exp and vector exp callers.\n// Clamps to the saturating exp input domain [-10.0, +10.0] in Q16.\nI32 FPQ16ExpClampToInputDomainChecked(I64 input_q16,\n                                      I64 *out_clamped_q16)\n{\n    if (!out_clamped_q16)\n        return FP_Q16_ERR_NULL_PTR;\n\n    // Protect against accidental constant inversion during refactors.\n    if (EXP_Q16_MIN_INPUT > EXP_Q16_MAX_INPUT)\n        return FP_Q16_ERR_BAD_PARAM;\n\n    if (input_q16 < EXP_Q16_MIN_INPUT)\n    {\n        *out_clamped_q16 = EXP_Q16_MIN_INPUT;\n        return FP_Q16_OK;\n    }\n\n    if (input_q16 > EXP_Q16_MAX_INPUT)\n    {\n        *out_clamped_q16 = EXP_Q16_MAX_INPUT;\n        return FP_Q16_OK;\n    }\n\n    *out_clamped_q16 = input_q16;\n    return FP_Q16_OK;\n}\n\nI64 FPQ16Exp(I64 x)\n{\n    I32 clamp_status;\n    I64 clamped_x;\n    I64 k;\n    I64 r;\n    I64 r2;\n    I64 r3;\n    I64 r4;\n    I64 t1;\n    I64 t2;\n    I64 t3;\n    I64 t4;\n    I64 poly;\n\n    clamp_status = FPQ16ExpClampToInputDomainChecked(x,\n                                                     &clamped_x);\n    if (clamp_status)\n        return 0;\n\n    // Keep scalar exp saturation behavior exactly explicit at boundaries.\n    if (clamped_x >= EXP_Q16_MAX_INPUT)\n        return I64_MAX_VALUE;\n    if (clamped_x <= EXP_Q16_MIN_INPUT)\n        return 0;\n\n    // Range reduction: x = k*ln(2) + r, where r in [0, ln(2))\n    k = clamped_x / EXP_Q16_LN2;\n    if (clamped_x < 0 && (clamped_x % EXP_Q16_LN2))\n        k--;\n\n    r = clamped_x - (k * EXP_Q16_LN2);\n\n    // exp(r) ~= 1 + r + r^2/2 + r^3/6 + r^4/24\n    r2 = FPQ16Mul(r, r);\n    r3 = FPQ16Mul(r2, r);\n    r4 = FPQ16Mul(r3, r);\n\n    t1 = r;\n    t2 = r2 / 2;\n    t3 = r3 / 6;\n    t4 = r4 / 24;\n\n    poly = FP_Q16_ONE + t1 + t2 + t3 + t4;\n\n    if (k >= 0)\n    {\n        if (k >= 30)\n            return I64_MAX_VALUE;\n\n        if (poly > (I64_MAX_VALUE >> k))\n            return I64_MAX_VALUE;\n\n        return poly << k;\n    }\n\n    if (k <= -63)\n        return 0;\n\n    return poly >> (-k);\n}\n","exit_code":0,"status":"completed"}}
