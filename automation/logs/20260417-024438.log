{"type":"item.completed","item":{"id":"item_38","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/math/intexp.HC | sed -n '1,170p'; nl -ba MASTER_TASKS.md | sed -n '350,372p'; nl -ba tests/test_intexp_clamp_array_to_input_domain_checked.py | sed -n '1,220p'\"","aggregated_output":"     1\t// intexp.HC\n     2\t// Integer-only Q16.16 exponential approximation for TempleOS HolyC inference.\n     3\t\n     4\t#define FP_Q16_SHIFT 16\n     5\t#define FP_Q16_ONE   (1 << FP_Q16_SHIFT)\n     6\t\n     7\t#define FP_Q16_OK            0\n     8\t#define FP_Q16_ERR_NULL_PTR  1\n     9\t#define FP_Q16_ERR_BAD_PARAM 2\n    10\t#define FP_Q16_ERR_OVERFLOW  4\n    11\t\n    12\t#define EXP_Q16_LN2       45426   // round(ln(2) * 65536)\n    13\t#define EXP_Q16_MAX_INPUT 655360  // +10.0 in Q16\n    14\t#define EXP_Q16_MIN_INPUT -655360 // -10.0 in Q16\n    15\t\n    16\t#define I64_MAX_VALUE 0x7FFFFFFFFFFFFFFF\n    17\t#define U64_MAX_VALUE 0xFFFFFFFFFFFFFFFF\n    18\t\n    19\tI64 FPQ16Mul(I64 a, I64 b);\n    20\t\n    21\t// Checked clamp helper used by scalar exp and vector exp callers.\n    22\t// Clamps to the saturating exp input domain [-10.0, +10.0] in Q16.\n    23\tI32 FPQ16ExpClampToInputDomainChecked(I64 input_q16,\n    24\t                                      I64 *out_clamped_q16)\n    25\t{\n    26\t    if (!out_clamped_q16)\n    27\t        return FP_Q16_ERR_NULL_PTR;\n    28\t\n    29\t    // Protect against accidental constant inversion during refactors.\n    30\t    if (EXP_Q16_MIN_INPUT > EXP_Q16_MAX_INPUT)\n    31\t        return FP_Q16_ERR_BAD_PARAM;\n    32\t\n    33\t    if (input_q16 < EXP_Q16_MIN_INPUT)\n    34\t    {\n    35\t        *out_clamped_q16 = EXP_Q16_MIN_INPUT;\n    36\t        return FP_Q16_OK;\n    37\t    }\n    38\t\n    39\t    if (input_q16 > EXP_Q16_MAX_INPUT)\n    40\t    {\n    41\t        *out_clamped_q16 = EXP_Q16_MAX_INPUT;\n    42\t        return FP_Q16_OK;\n    43\t    }\n    44\t\n    45\t    *out_clamped_q16 = input_q16;\n    46\t    return FP_Q16_OK;\n    47\t}\n    48\t\n    49\t// Vector checked clamp helper for Q16 exp input-domain saturation.\n    50\t// Applies the same scalar clamp contract lane-by-lane:\n    51\t//   out[i] = clamp(in[i], EXP_Q16_MIN_INPUT, EXP_Q16_MAX_INPUT)\n    52\t// This keeps scalar and vector behavior identical by delegating each lane to\n    53\t// FPQ16ExpClampToInputDomainChecked instead of duplicating clamp logic.\n    54\tI32 FPQ16ExpClampArrayToInputDomainChecked(I64 *input_q16,\n    55\t                                           I64 *output_q16,\n    56\t                                           I64 count)\n    57\t{\n    58\t    I64 i;\n    59\t    I64 last_index;\n    60\t    I64 last_byte_offset;\n    61\t    I32 status;\n    62\t\n    63\t    if (!input_q16 || !output_q16)\n    64\t        return FP_Q16_ERR_NULL_PTR;\n    65\t    if (count < 0)\n    66\t        return FP_Q16_ERR_BAD_PARAM;\n    67\t    if (!count)\n    68\t        return FP_Q16_OK;\n    69\t\n    70\t    // Guard pointer-span arithmetic used by indexed array access.\n    71\t    last_index = count - 1;\n    72\t    if (last_index > (I64_MAX_VALUE >> 3))\n    73\t        return FP_Q16_ERR_OVERFLOW;\n    74\t\n    75\t    last_byte_offset = last_index << 3;\n    76\t    if ((U64)input_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n    77\t        return FP_Q16_ERR_OVERFLOW;\n    78\t    if ((U64)output_q16 > (U64_MAX_VALUE - (U64)last_byte_offset))\n    79\t        return FP_Q16_ERR_OVERFLOW;\n    80\t\n    81\t    for (i = 0; i < count; i++)\n    82\t    {\n    83\t        status = FPQ16ExpClampToInputDomainChecked(input_q16[i],\n    84\t                                                   &output_q16[i]);\n    85\t        if (status)\n    86\t            return status;\n    87\t    }\n    88\t\n    89\t    return FP_Q16_OK;\n    90\t}\n    91\t\n    92\tI64 FPQ16Exp(I64 x)\n    93\t{\n    94\t    I32 clamp_status;\n    95\t    I64 clamped_x;\n    96\t    I64 k;\n    97\t    I64 r;\n    98\t    I64 r2;\n    99\t    I64 r3;\n   100\t    I64 r4;\n   101\t    I64 t1;\n   102\t    I64 t2;\n   103\t    I64 t3;\n   104\t    I64 t4;\n   105\t    I64 poly;\n   106\t\n   107\t    clamp_status = FPQ16ExpClampToInputDomainChecked(x,\n   108\t                                                     &clamped_x);\n   109\t    if (clamp_status)\n   110\t        return 0;\n   111\t\n   112\t    // Keep scalar exp saturation behavior exactly explicit at boundaries.\n   113\t    if (clamped_x >= EXP_Q16_MAX_INPUT)\n   114\t        return I64_MAX_VALUE;\n   115\t    if (clamped_x <= EXP_Q16_MIN_INPUT)\n   116\t        return 0;\n   117\t\n   118\t    // Range reduction: x = k*ln(2) + r, where r in [0, ln(2))\n   119\t    k = clamped_x / EXP_Q16_LN2;\n   120\t    if (clamped_x < 0 && (clamped_x % EXP_Q16_LN2))\n   121\t        k--;\n   122\t\n   123\t    r = clamped_x - (k * EXP_Q16_LN2);\n   124\t\n   125\t    // exp(r) ~= 1 + r + r^2/2 + r^3/6 + r^4/24\n   126\t    r2 = FPQ16Mul(r, r);\n   127\t    r3 = FPQ16Mul(r2, r);\n   128\t    r4 = FPQ16Mul(r3, r);\n   129\t\n   130\t    t1 = r;\n   131\t    t2 = r2 / 2;\n   132\t    t3 = r3 / 6;\n   133\t    t4 = r4 / 24;\n   134\t\n   135\t    poly = FP_Q16_ONE + t1 + t2 + t3 + t4;\n   136\t\n   137\t    if (k >= 0)\n   138\t    {\n   139\t        if (k >= 30)\n   140\t            return I64_MAX_VALUE;\n   141\t\n   142\t        if (poly > (I64_MAX_VALUE >> k))\n   143\t            return I64_MAX_VALUE;\n   144\t\n   145\t        return poly << k;\n   146\t    }\n   147\t\n   148\t    if (k <= -63)\n   149\t        return 0;\n   150\t\n   151\t    return poly >> (-k);\n   152\t}\n   350\t- [x] IQ-159 Implement HolyC helper `FPQ16RMSNormApplyInvDenomWeightedAutoSelectPathChecked` in `src/math/rmsnorm.HC` to derive deterministic in-place vs out-of-place dispatch from pointer aliasing and preserve shared error surfaces (WS1-04)\n   351\t- [x] IQ-160 Add host-side parity harness `tests/test_rmsnorm_apply_inv_denom_weighted_auto_checked.py` covering alias/non-alias dispatch equivalence and BAD_PARAM/OVERFLOW parity against explicit in-place/out-of-place references (WS1-04)\n   352\t- [x] IQ-161 Implement HolyC helper `FPQ16ExpClampToInputDomainChecked` in `src/math/intexp.HC` to centralize saturating Q16 exponent input clamp (min/max domain + checked bounds) shared by scalar exp and upcoming vectorized exp callers (WS1-02)\n   353\t- [ ] IQ-162 Implement HolyC helper `FPQ16RMSNormApplyInvDenomWeightedAutoCheckedWithPathOut` in `src/math/rmsnorm.HC` to execute auto-dispatch scaling while returning selected path id for WS1-04 harness parity probes without duplicating math loops (WS1-04)\n   354\t- [x] IQ-163 Implement HolyC helper `FPQ16ExpClampArrayToInputDomainChecked` in `src/math/intexp.HC` to apply checked per-lane domain clamping over Q16 vectors (`in[i] -> out[i]`) with shared scalar clamp semantics for upcoming WS1 vectorized exp kernels (WS1-02)\n   355\t- [ ] IQ-164 Implement HolyC helper `FPQ16ExpFromClampedInputChecked` in `src/math/intexp.HC` to evaluate Q16 exp only for pre-clamped inputs (`EXP_Q16_MIN_INPUT <= x <= EXP_Q16_MAX_INPUT`) and expose checked BAD_PARAM contracts for vector callers that separate clamp and eval phases (WS1-02)\n   356\t- [ ] IQ-165 Implement HolyC helper `FPQ16ExpArrayChecked` in `src/math/intexp.HC` to compute elementwise Q16 exp over arrays with checked pointer/count contracts and per-lane clamp+eval composition for softmax precompute paths (WS1-02)\n   357\t- [ ] IQ-166 Add host-side parity harness `tests/test_intexp_exp_array_checked.py` validating clamp+eval array semantics, saturation edges, and BAD_PARAM/NULL_PTR surfaces against scalar reference composition (WS1-05)\n   358\t\n   359\t## Progress Ledger\n   360\t\n   361\t\n   362\t| Date | Iteration | Task | Result | Notes |\n   363\t|---|---|---|---|---|\n   364\t| 2026-04-17 | loop-142 | IQ-163 exp clamp-array domain helper | done | Added `FPQ16ExpClampArrayToInputDomainChecked` in `src/math/intexp.HC` with scalar-delegated lane clamping + overflow guards and `tests/test_intexp_clamp_array_to_input_domain_checked.py`; `python3 tests/test_intexp_clamp_array_to_input_domain_checked.py && python3 tests/test_intexp_clamp_to_input_domain_checked.py` passed |\n   365\t| 2026-04-17 | loop-141 | IQ-161 exp input-domain clamp helper | done | Added `FPQ16ExpClampToInputDomainChecked` in `src/math/intexp.HC` plus `tests/test_intexp_clamp_to_input_domain_checked.py`; `python3 tests/test_intexp_clamp_to_input_domain_checked.py` passed |\n   366\t| 2026-04-17 | loop-140 | IQ-160 RMSNorm auto-dispatch parity harness | done | Added `tests/test_rmsnorm_apply_inv_denom_weighted_auto_checked.py`; `python3 tests/test_rmsnorm_apply_inv_denom_weighted_auto_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_weighted_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py` passed |\n   367\t| 2026-04-17 | loop-139 | IQ-159 RMSNorm auto-dispatch path selector helper | done | Added `FPQ16RMSNormApplyInvDenomWeightedAutoSelectPathChecked` in `src/math/rmsnorm.HC` and routed `FPQ16RMSNormApplyInvDenomWeightedAutoChecked` through explicit path selection constants; `python3 tests/test_rmsnorm_apply_inv_denom_weighted_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_checked.py` passed |\n   368\t| 2026-04-17 | loop-138 | IQ-016 GGUF format parser contract refresh | done | Expanded `docs/GGUF_FORMAT.md` into a strict HolyC parser spec for header/metadata/tensor/alignment/range/error invariants; `python3 tests/test_gguf_tensor_data_base.py` passed |\n   369\t| 2026-04-17 | loop-137 | IQ-158 RMSNorm auto-dispatch shared preflight helper | done | Added `FPQ16RMSNormApplyInvDenomWeightedAutoValidateChecked` in `src/math/rmsnorm.HC` and routed auto-dispatch through it; `python3 tests/test_rmsnorm_apply_inv_denom_weighted_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py` passed |\n   370\t| 2026-04-17 | loop-136 | IQ-157 RMSNorm weighted inverse-denominator auto-dispatch helper | done | Added `FPQ16RMSNormApplyInvDenomWeightedAutoChecked` in `src/math/rmsnorm.HC`; `python3 tests/test_rmsnorm_apply_inv_denom_weighted_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py` passed |\n   371\t| 2026-04-17 | loop-135 | IQ-150 cached head-base token-window execution path | done | Routed `RoPEQ16RotateHeadRangeByTokenWindowPreflightedChecked` through cached-base execution helper with checked scratch allocation in `src/model/rope.HC`; `python3 tests/test_rope_q16_rotate_head_range_token_window.py && python3 tests/test_rope_q16_rotate_head_range_token_window_preflighted_head_bases.py && python3 tests/test_rope_q16_rotate_head_range_preflighted_position.py && python3 tests/test_rope_q16_rotate_head_range_position.py && python3 tests/test_rope_q16_rotate_head_position.py` passed |\n   372\t| 2026-04-17 | loop-134 | IQ-156 RMSNorm weighted inverse-denominator in-place helper | done | Added `FPQ16RMSNormApplyInvDenomWeightedInPlaceChecked` in `src/math/rmsnorm.HC` and parity harness `tests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py`; `python3 tests/test_rmsnorm_apply_inv_denom_weighted_inplace_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_weighted_checked.py && python3 tests/test_rmsnorm_apply_inv_denom_checked.py` passed |\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for FPQ16ExpClampArrayToInputDomainChecked semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\t\n     8\tFP_Q16_SHIFT = 16\n     9\tEXP_Q16_MAX_INPUT = 655360\n    10\tEXP_Q16_MIN_INPUT = -655360\n    11\t\n    12\tI64_MAX_VALUE = (1 << 63) - 1\n    13\tU64_MAX_VALUE = (1 << 64) - 1\n    14\t\n    15\tFP_Q16_OK = 0\n    16\tFP_Q16_ERR_NULL_PTR = 1\n    17\tFP_Q16_ERR_BAD_PARAM = 2\n    18\tFP_Q16_ERR_OVERFLOW = 4\n    19\t\n    20\t\n    21\tdef fpq16_exp_clamp_to_input_domain_checked(input_q16: int, out_present: bool = True) -> tuple[int, int]:\n    22\t    if not out_present:\n    23\t        return FP_Q16_ERR_NULL_PTR, 0\n    24\t\n    25\t    if EXP_Q16_MIN_INPUT > EXP_Q16_MAX_INPUT:\n    26\t        return FP_Q16_ERR_BAD_PARAM, 0\n    27\t\n    28\t    if input_q16 < EXP_Q16_MIN_INPUT:\n    29\t        return FP_Q16_OK, EXP_Q16_MIN_INPUT\n    30\t\n    31\t    if input_q16 > EXP_Q16_MAX_INPUT:\n    32\t        return FP_Q16_OK, EXP_Q16_MAX_INPUT\n    33\t\n    34\t    return FP_Q16_OK, input_q16\n    35\t\n    36\t\n    37\tdef fpq16_exp_clamp_array_to_input_domain_checked(\n    38\t    input_q16: list[int] | None,\n    39\t    output_q16: list[int] | None,\n    40\t    count: int,\n    41\t    *,\n    42\t    synthetic_input_addr: int = 0x1000,\n    43\t    synthetic_output_addr: int = 0x2000,\n    44\t) -> tuple[int, list[int] | None]:\n    45\t    if input_q16 is None or output_q16 is None:\n    46\t        return FP_Q16_ERR_NULL_PTR, output_q16\n    47\t    if count < 0:\n    48\t        return FP_Q16_ERR_BAD_PARAM, output_q16\n    49\t    if count == 0:\n    50\t        return FP_Q16_OK, output_q16\n    51\t\n    52\t    last_index = count - 1\n    53\t    if last_index > (I64_MAX_VALUE >> 3):\n    54\t        return FP_Q16_ERR_OVERFLOW, output_q16\n    55\t\n    56\t    last_byte_offset = last_index << 3\n    57\t    if synthetic_input_addr > (U64_MAX_VALUE - last_byte_offset):\n    58\t        return FP_Q16_ERR_OVERFLOW, output_q16\n    59\t    if synthetic_output_addr > (U64_MAX_VALUE - last_byte_offset):\n    60\t        return FP_Q16_ERR_OVERFLOW, output_q16\n    61\t\n    62\t    if len(input_q16) < count or len(output_q16) < count:\n    63\t        raise ValueError(\"test harness requires count <= provided buffer lengths\")\n    64\t\n    65\t    for i in range(count):\n    66\t        err, clamped = fpq16_exp_clamp_to_input_domain_checked(input_q16[i])\n    67\t        if err != FP_Q16_OK:\n    68\t            return err, output_q16\n    69\t        output_q16[i] = clamped\n    70\t\n    71\t    return FP_Q16_OK, output_q16\n    72\t\n    73\t\n    74\tdef test_null_pointer_surfaces() -> None:\n    75\t    err, _ = fpq16_exp_clamp_array_to_input_domain_checked(None, [0], 1)\n    76\t    assert err == FP_Q16_ERR_NULL_PTR\n    77\t\n    78\t    err, _ = fpq16_exp_clamp_array_to_input_domain_checked([0], None, 1)\n    79\t    assert err == FP_Q16_ERR_NULL_PTR\n    80\t\n    81\t\n    82\tdef test_bad_param_negative_count() -> None:\n    83\t    err, out = fpq16_exp_clamp_array_to_input_domain_checked([1, 2], [0, 0], -1)\n    84\t    assert err == FP_Q16_ERR_BAD_PARAM\n    85\t    assert out == [0, 0]\n    86\t\n    87\t\n    88\tdef test_zero_count_no_write() -> None:\n    89\t    out = [111, 222, 333]\n    90\t    err, got = fpq16_exp_clamp_array_to_input_domain_checked([1, 2, 3], out, 0)\n    91\t    assert err == FP_Q16_OK\n    92\t    assert got == [111, 222, 333]\n    93\t\n    94\t\n    95\tdef test_overflow_pointer_span_guards() -> None:\n    96\t    huge_count = (I64_MAX_VALUE >> 3) + 2\n    97\t    err, _ = fpq16_exp_clamp_array_to_input_domain_checked([0], [0], huge_count)\n    98\t    assert err == FP_Q16_ERR_OVERFLOW\n    99\t\n   100\t    count = 4\n   101\t    end_minus_two = U64_MAX_VALUE - ((count - 1) << 3) + 1\n   102\t    err, _ = fpq16_exp_clamp_array_to_input_domain_checked(\n   103\t        [0] * count,\n   104\t        [0] * count,\n   105\t        count,\n   106\t        synthetic_input_addr=end_minus_two,\n   107\t    )\n   108\t    assert err == FP_Q16_ERR_OVERFLOW\n   109\t\n   110\t    err, _ = fpq16_exp_clamp_array_to_input_domain_checked(\n   111\t        [0] * count,\n   112\t        [0] * count,\n   113\t        count,\n   114\t        synthetic_output_addr=end_minus_two,\n   115\t    )\n   116\t    assert err == FP_Q16_ERR_OVERFLOW\n   117\t\n   118\t\n   119\tdef test_lanewise_scalar_parity_on_boundaries() -> None:\n   120\t    data = [\n   121\t        EXP_Q16_MIN_INPUT - 99,\n   122\t        EXP_Q16_MIN_INPUT,\n   123\t        EXP_Q16_MIN_INPUT + 1,\n   124\t        -1,\n   125\t        0,\n   126\t        1,\n   127\t        EXP_Q16_MAX_INPUT - 1,\n   128\t        EXP_Q16_MAX_INPUT,\n   129\t        EXP_Q16_MAX_INPUT + 99,\n   130\t    ]\n   131\t    out = [0] * len(data)\n   132\t\n   133\t    err, got = fpq16_exp_clamp_array_to_input_domain_checked(data, out, len(data))\n   134\t    assert err == FP_Q16_OK\n   135\t    assert got is not None\n   136\t\n   137\t    for i, value in enumerate(data):\n   138\t        scalar_err, scalar_out = fpq16_exp_clamp_to_input_domain_checked(value)\n   139\t        assert scalar_err == FP_Q16_OK\n   140\t        assert got[i] == scalar_out\n   141\t\n   142\t\n   143\tdef test_randomized_scalar_composition_and_idempotence() -> None:\n   144\t    rng = random.Random(20260417_163)\n   145\t\n   146\t    for _ in range(2000):\n   147\t        count = rng.randint(1, 128)\n   148\t        data = [rng.randint(-(1 << 62), (1 << 62)) for _ in range(count)]\n   149\t        out = [0] * count\n   150\t\n   151\t        err, first = fpq16_exp_clamp_array_to_input_domain_checked(data, out, count)\n   152\t        assert err == FP_Q16_OK\n   153\t        assert first is not None\n   154\t\n   155\t        for i in range(count):\n   156\t            scalar_err, scalar_out = fpq16_exp_clamp_to_input_domain_checked(data[i])\n   157\t            assert scalar_err == FP_Q16_OK\n   158\t            assert first[i] == scalar_out\n   159\t\n   160\t        second_buf = [0] * count\n   161\t        err2, second = fpq16_exp_clamp_array_to_input_domain_checked(first.copy(), second_buf, count)\n   162\t        assert err2 == FP_Q16_OK\n   163\t        assert second == first\n   164\t\n   165\t\n   166\tdef test_inplace_alias_path_same_results() -> None:\n   167\t    values = [\n   168\t        EXP_Q16_MIN_INPUT - 1,\n   169\t        -123,\n   170\t        0,\n   171\t        456,\n   172\t        EXP_Q16_MAX_INPUT + 1,\n   173\t    ]\n   174\t\n   175\t    err, got = fpq16_exp_clamp_array_to_input_domain_checked(values, values, len(values))\n   176\t    assert err == FP_Q16_OK\n   177\t    assert got == [\n   178\t        EXP_Q16_MIN_INPUT,\n   179\t        -123,\n   180\t        0,\n   181\t        456,\n   182\t        EXP_Q16_MAX_INPUT,\n   183\t    ]\n   184\t\n   185\t\n   186\tdef run() -> None:\n   187\t    test_null_pointer_surfaces()\n   188\t    test_bad_param_negative_count()\n   189\t    test_zero_count_no_write()\n   190\t    test_overflow_pointer_span_guards()\n   191\t    test_lanewise_scalar_parity_on_boundaries()\n   192\t    test_randomized_scalar_composition_and_idempotence()\n   193\t    test_inplace_alias_path_same_results()\n   194\t    print(\"intexp_clamp_array_to_input_domain_checked_reference_checks=ok\")\n   195\t\n   196\t\n   197\tif __name__ == \"__main__\":\n   198\t    run()\n","exit_code":0,"status":"completed"}}
