ase GGUF_TYPE_UINT8:\n   718\t            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n   719\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   720\t            out->u64 = u8v;\n   721\t            return GGUF_META_PARSE_OK;\n   722\t\n   723\t        case GGUF_TYPE_INT8:\n   724\t            if (!GGUFMetaReadU8(buf, size, cursor, &u8v))\n   725\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   726\t            out->i64 = (I8)u8v;\n   727\t            return GGUF_META_PARSE_OK;\n   728\t\n   729\t        case GGUF_TYPE_UINT16:\n   730\t            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n   731\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   732\t            out->u64 = u16v;\n   733\t            return GGUF_META_PARSE_OK;\n   734\t\n   735\t        case GGUF_TYPE_INT16:\n   736\t            if (!GGUFMetaReadU16LE(buf, size, cursor, &u16v))\n   737\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   738\t            out->i64 = (I16)u16v;\n   739\t            return GGUF_META_PARSE_OK;\n   740\t\n   741\t        case GGUF_TYPE_UINT32:\n   742\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n   743\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   744\t            out->u64 = u32v;\n   745\t            return GGUF_META_PARSE_OK;\n   746\t\n   747\t        case GGUF_TYPE_INT32:\n   748\t            if (!GGUFMetaReadU32LE(buf, size, cursor, &u32v))\n   749\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   750\t            out->i64 = (I32)u32v;\n   751\t            return GGUF_META_PARSE_OK;\n   752\t\n   753\t        case GGUF_TYPE_UINT64:\n   754\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n   755\t                return GGUF_META_PARSE_ERR_TRUNCATED;\n   756\t            out->u64 = u64v;\n   757\t            return GGUF_META_PARSE_OK;\n   758\t\n   759\t        case GGUF_TYPE_INT64:\n   760\t            if (!GGUFMetaReadU64LE(buf, size, cursor, &u64v))\n","exit_code":0,"s