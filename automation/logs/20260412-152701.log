{"type":"item.completed","item":{"id":"item_37","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/quant/q4_0.HC | sed -n '1,260p' && echo '---' && nl -ba tests/test_q4_0_dequant.py | sed -n '1,260p' && echo '---' && nl -ba MASTER_TASKS.md | sed -n '178,250p'\"","aggregated_output":"     1\t// q4_0.HC\n     2\t// Q4_0 block layout + integer-only dequantization helpers for TempleOS.\n     3\t//\n     4\t// GGML Q4_0 block layout (18 bytes total):\n     5\t//   - d_fp16 : fp16 scale\n     6\t//   - qs[16] : packed nibbles (32 values, 2 values per byte)\n     7\t//\n     8\t// Decode equation (reference):\n     9\t//   x = d * (q - 8)\n    10\t//\n    11\t// Integer HolyC form:\n    12\t//   d_q16  = Round(d_fp16 * 2^16)\n    13\t//   x_q16  = d_q16 * q_signed\n    14\t//\n    15\t// No float ops are used in runtime decode.\n    16\t\n    17\t#define Q4_0_VALUES_PER_BLOCK 32\n    18\t#define Q4_0_PACKED_BYTES     16\n    19\t#define Q4_0_BLOCK_BYTES      18\n    20\t\n    21\t#define Q4_0_OK               0\n    22\t#define Q4_0_ERR_NULL_PTR     1\n    23\t#define Q4_0_ERR_BAD_DST_LEN  2\n    24\t\n    25\tclass Q4_0Block\n    26\t{\n    27\t    U16 d_fp16;\n    28\t    U8 qs[Q4_0_PACKED_BYTES];\n    29\t};\n    30\t\n    31\tI64 Q4_0RoundShiftRightUnsigned(I64 value, I64 shift)\n    32\t{\n    33\t    I64 round_bias;\n    34\t\n    35\t    if (shift <= 0)\n    36\t        return value;\n    37\t\n    38\t    round_bias = 1 << (shift - 1);\n    39\t    return (value + round_bias) >> shift;\n    40\t}\n    41\t\n    42\tI64 Q4_0F16ToQ16(U16 fp16_bits)\n    43\t{\n    44\t    I64 sign_bit;\n    45\t    I64 exponent_bits;\n    46\t    I64 fraction_bits;\n    47\t    I64 mantissa;\n    48\t    I64 shift_amount;\n    49\t    I64 magnitude_q16;\n    50\t\n    51\t    sign_bit = (fp16_bits >> 15) & 1;\n    52\t    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    53\t    fraction_bits = fp16_bits & 0x03FF;\n    54\t\n    55\t    // Subnormal and zero numbers:\n    56\t    // value = fraction * 2^-24, so Q16 = fraction * 2^-8.\n    57\t    if (!exponent_bits)\n    58\t    {\n    59\t        if (!fraction_bits)\n    60\t            return 0;\n    61\t\n    62\t        magnitude_q16 = Q4_0RoundShiftRightUnsigned(fraction_bits, 8);\n    63\t        if (sign_bit)\n    64\t            return -magnitude_q16;\n    65\t        return magnitude_q16;\n    66\t    }\n    67\t\n    68\t    // INF/NAN: saturate to a very large signed magnitude instead of trapping.\n    69\t    if (exponent_bits == 0x1F)\n    70\t    {\n    71\t        if (sign_bit)\n    72\t            return -0x3FFFFFFFFFFFFFFF;\n    73\t        return 0x3FFFFFFFFFFFFFFF;\n    74\t    }\n    75\t\n    76\t    // Normal numbers:\n    77\t    // value = (1024 + fraction) * 2^(exp-25)\n    78\t    // Q16  = (1024 + fraction) * 2^(exp-9)\n    79\t    mantissa = 1024 + fraction_bits;\n    80\t    shift_amount = exponent_bits - 9;\n    81\t\n    82\t    if (shift_amount >= 0)\n    83\t        magnitude_q16 = mantissa << shift_amount;\n    84\t    else\n    85\t        magnitude_q16 = Q4_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n    86\t\n    87\t    if (sign_bit)\n    88\t        return -magnitude_q16;\n    89\t    return magnitude_q16;\n    90\t}\n    91\t\n    92\tI64 Q4_0NibbleToSigned(U8 packed, Bool upper_nibble)\n    93\t{\n    94\t    I64 q_unsigned;\n    95\t\n    96\t    if (upper_nibble)\n    97\t        q_unsigned = (packed >> 4) & 0x0F;\n    98\t    else\n    99\t        q_unsigned = packed & 0x0F;\n   100\t\n   101\t    return q_unsigned - 8;\n   102\t}\n   103\t\n   104\tI32 Q4_0UnpackBlockSigned(Q4_0Block *block, I64 *dst_signed, I64 dst_len)\n   105\t{\n   106\t    I64 byte_index;\n   107\t    I64 out_index;\n   108\t    U8 packed;\n   109\t\n   110\t    if (!block || !dst_signed)\n   111\t        return Q4_0_ERR_NULL_PTR;\n   112\t    if (dst_len < Q4_0_VALUES_PER_BLOCK)\n   113\t        return Q4_0_ERR_BAD_DST_LEN;\n   114\t\n   115\t    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n   116\t    {\n   117\t        packed = block->qs[byte_index];\n   118\t\n   119\t        out_index = byte_index << 1;\n   120\t        dst_signed[out_index] = Q4_0NibbleToSigned(packed, FALSE);\n   121\t        dst_signed[out_index + 1] = Q4_0NibbleToSigned(packed, TRUE);\n   122\t    }\n   123\t\n   124\t    return Q4_0_OK;\n   125\t}\n   126\t\n   127\tI32 Q4_0DequantizeBlockQ16(Q4_0Block *block, I64 *dst_q16, I64 dst_len)\n   128\t{\n   129\t    I64 scale_q16;\n   130\t    I64 byte_index;\n   131\t    I64 out_index;\n   132\t    U8 packed;\n   133\t    I64 q_signed;\n   134\t\n   135\t    if (!block || !dst_q16)\n   136\t        return Q4_0_ERR_NULL_PTR;\n   137\t    if (dst_len < Q4_0_VALUES_PER_BLOCK)\n   138\t        return Q4_0_ERR_BAD_DST_LEN;\n   139\t\n   140\t    scale_q16 = Q4_0F16ToQ16(block->d_fp16);\n   141\t\n   142\t    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n   143\t    {\n   144\t        packed = block->qs[byte_index];\n   145\t        out_index = byte_index << 1;\n   146\t\n   147\t        // Lower nibble is even index; upper nibble is odd index.\n   148\t        q_signed = Q4_0NibbleToSigned(packed, FALSE);\n   149\t        dst_q16[out_index] = scale_q16 * q_signed;\n   150\t\n   151\t        q_signed = Q4_0NibbleToSigned(packed, TRUE);\n   152\t        dst_q16[out_index + 1] = scale_q16 * q_signed;\n   153\t    }\n   154\t\n   155\t    return Q4_0_OK;\n   156\t}\n   157\t\n   158\tI32 Q4_0DequantizeBlocksQ16(Q4_0Block *blocks, I64 block_count, I64 *dst_q16, I64 dst_len)\n   159\t{\n   160\t    I64 block_index;\n   161\t    I64 dst_offset;\n   162\t    I32 status;\n   163\t\n   164\t    if (!blocks || !dst_q16)\n   165\t        return Q4_0_ERR_NULL_PTR;\n   166\t    if (block_count < 0)\n   167\t        return Q4_0_ERR_BAD_DST_LEN;\n   168\t    if (dst_len < block_count * Q4_0_VALUES_PER_BLOCK)\n   169\t        return Q4_0_ERR_BAD_DST_LEN;\n   170\t\n   171\t    dst_offset = 0;\n   172\t    for (block_index = 0; block_index < block_count; ++block_index)\n   173\t    {\n   174\t        status = Q4_0DequantizeBlockQ16(&blocks[block_index], &dst_q16[dst_offset], Q4_0_VALUES_PER_BLOCK);\n   175\t        if (status != Q4_0_OK)\n   176\t            return status;\n   177\t\n   178\t        dst_offset += Q4_0_VALUES_PER_BLOCK;\n   179\t    }\n   180\t\n   181\t    return Q4_0_OK;\n   182\t}\n---\n     1\t#!/usr/bin/env python3\n     2\t\"\"\"Reference checks for Q4_0 unpack + integer Q16 dequant semantics.\"\"\"\n     3\t\n     4\tfrom __future__ import annotations\n     5\t\n     6\timport random\n     7\timport struct\n     8\t\n     9\tQ4_0_VALUES_PER_BLOCK = 32\n    10\tQ4_0_PACKED_BYTES = 16\n    11\t\n    12\tQ4_0_OK = 0\n    13\tQ4_0_ERR_NULL_PTR = 1\n    14\tQ4_0_ERR_BAD_DST_LEN = 2\n    15\t\n    16\t\n    17\tdef round_shift_right_unsigned(value: int, shift: int) -> int:\n    18\t    if shift <= 0:\n    19\t        return value\n    20\t    round_bias = 1 << (shift - 1)\n    21\t    return (value + round_bias) >> shift\n    22\t\n    23\t\n    24\tdef f16_to_q16(fp16_bits: int) -> int:\n    25\t    sign_bit = (fp16_bits >> 15) & 1\n    26\t    exponent_bits = (fp16_bits >> 10) & 0x1F\n    27\t    fraction_bits = fp16_bits & 0x03FF\n    28\t\n    29\t    if exponent_bits == 0:\n    30\t        if fraction_bits == 0:\n    31\t            return 0\n    32\t        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n    33\t        return -magnitude_q16 if sign_bit else magnitude_q16\n    34\t\n    35\t    if exponent_bits == 0x1F:\n    36\t        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n    37\t\n    38\t    mantissa = 1024 + fraction_bits\n    39\t    shift_amount = exponent_bits - 9\n    40\t\n    41\t    if shift_amount >= 0:\n    42\t        magnitude_q16 = mantissa << shift_amount\n    43\t    else:\n    44\t        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n    45\t\n    46\t    return -magnitude_q16 if sign_bit else magnitude_q16\n    47\t\n    48\t\n    49\tdef nibble_to_signed(packed: int, upper_nibble: bool) -> int:\n    50\t    if upper_nibble:\n    51\t        q_unsigned = (packed >> 4) & 0x0F\n    52\t    else:\n    53\t        q_unsigned = packed & 0x0F\n    54\t    return q_unsigned - 8\n    55\t\n    56\t\n    57\tdef unpack_block_signed(qs: bytes):\n    58\t    if len(qs) != Q4_0_PACKED_BYTES:\n    59\t        return Q4_0_ERR_BAD_DST_LEN, []\n    60\t\n    61\t    out = [0] * Q4_0_VALUES_PER_BLOCK\n    62\t    for byte_index, packed in enumerate(qs):\n    63\t        out_index = byte_index << 1\n    64\t        out[out_index] = nibble_to_signed(packed, False)\n    65\t        out[out_index + 1] = nibble_to_signed(packed, True)\n    66\t    return Q4_0_OK, out\n    67\t\n    68\t\n    69\tdef dequantize_block_q16(scale_fp16: int, qs: bytes):\n    70\t    if len(qs) != Q4_0_PACKED_BYTES:\n    71\t        return Q4_0_ERR_BAD_DST_LEN, []\n    72\t\n    73\t    out = [0] * Q4_0_VALUES_PER_BLOCK\n    74\t    scale_q16 = f16_to_q16(scale_fp16)\n    75\t\n    76\t    for byte_index, packed in enumerate(qs):\n    77\t        out_index = byte_index << 1\n    78\t\n    79\t        q_signed = nibble_to_signed(packed, False)\n    80\t        out[out_index] = scale_q16 * q_signed\n    81\t\n    82\t        q_signed = nibble_to_signed(packed, True)\n    83\t        out[out_index + 1] = scale_q16 * q_signed\n    84\t\n    85\t    return Q4_0_OK, out\n    86\t\n    87\t\n    88\tdef half_bits(value: float) -> int:\n    89\t    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n    90\t\n    91\t\n    92\tdef test_unpack_known_pattern() -> None:\n    93\t    qs = bytes(((2 * i) & 0x0F) | (((2 * i + 1) & 0x0F) << 4) for i in range(Q4_0_PACKED_BYTES))\n    94\t    err, out = unpack_block_signed(qs)\n    95\t    assert err == Q4_0_OK\n    96\t    assert out == [i - 8 for i in range(16)] * 2\n    97\t\n    98\t\n    99\tdef test_dequant_known_scale() -> None:\n   100\t    scale_fp16 = half_bits(0.5)\n   101\t    qs = bytes([0x10, 0x32, 0x54, 0x76, 0x98, 0xBA, 0xDC, 0xFE] * 2)\n   102\t\n   103\t    err, out_q16 = dequantize_block_q16(scale_fp16, qs)\n   104\t    assert err == Q4_0_OK\n   105\t\n   106\t    expected_signed = []\n   107\t    for packed in qs:\n   108\t        expected_signed.append((packed & 0x0F) - 8)\n   109\t        expected_signed.append(((packed >> 4) & 0x0F) - 8)\n   110\t\n   111\t    expected_q16 = [round(0.5 * q * (1 << 16)) for q in expected_signed]\n   112\t    assert out_q16 == expected_q16\n   113\t\n   114\t\n   115\tdef test_fp16_to_q16_matches_float_rounding_for_finite_values() -> None:\n   116\t    finite_values = [\n   117\t        0.0,\n   118\t        1.0,\n   119\t        -1.0,\n   120\t        0.5,\n   121\t        -0.5,\n   122\t        2.0,\n   123\t        -2.0,\n   124\t        1.5,\n   125\t        -3.25,\n   126\t        0.125,\n   127\t        -0.03125,\n   128\t    ]\n   129\t\n   130\t    for value in finite_values:\n   131\t        bits = half_bits(value)\n   132\t        got = f16_to_q16(bits)\n   133\t        expected = round(value * (1 << 16))\n   134\t        assert got == expected\n   135\t\n   136\t\n   137\tdef test_random_blocks_match_reference_float_path() -> None:\n   138\t    rng = random.Random(1337)\n   139\t    for _ in range(200):\n   140\t        # Keep finite, normal scales in a stable range.\n   141\t        scale = rng.uniform(-4.0, 4.0)\n   142\t        scale_fp16 = half_bits(scale)\n   143\t        scale_q16 = f16_to_q16(scale_fp16)\n   144\t\n   145\t        qs = bytes(rng.randrange(256) for _ in range(Q4_0_PACKED_BYTES))\n   146\t        err, out_q16 = dequantize_block_q16(scale_fp16, qs)\n   147\t        assert err == Q4_0_OK\n   148\t\n   149\t        scale_from_half = struct.unpack(\"<e\", struct.pack(\"<H\", scale_fp16))[0]\n   150\t        expected_q16 = []\n   151\t        expected_float_q16 = []\n   152\t        for packed in qs:\n   153\t            q_low = (packed & 0x0F) - 8\n   154\t            q_high = ((packed >> 4) & 0x0F) - 8\n   155\t            expected_q16.append(scale_q16 * q_low)\n   156\t            expected_q16.append(scale_q16 * q_high)\n   157\t            expected_float_q16.append(round(scale_from_half * q_low * (1 << 16)))\n   158\t            expected_float_q16.append(round(scale_from_half * q_high * (1 << 16)))\n   159\t\n   160\t        for got, want in zip(out_q16, expected_q16):\n   161\t            assert got == want\n   162\t\n   163\t        for got, want in zip(out_q16, expected_float_q16):\n   164\t            # Integer path rounds scale once per block; float path rounds per value.\n   165\t            # For Q4_0 q in [-8,7], delta stays bounded and deterministic.\n   166\t            assert abs(got - want) <= 8\n   167\t\n   168\t\n   169\tdef run() -> None:\n   170\t    test_unpack_known_pattern()\n   171\t    test_dequant_known_scale()\n   172\t    test_fp16_to_q16_matches_float_rounding_for_finite_values()\n   173\t    test_random_blocks_match_reference_float_path()\n   174\t    print(\"q4_0_dequant_reference_checks=ok\")\n   175\t\n   176\t\n   177\tif __name__ == \"__main__\":\n   178\t    run()\n---\n   178\t- [x] IQ-006 Implement integer exp approximation in `src/math/intexp.HC` (WS1-02)\n   179\t- [x] IQ-007 Implement integer sqrt approximation in `src/math/intsqrt.HC` (WS1-02)\n   180\t- [x] IQ-008 Implement integer softmax in `src/math/softmax.HC` (WS1-03)\n   181\t- [x] IQ-009 Implement RMSNorm (integer path) in `src/math/rmsnorm.HC` (WS1-04)\n   182\t- [x] IQ-010 Implement GGUF magic/version/header parser in `src/gguf/header.HC` (WS2-01)\n   183\t- [x] IQ-011 Implement GGUF metadata KV reader in `src/gguf/metadata.HC` (WS2-02)\n   184\t- [x] IQ-012 Implement GGUF tensor info reader in `src/gguf/tensorinfo.HC` (WS2-03)\n   185\t- [x] IQ-013 Implement Q4_0 block struct and dequantize in `src/quant/q4_0.HC` (WS3-01, WS3-02)\n   186\t- [ ] IQ-014 Implement Q4_0 dot product (naive) in `src/quant/q4_0_dot.HC` (WS3-03)\n   187\t- [ ] IQ-015 Implement Q8_0 block struct and dequantize in `src/quant/q8_0.HC` (WS3-04)\n   188\t- [ ] IQ-016 Draft `docs/GGUF_FORMAT.md` skeleton with sections for header, metadata, tensor info, and alignment rules (WS0-02)\n   189\t- [ ] IQ-017 Write host-side GGUF header/tensor dump fixture plan in `tests/README.md` for llama.cpp parity checks (WS0-05, WS2-05)\n   190\t- [ ] IQ-018 Create `tests/README.md` skeleton for llama.cpp parity fixtures (header, metadata, tensor offsets) (WS0-05, WS2-05)\n   191\t- [ ] IQ-019 Create `src/math/fixedpoint.HC` skeleton with Q16 constants, core type aliases, and TODO stubs for mul/div helpers (WS1-01)\n   192\t- [ ] IQ-020 Implement Q16 integer exponent range clamp and base constants in `src/math/intexp.HC` (WS1-02)\n   193\t- [ ] IQ-021 Add host-side Q16 exp parity harness in `tests/test_intexp_q16.py` against `math.exp` samples (WS1-05)\n   194\t- [ ] IQ-022 Implement GGUF header constants and struct layout notes in `src/gguf/header.HC` before parser logic (WS2-01)\n   195\t- [ ] IQ-023 Create `src/math/rmsnorm.HC` skeleton with Q16 constants, tensor shape assumptions, and TODO stubs for scale/variance accumulation (WS1-04)\n   196\t- [ ] IQ-024 Create `src/gguf/header.HC` skeleton with `GGUFHeader` struct and endian-safe integer read helper stubs (WS2-01)\n   197\t- [ ] IQ-025 Add host-side GGUF header parser parity fixture in `tests/test_gguf_header_parse.py` covering valid/magic/version/truncation cases (WS2-01, WS2-05)\n   198\t- [ ] IQ-026 Implement metadata key lookup helpers (`GGUFMetaFindByKey`, scalar extractors) in `src/gguf/metadata.HC` (WS2-02)\n   199\t- [ ] IQ-027 Add host-side metadata parser parity fixture for scalar/string/array/nested-array cases in `tests/test_gguf_metadata_parse.py` (WS2-02, WS2-05)\n   200\t- [ ] IQ-028 Implement GGUF tensor data base alignment helper in `src/gguf/tensor_data_base.HC` (WS2-04)\n   201\t\n   202\t## Progress Ledger\n   203\t\n   204\t| Date | Iteration | Task | Result | Notes |\n   205\t|---|---|---|---|---|\n   206\t| 2026-04-12 | bootstrap | MASTER_TASKS init | done | Initial roadmap + queue created |\n   207\t| 2026-04-12 | loop-001 | IQ-001 directory structure | done | Verified `src/`, `tests/`, `docs/`, `automation/`, `models/` exist locally |\n   208\t| 2026-04-12 | loop-002 | IQ-002 GGUF format reference doc | done | Added `docs/GGUF_FORMAT.md` with header/metadata/tensor/alignment rules and HolyC parser safety checks |\n   209\t| 2026-04-12 | loop-003 | IQ-003 quantization reference doc | done | Added `docs/QUANTIZATION.md` with integer-only Q4_0/Q8_0 decode, fixed-point scaling, and dot-product formulas |\n   210\t| 2026-04-12 | loop-004 | IQ-004 LLaMA architecture reference doc | done | Added `docs/LLAMA_ARCH.md` covering decoder flow, RMSNorm, RoPE, GQA, SwiGLU, KV cache, and required GGUF fields |\n   211\t| 2026-04-12 | loop-005 | IQ-005 fixed-point mul/div helpers | done | Added `src/math/fixedpoint.HC` with Q16 helpers (`FPQ16Mul`, `FPQ16Div`, conversions); validated host-side with `python3` arithmetic parity checks |\n   212\t| 2026-04-12 | loop-006 | IQ-006 integer exp approximation | done | Added `src/math/intexp.HC` with Q16 range reduction + 4th-order polynomial; validated host-side over x∈[-8,8] (`max_rel_err=4.48%`) |\n   213\t| 2026-04-12 | loop-007 | IQ-007 integer sqrt approximation | done | Added `src/math/intsqrt.HC` with bitwise `IntSqrtU64` + `FPQ16Sqrt`; validated via host parity checks (`intsqrt_exact_checks=ok`, `max_rel_err=0.007690%`) |\n   214\t| 2026-04-12 | loop-008 | IQ-008 integer softmax | done | Added `src/math/softmax.HC` with stable max-shifted Q16 softmax and sum-to-one correction; validated host-side parity (`softmax_q16_checks=ok`, `max_abs_err=0.003334`) |\n   215\t| 2026-04-12 | loop-009 | IQ-009 integer RMSNorm | done | Added `src/math/rmsnorm.HC` with Q16 RMSNorm (`mean(x^2)+eps`, rsqrt via `FPQ16Sqrt`, per-channel scale); validated host-side parity (`rmsnorm_q16_checks=ok`, `max_abs_err=0.000075`) |\n   216\t| 2026-04-12 | loop-010 | IQ-010 GGUF header parser | done | Added `src/gguf/header.HC` with little-endian U32/U64 readers and `GGUFParseHeader` validation (magic/version/count/truncation); validated via focused host parity check (`gguf_header_reference_checks=ok`) |\n   217\t| 2026-04-12 | loop-011 | IQ-011 GGUF metadata KV reader | done | Added `src/gguf/metadata.HC` with full key/value parsing (scalar, string, array), strict bounds/type checks, and metadata table lifetime helpers; validated with `python3 tests/test_gguf_metadata_parse.py` (`gguf_metadata_reference_checks=ok`) |\n   218\t| 2026-04-12 | loop-012 | IQ-012 GGUF tensor info reader | done | Added `src/gguf/tensorinfo.HC` with tensor-name parsing, dim/product overflow guards, GGML type validation, and table lifetime helpers; validated with `python3 tests/test_gguf_tensorinfo_parse.py` + `python3 tests/test_gguf_metadata_parse.py` (`gguf_tensorinfo_reference_checks=ok`, `gguf_metadata_reference_checks=ok`) |\n   219\t| 2026-04-12 | loop-013 | IQ-013 Q4_0 block struct + dequant | done | Added `src/quant/q4_0.HC` with Q4_0 block layout, fp16->Q16 integer scale conversion, nibble unpack (`q-8`), single/multi-block dequant helpers; validated with `python3 tests/test_q4_0_dequant.py` + regression parsers (`q4_0_dequant_reference_checks=ok`) |\n   220\t\n   221\t## Blockers & Decisions\n   222\t\n   223\t- HolyC float support: deferred. Use integer-only quantized inference (Q4_0, Q8_0).\n   224\t- Model architecture: LLaMA family only. Single forward pass implementation.\n   225\t- Target model: TinyLlama 1.1B Q4_0 (~600MB). Proves correctness before scaling up.\n   226\t- All .HC files are HolyC source intended for TempleOS compilation. Host-side test\n   227\t  harnesses may use Python/C to validate outputs against llama.cpp reference.\n   228\t- Air-gap mandate: networking stack wo