utput for callers that always read inner offset.\n+    *out_offset_in_tensor = 0;\n+\n+    // Reuse relative-offset lookup so range-search, alignment checks,\n+    // sorted-index mapping, and malformed-range handling stay identical.\n+    err = GGUFTensorLookupByRelOffset(tensor_rel_offset,\n+                                      tensor_data_base,\n+                                      alignment,\n+                                      tensor_count,\n+                                      tensor_abs_starts,\n+                                      tensor_abs_ends,\n+                                      sorted_tensor_indices,\n+                                      &tensor_index,\n+                                      &abs_start,\n+                                      &abs_end);\n+    if (err != GGUF_TDBASE_OK)\n+        return err;\n+\n+    // Convert caller-provided relative offset to absolute byte position.\n+    // This preserves the same alignment/misalignment semantics as the core\n+    // range resolver used by GGUF parser paths.\n+    err = GGUFTensorDataBaseOffset(tensor_data_base,\n+                                   tensor_rel_offset,\n+                                   alignment,\n+                                   &abs_offset);\n+    if (err != GGUF_TDBASE_OK)\n+        return err;\n+\n+    if (abs_offset < abs_start || abs_offset >= abs_end)\n+        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS;\n+\n+    *out_tensor_index = tensor_index;\n+    *out_abs_start = abs_start;\n+    *out_abs_end = abs_end;\n+    *out_offset_in_tensor = abs_offset - abs_start;\n+    return GGUF_TDBASE_OK;\n+}\n---\ndiff --git a/tests/test_gguf_tensor_data_base.py b/tests/test_gguf_tensor_data_base.py\nindex 4f21b96..291829e 100644\n--- a/tests/test_gguf_tensor_data_base.py\n+++ b/tests/test_gguf_tensor_data_base.py\n@@ -796,6 +796,39 @@ def tensor_lookup_by_abs_offset_with_inner_offset(\n     return GGUF_TDBASE_OK, tensor_index, abs_start, abs_end, abs_offset - abs_start\n \n \n+def tensor_lookup_by_rel_offset_with_inner_offset(\n+    tensor_rel_offset: int,\n+    tensor_data_base: int,\n+    alignment: int,\n+    tensor_abs_starts: list[int],\n+    tensor_abs_ends: list[int],\n+    sorted_tensor_indices: list[int],\n+):\n+    err, tensor_index, abs_start, abs_end = tensor_lookup_by_rel_offset(\n+        tensor_rel_offset=tensor_rel_offset,\n+        tensor_data_base=tensor_data_base,\n+        alignment=alignment,\n+        tensor_abs_starts=tensor_abs_starts,\n+        tensor_abs_ends=tensor_abs_ends,\n+        sorted_tensor_indices=sorted_tensor_indices,\n+    )\n+    if err != GGUF_TDBASE_OK:\n+        return err, 0, 0, 0, 0\n+\n+    err, abs_offset = tensor_data_base_offset(\n+        tensor_data_base=tensor_data_base,\n+        tensor_rel_offset=tensor_rel_offset,\n+        alignment=alignment,\n+    )\n+    if err != GGUF_TDBASE_OK:\n+        return err, 0, 0, 0, 0\n+\n+    if abs_offset < abs_start or abs_offset >= abs_end:\n+        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0, 0, 0, 0\n+\n+    return GGUF_TDBASE_OK, tensor_index, abs_start, abs_end, abs_offset - abs_start\n+\n+\n def _abs_range_greater(\n     starts: list[int],\n     ends: list[int],\n@@ -2952,6 +2985,114 @@ def test_tensor_lookup_by_abs_offset_with_inner_offset_with_built_offset_index()\n             assert inner == (mid - abs_start)\n \n \n+def test_tensor_lookup_by_rel_offset_with_inner_offset_happy_path() -> None:\n+    starts = [0x1000, 0x1080, 0x1100]\n+    ends = [0x1020, 0x10B0, 0x1160]\n+    sorted_idx = [2, 0, 1]\n+\n+    assert tensor_lookup_by_rel_offset_with_inner_offset(0x00, 0x1000, 32, starts, ends, sorted_idx) == (\n+        GGUF_TDBASE_OK,\n+        2,\n+        0x1000,\n+        0x1020,\n+        0,\n+    )\n+    assert tensor_lookup_by_rel_offset_with_inner_offset(0x95, 0x1000, 1, starts, ends, sorted_idx) == (\n+        GGUF_TDBASE_OK,\n+        0,\n+        0x1080,\n+        0x10B0,\n+        0x15,\n+    )\n+    assert tensor_lookup_by_rel_offset_with_inner_offset(0x15F, 0x1000, 1, starts, ends, sorted_idx) == (\n+        GGUF_TDBASE_OK,\n+        1,\n+        0x1100,\n+        0x1160,\n+        0x5F,\n+    )\n+\n+\n+def test_tensor_lookup_by_rel_offset_with_inner_offset_propagates_errors() -> None:\n+    starts = [0x2000, 0x2100]\n+    ends = [0x2040, 0x2140]\n+    sorted_idx = [0, 1]\n+\n+    assert tensor_lookup_by_rel_offset_with_inner_offset(0x80, 0x2000, 32, starts, ends, sorted_idx) == (\n+        GGUF_TDBASE_ERR_OUT_OF_BOUNDS,\n+        0,\n+        0,\n+        0,\n+        0,\n+    )\n+    assert tensor_lookup_by_rel_offset_with_inner_offset(0x48, 0x2000, 32, starts, ends, sorted_idx) == (\n+        GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET,\n+        0,\n+        0,\n+        0,\n+        0,\n+    )\n+\n+\n+def test_tensor_lookup_by_rel_offset_with_inner_offset_with_built_offset_index() -> None:\n+    rel_offsets = [0x280, 0x00, 0x2C0, 0x40]\n+    elem_counts = [32, 64, 32, 128]\n+    ggml_types = [GGML_TYPE_Q8_0, GGML_TYPE_Q4_0, GGML_TYPE_F16, GGML_TYPE_F32]\n+    starts = [0, 0, 0, 0]\n+    ends = [0, 0, 0, 0]\n+    sorted_idx = [0, 0, 0, 0]\n+\n+    err, bad = tensor_info_build_offset_index(\n+        tensor_data_base=0x5000,\n+        alignment=32,\n+        gguf_file_nbytes=0x9000,\n+        tensor_rel_offsets=rel_offsets,\n+        tensor_element_counts=elem_counts,\n+        tensor_ggml_types=ggml_types,\n+        out_abs_starts=starts,\n+        out_abs_ends=ends,\n+        out_sorted_tensor_indices=sorted_idx,\n+    )\n+    assert err == GGUF_TDBASE_OK\n+    assert bad == 0\n+\n+    for original_idx in range(len(rel_offsets)):\n+        rel_start = rel_offsets[original_idx]\n+        abs_start = 0x5000 + rel_start\n+        err, tensor_index, out_start, out_end, inner = tensor_lookup_by_rel_offset_with_inner_offset(\n+            rel_start,\n+            0x5000,\n+            32,\n+            starts,\n+            ends,\n+            sorted_idx,\n+        )\n+        assert err == GGUF_