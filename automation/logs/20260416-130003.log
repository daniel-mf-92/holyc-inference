intlog_ratio_q16.py\n-rw-r--r--   1 danielmatthews-ferrero  staff    5196 Apr 15 16:33 test_q4_0_dequant.py\n-rw-r--r--   1 danielmatthews-ferrero  staff   13580 Apr 16 10:08 test_q4_0_dot.py\n-rw-r--r--   1 danielmatthews-ferrero  staff   23766 Apr 16 10:27 test_q4_0_q8_0_dot_kernel.py\n-rw-r--r--   1 danielmatthews-ferrero  staff    4719 Apr 15 16:33 test_q8_0_dequant.py\n-rw-r--r--   1 danielmatthews-ferrero  staff   28845 Apr 16 12:37 test_q8_0_dot.py\n-rw-r--r--   1 danielmatthews-ferrero  staff    5871 Apr 16 09:52 test_q8_0_dot_matrix_vector.py\n-rw-r--r--   1 danielmatthews-ferrero  staff    5676 Apr 16 12:47 test_q8_0_dot_matrix_vector_checked.py\n-rw-r--r--   1 danielmatthews-ferrero  staff   10563 Apr 16 12:55 test_q8_0_matmul_tiled_checked.py\n-rw-r--r--   1 danielmatthews-ferrero  staff    4811 Apr 15 21:44 test_softmax_entropy_q16.py\n--- q8 matmul ---\n// q8_0_matmul.HC\n// Checked tiled Q8_0 matmul kernel for TempleOS.\n//\n// Runtime contract:\n//   - lhs is an MxK matrix in row-major block layout (Q8_0 blocks).\n//   - rhs is an NxK matrix in row-major \"column bank\" layout where each output\n//     column of logical B (KxN) is stored as one contiguous row of K blocks.\n//     This keeps every output cell as an explicit row-dot between two block rows.\n//   - out is MxN Q16 matrix (I64 lanes) with explicit output row stride.\n\n#define Q8_0_MATMUL_VALUES_PER_BLOCK 32\n#define Q8_0_MATMUL_PACKED_BYTES     32\n\n#define Q8_0_MATMUL_OK               0\n#define Q8_0_MATMUL_ERR_NULL_PTR     1\n#define Q8_0_MATMUL_ERR_BAD_DST_LEN  2\n#define Q8_0_MATMUL_ERR_OVERFLOW     3\n#define Q8_0_MATMUL_I64_MAX          0x7FFFFFFFFFFFFFFF\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_MATMUL_PACKED_BYTES];\n};\n\n// Declared in src/quant/q8_0_dot.HC.\nI32 Q8_0DotProductBlocksQ16AccumulateChecked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16);\n\nBool Q8_0MatMulTryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs > Q8_0_MATMUL_I64_MAX / rhs)\n        return FALSE;\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nBool Q8_0MatMulTryAddI64NonNeg(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n    if (lhs > Q8_0_MATMUL_I64_MAX - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nI64 Q8_0MatMulMinI64(I64 lhs, I64 rhs)\n{\n    if (lhs < rhs)\n        return lhs;\n    return rhs;\n}\n\nI32 Q8_0MatMulQ16TiledChecked(\n    Q8_0Block *lhs_blocks,\n    I64 lhs_block_capacity,\n    I64 row_count,\n    I64 lhs_row_stride_blocks,\n    Q8_0Block *rhs_col_blocks,\n    I64 rhs_block_capacity,\n    I64 col_count,\n    I64 rhs_col_stride_blocks,\n    I64 k_block_count,\n    I64 tile_rows,\n    I64 tile_cols,\n    I64 *out_cells_q16,\n    I64 out_cell_capacity,\n    I64 out_row_stride_cells)\n{\n    I64 lhs_required_blocks;\n    I64 rhs_required_blocks;\n    I64 out_required_cells;\n    I64 row_tile_start;\n    I64 col_tile_start;\n    I64 row_tile_end;\n    I64 col_tile_end;\n    I64 row_index;\n    I64 col_index;\n    I64 lhs_row_base;\n    I64 rhs_col_base;\n    I64 out_row_base;\n    I64 out_index;\n    I64 cell_dot_q16;\n    Q8_0Block *lhs_row_ptr;\n    Q8_0Block *rhs_col_ptr;\n    I32 status;\n\n    if (!lhs_blocks || !rhs_col_blocks || !out_cells_q16)\n        return Q8_0_MATMUL_ERR_NULL_PTR;\n\n    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_cell_capacity < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (row_count < 0 || col_count < 0 || k_block_count < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (lhs_row_stride_blocks < 0 || rhs_col_stride_blocks < 0 || out_row_stride_cells < 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (tile_rows <= 0 || tile_cols <= 0)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Active K span must fit inside each source row stride.\n    if (k_block_count > lhs_row_stride_blocks || k_block_count > rhs_col_stride_blocks)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Output row stride must cover active output columns.\n    if (row_count > 0 && out_row_stride_cells < col_count)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Capacity proofs for full row-strided views.\n    if (!Q8_0MatMulTryMulI64NonNeg(row_count, lhs_row_stride_blocks, &lhs_required_blocks))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q8_0MatMulTryMulI64NonNeg(col_count, rhs_col_stride_blocks, &rhs_required_blocks))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n    if (!Q8_0MatMulTryMulI64NonNeg(row_count, out_row_stride_cells, &out_required_cells))\n        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n    if (lhs_required_blocks > lhs_block_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (rhs_required_blocks > rhs_block_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n    if (out_required_cells > out_cell_capacity)\n        return Q8_0_MATMUL_ERR_BAD_DST_LEN;\n\n    // Tiled traversal keeps working-set bounded while preserving direct math visibility.\n    row_tile_start = 0;\n    while (row_tile_start < row_count)\n    {\n        if (!Q8_0MatMulTryAddI64NonNeg(row_tile_start, tile_rows, &row_tile_end))\n            return Q8_0_MATMUL_ERR_OVERFLOW;\n        row_tile_end = Q8_0MatMulMinI64(row_tile_end, row_count);\n\n        col_tile_start = 0;\n        while (col_tile_start < col_count)\n        {\n            if (!Q8_0MatMulTryAddI64NonNeg(col_tile_start, tile_cols, &col_tile_end))\n                return Q8_0_MATMUL_ERR_OVERFLOW;\n            col_tile_end = Q8_0MatMulMinI64(col_tile_end, col_count);\n\n            for (row_index = row_tile_start; row_index < row_tile_end; ++row_index)\n            {\n                if (!Q8_0MatMulTryMulI64NonNeg(row_index, lhs_row_stride_blocks, &lhs_row_base))\n                    return Q8_0_MATMUL_ERR_OVERFLOW;\n                if (!Q8_0MatMulTryMulI64NonNeg(row_index, out_row_stride_cells, &out_row_base))\n                    return Q8_0_MATMUL_ERR_OVERFLOW;\n\n                lhs_row_ptr = &lhs_blocks[lhs_row_base];\n\n                for (col_index = col_tile_start; col_index < col_tile_end; ++col_index)\n                {\n                    if (!Q8_0MatMulTryMulI64NonNeg(col_index, rhs_col_stride_blocks, &rhs_col_base))\n                        return Q8_0_MATMUL_ERR_OVERFLOW;\n                    if (!Q8_0MatMulTryAddI64NonNeg(out_row_base, col_index, &out_index))\n                        return Q8_0_MATMUL_ERR_OVERFLOW;\n\n                    rhs_col_ptr = &rhs_col_blocks[rhs_col_base];\n                    cell_dot_q16 = 0;\n\n                    status = Q8_0DotProductBlocksQ16AccumulateChecked(lhs_row_ptr, rhs_col_ptr, k_block_count, &cell_dot_q16);\n                    if (status != Q8_0_MATMUL_OK)\n                        return status;\n\n                    out_cells_q16[out_index] = cell_dot_q16;\n                }\n            }\n\n            col_tile_start = col_tile_end;\n        }\n\n        row_tile_start = row_tile_end;\n    }\n\n    return Q8_0_MATMUL_OK;\n}\n\n--- mixed dot ---\n// q4_0_q8_0_dot.HC\n// Naive integer-only mixed Q4_0 x Q8_0 dot kernels for TempleOS.\n//\n// Math:\n//   Q4_0 decode: x_i = d4 * (q4_i - 8)\n//   Q8_0 decode: y_i = d8 * q8_i\n//\n// Integer HolyC form:\n//   d4_q16   = Round(d4 * 2^16)\n//   d8_q16   = Round(d8 * 2^16)\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (d4_q16 * d8_q16) * Sum(q4_signed_i * q8_signed_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q4_0_Q8_0_OK               0\n#define Q4_0_Q8_0_ERR_NULL_PTR     1\n#define Q4_0_Q8_0_ERR_BAD_DST_LEN  2\n#define Q4_0_Q8_0_ERR_OVERFLOW     3\n#define Q4_0_Q8_0_I64_MAX          0x7FFFFFFFFFFFFFFF\n#define Q4_0_Q8_0_I64_MIN          (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q4_0_Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0_Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0_Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0_Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0_Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0_Q8_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nBool Q4_0Q8_0TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q4_0_Q8_0_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q4_0_Q8_0_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nBool Q4_0Q8_0TryMulI64NonNeg(I64 lhs, I64 rhs, I64 *out_prod)\n{\n    if (!out_prod)\n        return FALSE;\n\n    if (lhs < 0 || rhs < 0)\n        return FALSE;\n\n    if (!lhs || !rhs)\n    {\n        *out_prod = 0;\n        return TRUE;\n    }\n\n    if (lhs > Q4_0_Q8_0_I64_MAX / rhs)\n        return FALSE;\n\n    *out_prod = lhs * rhs;\n    return TRUE;\n}\n\nI32 Q4_0_Q8_0DotProductBlockQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n    U8 packed_q4;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0_Q8_0F16ToQ16(lhs_q4->d_fp16);\n    rhs_scale_q16 = Q4_0_Q8_0F16ToQ16(rhs_q8->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // q_dot_q0 = Sum(q4_signed_i * q8_signed_i).\n    // Q4 stores two values per byte, so map each nibble to one Q8 lane.\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        packed_q4 = lhs_q4->qs[byte_index];\n\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, FALSE) * rhs_q8->qs[(byte_index << 1)];\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, TRUE) * rhs_q8->qs[(byte_index << 1) + 1];\n    }\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32);\n\nI32 Q4_0_Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    return Q4_0Q8_0DotProductBlocksQ32(lhs_q4, rhs_q8, block_count, out_dot_q32);\n}\n\nI32 Q4_0Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16);\n\nI32 Q4_0_Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16)\n{\n    return Q4_0Q8_0DotRowBlocksQ16(row_blocks_q4, vec_blocks_q8, block_count, out_dot_q16);\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        // Keep the widened Q32 accumulation explicit and checked.\n        // For realistic LLaMA dimensions this stays far inside I64,\n        // but we still hard-fail if a hostile input tries to overflow.\n        if (!Q4_0Q8_0TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n            return Q4_0_Q8_0_ERR_OVERFLOW;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32ToQ16(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    // Mixed-kernel WS4 matmul callers can keep the full dot in I64 Q32,\n    // then round once when handing the lane back to Q16 accumulation.\n    status = Q4_0Q8_0DotProductBlocksQ32(lhs_q4, rhs_q8, block_count, &total_dot_q32);\n    if (status != Q4_0_Q8_0_OK)\n        return status;\n\n    *out_dot_q16 = Q4_0_Q8_0DotQ32ToQ16(total_dot_q32);\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ16Accumulate(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !io_accum_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n\n    // Matmul callers accumulate rows in Q16 lanes.\n    // Keep each block explicit and auditable:\n    //   block_q32 -> rounded block_q16 -> add to running accumulator.\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        total_q16 += Q4_0_Q8_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *io_accum_q16 = total_q16;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ16AccumulateChecked(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 block_dot_q16;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !io_accum_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n\n    // Checked variant for hostile inputs:\n    //   block Q32 dot -> rounded Q16 -> checked add into accumulator lane.\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        block_dot_q16 = Q4_0_Q8_0DotQ32ToQ16(block_dot_q32);\n        if (!Q4_0Q8_0TryAddI64(total_q16, block_dot_q16,