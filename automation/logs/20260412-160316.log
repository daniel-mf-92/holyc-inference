{"type":"item.completed","item":{"id":"item_9","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' src/quant/q8_0_dot.HC; echo '---'; sed -n '1,260p' src/quant/q8_0.HC; echo '---'; sed -n '1,260p' tests/test_q8_0_dot.py; echo '---'; ls -la tests\"","aggregated_output":"// q8_0_dot.HC\n// Naive integer-only Q8_0 dot product kernels for TempleOS.\n//\n// Math:\n//   GGML Q8_0 stores 32 signed 8-bit values and one fp16 scale d per block.\n//   Decode uses: x_i = d * q_i\n//\n// Integer HolyC form:\n//   d_q16    = Round(d * 2^16)\n//   x_q16    = d_q16 * q_i\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (dA_q16 * dB_q16) * Sum(qA_i * qB_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q8_0_OK               0\n#define Q8_0_ERR_NULL_PTR     1\n#define Q8_0_ERR_BAD_DST_LEN  2\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0DotProductBlockQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q8_0F16ToQ16(lhs->d_fp16);\n    rhs_scale_q16 = Q8_0F16ToQ16(rhs->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // Keep the integer dot explicit and auditable:\n    // q_dot_q0 = Sum(qA_i * qB_i), with q in signed byte domain [-128, 127].\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q8_0_PACKED_BYTES; ++byte_index)\n        q_dot_q0 += lhs->qs[byte_index] * rhs->qs[byte_index];\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q8_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q8_0_OK;\n}\n\nI64 Q8_0DotQ32ToQ16(I64 dot_q32)\n{\n    return Q8_0RoundShiftRightSigned(dot_q32, 16);\n}\n\n---\n// q8_0.HC\n// Q8_0 block layout + integer-only dequantization helpers for TempleOS.\n//\n// GGML Q8_0 block layout (34 bytes total):\n//   - d_fp16 : fp16 scale\n//   - qs[32] : signed 8-bit quantized values\n//\n// Decode equation (reference):\n//   x = d * q\n//\n// Integer HolyC form:\n//   d_q16 = Round(d_fp16 * 2^16)\n//   x_q16 = d_q16 * q_signed\n//\n// Runtime path is integer-only after one fp16->Q16 conversion per block.\n\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n#define Q8_0_BLOCK_BYTES      34\n\n#define Q8_0_OK               0\n#define Q8_0_ERR_NULL_PTR     1\n#define Q8_0_ERR_BAD_DST_LEN  2\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    // Subnormal and zero:\n    // value = fraction * 2^-24, so Q16 = fraction * 2^-8.\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    // INF/NAN: saturate instead of trapping.\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    // Normal numbers:\n    // value = (1024 + fraction) * 2^(exp-25)\n    // Q16  = (1024 + fraction) * 2^(exp-9)\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0UnpackBlockSigned(Q8_0Block *block, I64 *dst_signed, I64 dst_len)\n{\n    I64 index;\n\n    if (!block || !dst_signed)\n        return Q8_0_ERR_NULL_PTR;\n    if (dst_len < Q8_0_VALUES_PER_BLOCK)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    for (index = 0; index < Q8_0_VALUES_PER_BLOCK; ++index)\n        dst_signed[index] = block->qs[index];\n\n    return Q8_0_OK;\n}\n\nI32 Q8_0DequantizeBlockQ16(Q8_0Block *block, I64 *dst_q16, I64 dst_len)\n{\n    I64 scale_q16;\n    I64 index;\n\n    if (!block || !dst_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (dst_len < Q8_0_VALUES_PER_BLOCK)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    scale_q16 = Q8_0F16ToQ16(block->d_fp16);\n\n    // Explicit element-wise integer decode keeps math auditable:\n    // x_q16 = d_q16 * q_signed.\n    for (index = 0; index < Q8_0_VALUES_PER_BLOCK; ++index)\n        dst_q16[index] = scale_q16 * block->qs[index];\n\n    return Q8_0_OK;\n}\n\nI32 Q8_0DequantizeBlocksQ16(Q8_0Block *blocks, I64 block_count, I64 *dst_q16, I64 dst_len)\n{\n    I64 block_index;\n    I64 dst_offset;\n    I32 status;\n\n    if (!blocks || !dst_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n    if (dst_len < block_count * Q8_0_VALUES_PER_BLOCK)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    dst_offset = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DequantizeBlockQ16(&blocks[block_index], &dst_q16[dst_offset], Q8_0_VALUES_PER_BLOCK);\n        if (status != Q8_0_OK)\n            return status;\n\n        dst_offset += Q8_0_VALUES_PER_BLOCK;\n    }\n\n    return Q8_0_OK;\n}\n\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0 integer-only dot product semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ8_0_VALUES_PER_BLOCK = 32\nQ8_0_PACKED_BYTES = 32\n\nQ8_0_OK = 0\nQ8_0_ERR_NULL_PTR = 1\nQ8_0_ERR_BAD_DST_LEN = 2\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    round_bias = 1 << (shift - 1)\n    return (value + round_bias) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef f16_to_q16(fp16_bits: int) -> int:\n    sign_bit = (fp16_bits >> 15) & 1\n    exponent_bits = (fp16_bits >> 10) & 0x1F\n    fraction_bits = fp16_bits & 0x03FF\n\n    if exponent_bits == 0:\n        if fraction_bits == 0:\n            return 0\n        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n        return -magnitude_q16 if sign_bit else magnitude_q16\n\n    if exponent_bits == 0x1F:\n        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n\n    mantissa = 1024 + fraction_bits\n    shift_amount = exponent_bits - 9\n    if shift_amount >= 0:\n        magnitude_q16 = mantissa << shift_amount\n    else:\n        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n\n    return -magnitude_q16 if sign_bit else magnitude_q16\n\n\ndef half_bits(value: float) -> int:\n    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n\n\ndef pack_signed(values: list[int]) -> bytes:\n    assert len(values) == Q8_0_PACKED_BYTES\n    return bytes((v + 256) % 256 for v in values)\n\n\ndef unpack_signed(qs: bytes) -> list[int]:\n    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n\n\ndef dot_product_block_q32(\n    lhs_scale_fp16: int,\n    lhs_qs: bytes,\n    rhs_scale_fp16: int,\n    rhs_qs: bytes,\n) -> tuple[int, int]:\n    if len(lhs_qs) != Q8_0_PACKED_BYTES or len(rhs_qs) != Q8_0_PACKED_BYTES:\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    lhs_signed = unpack_signed(lhs_qs)\n    rhs_signed = unpack_signed(rhs_qs)\n\n    q_dot_q0 = 0\n    for lhs_q, rhs_q in zip(lhs_signed, rhs_signed):\n        q_dot_q0 += lhs_q * rhs_q\n\n    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n    dot_q32 = lhs_scale_q16 * rhs_scale_q16 * q_dot_q0\n    return Q8_0_OK, dot_q32\n\n\ndef dot_product_blocks_q32(\n    lhs_blocks: list[tuple[int, bytes]],\n    rhs_blocks: list[tuple[int, bytes]],\n) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q8_0_ERR_BAD_DST_LEN, 0\n\n    total = 0\n    for (lhs_scale, lhs_qs), (rhs_scale, rhs_qs) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot = dot_product_block_q32(lhs_scale, lhs_qs, rhs_scale, rhs_qs)\n        if err != Q8_0_OK:\n            return err, 0\n        total += block_dot\n\n    return Q8_0_OK, total\n\n\ndef dot_q32_to_q16(dot_q32: int) -> int:\n    return round_shift_right_signed(dot_q32, 16)\n\n\ndef test_identity_block() -> None:\n    lhs_scale_fp16 = half_bits(1.0)\n    rhs_scale_fp16 = half_bits(1.0)\n    signed = list(range(-16, 16))\n    packed = pack_signed(signed)\n\n    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, packed, rhs_scale_fp16, packed)\n    assert err == Q8_0_OK\n\n    expected_q0 = sum(v * v for v in signed)\n    expected_q32 = expected_q0 * (1 << 32)\n    assert got_q32 == expected_q32\n    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n\n\ndef test_negative_scale_sign() -> None:\n    lhs_scale_fp16 = half_bits(-0.5)\n    rhs_scale_fp16 = half_bits(2.0)\n\n    lhs_signed = [5] * Q8_0_VALUES_PER_BLOCK\n    rhs_signed = [3] * Q8_0_VALUES_PER_BLOCK\n\n    err, got_q32 = dot_product_block_q32(\n        lhs_scale_fp16,\n        pack_signed(lhs_signed),\n        rhs_scale_fp16,\n        pack_signed(rhs_signed),\n    )\n    assert err == Q8_0_OK\n\n    expected_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n    expected_q32 = -expected_q0 * (1 << 32)\n    assert got_q32 == expected_q32\n\n\ndef test_random_blocks_match_float_reference_bounds() -> None:\n    rng = random.Random(992244)\n\n    for _ in range(400):\n        lhs_scale = rng.uniform(-3.0, 3.0)\n        rhs_scale = rng.uniform(-3.0, 3.0)\n        lhs_scale_fp16 = half_bits(lhs_scale)\n        rhs_scale_fp16 = half_bits(rhs_scale)\n\n        lhs_signed = [rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)]\n        rhs_signed = [rng.randint(-128, 127) for _ in range(Q8_0_VALUES_PER_BLOCK)]\n\n        err, got_q32 = dot_product_block_q32(\n            lhs_scale_fp16,\n            pack_signed(lhs_signed),\n            rhs_scale_fp16,\n            pack_signed(rhs_signed),\n        )\n        assert err == Q8_0_OK\n\n        dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n        expected_int_q32 = lhs_scale_q16 * rhs_scale_q16 * dot_q0\n        assert got_q32 == expected_int_q32\n\n        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * dot_q0 * (1 << 32))\n\n        # Integer path rounds scales once to Q16. Tight deterministic bound.\n        assert abs(got_q32 - expected_float_q32) <= 700_000_000\n\n\ndef test_multiblock_accumulation() -> None:\n    lhs_blocks = [\n        (half_bits(1.0), pack_signed([1] * Q8_0_VALUES_PER_BLOCK)),\n        (half_bits(0.5), pack_signed([2] * Q8_0_VALUES_PER_BLOCK)),\n    ]\n    rhs_blocks = [\n        (half_bits(1.0), pack_signed([3] * Q8_0_VALUES_PER_BLOCK)),\n        (half_bits(-2.0), pack_signed([4] * Q8_0_VALUES_PER_BLOCK)),\n    ]\n\n    err, got_total_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n    assert err == Q8_0_OK\n\n    _, block0 = dot_product_block_q32(*lhs_blocks[0], *rhs_blocks[0])\n    _, block1 = dot_product_block_q32(*lhs_blocks[1], *rhs_blocks[1])\n    assert got_total_q32 == block0 + block1\n\n\ndef test_error_on_bad_input_length() -> None:\n    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 31, half_bits(1.0), b\"\\x00\" * 32)\n    assert err == Q8_0_ERR_BAD_DST_LEN\n\n\ndef run() -> None:\n    test_identity_block()\n    test_negative_scale_sign()\n    test_random_blocks_match_float_reference_bounds()\n    test_multiblock_accumulation()\n    test_error_on_bad_input_length()\n    print(\"q8_0_dot_reference_checks=ok\")\n\n\nif __name__ == \"__main__\":\n    run()\n\n---\ntotal 112\ndrwxr-xr-x   9 danielmatthews-ferrero  staff   288 Apr 12 15:59 .\ndrwxr-xr-x  10 danielmatthews-ferrero  staff   320 Apr 12 15:54 ..\n-rw-r--r--   1 danielmatthews-ferrero  staff  7842 Apr 12 15:14 test_gguf_metadata_parse.py\n-rw-r--r--   1 danielmatthews-ferrero  staff  5050 Apr 12 15:21 test_gguf_tensorinfo_parse.py\n-rw-r--r--   1 danielmatthews-ferrero  staff  5196 Apr 12 15:32 test_q4_0_dequant.py\n-rw-r--r--   1 danielmatthews-ferrero  staff  5846 Apr 12 15:38 test_q4_0_dot.py\n-rw-r--r--   1 danielmatthews-ferrero  staff  6758 Apr 12 15:59 test_q4_0_q8_0_dot_kernel.py\n-rw-r--r--   1 danielmatthews-ferrero  staff  4719 Apr 12 15:44 test_q8_0_dequant.py\n-rw-r--r--   1 danielmatthews-ferrero  staff  6521 Apr 12 15:52 test_q8_0_dot.py\n","exit_code":0,"status":"completed"}}
