{"type":"item.completed","item":{"id":"item_13","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' src/quant/q4_0_q8_0_dot.HC; sed -n '1,320p' tests/test_q4_0_q8_0_dot_kernel.py; sed -n '1,220p' src/quant/q4_0_dot.HC; sed -n '1,220p' src/quant/q8_0_dot.HC\"","aggregated_output":"// q4_0_q8_0_dot.HC\n// Naive integer-only mixed Q4_0 x Q8_0 dot kernels for TempleOS.\n//\n// Math:\n//   Q4_0 decode: x_i = d4 * (q4_i - 8)\n//   Q8_0 decode: y_i = d8 * q8_i\n//\n// Integer HolyC form:\n//   d4_q16   = Round(d4 * 2^16)\n//   d8_q16   = Round(d8 * 2^16)\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (d4_q16 * d8_q16) * Sum(q4_signed_i * q8_signed_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q4_0_Q8_0_OK               0\n#define Q4_0_Q8_0_ERR_NULL_PTR     1\n#define Q4_0_Q8_0_ERR_BAD_DST_LEN  2\n#define Q4_0_Q8_0_ERR_OVERFLOW     3\n#define Q4_0_Q8_0_I64_MAX          0x7FFFFFFFFFFFFFFF\n#define Q4_0_Q8_0_I64_MIN          (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nI64 Q4_0_Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0_Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0_Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0_Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0_Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0_Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0_Q8_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nBool Q4_0Q8_0TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q4_0_Q8_0_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q4_0_Q8_0_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nI32 Q4_0_Q8_0DotProductBlockQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n    U8 packed_q4;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0_Q8_0F16ToQ16(lhs_q4->d_fp16);\n    rhs_scale_q16 = Q4_0_Q8_0F16ToQ16(rhs_q8->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // q_dot_q0 = Sum(q4_signed_i * q8_signed_i).\n    // Q4 stores two values per byte, so map each nibble to one Q8 lane.\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        packed_q4 = lhs_q4->qs[byte_index];\n\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, FALSE) * rhs_q8->qs[(byte_index << 1)];\n        q_dot_q0 += Q4_0_Q8_0NibbleToSigned(packed_q4, TRUE) * rhs_q8->qs[(byte_index << 1) + 1];\n    }\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32);\n\nI32 Q4_0_Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    return Q4_0Q8_0DotProductBlocksQ32(lhs_q4, rhs_q8, block_count, out_dot_q32);\n}\n\nI32 Q4_0Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16);\n\nI32 Q4_0_Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16)\n{\n    return Q4_0Q8_0DotRowBlocksQ16(row_blocks_q4, vec_blocks_q8, block_count, out_dot_q16);\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q32)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        // Keep the widened Q32 accumulation explicit and checked.\n        // For realistic LLaMA dimensions this stays far inside I64,\n        // but we still hard-fail if a hostile input tries to overflow.\n        if (!Q4_0Q8_0TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n            return Q4_0_Q8_0_ERR_OVERFLOW;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotProductBlocksQ32ToQ16(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !out_dot_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    // Mixed-kernel WS4 matmul callers can keep the full dot in I64 Q32,\n    // then round once when handing the lane back to Q16 accumulation.\n    status = Q4_0Q8_0DotProductBlocksQ32(lhs_q4, rhs_q8, block_count, &total_dot_q32);\n    if (status != Q4_0_Q8_0_OK)\n        return status;\n\n    *out_dot_q16 = Q4_0_Q8_0DotQ32ToQ16(total_dot_q32);\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0_Q8_0DotProductBlocksQ16Accumulate(Q4_0Block *lhs_q4, Q8_0Block *rhs_q8, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs_q4 || !rhs_q8 || !io_accum_q16)\n        return Q4_0_Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN;\n\n    total_q16 = *io_accum_q16;\n\n    // Matmul callers accumulate rows in Q16 lanes.\n    // Keep each block explicit and auditable:\n    //   block_q32 -> rounded block_q16 -> add to running accumulator.\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0_Q8_0DotProductBlockQ32(&lhs_q4[block_index], &rhs_q8[block_index], &block_dot_q32);\n        if (status != Q4_0_Q8_0_OK)\n            return status;\n\n        total_q16 += Q4_0_Q8_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *io_accum_q16 = total_q16;\n    return Q4_0_Q8_0_OK;\n}\n\nI32 Q4_0Q8_0DotRowBlocksQ16(Q4_0Block *row_blocks_q4, Q8_0Block *vec_blocks_q8, I64 block_count, I64 *out_dot_q16)\n{\n    I64 accum_q16;\n    I32 status;\n#!/usr/bin/env python3\n\"\"\"Reference checks for integer mixed Q4_0 x Q8_0 dot-product semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport random\nimport struct\n\nQ4_0_PACKED_BYTES = 16\nQ8_0_PACKED_BYTES = 32\n\nQ4_0_Q8_0_OK = 0\nQ4_0_Q8_0_ERR_NULL_PTR = 1\nQ4_0_Q8_0_ERR_BAD_DST_LEN = 2\nQ4_0_Q8_0_ERR_OVERFLOW = 3\n\n\ndef round_shift_right_unsigned(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    round_bias = 1 << (shift - 1)\n    return (value + round_bias) >> shift\n\n\ndef round_shift_right_signed(value: int, shift: int) -> int:\n    if shift <= 0:\n        return value\n    if value >= 0:\n        return round_shift_right_unsigned(value, shift)\n    return -round_shift_right_unsigned(-value, shift)\n\n\ndef f16_to_q16(fp16_bits: int) -> int:\n    sign_bit = (fp16_bits >> 15) & 1\n    exponent_bits = (fp16_bits >> 10) & 0x1F\n    fraction_bits = fp16_bits & 0x03FF\n\n    if exponent_bits == 0:\n        if fraction_bits == 0:\n            return 0\n        magnitude_q16 = round_shift_right_unsigned(fraction_bits, 8)\n        return -magnitude_q16 if sign_bit else magnitude_q16\n\n    if exponent_bits == 0x1F:\n        return -(0x3FFFFFFFFFFFFFFF) if sign_bit else 0x3FFFFFFFFFFFFFFF\n\n    mantissa = 1024 + fraction_bits\n    shift_amount = exponent_bits - 9\n    if shift_amount >= 0:\n        magnitude_q16 = mantissa << shift_amount\n    else:\n        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n\n    return -magnitude_q16 if sign_bit else magnitude_q16\n\n\ndef half_bits(value: float) -> int:\n    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n\n\ndef nibble_to_signed(packed: int, upper_nibble: bool) -> int:\n    if upper_nibble:\n        q_unsigned = (packed >> 4) & 0x0F\n    else:\n        q_unsigned = packed & 0x0F\n    return q_unsigned - 8\n\n\ndef unpack_q4_signed(qs: bytes) -> list[int]:\n    out: list[int] = []\n    for packed in qs:\n        out.append(nibble_to_signed(packed, False))\n        out.append(nibble_to_signed(packed, True))\n    return out\n\n\ndef unpack_q8_signed(qs: bytes) -> list[int]:\n    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n\n\ndef pack_q4_from_signed(vals: list[int]) -> bytes:\n    assert len(vals) == 32\n    out = bytearray()\n    for idx in range(0, 32, 2):\n        lo = vals[idx] + 8\n        hi = vals[idx + 1] + 8\n        assert 0 <= lo <= 15 and 0 <= hi <= 15\n        out.append((lo & 0x0F) | ((hi & 0x0F) << 4))\n    return bytes(out)\n\n\ndef pack_q8_signed(vals: list[int]) -> bytes:\n    assert len(vals) == 32\n    return bytes((v + 256) % 256 for v in vals)\n\n\ndef dot_product_block_q32(lhs_scale_fp16: int, lhs_q4: bytes, rhs_scale_fp16: int, rhs_q8: bytes) -> tuple[int, int]:\n    if len(lhs_q4) != Q4_0_PACKED_BYTES or len(rhs_q8) != Q8_0_PACKED_BYTES:\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n\n    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n    rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16\n\n    lhs_signed = unpack_q4_signed(lhs_q4)\n    rhs_signed = unpack_q8_signed(rhs_q8)\n    q_dot_q0 = sum(a * b for a, b in zip(lhs_signed, rhs_signed))\n    return Q4_0_Q8_0_OK, scale_prod_q32 * q_dot_q0\n\n\ndef dot_product_blocks_q32(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n\n    total = 0\n    for (l_scale, l_q4), (r_scale, r_q8) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot = dot_product_block_q32(l_scale, l_q4, r_scale, r_q8)\n        if err != Q4_0_Q8_0_OK:\n            return err, 0\n        total += block_dot\n\n    return Q4_0_Q8_0_OK, total\n\n\ndef dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n    err, dot_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n    if err != Q4_0_Q8_0_OK:\n        return err, 0\n    return Q4_0_Q8_0_OK, dot_q32_to_q16(dot_q32)\n\n\ndef dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, initial_accum_q16: int) -> tuple[int, int]:\n    if len(lhs_blocks) != len(rhs_blocks):\n        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n\n    total_q16 = initial_accum_q16\n    for (l_scale, l_q4), (r_scale, r_q8) in zip(lhs_blocks, rhs_blocks):\n        err, block_dot_q32 = dot_product_block_q32(l_scale, l_q4, r_scale, r_q8)\n        if err != Q4_0_Q8_0_OK:\n            return err, 0\n        total_q16 += dot_q32_to_q16(block_dot_q32)\n\n    return Q4_0_Q8_0_OK, total_q16\n\n\ndef dot_row_blocks_q16(lhs_blocks, rhs_blocks) -> tuple[int, int]:\n    return dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n\n\ndef dot_q32_to_q16(dot_q32: int) -> int:\n    return round_shift_right_signed(dot_q32, 16)\n\n\ndef test_identity_mixed_block() -> None:\n    lhs_scale_fp16 = half_bits(1.0)\n    rhs_scale_fp16 = half_bits(1.0)\n\n    q4_signed = [((idx % 16) - 8) for idx in range(32)]\n    q8_signed = q4_signed[:]\n\n    lhs_q4 = pack_q4_from_signed(q4_signed)\n    rhs_q8 = pack_q8_signed(q8_signed)\n\n    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n    assert err == Q4_0_Q8_0_OK\n\n    expected_q0 = sum(v * v for v in q4_signed)\n    expected_q32 = (1 << 16) * (1 << 16) * expected_q0\n    assert got_q32 == expected_q32\n    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n\n\ndef test_random_blocks_match_integer_reference() -> None:\n    rng = random.Random(20260412)\n\n    for _ in range(500):\n        lhs_scale = rng.uniform(-4.0, 4.0)\n        rhs_scale = rng.uniform(-4.0, 4.0)\n\n        lhs_scale_fp16 = half_bits(lhs_scale)\n        rhs_scale_fp16 = half_bits(rhs_scale)\n\n        q4_signed = [rng.randrange(-8, 8) for _ in range(32)]\n        q8_signed = [rng.randrange(-128, 128) for _ in range(32)]\n\n        lhs_q4 = pack_q4_from_signed(q4_signed)\n        rhs_q8 = pack_q8_signed(q8_signed)\n\n        err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n        assert err == Q4_0_Q8_0_OK\n\n        expected_q0 = sum(a * b for a, b in zip(q4_signed, q8_signed))\n        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n        expected_q32 = lhs_scale_q16 * rhs_scale_q16 * expected_q0\n        assert got_q32 == expected_q32\n\n        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * expected_q0 * (1 << 32))\n\n        # Integer path rounds scales once to Q16 then multiplies.\n        assert abs(got_q32 - expected_float_q32) <= 70_000_000\n\n\ndef test_multiblock_accumulation() -> None:\n    b0 = (half_bits(0.75), pack_q4_from_signed([((i % 8) - 4) for i in range(32)]))\n    b1 = (half_bits(-0.5), pack_q4_from_signed([4 - (i % 8) for i in range(32)]))\n\n    r0 = (half_bits(1.25), pack_q8_signed([((i % 11) - 5) * 3 for i in range(32)]))\n    r1 = (half_bits(-1.5), pack_q8_signed([7 - (i % 13) for i in range(32)]))\n\n    err, total = dot_product_blocks_q32([b0, b1], [r0, r1])\n    assert err == Q4_0_Q8_0_OK\n\n    _, part0 = dot_product_block_q32(*b0, *r0)\n    _, part1 = dot_product_block_q32(*b1, *r1)\n    assert total == part0 + part1\n\n\ndef test_error_on_bad_lengths() -> None:\n    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 15, half_bits(1.0), b\"\\x00\" * 32)\n    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n\n    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 16, half_bits(1.0), b\"\\x00\" * 31)\n    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n\n\ndef test_q16_accumulator_helper_matches_blockwise_rounding() -> None:\n    rng = random.Random(2026041217)\n\n    for _ in range(250):\n        block_count = rng.randint(1, 6)\n        lhs_blocks = []\n        rhs_blocks = []\n\n        for _ in range(block_count):\n            l_scale = half_bits(rng.uniform(-3.0, 3.0))\n            r_scale = half_bits(rng.uniform(-3.0, 3.0))\n            l_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n            r_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n            lhs_blocks.append((l_scale, l_q4))\n            rhs_blocks.append((r_scale, r_q8))\n\n        initial_accum = rng.randint(-(1 << 30), (1 << 30))\n        err, got_q16 = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, initial_accum)\n        assert err == Q4_0_Q8_0_OK\n\n        expected_q16 = initial_accum\n        for lhs_block, rhs_block in zip(lhs_blocks, rhs_blocks):\n            err, block_dot_q32 = dot_product_block_q32(*lhs_block, *rhs_block)\n            assert err == Q4_0_Q8_0_OK\n            expected_q16 += dot_q32_to_q16(block_dot_q32)\n\n        assert got_q16 == expected_q16\n\n\ndef test_q32_to_q16_helper_rounds_once_after_full_accumulation() -> None:\n    b0 = (half_bits(0.125), pack_q4_from_signed([7] * 32))\n    b1 = (half_bits(0.125), pack_q4_from_signed([-8] * 32))\n    r0 = (half_bits(0.125), pack_q8_signed([127] * 32))\n    r1 = (half_bits(0.125), pack_q8_signed([127] * 32))\n\n    err, dot_q16_single_round = dot_product_blocks_q32_to_q16([b0, b1], [r0, r1])\n    assert err == Q4_0_Q8_0_OK\n\n    err, dot_q16_blockwise = dot_product_blocks_q16_accumulate([b0, b1], [r0, r1], 0)\n    assert err == Q4_0_Q8_0_OK\n\n    # This vector pair intentionally exercises fractional cancellation.\n    # Full-dot single rounding (Q32->Q16 once) is the IQ-085 contract,\n    # while blockwise Q16 accumulation can differ by a few LSBs.\n    assert abs(dot_q16_single_round - dot_q16_blockwise) <= 2\n\n\ndef test_q32_to_q16_helper_matches_full_dot_reference() -> None:\n    rng = random.Random(202604151)\n\n    for _ in range(200):\n        block_count = rng.randint(1, 8)\n        lhs_blocks = []\n        rhs_blocks = []\n\n        for _ in range(block_count):\n            l_scale = half_bits(rng.uniform(-3.5, 3.5))\n            r_scale = half_bits(rng.uniform(-3.5, 3.5))\n            l_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n            r_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n            lhs_blocks.append((l_scale, l_q4))\n            rhs_blocks.append((r_scale, r_q8))\n\n        err, got_q16 = dot_product_blocks_q32_to_q16(lhs_blocks, rhs_blocks)\n        assert err == Q4_0_Q8_0_OK\n\n        err, full_q32 = dot_product_blocks_q32(lhs_blocks, rhs_blocks)\n        assert err == Q4_0_Q8_0_OK\n        assert got_q16 == dot_q32_to_q16(full_q32)\n\n\ndef test_q16_accumulator_bad_length_error() -> None:\n    lhs_blocks = [(half_bits(1.0), pack_q4_from_signed([0] * 32))]\n    rhs_blocks = []\n    err, _ = dot_product_blocks_q16_accumulate(lhs_blocks, rhs_blocks, 0)\n    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n\n\ndef test_row_helper_matches_zero_init_accumulate() -> None:\n    rng = random.Random(2026041527)\n\n    for _ in range(220):\n        block_count = rng.randint(1, 8)\n        lhs_blocks = []\n        rhs_blocks = []\n\n        for _ in range(block_count):\n            l_scale = half_bits(rng.uniform(-3.25, 3.25))\n            r_scale = half_bits(rng.uniform(-3.25, 3.25))\n            l_q4 = pack_q4_from_signed([rng.randrange(-8, 8) for _ in range(32)])\n            r_q8 = pack_q8_signed([rng.randrange(-128, 128) for _ in range(32)])\n            lhs_blocks.append((l_scale, l_q4))\n// q4_0_dot.HC\n// Naive integer-only Q4_0 dot product kernels for TempleOS.\n//\n// Math:\n//   For each block, GGML Q4_0 stores 32 4-bit values and one fp16 scale d.\n//   Decode uses: x_i = d * (q_i - 8)\n//\n// Integer HolyC form:\n//   d_q16   = Round(d * 2^16)\n//   q_s     = nibble - 8   (in [-8, 7])\n//   x_q16   = d_q16 * q_s\n//   dot_q32 = Sum(x_q16 * y_q16)\n//           = (dA_q16 * dB_q16) * Sum(qA_s * qB_s)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q4_0_VALUES_PER_BLOCK 32\n#define Q4_0_PACKED_BYTES     16\n\n#define Q4_0_OK               0\n#define Q4_0_ERR_NULL_PTR     1\n#define Q4_0_ERR_BAD_DST_LEN  2\n\nclass Q4_0Block\n{\n    U16 d_fp16;\n    U8 qs[Q4_0_PACKED_BYTES];\n};\n\nI64 Q4_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q4_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q4_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q4_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q4_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q4_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI64 Q4_0NibbleToSigned(U8 packed, Bool upper_nibble)\n{\n    I64 q_unsigned;\n\n    if (upper_nibble)\n        q_unsigned = (packed >> 4) & 0x0F;\n    else\n        q_unsigned = packed & 0x0F;\n\n    return q_unsigned - 8;\n}\n\nI32 Q4_0DotProductBlockQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 nibble_dot_q0;\n    I64 byte_index;\n    U8 lhs_packed;\n    U8 rhs_packed;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q4_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q4_0F16ToQ16(lhs->d_fp16);\n    rhs_scale_q16 = Q4_0F16ToQ16(rhs->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    nibble_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q4_0_PACKED_BYTES; ++byte_index)\n    {\n        lhs_packed = lhs->qs[byte_index];\n        rhs_packed = rhs->qs[byte_index];\n\n        nibble_dot_q0 += Q4_0NibbleToSigned(lhs_packed, FALSE) * Q4_0NibbleToSigned(rhs_packed, FALSE);\n        nibble_dot_q0 += Q4_0NibbleToSigned(lhs_packed, TRUE) * Q4_0NibbleToSigned(rhs_packed, TRUE);\n    }\n\n    *out_dot_q32 = scale_prod_q32 * nibble_dot_q0;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotProductBlocksQ32(Q4_0Block *lhs, Q4_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q4_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotProductBlocksQ32ToQ16(Q4_0Block *lhs, Q4_0Block *rhs, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q16)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    // WS4 matmul callers can keep a widened I64 Q32 path for the full dot,\n    // then round once to Q16 at the hand-off boundary.\n    status = Q4_0DotProductBlocksQ32(lhs, rhs, block_count, &total_dot_q32);\n    if (status != Q4_0_OK)\n        return status;\n\n    *out_dot_q16 = Q4_0DotQ32ToQ16(total_dot_q32);\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotRowBlocksQ16(Q4_0Block *row_blocks, Q4_0Block *vec_blocks, I64 block_count, I64 *out_dot_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q16;\n    I32 status;\n\n    if (!row_blocks || !vec_blocks || !out_dot_q16)\n        return Q4_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q4_0_ERR_BAD_DST_LEN;\n\n    // Matmul row kernels usually keep accumulators in Q16 lanes.\n    // Convert each block dot Q32->Q16 with explicit rounding before summation,\n    // so every 32-value block contribution stays auditable and deterministic.\n    total_dot_q16 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q4_0DotProductBlockQ32(&row_blocks[block_index], &vec_blocks[block_index], &block_dot_q32);\n        if (status != Q4_0_OK)\n            return status;\n\n        total_dot_q16 += Q4_0DotQ32ToQ16(block_dot_q32);\n    }\n\n    *out_dot_q16 = total_dot_q16;\n    return Q4_0_OK;\n}\n\nI32 Q4_0DotRowsQ16MatrixVector(Q4_0Block *matrix_blocks, I64 row_count, I64 row_stride_blocks, Q4_0Block *vec_blocks, I64 vec_block_count, I64 *out_rows_q16)\n{\n    I64 row_index;\n    I64 row_dot_q16;\n    Q4_0Block *row_ptr;\n    I32 status;\n\n// q8_0_dot.HC\n// Naive integer-only Q8_0 dot product kernels for TempleOS.\n//\n// Math:\n//   GGML Q8_0 stores 32 signed 8-bit values and one fp16 scale d per block.\n//   Decode uses: x_i = d * q_i\n//\n// Integer HolyC form:\n//   d_q16    = Round(d * 2^16)\n//   x_q16    = d_q16 * q_i\n//   dot_q32  = Sum(x_q16 * y_q16)\n//            = (dA_q16 * dB_q16) * Sum(qA_i * qB_i)\n//\n// dot_q32 keeps 32 fractional bits; caller may round to Q16 as needed.\n\n#define Q8_0_VALUES_PER_BLOCK 32\n#define Q8_0_PACKED_BYTES     32\n\n#define Q8_0_OK               0\n#define Q8_0_ERR_NULL_PTR     1\n#define Q8_0_ERR_BAD_DST_LEN  2\n#define Q8_0_ERR_OVERFLOW     3\n#define Q8_0_I64_MAX          0x7FFFFFFFFFFFFFFF\n#define Q8_0_I64_MIN          (-0x7FFFFFFFFFFFFFFF - 1)\n\nclass Q8_0Block\n{\n    U16 d_fp16;\n    I8 qs[Q8_0_PACKED_BYTES];\n};\n\nBool Q8_0TryAddI64(I64 lhs, I64 rhs, I64 *out_sum)\n{\n    if (!out_sum)\n        return FALSE;\n\n    if (rhs > 0 && lhs > Q8_0_I64_MAX - rhs)\n        return FALSE;\n    if (rhs < 0 && lhs < Q8_0_I64_MIN - rhs)\n        return FALSE;\n\n    *out_sum = lhs + rhs;\n    return TRUE;\n}\n\nI64 Q8_0RoundShiftRightUnsigned(I64 value, I64 shift)\n{\n    I64 round_bias;\n\n    if (shift <= 0)\n        return value;\n\n    round_bias = 1 << (shift - 1);\n    return (value + round_bias) >> shift;\n}\n\nI64 Q8_0RoundShiftRightSigned(I64 value, I64 shift)\n{\n    if (shift <= 0)\n        return value;\n\n    if (value >= 0)\n        return Q8_0RoundShiftRightUnsigned(value, shift);\n\n    return -Q8_0RoundShiftRightUnsigned(-value, shift);\n}\n\nI64 Q8_0F16ToQ16(U16 fp16_bits)\n{\n    I64 sign_bit;\n    I64 exponent_bits;\n    I64 fraction_bits;\n    I64 mantissa;\n    I64 shift_amount;\n    I64 magnitude_q16;\n\n    sign_bit = (fp16_bits >> 15) & 1;\n    exponent_bits = (fp16_bits >> 10) & 0x1F;\n    fraction_bits = fp16_bits & 0x03FF;\n\n    if (!exponent_bits)\n    {\n        if (!fraction_bits)\n            return 0;\n\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(fraction_bits, 8);\n        if (sign_bit)\n            return -magnitude_q16;\n        return magnitude_q16;\n    }\n\n    if (exponent_bits == 0x1F)\n    {\n        if (sign_bit)\n            return -0x3FFFFFFFFFFFFFFF;\n        return 0x3FFFFFFFFFFFFFFF;\n    }\n\n    mantissa = 1024 + fraction_bits;\n    shift_amount = exponent_bits - 9;\n\n    if (shift_amount >= 0)\n        magnitude_q16 = mantissa << shift_amount;\n    else\n        magnitude_q16 = Q8_0RoundShiftRightUnsigned(mantissa, -shift_amount);\n\n    if (sign_bit)\n        return -magnitude_q16;\n    return magnitude_q16;\n}\n\nI32 Q8_0DotProductBlockQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 *out_dot_q32)\n{\n    I64 lhs_scale_q16;\n    I64 rhs_scale_q16;\n    I64 scale_prod_q32;\n    I64 byte_index;\n    I64 q_dot_q0;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n\n    lhs_scale_q16 = Q8_0F16ToQ16(lhs->d_fp16);\n    rhs_scale_q16 = Q8_0F16ToQ16(rhs->d_fp16);\n    scale_prod_q32 = lhs_scale_q16 * rhs_scale_q16;\n\n    // Keep the integer dot explicit and auditable:\n    // q_dot_q0 = Sum(qA_i * qB_i), with q in signed byte domain [-128, 127].\n    q_dot_q0 = 0;\n    for (byte_index = 0; byte_index < Q8_0_PACKED_BYTES; ++byte_index)\n        q_dot_q0 += lhs->qs[byte_index] * rhs->qs[byte_index];\n\n    *out_dot_q32 = scale_prod_q32 * q_dot_q0;\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ32(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q8_0_OK)\n            return status;\n\n        total_dot_q32 += block_dot_q32;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ32Checked(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q32)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q32)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    total_dot_q32 = 0;\n    for (block_index = 0; block_index < block_count; ++block_index)\n    {\n        status = Q8_0DotProductBlockQ32(&lhs[block_index], &rhs[block_index], &block_dot_q32);\n        if (status != Q8_0_OK)\n            return status;\n\n        // Keep hostile stream handling explicit.\n        // A malicious block sequence can drive total_dot_q32 beyond I64; reject early.\n        if (!Q8_0TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n            return Q8_0_ERR_OVERFLOW;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ32ToQ16(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *out_dot_q16)\n{\n    I64 total_dot_q32;\n    I32 status;\n\n    if (!lhs || !rhs || !out_dot_q16)\n        return Q8_0_ERR_NULL_PTR;\n    if (block_count < 0)\n        return Q8_0_ERR_BAD_DST_LEN;\n\n    // WS4 callers can keep the full multi-block dot in widened I64 Q32,\n    // then round once to Q16 for deterministic lane hand-off.\n    status = Q8_0DotProductBlocksQ32(lhs, rhs, block_count, &total_dot_q32);\n    if (status != Q8_0_OK)\n        return status;\n\n    *out_dot_q16 = Q8_0DotQ32ToQ16(total_dot_q32);\n    return Q8_0_OK;\n}\n\nI32 Q8_0DotProductBlocksQ16Accumulate(Q8_0Block *lhs, Q8_0Block *rhs, I64 block_count, I64 *io_accum_q16)\n{\n    I64 block_index;\n    I64 block_dot_q32;\n    I64 total_q16;\n    I32 status;\n\n    if (!lhs || !rhs || !io_accum_q16)\n        return Q8_0_ERR_NULL_PTR;\n","exit_code":0,"status":"completed"}}
