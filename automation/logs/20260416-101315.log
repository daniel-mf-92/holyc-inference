   else:\n    52\t        magnitude_q16 = round_shift_right_unsigned(mantissa, -shift_amount)\n    53\t\n    54\t    return -magnitude_q16 if sign_bit else magnitude_q16\n    55\t\n    56\t\n    57\tdef half_bits(value: float) -> int:\n    58\t    return struct.unpack(\"<H\", struct.pack(\"<e\", value))[0]\n    59\t\n    60\t\n    61\tdef nibble_to_signed(packed: int, upper_nibble: bool) -> int:\n    62\t    if upper_nibble:\n    63\t        q_unsigned = (packed >> 4) & 0x0F\n    64\t    else:\n    65\t        q_unsigned = packed & 0x0F\n    66\t    return q_unsigned - 8\n    67\t\n    68\t\n    69\tdef unpack_q4_signed(qs: bytes) -> list[int]:\n    70\t    out: list[int] = []\n    71\t    for packed in qs:\n    72\t        out.append(nibble_to_signed(packed, False))\n    73\t        out.append(nibble_to_signed(packed, True))\n    74\t    return out\n    75\t\n    76\t\n    77\tdef unpack_q8_signed(qs: bytes) -> list[int]:\n    78\t    return [struct.unpack(\"<b\", bytes([byte]))[0] for byte in qs]\n    79\t\n    80\t\n    81\tdef pack_q4_from_signed(vals: list[int]) -> bytes:\n    82\t    assert len(vals) == 32\n    83\t    out = bytearray()\n    84\t    for idx in range(0, 32, 2):\n    85\t        lo = vals[idx] + 8\n    86\t        hi = vals[idx + 1] + 8\n    87\t        assert 0 <= lo <= 15 and 0 <= hi <= 15\n    88\t        out.append((lo & 0x0F) | ((hi & 0x0F) << 4))\n    89\t    return bytes(out)\n    90\t\n    91\t\n    92\tdef pack_q8_signed(vals: list[int]) -> bytes:\n    93\t    assert len(vals) == 32\n    94\t    return bytes((v + 256) % 256 for v in vals)\n    95\t\n    96\t\n    97\tdef dot_product_block_q32(lhs_scale_fp16: int, lhs_q4: bytes, rhs_scale_fp16: int, rhs_q8: bytes) -> tuple[int, int]:\n    98\t    if len(lhs_q4) != Q4_0_PACKED_BYTES or len(rhs_q8) != Q8_0_PACKED_BYTES:\n    99\t        return Q4_0_Q8_0_ERR_BAD_DST_LEN, 0\n   100\t\n   101\t    lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   102\t    rhs_scale_q16 = f16_to_q16(rhs_scale_fp1