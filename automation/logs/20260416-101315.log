s, rhs_blocks, 0)\n   148\t\n   149\t\n   150\tdef dot_q32_to_q16(dot_q32: int) -> int:\n   151\t    return round_shift_right_signed(dot_q32, 16)\n   152\t\n   153\t\n   154\tdef test_identity_mixed_block() -> None:\n   155\t    lhs_scale_fp16 = half_bits(1.0)\n   156\t    rhs_scale_fp16 = half_bits(1.0)\n   157\t\n   158\t    q4_signed = [((idx % 16) - 8) for idx in range(32)]\n   159\t    q8_signed = q4_signed[:]\n   160\t\n   161\t    lhs_q4 = pack_q4_from_signed(q4_signed)\n   162\t    rhs_q8 = pack_q8_signed(q8_signed)\n   163\t\n   164\t    err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n   165\t    assert err == Q4_0_Q8_0_OK\n   166\t\n   167\t    expected_q0 = sum(v * v for v in q4_signed)\n   168\t    expected_q32 = (1 << 16) * (1 << 16) * expected_q0\n   169\t    assert got_q32 == expected_q32\n   170\t    assert dot_q32_to_q16(got_q32) == expected_q0 * (1 << 16)\n   171\t\n   172\t\n   173\tdef test_random_blocks_match_integer_reference() -> None:\n   174\t    rng = random.Random(20260412)\n   175\t\n   176\t    for _ in range(500):\n   177\t        lhs_scale = rng.uniform(-4.0, 4.0)\n   178\t        rhs_scale = rng.uniform(-4.0, 4.0)\n   179\t\n   180\t        lhs_scale_fp16 = half_bits(lhs_scale)\n   181\t        rhs_scale_fp16 = half_bits(rhs_scale)\n   182\t\n   183\t        q4_signed = [rng.randrange(-8, 8) for _ in range(32)]\n   184\t        q8_signed = [rng.randrange(-128, 128) for _ in range(32)]\n   185\t\n   186\t        lhs_q4 = pack_q4_from_signed(q4_signed)\n   187\t        rhs_q8 = pack_q8_signed(q8_signed)\n   188\t\n   189\t        err, got_q32 = dot_product_block_q32(lhs_scale_fp16, lhs_q4, rhs_scale_fp16, rhs_q8)\n   190\t        assert err == Q4_0_Q8_0_OK\n   191\t\n   192\t        expected_q0 = sum(a * b for a, b in zip(q4_signed, q8_signed))\n   193\t        lhs_scale_q16 = f16_to_q16(lhs_scale_fp16)\n   194\t        rhs_scale_q16 = f16_to_q16(rhs_scale_fp16)\n   195\t        expected_q32 = lhs_scale_q16 * rhs_scale_q16 * expected_q0\n   196\t        assert got_q32 == expected_q32\n   197\t\n   198\t        lhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", lhs_scale_fp16))[0]\n   199\t        rhs_scale_half = struct.unpack(\"<e\", struct.pack(\"<H\", rhs_scale_fp16))[0]\n   200\t        expected_float_q32 = round((lhs_scale_half * rhs_scale_half) * expected_q0 * (1 << 32))\n   201\t\n   202\t        # Integer path rounds scales once to Q16 then multiplies.\n   203\t        assert abs(got_q32 - expected_float_q32) <= 70_000_000\n   204\t\n   205\t\n   206\tdef test_multiblock_accumulation() -> None:\n   207\t    b0 = (half_bits(0.75), pack_q4_from_signed([((i % 8) - 4) for i in range(32)]))\n   208\t    b1 = (half_bits(-0.5), pack_q4_from_signed([4 - (i % 8) for i in range(32)]))\n   209\t\n   210\t    r0 = (half_bits(1.25), pack_q8_signed([((i % 11) - 5) * 3 for i in range(32)]))\n   211\t    r1 = (half_bits(-1.5), pack_q8_signed([7 - (i % 13) for i in range(32)]))\n   212\t\n   213\t    err, total = dot_product_blocks_q32([b0, b1], [r0, r1])\n   214\t    assert err == Q4_0_Q8_0_OK\n   215\t\n   216\t    _, part0 = dot_product_block_q32(*b0, *r0)\n   217\t    _, part1 = dot_product_block_q32(*b1, *r1)\n   218\t    assert total == part0 + part1\n   219\t\n   220\t\n   221\tdef test_error_on_bad_lengths() -> None:\n   222\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 15, half_bits(1.0), b\"\\x00\" * 32)\n   223\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   224\t\n   225\t    err, _ = dot_product_block_q32(half_bits(1.0), b\"\\x00\" * 16, half_bits(1.0), b\"\\x00\" * 31)\n   226\t    assert err == Q4_0_Q8_0_ERR_BAD_DST_LEN\n   227\t\n   228\t\n   229\tdef test_q16_accumulator_helper_matches_blockwise_rounding() -> None:\n   230\t    rng = random.Random(2026041217)\n   231\t\n   232\t    for _ in range(250):\n   233\t        block_count = rng.randint(1, 6)\n   234\t        lhs_blocks = []\n   235\t        rhs_blocks = []\n   236\t