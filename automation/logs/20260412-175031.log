tensor_nbytes[i]\n   381\t        if abs_start > U64_MAX - nbytes:\n   382\t            return GGUF_TDBASE_ERR_OVERFLOW, i\n   383\t\n   384\t        out_abs_starts[i] = abs_start\n   385\t        out_abs_ends[i] = abs_start + nbytes\n   386\t\n   387\t    return GGUF_TDBASE_OK, 0\n   388\t\n   389\t\n   390\tdef tensor_range_find_by_abs_offset(\n   391\t    abs_offset: int,\n   392\t    tensor_abs_starts: list[int],\n   393\t    tensor_abs_ends: list[int],\n   394\t):\n   395\t    count = len(tensor_abs_starts)\n   396\t    if len(tensor_abs_ends) != count:\n   397\t        return GGUF_TDBASE_ERR_NULL_PTR, 0\n   398\t    if count == 0:\n   399\t        return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0\n   400\t\n   401\t    lo = 0\n   402\t    hi = count\n   403\t    while lo < hi:\n   404\t        mid = lo + ((hi - lo) >> 1)\n   405\t        start_mid = tensor_abs_starts[mid]\n   406\t        end_mid = tensor_abs_ends[mid]\n   407\t\n   408\t        if end_mid < start_mid:\n   409\t            return GGUF_TDBASE_ERR_OVERFLOW, 0\n   410\t\n   411\t        if abs_offset < start_mid:\n   412\t            hi = mid\n   413\t            continue\n   414\t\n   415\t        if abs_offset >= end_mid:\n   416\t            lo = mid + 1\n   417\t            continue\n   418\t\n   419\t        return GGUF_TDBASE_OK, mid\n   420\t\n   421\t    return GGUF_TDBASE_ERR_OUT_OF_BOUNDS, 0\n   422\t\n   423\t\n   424\t\n   425\t\n   426\tdef test_tensor_bytes_for_type_scalars() -> None:\n   427\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 0) == (GGUF_TDBASE_OK, 0)\n   428\t    assert tensor_bytes_for_type(GGML_TYPE_F32, 7) == (GGUF_TDBASE_OK, 28)\n   429\t    assert tensor_bytes_for_type(GGML_TYPE_F16, 7) == (GGUF_TDBASE_OK, 14)\n   430\t\n   431\t\n   432\tdef test_tensor_bytes_for_type_quantized_exact_blocks() -> None:\n   433\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 32) == (GGUF_TDBASE_OK, 18)\n   434\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 64) == (GGUF_TDBASE_OK, 36)\n   435\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 32) == (GGUF_TDBASE_OK, 34)\n   436\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 96) == (GGUF_TDBASE_OK, 102)\n   437\t\n   438\t\n   439\tdef test_tensor_bytes_for_type_reject_non_multiple_block() -> None:\n   440\t    assert tensor_bytes_for_type(GGML_TYPE_Q4_0, 31) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   441\t    assert tensor_bytes_for_type(GGML_TYPE_Q8_0, 33) == (GGUF_TDBASE_ERR_BAD_BLOCK_MULTIPLE, 0)\n   442\t\n   443\t\n   444\tdef test_tensor_bytes_for_type_reject_unknown_type() -> None:\n   445\t    assert tensor_bytes_for_type(999, 32) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   446\t\n   447\t\n   448\tdef test_tensor_bytes_for_type_overflow_guard() -> None:\n   449\t    q8_block = 32\n   450\t    q8_bytes = 34\n   451\t    max_blocks = U64_MAX // q8_bytes\n   452\t    ok_elements = max_blocks * q8_block\n   453\t    err, nbytes = tensor_bytes_for_type(GGML_TYPE_Q8_0, ok_elements)\n   454\t    assert err == GGUF_TDBASE_OK\n   455\t    assert nbytes == max_blocks * q8_bytes\n   456\t\n   457\t    overflow_elements = (max_blocks + 1) * q8_block\n   458\t    err, _ = tensor_bytes_for_type(GGML_TYPE_Q8_0, overflow_elements)\n   459\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   460\t\n   461\tdef test_default_alignment_examples() -> None:\n   462\t    assert tensor_data_base_align_default(0) == (GGUF_TDBASE_OK, 0)\n   463\t    assert tensor_data_base_align_default(1) == (GGUF_TDBASE_OK, 32)\n   464\t    assert tensor_data_base_align_default(31) == (GGUF_TDBASE_OK, 32)\n   465\t    assert tensor_data_base_align_default(32) == (GGUF_TDBASE_OK, 32)\n   466\t    assert tensor_data_base_align_default(33) == (GGUF_TDBASE_OK, 64)\n   467\t\n   468\t\n   469\tdef test_tensor_type_block_size_known_types() -> None:\n   470\t    assert tensor_type_block_size(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 1)\n   471\t    assert tensor_type_block_size(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 1)\n   472\t    assert tensor_type_block_size(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 32)\n   473\t    assert tensor_type_block_size(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 32)\n   474\t\n   475\t\n   476\tdef test_tensor_type_block_bytes_known_types() -> None:\n   477\t    assert tensor_type_block_bytes(GGML_TYPE_F32) == (GGUF_TDBASE_OK, 4)\n   478\t    assert tensor_type_block_bytes(GGML_TYPE_F16) == (GGUF_TDBASE_OK, 2)\n   479\t    assert tensor_type_block_bytes(GGML_TYPE_Q4_0) == (GGUF_TDBASE_OK, 18)\n   480\t    assert tensor_type_block_bytes(GGML_TYPE_Q8_0) == (GGUF_TDBASE_OK, 34)\n   481\t\n   482\t\n   483\tdef test_tensor_type_helpers_reject_unknown_type() -> None:\n   484\t    assert tensor_type_block_size(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   485\t    assert tensor_type_block_bytes(999) == (GGUF_TDBASE_ERR_BAD_TYPE, 0)\n   486\t\n   487\t\n   488\tdef test_custom_power_of_two_alignment() -> None:\n   489\t    err, base = tensor_data_base_align(0x1234, 64)\n   490\t    assert err == GGUF_TDBASE_OK\n   491\t    assert base == 0x1240\n   492\t    assert tensor_data_base_is_aligned(base, 64)\n   493\t\n   494\t\n   495\tdef test_reject_non_power_of_two_alignment() -> None:\n   496\t    assert tensor_data_base_align(100, 0)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   497\t    assert tensor_data_base_align(100, 3)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   498\t    assert tensor_data_base_align(100, 24)[0] == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   499\t    assert tensor_data_base_is_aligned(128, 24) is False\n   500\t\n   501\t\n   502\tdef test_overflow_guard_near_u64_max() -> None:\n   503\t    err, _ = tensor_data_base_align(U64_MAX - 7, 16)\n   504\t    assert err == GGUF_TDBASE_ERR_OVERFLOW\n   505\t\n   506\t    err, base = tensor_data_base_align(U64_MAX - 15, 16)\n   507\t    assert err == GGUF_TDBASE_OK\n   508\t    assert base == U64_MAX - 15\n   509\t\n   510\t\n   511\tdef test_random_alignment_matches_reference_formula() -> None:\n   512\t    rng = random.Random(760031)\n   513\t\n   514\t    for _ in range(1000):\n   515\t        alignment = 1 << rng.randint(0, 20)\n   516\t        cursor = rng.randrange(0, 1 << 56)\n   517\t\n   518\t        err, got = tensor_data_base_align(cursor, alignment)\n   519\t        assert err == GGUF_TDBASE_OK\n   520\t\n   521\t        reference = ((cursor + (alignment - 1)) // alignment) * alignment\n   522\t        assert got == reference\n   523\t        assert got >= cursor\n   524\t        assert tensor_data_base_is_aligned(got, alignment)\n   525\t\n   526\t\n   527\tdef test_tensor_data_base_offset_happy_path() -> None:\n   528\t    err, abs_off = tensor_data_base_offset(0x2000, 0x80, 32)\n   529\t    assert err == GGUF_TDBASE_OK\n   530\t    assert abs_off == 0x2080\n   531\t\n   532\t\n   533\t\n   534\tdef test_tensor_data_base_offset_default_alignment() -> None:\n   535\t    err, abs_off = tensor_data_base_offset_default(0x100, 0x40)\n   536\t    assert err == GGUF_TDBASE_OK\n   537\t    assert abs_off == 0x140\n   538\t\n   539\t\n   540\t\n   541\tdef test_tensor_data_base_offset_reject_bad_alignment() -> None:\n   542\t    err, _ = tensor_data_base_offset(0x1000, 0x40, 24)\n   543\t    assert err == GGUF_TDBASE_ERR_BAD_ALIGNMENT\n   544\t\n   545\t\n   546\t\n   547\tdef test_tensor_data_base_offset_reject_misaligned_base() -> None:\n   548\t    err, _ = tensor_data_base_offset(0x1010, 0x40, 32)\n   549\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_BASE\n   550\t\n   551\t\n   552\t\n   553\tdef test_tensor_data_base_offset_reject_misaligned_rel() -> None:\n   554\t    err, _ = tensor_data_base_offset(0x1000, 0x48, 32)\n   555\t    assert err == GGUF_TDBASE_ERR_MISALIGNED_TENSOR_OFFSET\n   556\t\n   557\t\n   558\t\n   559\tdef test_tensor_data_base_offset_overflow_guard() -> None:\n   560\t    err, _ = tensor_data_base_offset(U64_MAX - 31, 32, 32)\n","exit_code":0,"status":"completed"}}
