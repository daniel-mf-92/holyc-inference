\t        nbytes = []\n   849\t        cursor = 0\n   850\t\n   851\t        force_overlap = rng.random() < 0.5 and count >= 2\n   852\t        overlap_i = rng.randint(0, count - 2) if force_overlap else -1\n   853\t\n   854\t        for i in range(count):\n   855\t            gap = rng.randint(0, 6) * alignment\n   856\t            cursor += gap\n   857\t            span = rng.randint(0, 6) * alignment\n   858\t\n   859\t            start = cursor\n   860\t            if force_overlap and i == overlap_i + 1:\n   861\t                prev_start = rel_offsets[-1]\n   862\t                prev_span = nbytes[-1]\n   863\t                if prev_span == 0:\n   864\t                    start = prev_start\n   865\t                else:\n   866\t                    start = prev_start + rng.randint(0, max(0, (prev_span // alignment) - 1)) * alignment\n   867\t\n   868\t            rel_offsets.append(start)\n   869\t            nbytes.append(span)\n   870\t            cursor = max(cursor, start + span)\n   871\t\n   872\t        file_nbytes = base + cursor + rng.randint(0, 8) * alignment + alignment\n   873\t\n   874\t        rel_a = rel_offsets.copy()\n   875\t        nbytes_a = nbytes.copy()\n   876\t        err_quad, bad_quad = validate_tensor_ranges(\n   877\t            tensor_data_base=base,\n   878\t            alignment=alignment,\n   879\t            gguf_file_nbytes=file_nbytes,\n   880\t            tensor_rel_offsets=rel_a,\n   881\t            tensor_nbytes=nbytes_a,\n   882\t        )\n   883\t\n   884\t        rel_b = rel_offsets.copy()\n   885\t        nbytes_b = nbytes.copy()\n   886\t        err_sorted, bad_sorted = validate_tensor_ranges_sorted(\n   887\t            tensor_data_base=base,\n   888\t            alignment=alignment,\n   889\t            gguf_file_nbytes=file_nbytes,\n   890\t            tensor_rel_offsets=rel_b,\n   891\t            tensor_nbytes=nbytes_b,\n   892\t        )\n   893\t\n   894\t        assert err_sorted == err_quad\n   895\t   