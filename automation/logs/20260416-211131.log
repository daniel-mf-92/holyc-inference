_stride)\n   144\t        err_q32, out_q32 = compute_rhs_col_base_checked_avx2_q32(col_index, rhs_stride)\n   145\t\n   146\t        assert err_scalar == err_q16 == err_q32 == expected_err\n   147\t        if expected_err == Q8_0_AVX2_OK:\n   148\t            assert out_scalar == out_q16 == out_q32\n   149\t\n   150\t\n   151\tdef test_helper_randomized_parity() -> None:\n   152\t    rng = random.Random(20260416128)\n   153\t\n   154\t    for _ in range(900):\n   155\t        mode = rng.choice([\"ok\", \"bad\", \"overflow\"])\n   156\t        if mode == \"ok\":\n   157\t            col_index = rng.randint(0, 1 << 20)\n   158\t            rhs_stride = rng.randint(0, 1 << 20)\n   159\t        elif mode == \"bad\":\n   160\t            col_index = rng.choice([-rng.randint(1, 1 << 20), rng.randint(0, 1 << 20)])\n   161\t            rhs_stride = rng.choice([-rng.randint(1, 1 << 20), rng.randint(0, 1 << 20)])\n   162\t            if col_index >= 0 and rhs_stride >= 0:\n   163\t                col_index = -1\n   164\t        else:\n   165\t            col_index = I64_MAX - rng.randint(0, 256)\n   166\t            rhs_stride = rng.randint(2, 512)\n   167\t\n   168\t        err_scalar, out_scalar = compute_rhs_col_base_checked_scalar_q16(col_index, rhs_stride)\n   169\t        err_q16, out_q16 = compute_rhs_col_base_checked_avx2_q16(col_index, rhs_stride)\n   170\t        err_q32, out_q32 = compute_rhs_col_base_checked_avx2_q32(col_index, rhs_stride)\n   171\t\n   172\t        assert err_scalar == err_q16 == err_q32\n   173\t        if err_scalar == Q8_0_AVX2_OK:\n   174\t            assert out_scalar == out_q16 == out_q32\n   175\t\n   176\t\n   177\tdef test_entrypoint_rhs_stride_contract_parity() -> None:\n   178\t    lhs = [make_block(0x3C00, [1] * 32) for _ in range(128)]\n   179\t    rhs = [make_block(0x3C00, [1] * 32) for _ in range(128)]\n   180\t\n   181\t    # k_block_count > rhs_col_stride_blocks: shared BAD_LEN surface, rooted in\n   182\t    # the same invariant