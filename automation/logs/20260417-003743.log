{"type":"item.started","item":{"id":"item_33","type":"command_execution","command":"/bin/zsh -lc \"rg -n 'RoPEQ16RotateHeadRangeByTokenWindowChecked' src/model/rope.HC && python3 tests/test_rope_q16_rotate_head_range_preflighted_position.py && python3 tests/test_rope_q16_rotate_head_range_position.py && python3 - <<'PY'\nimport random\nimport sys\nfrom pathlib import Path\n\nsys.path.append(str(Path('tests').resolve()))\nimport test_rope_q16_angle_step as ref\nimport test_rope_q16_rotate_head_position as head_ref\nimport test_rope_q16_validate_head_range_capacity as cap_ref\nimport test_rope_q16_rotate_head_range_preflighted_position as preflight_ref\n\ndef try_add(lhs, rhs):\n    if rhs > 0 and lhs > ref.I64_MAX - rhs:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    if rhs < 0 and lhs < ref.I64_MIN - rhs:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return ref.ROPE_Q16_OK, lhs + rhs\n\ndef try_mul(lhs, rhs):\n    p = lhs * rhs\n    if p > ref.I64_MAX or p < ref.I64_MIN:\n        return ref.ROPE_Q16_ERR_OVERFLOW, 0\n    return ref.ROPE_Q16_OK, p\n\ndef rope_q16_rotate_head_range_by_token_window_checked(\n    head_cells_q16,\n    head_cell_capacity,\n    range_base_index,\n    head_count,\n    head_stride_cells,\n    head_dim,\n    pair_stride_cells,\n    freq_base_q16,\n    position_start,\n    token_count,\n    position_step,\n):\n    if head_cells_q16 is None:\n        return ref.ROPE_Q16_ERR_NULL_PTR, []\n    if token_count < 0:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n\n    err, last_head_base = cap_ref.rope_q16_validate_head_range_capacity_checked(\n        head_cell_capacity,\n        range_base_index,\n        head_count,\n        head_stride_cells,\n    )\n    if err \"'!= ref.ROPE_Q16_OK:\n        return err, []\n\n    err, last_pair_y = preflight_ref.rope_q16_validate_head_range_span_for_dim_checked(\n        head_cell_capacity,\n        range_base_index,\n        head_count,\n        head_stride_cells,\n        head_dim,\n        pair_stride_cells,\n    )\n    if err != ref.ROPE_Q16_OK:\n        return err, []\n\n    if token_count == 0 or head_count == 0:\n        return ref.ROPE_Q16_OK, list(head_cells_q16)\n\n    work = list(head_cells_q16)\n    for token_index in range(token_count):\n        err, pos_off = try_mul(token_index, position_step)\n        if err != ref.ROPE_Q16_OK:\n            return err, []\n        err, pos = try_add(position_start, pos_off)\n        if err != ref.ROPE_Q16_OK:\n            return err, []\n\n        for head_index in range(head_count):\n            err, head_off = try_mul(head_index, head_stride_cells)\n            if err != ref.ROPE_Q16_OK:\n                return err, []\n            err, head_base = try_add(range_base_index, head_off)\n            if err != ref.ROPE_Q16_OK:\n                return err, []\n            if head_base > last_head_base:\n                return ref.ROPE_Q16_ERR_BAD_PARAM, []\n            err, work = head_ref.rope_q16_rotate_head_by_position_checked(\n                work,\n                head_cell_capacity,\n                head_base,\n                head_dim,\n                pair_stride_cells,\n                freq_base_q16,\n                pos,\n            )\n            if err != ref.ROPE_Q16_OK:\n                return err, []\n\n    if last_pair_y >= head_cell_capacity:\n        return ref.ROPE_Q16_ERR_BAD_PARAM, []\n\n    return ref.ROPE_Q16_OK, work\n\ndef mkbuf(n, seed):\n    rng = random.Random(seed)\n    return [ref.q16_from_float(rng.uniform(-2.0, 2.0)) for _ in range(n)]\n\n# Deterministic composition parity\nbase_q16 = ref.q16_from_float(10000.0)\ncap = 640\nbuf = mkbuf(cap, 11)\nerr, got = rope_q16_rotate_head_range_by_token_window_checked(\n    buf, cap, 17, 3, 64, 16, 2, base_q16, 10, 7, 3\n)\nassert err == ref.ROPE_Q16_OK\nwant = list(buf)\nfor t in range(7):\n    pos = 10 + t * 3\n    for h in range(3):\n        hb = 17 + h * 64\n        e, want = head_ref.rope_q16_rotate_head_by_position_checked(\n            want, cap, hb, 16, 2, base_q16, pos\n        )\n        assert e == ref.ROPE_Q16_OK\nassert got == want\n\n# Overflow surface on position stepping\nerr, _ = rope_q16_rotate_head_range_by_token_window_checked(\n    buf, cap, 17, 1, 64, 16, 2, base_q16, ref.I64_MAX - 1, 3, 2\n)\nassert err == ref.ROPE_Q16_ERR_OVERFLOW\n\n# Randomized contract parity\nrng = random.Random(202604170146)\nfor _ in range(700):\n    head_dim = rng.choice([8, 16, 24, 32])\n    pair_stride = rng.randint(2, 6)\n    head_span = (head_dim // 2) * pair_stride + 1\n    head_count = rng.randint(0, 4)\n    if head_count == 0:\n        cap = rng.randint(max(1, head_span), head_span + 64)\n        base = rng.randint(0, cap - 1)\n        stride = rng.randint(1, 64)\n    else:\n        stride = rng.randint(head_span, head_span + 20)\n        need = (head_count - 1) * stride + head_span\n        cap = rng.randint(need, need + 120)\n        base = rng.randint(0, cap - need)\n\n    token_count = rng.randint(0, 20)\n    position_start = rng.randint(0, 8192)\n    position_step = rng.randint(0, 11)\n    freq_base_q16 = ref.q16_from_float(rng.choice([5000.0, 10000.0, 50000.0]))\n    inp = mkbuf(cap, rng.randint(0, 1_000_000))\n\n    err_got, got = rope_q16_rotate_head_range_by_token_window_checked(\n        inp,\n        cap,\n        base,\n        head_count,\n        stride,\n        head_dim,\n        pair_stride,\n        freq_base_q16,\n        position_start,\n        token_count,\n        position_step,\n    )\n\n    # Compose expected by repeatedly using preflighted single-position helper.\n    want = list(inp)\n    err_want = ref.ROPE_Q16_OK\n    for t in range(token_count):\n        pos = position_start + t * position_step\n        err_want, want = preflight_ref.rope_q16_rotate_head_range_by_position_preflighted_checked(\n            want,\n            cap,\n            base,\n            head_count,\n            stride,\n            head_dim,\n            pair_stride,\n            freq_base_q16,\n     