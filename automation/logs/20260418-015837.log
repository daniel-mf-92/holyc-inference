status;\n\n        status = Q8_0DotI16LanesAVX2(lhs_lanes_i16,\n                                     Q8_0_AVX2_VALUES_PER_BLOCK,\n                                     rhs_lanes_i16,\n                                     Q8_0_AVX2_VALUES_PER_BLOCK,\n                                     &q_dot_q0);\n        if (status != Q8_0_AVX2_OK)\n            return status;\n\n        lhs_scale_q16 = Q8_0AVX2F16ToQ16(lhs[block_index].d_fp16);\n        rhs_scale_q16 = Q8_0AVX2F16ToQ16(rhs[block_index].d_fp16);\n\n        if (!Q8_0AVX2TryMulI64(lhs_scale_q16, rhs_scale_q16, &scale_prod_q32))\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (!Q8_0AVX2TryMulI64(scale_prod_q32, q_dot_q0, &block_dot_q32))\n            return Q8_0_AVX2_ERR_OVERFLOW;\n        if (!Q8_0AVX2TryAddI64(total_dot_q32, block_dot_q32, &total_dot_q32))\n            return Q8_0_AVX2_ERR_OVERFLOW;\n    }\n\n    *out_dot_q32 = total_dot_q32;\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0DotRowsAVX2Q32Checked(\n    Q8_0Block *matrix_blocks,\n    I64 matrix_block_capacity,\n    I64 row_count,\n    I64 row_stride_blocks,\n    Q8_0Block *vec_blocks,\n    I64 vec_block_capacity,\n    I64 vec_block_count,\n    I64 *out_rows_q32)\n{\n    I64 row_index;\n    I64 required_matrix_blocks;\n    I64 row_base;\n    Q8_0Block *row_ptr;\n    I64 row_dot_q32;\n    I32 status;\n\n    if (!matrix_blocks || !vec_blocks || !out_rows_q32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (matrix_block_capacity < 0 || vec_block_capacity < 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (row_count < 0 || row_stride_blocks < 0 || vec_block_count < 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Row layout contract:\n    // - Row i starts at matrix_blocks + i*row_stride_blocks.\n    // - Active row span consumes vec_block_count blocks.\n    // Require stride to cover active K span so every row window is valid.\n    if (row_count > 0 && row_stride_blocks < vec_block_count)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (vec_block_count > vec_block_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Full matrix view capacity proof for strided rows.\n    if (!Q8_0AVX2TryMulI64(row_count, row_stride_blocks, &required_matrix_blocks))\n        return Q8_0_AVX2_ERR_OVERFLOW;\n    if (required_matrix_blocks > matrix_block_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    for (row_index = 0; row_index < row_count; ++row_index)\n    {\n        if (!Q8_0AVX2TryMulI64(row_index, row_stride_blocks, &row_base))\n            return Q8_0_AVX2_ERR_OVERFLOW;\n\n        row_ptr = &matrix_blocks[row_base];\n        status = Q8_0DotBlocksAVX2Q32Checked(row_ptr,\n                                             vec_blocks,\n                                             vec_block_count,\n                                             &row_dot_q32);\n        if (status != Q8_0_AVX2_OK)\n            return status;\n\n        out_rows_q32[row_index] = row_dot_q32;\n    }\n\n    return Q8_0_AVX2_OK;\n}\n\nI32 Q8_0MatMulTiledAVX2Q32Checked(\n    Q8_0Block *lhs_matrix_blocks,\n    I64 lhs_block_capacity,\n    I64 lhs_rows,\n    I64 lhs_row_stride_blocks,\n    Q8_0Block *rhs_col_blocks,\n    I64 rhs_block_capacity,\n    I64 rhs_cols,\n    I64 rhs_col_stride_blocks,\n    I64 k_block_count,\n    I64 tile_rows,\n    I64 tile_cols,\n    I64 *out_mat_q32,\n    I64 out_capacity,\n    I64 out_row_stride_cols)\n{\n    I64 required_lhs_blocks;\n    I64 required_rhs_blocks;\n    I64 required_out_cells;\n    I64 tile_row_start;\n    I64 tile_col_start;\n    I64 tile_row_end;\n    I64 tile_col_end;\n    I64 row_index;\n    I64 col_index;\n    I64 lhs_row_base;\n    I64 rhs_col_base;\n    I64 out_index;\n    I64 dot_q32;\n    I32 status;\n\n    if (!lhs_matrix_blocks || !rhs_col_blocks || !out_mat_q32)\n        return Q8_0_AVX2_ERR_NULL_PTR;\n\n    if (lhs_block_capacity < 0 || rhs_block_capacity < 0 || out_capacity < 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (lhs_rows < 0 || lhs_row_stride_blocks < 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_cols < 0 || rhs_col_stride_blocks < 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (k_block_count < 0 || out_row_stride_cols < 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (tile_rows <= 0 || tile_cols <= 0)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Matrix layout contracts:\n    // - lhs_matrix_blocks stores A as row-major rows, each row consuming\n    //   k_block_count active Q8_0 blocks inside lhs_row_stride_blocks stride.\n    // - rhs_col_blocks stores B as pre-transposed columns, each column\n    //   consuming k_block_count active Q8_0 blocks inside rhs_col_stride_blocks.\n    // - out_mat_q32 stores C as row-major Q32 cells with out_row_stride_cols.\n    if (lhs_rows > 0 && lhs_row_stride_blocks < k_block_count)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (rhs_cols > 0 && rhs_col_stride_blocks < k_block_count)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n    if (lhs_rows > 0 && out_row_stride_cols < rhs_cols)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    if (!Q8_0AVX2TryMulI64(lhs_rows, lhs_row_stride_blocks, &required_lhs_blocks))\n        return Q8_0_AVX2_ERR_OVERFLOW;\n    if (required_lhs_blocks > lhs_block_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    if (!Q8_0AVX2TryMulI64(rhs_cols, rhs_col_stride_blocks, &required_rhs_blocks))\n        return Q8_0_AVX2_ERR_OVERFLOW;\n    if (required_rhs_blocks > rhs_block_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    if (!Q8_0AVX2TryMulI64(lhs_rows, out_row_stride_cols, &required_out_cells))\n        return Q8_0_AVX2_ERR_OVERFLOW;\n    if (required_out_cells > out_capacity)\n        return Q8_0_AVX2_ERR_BAD_LEN;\n\n    // Tiled traversal keeps hot row/column windows local for later AVX2 asm.\n    // Dot primitive remains the checked AVX2-shape kernel so arithmetic and\n    // overflow behavior are identical to the audited block-level path.\n    for (tile_row_start = 0; tile_row_start < lhs_rows; tile_row_start += tile_rows)\n    {\n        tile_row_end = tile_row_start + tile_rows;\n        if (tile_row_end > lhs_rows)\n            tile_row_end = lhs_rows;\n\n        for (tile_col_start = 0; tile_col_start < rhs_cols; tile_col_start += tile_cols)\n        {\n            tile_col_end = tile_col_start + tile_cols;\n            if (tile_col_end > rhs_cols)\n                tile_col_end = rhs_cols;\n\n            for (row_index = tile_row_start; row_index < tile_row_end; ++row_index)\n            {\n                if (!Q8_0AVX2TryMulI64(row_index, lhs_row_stride_blocks, &lhs_row_base))\n                    return Q8_0_AVX2_ERR_OVERFLOW;\n\n                for (col_index = tile_col_start; col_index < tile_col_end; ++col_index)\n                {\n---\n#!/usr/bin/env python3\n\"\"\"Reference checks for Q8_0DotRowsAVX2Q32Checked semantics.\"\"\"\n\nfrom __future__ import annotations\n\nimport pathlib\nimport sys\n\nsys.path.append(str(pathlib.Path(__file__).resolve().parent))\n\nfrom test_q8_0_avx2_blocks_q32 import (\n    I64_MAX,\n    Q8_0_AVX2_ERR_BAD_LEN,\n    Q8_0_AVX2_ERR_NULL_PTR,\n    Q8_0_AVX2_ERR_OVERFLOW,\n    Q8_0_AVX2_OK,\n    make_block,\n    q8_0_dot_blocks_avx2_q32_checked,\n    q8_0_try_mul_i64,\n)\n\n\ndef q8_0_dot_rows_avx2_q32_checked(\n    matrix_blocks,\n    matrix_block_capacity: int,\n    row_count: int,\n    row_stride_blocks: int,\n    vec_blocks,\n    vec_block_capacity: int,\n    vec_block_count: int,\n):\n    if matrix_blocks is None or vec_blocks is None:\n        return Q8_0_AVX2_ERR_NULL_PTR, []\n\n    if matrix_block_capacity < 0 or vec_block_capacity < 0:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n    if row_count < 0 or row_stride_blocks < 0 or vec_block_count < 0:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n\n    if row_count > 0 and row_stride_blocks < vec_block_count:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n    if vec_block_count > vec_block_capacity:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n\n    ok, required_matrix_blocks = q8_0_try_mul_i64(row_count, row_stride_blocks)\n    if not ok:\n        return Q8_0_AVX2_ERR_OVERFLOW, []\n    if required_matrix_blocks > matrix_block_capacity:\n        return Q8_0_AVX2_ERR_BAD_LEN, []\n\n    out_rows_q32 = []\n    for row_index in range(row_count):\n        ok, row_base = q8_0_try_mul_i64(row_index, row_stride_blocks)\n        if not ok:\n            return Q8_0_AVX2_ERR_OVERFLOW, []\n\n        row_blocks = matrix_blocks[row_base : row_base + vec_block_count]\n        err, row_dot_q32 = q8_0_dot_blocks_avx2_q32_checked(row_blocks, vec_blocks, vec_block_count)\n        if err != Q8_0_AVX2_OK:\n            return err, []\n\n        out_rows_q32.append(row_dot_q32)\n\n    return Q8_0_AVX2_OK, out_rows_q32\n\n\ndef test_known_rows_match_per_row_block_dot() -> None:\n    vec = [\n        make_block(0x3C00, [i - 16 for i in range(32)]),\n        make_block(0x3C00, [16 - i for i in range(32)]),\n    ]\n\n    row0 = [\n        make_block(0x3C00, [i - 8 for i in range(32)]),\n        make_block(0x3800, [(-1) ** i * (i % 9) for i in range(32)]),\n    ]\n    row1 = [\n        make_block(0x4000, [2 * i - 31 for i in range(32)]),\n        make_block(0x3555, [7 - (i % 13) for i in range(32)]),\n    ]\n\n    matrix = row0 + row1\n\n    err, rows = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=matrix,\n        matrix_block_capacity=len(matrix),\n        row_count=2,\n        row_stride_blocks=2,\n        vec_blocks=vec,\n        vec_block_capacity=len(vec),\n        vec_block_count=2,\n    )\n    assert err == Q8_0_AVX2_OK\n\n    err, exp0 = q8_0_dot_blocks_avx2_q32_checked(row0, vec, 2)\n    assert err == Q8_0_AVX2_OK\n    err, exp1 = q8_0_dot_blocks_avx2_q32_checked(row1, vec, 2)\n    assert err == Q8_0_AVX2_OK\n\n    assert rows == [exp0, exp1]\n\n\ndef test_row_stride_with_padding_blocks() -> None:\n    vec = [\n        make_block(0x3C00, [1] * 32),\n        make_block(0x3C00, [2] * 32),\n    ]\n\n    row0_live = [\n        make_block(0x3C00, [3] * 32),\n        make_block(0x3C00, [4] * 32),\n    ]\n    row1_live = [\n        make_block(0x3C00, [5] * 32),\n        make_block(0x3C00, [6] * 32),\n    ]\n\n    pad = make_block(0x3C00, [127] * 32)\n    matrix = row0_live + [pad] + row1_live + [pad]\n\n    err, rows = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=matrix,\n        matrix_block_capacity=len(matrix),\n        row_count=2,\n        row_stride_blocks=3,\n        vec_blocks=vec,\n        vec_block_capacity=len(vec),\n        vec_block_count=2,\n    )\n    assert err == Q8_0_AVX2_OK\n\n    err, exp0 = q8_0_dot_blocks_avx2_q32_checked(row0_live, vec, 2)\n    assert err == Q8_0_AVX2_OK\n    err, exp1 = q8_0_dot_blocks_avx2_q32_checked(row1_live, vec, 2)\n    assert err == Q8_0_AVX2_OK\n\n    assert rows == [exp0, exp1]\n\n\ndef test_bad_len_guards() -> None:\n    vec = [make_block(0x3C00, [1] * 32)]\n    matrix = [make_block(0x3C00, [1] * 32)]\n\n    err, _ = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=matrix,\n        matrix_block_capacity=1,\n        row_count=1,\n        row_stride_blocks=0,\n        vec_blocks=vec,\n        vec_block_capacity=1,\n        vec_block_count=1,\n    )\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n    err, _ = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=matrix,\n        matrix_block_capacity=1,\n        row_count=1,\n        row_stride_blocks=1,\n        vec_blocks=vec,\n        vec_block_capacity=0,\n        vec_block_count=1,\n    )\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n    err, _ = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=matrix,\n        matrix_block_capacity=0,\n        row_count=1,\n        row_stride_blocks=1,\n        vec_blocks=vec,\n        vec_block_capacity=1,\n        vec_block_count=1,\n    )\n    assert err == Q8_0_AVX2_ERR_BAD_LEN\n\n\ndef test_capacity_multiply_overflow_is_rejected() -> None:\n    vec = []\n    matrix = []\n\n    err, _ = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=matrix,\n        matrix_block_capacity=I64_MAX,\n        row_count=I64_MAX,\n        row_stride_blocks=2,\n        vec_blocks=vec,\n        vec_block_capacity=0,\n        vec_block_count=0,\n    )\n    assert err == Q8_0_AVX2_ERR_OVERFLOW\n\n\ndef test_null_ptr_rejected() -> None:\n    err, _ = q8_0_dot_rows_avx2_q32_checked(\n        matrix_blocks=None,\n        matrix_block_capacity=0,\n        row_count=0,\n        row_stride_blocks=0,\n        vec_blocks=[],\n        vec_block_capacity=0,\n        vec_block_count=0,\n    )\n    assert err == Q8_0_AVX2_ERR_NULL_PTR\n\n\nif __name__ == \"__main__\":\n    test_known_rows_match_per_row_block_dot()\n    test_row_stride_with_padding_blocks()\n    test_bad_len_guards()\n    test_capacity_multiply_overflow_is_rejected()\n    test_null_ptr_rejected()\n    print(\"ok\")\n","exit_code":0,"status":"completed"}}
